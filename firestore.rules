rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Organization tree ──────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      match /departments/{deptId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;

        match /units/{unitId} {
          allow read, write: if request.auth != null;

          // Encounters — the core clinical record
          match /encounters/{encounterId} {
            allow read, write: if request.auth != null;

            // Encounter events (timeline)
            match /events/{eventId} {
              allow read, write: if request.auth != null;
            }

            // Phase data
            match /phases/{phaseId} {
              allow read, write: if request.auth != null;
            }

            // Orders (labs, imaging, prescriptions)
            match /orders/{orderId} {
              allow read, write: if request.auth != null;
            }
          }
        }
      }
    }

    // ── Users (under organizations) ────────────────────────────────────
    match /organizations/{orgId}/users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId || request.auth.token.role == 'admin';
    }

    // ── Patients (under organizations) ─────────────────────────────────
    match /organizations/{orgId}/patients/{patientId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      match /encounters/{encounterId} {
        allow read, write: if request.auth != null;
      }

      match /lifeline/{eventId} {
        allow read, write: if request.auth != null;
      }
    }

    // ── Analytics & Audit ──────────────────────────────────────────────
    match /organizations/{orgId}/analytics/{metricId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.role == 'admin';
    }

    match /organizations/{orgId}/auditLogs/{logId} {
      allow read: if request.auth != null && request.auth.token.role == 'admin';
      allow create: if request.auth != null;
    }

    // ── Top-level users (backward compat with client-side writes) ─────
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // ── Legacy collections (backward compat) ───────────────────────────
    match /patients/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /prescriptions/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /alerts/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /clinicalNotes/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /appointments/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /timeline_events/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
