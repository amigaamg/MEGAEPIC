[
  {
    "origin": ["*"],  // 🔒 For production, replace "*" with your domains
    "method": ["GET", "POST", "PUT", "DELETE", "HEAD", "OPTIONS"],
    "maxAgeSeconds": 3600,
    "responseHeader": [
      "Content-Type",
      "Authorization",
      "Content-Length",
      "User-Agent",
      "x-goog-resumable",
      "x-firebase-gmpid",
      "x-firebase-auth",
      "x-client-version"
    ]
  }
]