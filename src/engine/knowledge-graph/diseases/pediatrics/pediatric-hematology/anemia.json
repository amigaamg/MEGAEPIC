        "probability": 0.3,
        "lagDays": [180, 1095],
        "severityBoost": 0.3,
        "clues": ["chronic_iron_deficiency", "age_<2_years"]
      }
    ],

    "mustNotMiss": false,
    "emergencyPriority": "medium",
    "diagnosticClues": ["pallor", "fatigue", "pica", "microcytosis", "low_ferritin"],
    "exclusionClues": ["normal_hb", "normal_rbc_indices", "well_appearing"]
  }
