      ]
    },

    "management": {
      "protocolReference": "Thalassemia International Federation Guidelines",
      "pathways": [
        {
          "severity": "trait_minor",
          "criteria": "Mild microcytic anemia, Hb >10, asymptomatic",
          "treatment": "Reassurance. Genetic counseling. No iron supplements. Differentiate from iron deficiency. Prenatal diagnosis options for at-risk couples."
        },
        {
          "severity": "major",
          "criteria": "Hb <7 by 6-12 months, transfusion-dependent, skeletal changes",
          "treatment": "Regular PRBC transfusion (10-15 mL/kg) q3-4w. Target pre-transfusion Hb 9-10. Iron chelation: deferasirox 20-40 mg/kg/day oral or deferoxamine 40-50 mg/kg SC 5-7 days/week. Monitor ferritin. Consider HSCT."
        }
      ]
    },

    "pathophysiology": [
