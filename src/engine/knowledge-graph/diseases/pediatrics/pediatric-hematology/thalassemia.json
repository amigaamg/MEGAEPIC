    "subtypes": [
      {
        "id": "thalassemia_minor_trait",
        "name": "Thalassemia Minor (Trait)",
        "prevalenceModifier": 0.7,
        "keyFeatures": [
          { "feature": "microcytic_hypochromic_anemia_mild", "weight": 5 },
          { "feature": "hb_>10_g_dL", "weight": 4 },
          { "feature": "frequent_asymptomatic", "weight": 4 }
        ],
        "management": "No treatment needed. Genetic counseling. Avoid iron supplementation unless proven iron deficiency. Differentiate from iron deficiency with Hb electrophoresis."
      },
      {
        "id": "thalassemia_major",
        "name": "Thalassemia Major (Cooley Anemia)",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "severe_anemia_by_6_months", "weight": 5 },
          { "feature": "transfusion_dependent", "weight": 5 },
          { "feature": "skeletal_deformities", "weight": 4 }
        ],
        "management": "Regular PRBC transfusions q3-4 weeks to maintain Hb >9-10. Chelation therapy (deferasirox/deferoxamine) to prevent iron overload. Monitor ferritin, cardiac/liver iron. Splenectomy if hypersplenism. Curative: hematopoietic stem cell transplant."
      },
      {
        "id": "thalassemia_intermedia",
        "name": "Thalassemia Intermedia",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "moderate_anemia_hb_7_to_10", "weight": 5 },
          { "feature": "intermittent_transfusion_needs", "weight": 4 },
          { "feature": "splenomegaly", "weight": 3 }
        ],
        "management": "Monitor Hb and growth. Transfuse during illness/surgery/pregnancy. Hydroxyurea may reduce transfusion needs. Splenectomy if massive splenomegaly. Folate supplementation. Avoid iron overload."
      }
    ],

    "mimics": [
      {
        "diseaseId": "iron_deficiency_anemia",
        "discriminators": ["low_ferritin", "normal_hb_electrophoresis", "mentzer_index_>13", "response_to_iron"]
      },
