        { "name": "Hb electrophoresis (HPLC)", "priority": "immediate", "yield": 1.0, "indication": "definitive diagnosis, HbA2, HbF levels" },
        { "name": "Serum ferritin", "priority": "high", "yield": 0.6, "indication": "differentiate from iron deficiency" },
