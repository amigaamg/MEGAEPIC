    "management": {
      "protocolReference": "WFH Guidelines for Management of Hemophilia",
      "pathways": [
        {
          "severity": "mild_moderate_bleed",
          "criteria": "Factor level >1%, minor trauma, superficial bruising, no joint bleed",
          "treatment": "Factor replacement 25-40 IU/kg (VIII) or 50-80 IU/kg (IX) once. DDAVP 0.3 mcg/kg IV for mild A. Rest, ice, compression, elevation. Avoid aspirin/NSAIDs."
        },
        {
          "severity": "severe_bleed_or_life_threatening",
          "criteria": "Factor level <1%, spontaneous bleeding, hemarthrosis, ICH, major trauma",
          "treatment": "Factor VIII 50-75 IU/kg (then 25-50 IU/kg q8-12h) or Factor IX 100-120 IU/kg (then 50-70 IU/kg q12-24h). Maintain factor >50% for 7-14 days. ICU for ICH. Orthopedic consultation for hemarthrosis. Avoid IM injections."
        }
      ]
    },

