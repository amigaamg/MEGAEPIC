    ],

    "subtypes": [
      {
        "id": "medical_nec",
        "name": "Medical NEC (Bell Stage 1-2)",
        "prevalenceModifier": 0.65,
        "keyFeatures": [
          { "feature": "abdominal_distension_mild", "weight": 4 },
          { "feature": "bloody_stools", "weight": 4 },
          { "feature": "no_pneumoperitoneum", "weight": 5 },
          { "feature": "pneumatosis_intestinalis", "weight": 5 }
        ],
        "management": "NPO, nasogastric decompression, IV broad-spectrum antibiotics (ampicillin, gentamicin, metronidazole), IV fluids, serial abdominal X-rays q6-12h."
      },
      {
        "id": "surgical_nec",
        "name": "Surgical NEC (Bell Stage 3)",
        "prevalenceModifier": 0.35,
        "keyFeatures": [
          { "feature": "pneumoperitoneum", "weight": 5 },
          { "feature": "septic_shock", "weight": 5 },
          { "feature": "abdominal_wall_erythema", "weight": 5 },
          { "feature": "thrombocytopenia", "weight": 4 }
        ],
        "management": "Emergency laparotomy. Resection of necrotic bowel with enterostomy. Peritoneal drainage if unstable. ICU with ventilatory and inotropic support."
      }
    ],

    "mimics": [
      {
        "diseaseId": "neonatal_sepsis",
        "discriminators": ["positive_blood_culture", "no_pneumatosis_on_xray", "respiratory_symptoms_predominate"]
      },
      {
        "diseaseId": "spontaneous_intestinal_perforation",
        "discriminators": ["no_pneumatosis", "no_bloody_stools", "early_onset_first_week", "no_erythema"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Serial abdominal girth measurement", "priority": "immediate", "yield": 0.5, "indication": "monitor progression" },
        { "name": "Gastric aspirate assessment", "priority": "immediate", "yield": 0.4, "indication": "assess feeding tolerance" }
      ],
      "laboratory": [
        { "name": "CBC with platelets", "priority": "immediate", "yield": 0.7, "indication": "thrombocytopenia suggests severe disease" },
        { "name": "CRP", "priority": "high", "yield": 0.7, "indication": "elevated in NEC" },
        { "name": "Blood gas", "priority": "high", "yield": 0.6, "indication": "metabolic acidosis suggests ischemia" },
        { "name": "Blood culture", "priority": "immediate", "yield": 0.3, "indication": "rule out sepsis" },
        { "name": "Serum electrolytes", "priority": "high", "yield": 0.4, "indication": "electrolyte imbalances" }
      ],
      "imaging": [
        { "name": "Abdominal X-ray (supine + left lateral decubitus)", "priority": "immediate", "yield": 0.9, "indication": "pneumatosis, portal venous gas, pneumoperitoneum" }
      ]
    },

    "management": {
      "protocolReference": "NEC Management Guidelines - Vermont Oxford Network",
      "pathways": [
        {
          "severity": "medical",
          "criteria": "Bell stage 1-2, no perforation, stable vitals",
          "treatment": "NPO, OG tube for decompression, IV broad-spectrum antibiotics (ampicillin + gentamicin + metronidazole) for 10-14 days, IV fluids, parenteral nutrition, serial abdominal X-rays."
        },
        {
          "severity": "surgical",
          "criteria": "Bell stage 3, pneumoperitoneum, or clinical deterioration despite medical therapy",
          "treatment": "Emergency laparotomy or peritoneal drain. Resection of gangrenous bowel. Stoma formation. ICU support. Inotropes. Ventilator. Blood product support. Antibiotics 14-21 days."
        }
      ]
    },

    "pathophysiology": [
      "intestinal_ischemia",
      "immature_gut_barrier",
      "bacterial_translocation",
      "inflammation_cytokine_release",
      "pneumatosis_intestinalis",
      "necrosis",
      "perforation"
    ],

    "complications": [
