      { "symptomId": "bloody_stools", "weight": 4 },
      { "symptomId": "feeding_intolerance", "weight": 4 },
      { "symptomId": "apnea_bradycardia", "weight": 3 }
    ],

    "examFeatures": [
      { "signId": "abdominal_distension", "baseWeight": 5, "doubleWeight": true },
      { "signId": "abdominal_tenderness", "baseWeight": 4 },
      { "signId": "absent_bowel_sounds", "baseWeight": 4 },
      { "signId": "abdominal_wall_erythema", "baseWeight": 5, "note": "Late sign, surgical abdomen" },
      { "signId": "palpable_abdominal_mass", "baseWeight": 3 },
