      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Rapid diagnostic test (RDT) for malaria", "priority": "immediate", "yield": 0.95, "indication": "all febrile children in endemic area" }
      ],
      "laboratory": [
        { "name": "Thick and thin blood film microscopy", "priority": "immediate", "yield": 0.98, "indication": "species identification, parasitemia quantification" },
        { "name": "CBC (Hb, platelets)", "priority": "high", "yield": 0.7, "indication": "anemia, thrombocytopenia" },
        { "name": "Blood glucose", "priority": "immediate", "yield": 0.5, "indication": "hypoglycemia in severe malaria" },
        { "name": "Blood gas", "priority": "medium", "yield": 0.4, "indication": "metabolic acidosis" }
      ],
      "imaging": []
    },

    "management": {
      "protocolReference": "WHO Guidelines for Malaria Treatment",
      "pathways": [
        {
          "severity": "uncomplicated",
          "criteria": "Fever + positive test, no severe features, able to take oral",
          "treatment": "Oral ACT (artemether-lumefantrine 3-day course). Paracetamol for fever. Monitor urine output. Follow-up at day 3 and 7. If no improvement or vomiting, admit for IV therapy."
        },
        {
          "severity": "severe",
          "criteria": "Any WHO severe malaria criterion (coma, severe anemia, prostration, respiratory distress, convulsions, hypoglycemia)",
          "treatment": "IV artesunate 2.4 mg/kg at 0, 12, 24h, then daily until able to take oral, then complete ACT course. Supportive: blood transfusion if Hb <5, anticonvulsants, glucose 10% 5 mL/kg for hypoglycemia, careful fluid balance."
        }
      ]
    },

    "pathophysiology": [
