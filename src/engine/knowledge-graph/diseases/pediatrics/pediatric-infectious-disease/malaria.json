          { "feature": "splenomegaly", "weight": 3 },
          { "feature": "positive_rdt_microscopy", "weight": 5 },
          { "feature": "no_severe_features", "weight": 5 }
        ],
        "management": "Oral artemisinin-based combination therapy (ACT): artemether-lumefantrine or artesunate-amodiaquine. Treat for 3 days. Ensure adequate hydration. Monitor for complications."
      },
      {
        "id": "severe_malaria",
        "name": "Severe Malaria (P. falciparum)",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
