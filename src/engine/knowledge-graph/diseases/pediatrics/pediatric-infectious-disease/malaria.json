          { "feature": "severe_anemia_hb_<5", "weight": 5 },
          { "feature": "respiratory_distress_acidosis", "weight": 5 },
          { "feature": "parasitemia_>10%", "weight": 4 }
        ],
        "management": "IV artesunate (2.4 mg/kg at 0, 12, 24h then daily) or IV quinine if artesunate unavailable. Treat complications: blood transfusion for severe anemia, anticonvulsants for seizures, glucose for hypoglycemia, IV fluids cautiously."
      }
    ],

    "mimics": [
