    "management": {
      "protocolReference": "WHO Measles Management Guidelines",
      "pathways": [
        {
          "severity": "uncomplicated",
          "criteria": "No pneumonia, no encephalitis, no severe dehydration, no malnutrition",
          "treatment": "Vitamin A 200,000 IU (<6m: 50,000 IU; 6-11m: 100,000 IU) x 2 doses. Antipyretics. Adequate hydration. Nutrition. Isolate for 4 days after rash onset. Report to public health."
        },
        {
          "severity": "complicated",
          "criteria": "Pneumonia, encephalitis, severe dehydration, croup, or severe malnutrition",
          "treatment": "Hospitalize. Vitamin A as above. Oxygen if SpO2 <92%. IV antibiotics for bacterial superinfection. IV fluids for dehydration. Anticonvulsants for seizures. Corticosteroids for croup. Isolation."
        }
      ]
