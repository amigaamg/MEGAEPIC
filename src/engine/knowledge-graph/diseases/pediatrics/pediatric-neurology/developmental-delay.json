{
  "disease": {
    "id": "developmental-delay",
    "name": "Global Developmental Delay",
    "system": "PAED",
    "agePeak_months": [6, 60],
    "note": "Significant delay in two or more developmental domains (motor, speech, social, cognitive). Early identification and intervention improve outcomes.",
    "prevalenceWeight": 0.3,
    "syndromeTags": ["neurodevelopmental_disorder", "developmental_delay"],

    "severityAssessment": {
      "immediateDangerSigns": [
        { "sign": "regression_of_milestones", "weight": 10 },
        { "sign": "unexplained_seizures", "weight": 9 },
        { "sign": "loss_of_vision_or_hearing", "weight": 9 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "severe_delay_all_domains", "weight": 7 },
          { "sign": "microcephaly_or_macrocephaly", "weight": 6 },
          { "sign": "dysmorphic_features", "weight": 6 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If regression or severe involvement of all domains -> SEVERE; else -> NON-SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "delayed_motor_milestones", "weight": 5 },
      { "symptomId": "delayed_speech", "weight": 5 },
      { "symptomId": "delayed_social_milestones", "weight": 4 },
      { "symptomId": "loss_of_milestones_regression", "weight": 5 },
      { "symptomId": "abnormal_pregnancy_birth_history", "weight": 3 },
      { "symptomId": "family_history_developmental_delay", "weight": 3 }
    ],

    "examFeatures": [
      { "signId": "hypotonia", "baseWeight": 4 },
      { "signId": "poor_head_control", "baseWeight": 4 },
      { "signId": "microcephaly_or_macrocephaly", "baseWeight": 4 },
      { "signId": "dysmorphic_features", "baseWeight": 4 },
      { "signId": "poor_visual_tracking", "baseWeight": 3 },
      { "signId": "abnormal_tone_spasticity", "baseWeight": 3 },
      { "signId": "contractures", "baseWeight": 2 },
      { "signId": "unusual_facial_features", "baseWeight": 3 }
    ],

    "riskFactors": [
      { "id": "prematurity", "multiplier": 2.5 },
      { "id": "birth_asphyxia", "multiplier": 3.0 },
      { "id": "low_birth_weight", "multiplier": 2.0 },
      { "id": "maternal_substance_abuse", "multiplier": 2.5 },
      { "id": "maternal_infection_during_pregnancy", "multiplier": 2.0 },
      { "id": "family_history", "multiplier": 2.5 },
      { "id": "chromosomal_abnormality", "multiplier": 3.0 },
      { "id": "postnatal_infection_meningitis", "multiplier": 2.5 }
    ],

    "subtypes": [
      {
        "id": "motor_delay",
        "name": "Motor Developmental Delay",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "delayed_rolling_sitting_walking", "weight": 5 },
          { "feature": "hypotonia", "weight": 4 },
          { "feature": "persistent_primitive_reflexes", "weight": 4 }
        ],
        "management": "Physical therapy. Occupational therapy. Orthotics if needed. Investigate underlying cause (MRI, CP workup, neuromuscular evaluation)."
      },
      {
        "id": "speech_language_delay",
        "name": "Speech and Language Delay",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "no_babbling_by_12_months", "weight": 5 },
          { "feature": "no_words_by_18_months", "weight": 5 },
          { "feature": "no_phrases_by_24_months", "weight": 5 }
        ],
        "management": "Speech therapy. Hearing test (audiology). Autism screening. Language stimulation at home. Monitor for other developmental domains."
      },
      {
        "id": "global_delay",
        "name": "Global Developmental Delay",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "delay_in_multiple_domains", "weight": 5 },
          { "feature": "cognitive_impairment", "weight": 5 },
          { "feature": "neurologic_abnormalities", "weight": 4 }
        ],
        "management": "Multidisciplinary evaluation. Genetic testing (CMA, fragile X). Brain MRI. Metabolic workup. Early intervention program. Special education planning."
      }
    ],

    "mimics": [
      {
        "diseaseId": "autism_spectrum_disorder",
        "discriminators": ["social_communication_deficits", "restricted_interests", "stereotypies", "normal_early_motor_milestones"]
      },
      {
        "diseaseId": "hearing_impairment",
        "discriminators": ["speech_delay_only", "normal_other_domains", "abnormal_audiometry"]
      },
      {
        "diseaseId": "environmental_deprivation",
        "discriminators": ["improvement_with_enriched_environment", "normal_physical_exam"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Developmental screening (Denver II, ASQ)", "priority": "immediate", "yield": 0.8, "indication": "all children with suspected delay" }
      ],
      "laboratory": [
        { "name": "Genetic microarray", "priority": "high", "yield": 0.4, "indication": "identify copy number variants" },
        { "name": "Fragile X DNA testing", "priority": "high", "yield": 0.3, "indication": "most common inherited cause" },
        { "name": "Thyroid function", "priority": "medium", "yield": 0.1, "indication": "congenital hypothyroidism" },
        { "name": "Metabolic screening (TMS, urine organic acids)", "priority": "medium", "yield": 0.15, "indication": "inborn errors of metabolism" }
      ],
      "imaging": [
        { "name": "Brain MRI", "priority": "high", "yield": 0.4, "indication": "structural brain abnormalities" }
      ]
    },

    "management": {
      "protocolReference": "AAP Guidelines for Developmental Delay Evaluation",
      "pathways": [
        {
          "severity": "mild_delay",
          "criteria": "Delay in one domain, mild, no regression, no neurologic signs",
          "treatment": "Targeted therapy for affected domain. Monitor development every 3-6 months. Early intervention program (EIP). Review at 6 months for progress."
        },
        {
          "severity": "moderate_to_severe_delay",
          "criteria": "Multiple domains affected, regression, abnormal neurologic exam, dysmorphism",
          "treatment": "Multidisciplinary team (developmental pediatrician, neurologist, genetics, PT/OT/SLP). MRI brain. Genetic testing. Metabolic workup. Epilepsy monitoring. Special education placement. Family support and counseling."
        }
      ]
    },

    "pathophysiology": [
      "genetic_mutation",
      "chromosomal_abnormality",
      "hypoxic_ischemic_injury",
      "metabolic_disorder",
      "structural_brain_anomaly",
      "environmental_deprivation"
    ],

    "complications": [
      {
        "diseaseId": "intellectual_disability",
        "probability": 0.4,
        "lagDays": [365, 3650],
        "severityBoost": 0.3,
        "clues": ["global_delay", "abnormal_mri", "genetic_diagnosis"]
      },
      {
        "diseaseId": "epilepsy",
        "probability": 0.2,
        "lagDays": [30, 3650],
        "severityBoost": 0.3,
        "clues": ["abnormal_eeg", "cerebral_palsy", "structural_abnormality"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "low",
    "diagnosticClues": ["missed_milestones", "abnormal_tone", "poor_visual_tracking", "dysmorphism", "regression"],
    "exclusionClues": ["normal_milestones", "catch_up_growth", "normal_exam"]
  }
}
