    "subtypes": [
      {
        "id": "spastic_cp",
        "name": "Spastic Cerebral Palsy",
        "prevalenceModifier": 0.75,
        "keyFeatures": [
          { "feature": "increased_tone", "weight": 5 },
          { "feature": "hyperreflexia", "weight": 4 },
          { "feature": "positive_babinski", "weight": 4 },
          { "feature": "scissoring_gait", "weight": 3 }
        ],
        "management": "Physical therapy (stretching, strengthening). Botulinum toxin for focal spasticity. Baclofen (oral or intrathecal pump). Orthopedic surgery for contractures (tendo-Achilles lengthening, adductor release)."
      },
      {
        "id": "dyskinetic_cp",
        "name": "Dyskinetic Cerebral Palsy",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "involuntary_movements", "weight": 5 },
          { "feature": "fluctuating_tone", "weight": 4 },
          { "feature": "dystonia_athetosis", "weight": 5 }
        ],
        "management": "Trihexyphenidyl or levodopa trials. Deep brain stimulation for severe dystonia. Physical and occupational therapy. Communication aids."
      },
      {
        "id": "ataxic_cp",
        "name": "Ataxic Cerebral Palsy",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
          { "feature": "intention_tremor", "weight": 4 },
          { "feature": "wide_based_gait", "weight": 5 },
          { "feature": "poor_coordination", "weight": 4 }
        ],
        "management": "Physical therapy with balance training. Occupational therapy for fine motor skills. Speech therapy."
      }
    ],

    "mimics": [
