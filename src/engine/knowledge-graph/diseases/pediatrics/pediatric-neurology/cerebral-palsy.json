        { "name": "GMFCS classification", "priority": "high", "yield": 0.8, "indication": "severity grading" }
      ],
      "laboratory": [
        { "name": "Metabolic screening", "priority": "medium", "yield": 0.2, "indication": "rule out progressive metabolic disorders" },
        { "name": "Genetic testing (microarray)", "priority": "medium", "yield": 0.3, "indication": "identify genetic etiology" }
      ],
      "imaging": [
        { "name": "Brain MRI", "priority": "high", "yield": 0.85, "indication": "identify structural brain abnormalities (PVL, stroke, malformation)" }
      ]
    },

    "management": {
      "protocolReference": "AACPDM Care Pathway for Cerebral Palsy",
      "pathways": [
        {
          "severity": "gmfcs_i_iii",
          "criteria": "Independent ambulation or with aids, no severe comorbidities",
          "treatment": "Early intervention (physical, occupational, speech therapy). Botulinum toxin for focal spasticity. Orthotics (AFOs). Regular orthopedic follow-up for contractures."
        },
        {
          "severity": "gmfcs_iv_v",
          "criteria": "Non-ambulatory, dependent for ADLs, often with intellectual disability",
          "treatment": "Multidisciplinary team. Baclofen (oral/ITB). Seating and positioning aids. Nutritional support (gastrostomy if needed). Respiratory care. Seizure management. Caregiver support and respite."
        }
      ]
    },

    "pathophysiology": [
      "periventricular_leukomalacia",
