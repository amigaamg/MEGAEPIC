      { "id": "certain_genetic_syndromes", "multiplier": 4.0 },
      { "id": "sibling_with_leukemia", "multiplier": 2.0 }
    ],

    "subtypes": [
      {
        "id": "b_cell_all",
        "name": "B-Cell Precursor ALL (Common ALL)",
        "prevalenceModifier": 0.85,
        "keyFeatures": [
          { "feature": "cd10_cd19_positive", "weight": 5 },
          { "feature": "age_2_to_5_years", "weight": 4 },
          { "feature": "good_prognosis_subtypes", "weight": 3 }
        ],
        "management": "Multi-agent chemotherapy protocol (induction, consolidation, maintenance phases) over 2-2.5 years. Intrathecal chemotherapy for CNS prophylaxis. Risk stratification based on age, WBC, cytogenetics."
      },
      {
        "id": "t_cell_all",
        "name": "T-Cell ALL",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "cd3_cd7_positive", "weight": 5 },
          { "feature": "older_age_male", "weight": 3 },
          { "feature": "mediastinal_mass", "weight": 4 }
        ],
        "management": "High-risk protocol with intensified therapy. Cyclophosphamide, cytarabine, nelarabine. Mediastinal mass monitoring. Cranial irradiation if CNS disease."
      }
    ],

    "mimics": [
      {
        "diseaseId": "aplastic_anemia",
        "discriminators": ["pancytopenia_no_blasts", "hypocellular_marrow", "no_lymphadenopathy_or_organomegaly"]
      },
      {
        "diseaseId": "infectious_mononucleosis",
        "discriminators": ["positive_monospot", "atypical_lymphocytes_on_film", "self_limiting"]
      },
      {
        "diseaseId": "neuroblastoma",
        "discriminators": ["abdominal_mass", "urinary_catecholamines", "bone_marrow_rosettes"]
      }
    ],

    "investigations": {
      "bedside": [],
      "laboratory": [
        { "name": "CBC with differential and blast count", "priority": "immediate", "yield": 0.95, "indication": "anemia, thrombocytopenia, blasts" },
        { "name": "Bone marrow aspirate and biopsy", "priority": "immediate", "yield": 1.0, "indication": "definitive diagnosis, immunophenotyping" },
        { "name": "Flow cytometry (CD markers)", "priority": "high", "yield": 1.0, "indication": "lineage classification" },
        { "name": "Cytogenetics/FISH", "priority": "high", "yield": 0.8, "indication": "prognostic markers (ETV6-RUNX1, BCR-ABL, etc.)" },
        { "name": "CSF analysis", "priority": "high", "yield": 0.6, "indication": "CNS involvement" }
      ],
      "imaging": [
        { "name": "Chest X-ray", "priority": "immediate", "yield": 0.5, "indication": "mediastinal mass" },
        { "name": "Abdominal Ultrasound", "priority": "medium", "yield": 0.5, "indication": "hepatosplenomegaly" }
      ]
    },

    "management": {
      "protocolReference": "COG (Children's Oncology Group) / UKALL Protocols",
      "pathways": [
        {
          "severity": "standard_risk",
          "criteria": "Age 1-10y, WBC <50K, no CNS/testicular disease, favorable cytogenetics",
          "treatment": "Induction (vincristine, dexamethasone, PEG-asparaginase, daunorubicin). Consolidation. Interim maintenance. Delayed intensification. Maintenance (oral 6-MP, MTX). Intrathecal chemotherapy. Total duration 2-2.5 years."
        },
        {
          "severity": "high_risk",
          "criteria": "Age <1y or >10y, WBC >50K, CNS disease, T-cell, poor cytogenetics",
          "treatment": "Intensified induction. High-dose MTX. Additional agents (cytarabine, etoposide). Cranial RT if CNS+. Allogeneic HSCT for very high risk (BCR-ABL, induction failure)."
        }
      ]
    },

    "pathophysiology": [
      "genetic_mutation", "clonal_expansion", "lymphoblast_proliferation", "bone_marrow_failure", "organ_infiltration", "immunosuppression"
    ],

    "complications": [
