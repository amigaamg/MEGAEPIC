      { "symptomId": "lymphadenopathy", "weight": 3 },
      { "symptomId": "abdominal_distension", "weight": 3, "note": "Hepatosplenomegaly" },
      { "symptomId": "loss_of_appetite_weight_loss", "weight": 3 },
      { "symptomId": "recurrent_fever_night_sweats", "weight": 3 }
    ],

    "examFeatures": [
      { "signId": "pallor", "baseWeight": 5 },
      { "signId": "petechiae_purpura", "baseWeight": 5, "doubleWeight": true },
      { "signId": "hepatosplenomegaly", "baseWeight": 4 },
      { "signId": "lymphadenopathy", "baseWeight": 4 },
      { "signId": "fever", "baseWeight": 3 },
