        "lagDays": [365, 1825],
        "severityBoost": 0.6,
        "clues": ["reappearance_of_blasts", "falling_counts_again"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "high",
    "diagnosticClues": ["pallor_bruising_fever_triad", "bone_pain", "hepatosplenomegaly", "blasts_on_film"],
    "exclusionClues": ["normal_cbc", "no_blasts", "self_limiting_fever"]
  }
