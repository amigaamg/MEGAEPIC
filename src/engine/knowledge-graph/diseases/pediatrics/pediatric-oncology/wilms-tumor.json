        "clues": ["doxorubicin_exposure", "reduced_ef"]
      },
      {
        "diseaseId": "second_malignancy",
        "probability": 0.02,
        "lagDays": [1825, 10950],
        "severityBoost": 0.5,
        "clues": ["prior_radiation", "prior_doxorubicin"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "high",
    "diagnosticClues": ["asymptomatic_abdominal_mass", "hematuria", "hypertension", "age_2_to_5_years"],
    "exclusionClues": ["cystic_renal_lesion", "extrarenal_mass", "normal_imaging"]
  }
