{
  "disease": {
    "id": "learning-disabilities",
    "name": "Specific Learning Disorders / Learning Disabilities",
    "system": "PAED",
    "agePeak_months": [72, 180],
    "note": "Neurodevelopmental disorders affecting specific academic skills (reading, writing, mathematics) despite adequate intelligence and educational opportunity. Dyslexia most common.",
    "prevalenceWeight": 0.4,
    "syndromeTags": ["neurodevelopmental_disorder", "academic_difficulty"],

    "severityAssessment": {
      "immediateDangerSigns": [
        { "sign": "severe_functional_illiteracy", "weight": 7 },
        { "sign": "significant_emotional_distress_school_refusal", "weight": 6 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "academic_skills_>2_sd_below_mean", "weight": 7 },
          { "sign": "multiple_domains_affected", "weight": 6 },
          { "sign": "severe_impact_on_daily_living", "weight": 6 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If severe underachievement across multiple domains -> SEVERE; else -> NON-SEVERE (mild/moderate single domain)"
    },

    "historyFeatures": [
      { "symptomId": "difficulty_learning_to_read", "weight": 5 },
      { "symptomId": "poor_spelling_phonetic_skills", "weight": 5 },
      { "symptomId": "slow_reading_accuracy_issues", "weight": 5 },
      { "symptomId": "difficulty_with_math_concepts", "weight": 3 },
      { "symptomId": "difficulty_expressing_thoughts_writing", "weight": 4 },
      { "symptomId": "gap_between_ability_and_achievement", "weight": 4 },
      { "symptomId": "history_of_speech_language_delay", "weight": 2 },
      { "symptomId": "family_history_learning_disorders", "weight": 3 },
      { "symptomId": "school_avoidance_low_self_esteem", "weight": 3 }
    ],

    "examFeatures": [
      { "signId": "difficulty_reading_age_appropriate_text", "baseWeight": 5, "doubleWeight": true },
      { "signId": "reversal_of_letters_b_d", "baseWeight": 3 },
      { "signId": "poor_phonological_awareness", "baseWeight": 4 },
      { "signId": "poor_comprehension_despite_decoding", "baseWeight": 3 },
      { "signId": "difficulty_following_sequences", "baseWeight": 3 }
    ],

    "riskFactors": [
      { "id": "family_history_learning_disability", "multiplier": 4.0 },
      { "id": "prematurity_low_birth_weight", "multiplier": 2.0 },
      { "id": "perinatal_asphyxia", "multiplier": 2.0 },
      { "id": "male_gender_dyslexia", "multiplier": 2.0 },
      { "id": "language_delay_early_childhood", "multiplier": 2.5 },
      { "id": "lead_exposure", "multiplier": 1.5 }
    ],

    "subtypes": [
      {
        "id": "dyslexia_reading_disorder",
        "name": "Dyslexia (Specific Reading Disorder)",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
          { "feature": "inaccurate_slow_reading", "weight": 5 },
          { "feature": "poor_phonological_awareness", "weight": 5 },
          { "feature": "letter_reversals", "weight": 3 },
          { "feature": "family_history_dyslexia", "weight": 4 }
        ],
        "management": "Structured literacy instruction (Orton-Gillingham, Wilson, Barton). Phonological awareness training. Audiobooks/text-to-speech. Extra time on tests. 504/IEP accommodations."
      },
      {
        "id": "dysgraphia_writing_disorder",
        "name": "Dysgraphia (Written Expression Disorder)",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "illegible_handwriting", "weight": 5 },
          { "feature": "difficulty_organizing_writing", "weight": 4 },
          { "feature": "pencil_grip_problems", "weight": 3 }
        ],
        "management": "Occupational therapy (fine motor skills, pencil grip). Typing instruction. Speech-to-text software. Graphic organizers. Reduced written output expectations."
      },
      {
        "id": "dyscalculia_math_disorder",
        "name": "Dyscalculia (Mathematics Disorder)",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "difficulty_with_number_sense", "weight": 5 },
          { "feature": "poor_math_facts_retrieval", "weight": 5 },
          { "feature": "difficulty_with_time_money", "weight": 3 }
        ],
        "management": "Multisensory math instruction (TouchMath). Concrete-representational-abstract approach. Calculator accommodations. Extra time. Repetition and visual supports."
      }
    ],

    "mimics": [
      {
        "diseaseId": "intellectual_disability",
        "discriminators": ["below_average_iq_<70", "global_delay_all_areas", "adaptive_functioning_deficits"]
      },
      {
        "diseaseId": "adhd",
        "discriminators": ["inattention_affects_all_subjects", "hyperactivity_impulsivity", "improves_with_stimulants"]
      },
      {
        "diseaseId": "vision_hearing_impairment",
        "discriminators": ["correctable_with_glasses_hearing_aids", "normal_learning_when_accommodated"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Psychoeducational assessment (IQ + achievement testing)", "priority": "high", "yield": 0.95, "indication": "confirm discrepancy between IQ and achievement" }
      ],
      "laboratory": [],
      "imaging": []
    },

    "management": {
      "protocolReference": "IDEA / DSM-5-TR Specific Learning Disorder Guidelines",
      "pathways": [
        {
          "severity": "mild_moderate",
          "criteria": "Single domain affected, IQ >85, can keep up with modified instruction",
          "treatment": "Specialized tutoring in affected area. Classroom accommodations (extra time, reduced assignments, audiobooks). Monitor progress quarterly. Build self-esteem."
        },
        {
          "severity": "severe",
          "criteria": "Multiple domains affected, or severe academic deficiency despite intervention",
          "treatment": "Intensive specialized instruction (pull-out/push-in services). Assistive technology (text-to-speech, speech-to-text). Individualized Education Program (IEP). Consider tutoring and mental health support for secondary anxiety/depression."
        }
      ]
    },

    "pathophysiology": [
      "genetic_basis", "cortical_dysfunction_reading_math_networks", "phonological_processing_deficit", "visual_spatial_processing_deficit"
    ],

    "complications": [
      {
        "diseaseId": "secondary_anxiety_depression",
        "probability": 0.4,
        "lagDays": [365, 3650],
        "severityBoost": 0.2,
        "clues": ["school_refusal", "low_self_esteem", "frustration"]
      }
    ],

    "mustNotMiss": false,
    "emergencyPriority": "low",
    "diagnosticClues": ["achievement_gap_despite_normal_iq", "reading_difficulty_persistent", "letter_reversals", "family_history"],
    "exclusionClues": ["global_delay", "no_gap_between_iq_and_achievement", "environmental_cause"]
  }
}
