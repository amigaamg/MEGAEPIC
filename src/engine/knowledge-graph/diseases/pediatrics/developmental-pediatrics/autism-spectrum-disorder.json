      { "id": "male_gender", "multiplier": 4.0 }
    ],

    "subtypes": [
      {
        "id": "asd_level_1",
        "name": "ASD Level 1 (Requiring Support)",
        "prevalenceModifier": 0.5,
        "keyFeatures": [
          { "feature": "verbal_with_pragmatic_deficits", "weight": 4 },
          { "feature": "social_awkwardness", "weight": 4 },
          { "feature": "restricted_interests_manageable", "weight": 3 }
        ],
        "management": "Behavioral therapy (ABA). Social skills training. Speech therapy. Occupational therapy. School accommodations (IEP/504 plan). Monitor for anxiety/ADHD."
      },
      {
        "id": "asd_level_3",
        "name": "ASD Level 3 (Requiring Very Substantial Support)",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "minimal_verbal_communication", "weight": 5 },
          { "feature": "severe_behavioral_challenges", "weight": 5 },
          { "feature": "intellectual_disability_often", "weight": 4 }
        ],
        "management": "Intensive behavioral intervention (30-40h/week ABA). Augmentative communication (PECS, AAC devices). Psychopharmacology for comorbidities (risperidone/aripiprazole for irritability). Respite care. Specialized school."
      }
    ],

    "mimics": [
      {
        "diseaseId": "hearing_impairment",
        "discriminators": ["normal_social_interaction", "abnormal_audiogram", "responds_to_sign_language"]
