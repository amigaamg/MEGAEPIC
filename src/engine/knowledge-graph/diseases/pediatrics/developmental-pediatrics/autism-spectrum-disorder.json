      { "signId": "lack_of_shared_attention", "baseWeight": 5 },
      { "signId": "hand_flapping_twirling", "baseWeight": 4 },
      { "signId": "toe_walking", "baseWeight": 3 },
      { "signId": "hyper_or_hypo_reactivity_to_sensory_input", "baseWeight": 4 },
