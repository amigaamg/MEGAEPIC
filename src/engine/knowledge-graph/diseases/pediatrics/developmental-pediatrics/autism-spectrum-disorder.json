      "pathways": [
        {
          "severity": "diagnosis_early_intervention",
          "criteria": "ASD diagnosis confirmed, any severity",
          "treatment": "Early intensive behavioral intervention (EIBI). Speech therapy. Occupational therapy (sensory integration). Parent training. Special education services. Medical management of comorbidities (GI issues, sleep, anxiety, ADHD)."
        }
      ]
    },

    "pathophysiology": [
