        "lagDays": [365, 3650],
        "severityBoost": 0.2,
        "clues": ["falling_grades", "homework_completion_difficulty"]
      },
      {
        "diseaseId": "oppositional_defiant_disorder",
        "probability": 0.3,
        "lagDays": [365, 1825],
        "severityBoost": 0.2,
        "clues": ["argumentative", "defiant", "angry_resentful"]
      }
    ],

    "mustNotMiss": false,
    "emergencyPriority": "low",
    "diagnosticClues": ["inattention_hyperactivity_impulsivity", "onset_before_12", "cross_setting_impairment"],
    "exclusionClues": ["symptoms_only_in_one_setting", "better_explained_by_another_condition"]
