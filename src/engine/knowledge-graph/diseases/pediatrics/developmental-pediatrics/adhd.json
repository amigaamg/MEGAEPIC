      { "id": "traumatic_brain_injury", "multiplier": 2.0 },
      { "id": "lead_exposure", "multiplier": 2.0 }
    ],

    "subtypes": [
      {
        "id": "adhd_inattentive",
        "name": "ADHD - Predominantly Inattentive Presentation",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "inattention_>5_of_9_criteria", "weight": 5 },
          { "feature": "less_hyperactivity", "weight": 3 },
          { "feature": "often_overlooked_girls", "weight": 3 }
        ],
        "management": "Behavioral classroom interventions. Academic accommodations. Stimulant medication: methylphenidate or amphetamine-based. Monitor growth and appetite."
      },
      {
        "id": "adhd_hyperactive_impulsive",
        "name": "ADHD - Predominantly Hyperactive-Impulsive Presentation",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
          { "feature": "hyperactivity_>5_of_9_criteria", "weight": 5 },
          { "feature": "impulsivity", "weight": 4 },
          { "feature": "runs_climbs_excessively", "weight": 4 }
        ],
        "management": "Parent behavior management training. Classroom behavior plan. Stimulant medication. Social skills training. Consistent routines and expectations."
      },
      {
        "id": "adhd_combined",
        "name": "ADHD - Combined Presentation",
        "prevalenceModifier": 0.35,
        "keyFeatures": [
          { "feature": "both_inattention_and_hyperactivity_impulsivity", "weight": 5 },
          { "feature": "greater_functional_impairment", "weight": 4 },
          { "feature": "more_comorbid_conditions", "weight": 3 }
        ],
        "management": "Multimodal treatment: medication + behavioral therapy. School accommodations (504 plan). Parent training. Address comorbidities (anxiety, ODD, learning disabilities)."
      }
    ],

    "mimics": [
      {
        "diseaseId": "anxiety_disorder",
        "discriminators": ["worry_predominant", "somatic_symptoms", "avoidance_behaviors"]
      },
      {
        "diseaseId": "learning_disorder",
        "discriminators": ["specific_academic_difficulty", "inattention_only_in_that_subject"]
      },
      {
        "diseaseId": "sleep_disorder_apnea",
        "discriminators": ["snoring", "daytime_sleepiness", "nocturnal_awakenings", "tonsillar_hypertrophy"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Vanderbilt ADHD Assessment Scale (parent + teacher)", "priority": "high", "yield": 0.9, "indication": "diagnostic assessment" }
      ],
      "laboratory": [],
      "imaging": []
    },

    "management": {
      "protocolReference": "AAP Clinical Practice Guidelines for ADHD",
      "pathways": [
        {
          "severity": "mild_moderate",
          "criteria": "Symptoms impairing but manageable, <6 years old or parent preference for behavioral first",
          "treatment": "Parent behavior training (first line for preschool). Classroom behavioral interventions. If inadequate response: trial of stimulant medication (methylphenidate). Monitor height/weight quarterly."
        },
        {
          "severity": "moderate_severe",
          "criteria": "Significant functional impairment in multiple settings, school-age",
          "treatment": "Stimulant medication (methylphenidate or amphetamine) combined with behavioral therapy. Start with low dose, titrate. Monitor BP, HR, appetite, sleep. Consider non-stimulants (atomoxetine, guanfacine) if stimulant contraindicated."
        }
      ]
    },

    "pathophysiology": [
      "dopamine_and_norepinephrine_dysregulation", "prefrontal_cortex_dysfunction", "frontostriatal_circuitry_impairment", "genetic_predisposition"
    ],

    "complications": [
      {
        "diseaseId": "academic_underachievement",
