          { "sign": "severe_impairment_multiple_settings", "weight": 7 },
          { "sign": "academic_failure", "weight": 6 },
          { "sign": "social_isolation", "weight": 5 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If dangerous impulsivity or severe functional impairment -> SEVERE; else -> NON-SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "difficulty_sustaining_attention", "weight": 5 },
      { "symptomId": "easily_distracted", "weight": 5 },
      { "symptomId": "fidgety_restless", "weight": 4 },
      { "symptomId": "interrupts_others", "weight": 4 },
      { "symptomId": "forgetful_loses_things", "weight": 4 },
      { "symptomId": "difficulty_organizing_tasks", "weight": 3 },
      { "symptomId": "symptoms_present_before_age_12", "weight": 5 },
      { "symptomId": "symptoms_in_multiple_settings", "weight": 4 }
    ],

    "examFeatures": [
      { "signId": "difficulty_staying_seated", "baseWeight": 4 },
      { "signId": "fidgeting_squirming", "baseWeight": 4 },
      { "signId": "blurts_out_answers", "baseWeight": 3 },
      { "signId": "poor_follow_through_on_instructions", "baseWeight": 3 },
      { "signId": "avoidance_of_sustained_mental_effort", "baseWeight": 3 },
      { "signId": "appears_not_listening", "baseWeight": 3 }
