    "mustNotMiss": true,
    "emergencyPriority": "medium",
    "diagnosticClues": ["migratory_polyarthritis", "carditis", "sydenham_chorea", "erythema_marginatum", "history_of_strep_throat"],
    "exclusionClues": ["no_strep_history", "negative_asotiter", "normal_echo"]
  }
