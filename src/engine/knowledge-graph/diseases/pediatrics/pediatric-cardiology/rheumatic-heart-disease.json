{
  "disease": {
    "id": "rheumatic-heart-disease",
    "name": "Rheumatic Heart Disease",
    "system": "PAED",
    "agePeak_months": [60, 180],
    "note": "Late sequelae of acute rheumatic fever causing chronic valvular damage. Most common acquired heart disease in children in developing countries.",
    "prevalenceWeight": 0.4,
    "syndromeTags": ["acquired_valvular_disease", "pediatric_cardiology"],

    "severityAssessment": {
      "immediateDangerSigns": [
        { "sign": "cardiogenic_shock", "weight": 10 },
        { "sign": "pulmonary_edema", "weight": 10 },
        { "sign": "acute_severe_valvular_regurgitation", "weight": 9 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "severe_valve_regurgitation", "weight": 8 },
          { "sign": "heart_failure_symptoms", "weight": 7 },
          { "sign": "atrial_fibrillation", "weight": 6 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If acute valvulitis with heart failure -> SEVERE; else -> NON-SEVERE (chronic stable RHD)"
    },

    "historyFeatures": [
      { "symptomId": "sore_throat_preceding_weeks", "weight": 4, "note": "Group A streptococcal pharyngitis" },
      { "symptomId": "joint_pain_swelling", "weight": 4 },
      { "symptomId": "fever", "weight": 3 },
      { "symptomId": "chest_pain", "weight": 3 },
      { "symptomId": "palpitations", "weight": 3 },
      { "symptomId": "shortness_of_breath", "weight": 4 },
      { "symptomId": "fatigue_exercise_intolerance", "weight": 3 }
    ],

    "examFeatures": [
      { "signId": "cardiac_murmur", "baseWeight": 5, "doubleWeight": true },
      { "signId": "fever", "baseWeight": 3 },
      { "signId": "tachycardia_out_of_proportion", "baseWeight": 4 },
      { "signId": "subcutaneous_nodules", "baseWeight": 3 },
      { "signId": "erythema_marginatum", "baseWeight": 3 },
      { "signId": "sydenham_chorea", "baseWeight": 4 },
      { "signId": "hepatomegaly", "baseWeight": 3 },
      { "signId": "signs_of_hf", "baseWeight": 4 }
    ],

    "riskFactors": [
      { "id": "untreated_strep_pharyngitis", "multiplier": 3.0 },
      { "id": "recurrent_strep_infections", "multiplier": 2.5 },
      { "id": "low_socioeconomic_status", "multiplier": 2.0 },
      { "id": "overcrowding", "multiplier": 2.0 },
      { "id": "family_history_rhd", "multiplier": 1.5 },
      { "id": "age_5_to_15_years", "multiplier": 2.5 }
    ],

    "subtypes": [
      {
        "id": "acute_rheumatic_fever_with_carditis",
        "name": "Acute Rheumatic Fever with Carditis",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "pancarditis", "weight": 5 },
          { "feature": "new_murmur_mitral_regurgitation", "weight": 5 },
          { "feature": "fever", "weight": 3 },
          { "feature": "arthralgia", "weight": 4 }
        ],
        "management": "Bed rest. High-dose aspirin (80-100 mg/kg/day). Prednisone if severe carditis. Penicillin V for 10 days to eradicate strep. Injectable benzathine penicillin G monthly for secondary prophylaxis."
      },
      {
        "id": "chronic_rheumatic_heart_disease",
        "name": "Chronic Rheumatic Heart Disease",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
          { "feature": "mitral_stenosis_or_regurgitation", "weight": 5 },
          { "feature": "aortic_valve_disease", "weight": 3 },
          { "feature": "exercise_intolerance", "weight": 4 }
        ],
        "management": "Secondary prophylaxis (benzathine penicillin G q3-4 weeks until age 40 or longer). Diuretics for HF. ACE inhibitors. Anticoagulation if AF. Surgical: valve repair/replacement for severe disease."
      }
    ],

    "mimics": [
      {
        "diseaseId": "infective_endocarditis",
        "discriminators": ["positive_blood_culture", "fever_rigors", "embolic_phenomena", "osler_nodes"]
      },
      {
        "diseaseId": "juvenile_idiopathic_arthritis",
        "discriminators": ["chronic_arthritis_no_carditis", "positive_rheumatoid_factor", "no_strep_history"]
      },
      {
        "diseaseId": "mitral_valve_prolapse",
        "discriminators": ["click_murmur", "no_fever_history", "no_arf_history"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "ECG", "priority": "immediate", "yield": 0.5, "indication": "PR prolongation, rhythm assessment" }
      ],
      "laboratory": [
        { "name": "ASO titer", "priority": "high", "yield": 0.8, "indication": "evidence of recent streptococcal infection" },
        { "name": "Anti-DNase B", "priority": "medium", "yield": 0.7, "indication": "confirmatory if ASO normal" },
        { "name": "ESR and CRP", "priority": "high", "yield": 0.7, "indication": "acute phase reactants" },
        { "name": "Throat culture", "priority": "high", "yield": 0.5, "indication": "identify Group A Streptococcus" }
      ],
      "imaging": [
        { "name": "Echocardiogram (Doppler)", "priority": "immediate", "yield": 0.95, "indication": "valvular morphology, regurgitation, stenosis" },
        { "name": "Chest X-ray", "priority": "high", "yield": 0.5, "indication": "cardiomegaly, pulmonary congestion" }
      ]
    },

    "management": {
      "protocolReference": "WHO RHD Guidelines / AHA Scientific Statement on ARF",
      "pathways": [
        {
          "severity": "acute_arf",
          "criteria": "Active carditis, arthritis, fever, elevated acute phase reactants",
          "treatment": "Bed rest. Aspirin 80-100 mg/kg/day in 4 doses. Prednisone 2 mg/kg/day if severe carditis. Treat strep infection. Start secondary prophylaxis."
        },
        {
          "severity": "chronic_rhd",
          "criteria": "Chronic valvular disease, compensated or decompensated",
          "treatment": "Benzathine penicillin G 1.2 million units IM q3-4 weeks for secondary prophylaxis. Diuretics for HF symptoms. ACE inhibitors. Valve surgery (repair preferred over replacement) for severe symptomatic disease."
        }
      ]
    },

    "pathophysiology": [
      "group_a_strep_pharyngitis",
      "molecular_mimicry",
      "cross_reactive_antibodies",
      "valvular_inflammation",
      "valvular_deformity",
      "chronic_hemodynamic_compromise"
    ],

    "complications": [
