        "diseaseId": "pulmonary_hypertension",
        "probability": 0.25,
        "lagDays": [365, 3650],
        "severityBoost": 0.4,
        "clues": ["large_shunt", "eisenmenger_physiology", "reversal_of_shunt"]
      },
      {
