      },
      {
        "diseaseId": "heart_failure",
        "probability": 0.2,
        "lagDays": [30, 365],
        "severityBoost": 0.4,
        "clues": ["poor_feeding", "tachypnea", "hepatomegaly", "sweating"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "high",
    "diagnosticClues": ["murmur", "cyanosis", "poor_feeding", "absent_femoral_pulses", "differential_cyanosis"],
    "exclusionClues": ["normal_saturation", "normal_echo", "no_murmur"]
  }
}
