{
  "disease": {
    "id": "heart-failure",
    "name": "Pediatric Heart Failure",
    "system": "PAED",
    "agePeak_months": [0, 12],
    "note": "Clinical syndrome of impaired cardiac output or elevated filling pressures. Causes include CHD, cardiomyopathy, myocarditis, and arrhythmias.",
    "prevalenceWeight": 0.5,
    "syndromeTags": ["congestive_heart_failure", "cardiac_decompensation"],

    "severityAssessment": {
      "immediateDangerSigns": [
        { "sign": "cardiogenic_shock", "weight": 10 },
        { "sign": "pulmonary_edema", "weight": 10 },
        { "sign": "anuria", "weight": 9 },
        { "sign": "altered_consciousness", "weight": 9 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "hypotension", "weight": 8 },
          { "sign": "severe_tachypnea", "weight": 7 },
          { "sign": "hepatomegaly_below_umbilicus", "weight": 7 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If shock or respiratory failure -> SEVERE (Ross class IV); else -> NON-SEVERE (Ross I-III)"
    },

    "historyFeatures": [
      { "symptomId": "tachypnea", "weight": 5 },
      { "symptomId": "poor_feeding", "weight": 5 },
      { "symptomId": "sweating_during_feeding", "weight": 4 },
      { "symptomId": "easy_fatigability", "weight": 4 },
      { "symptomId": "failure_to_thrive", "weight": 4 },
      { "symptomId": "recurrent_respiratory_infections", "weight": 3 },
      { "symptomId": "orthopnea", "weight": 3 },
      { "symptomId": "oliguria", "weight": 3 }
    ],

    "examFeatures": [
      { "signId": "tachycardia", "baseWeight": 5 },
      { "signId": "tachypnea", "baseWeight": 5 },
      { "signId": "hepatomegaly", "baseWeight": 5, "doubleWeight": true },
      { "signId": "gallop_rhythm", "baseWeight": 4 },
      { "signId": "pulmonary_crackles", "baseWeight": 3 },
      { "signId": "peripheral_edema", "baseWeight": 3, "note": "Less common in infants" },
      { "signId": "weak_pulses", "baseWeight": 4 },
      { "signId": "cool_extremities", "baseWeight": 3 },
      { "signId": "jugular_venous_distension", "baseWeight": 3 }
    ],

    "riskFactors": [
      { "id": "congenital_heart_disease", "multiplier": 4.0 },
      { "id": "cardiomyopathy", "multiplier": 4.0 },
      { "id": "myocarditis", "multiplier": 3.0 },
      { "id": "arrhythmia", "multiplier": 2.5 },
      { "id": "anomalous_coronary_artery", "multiplier": 3.0 },
      { "id": "post_cardiac_surgery", "multiplier": 2.0 }
    ],

    "subtypes": [
      {
        "id": "acute_decompensated_hf",
        "name": "Acute Decompensated Heart Failure",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "acute_onset_respiratory_distress", "weight": 5 },
          { "feature": "pulmonary_edema", "weight": 5 },
          { "feature": "hypotension", "weight": 4 },
          { "feature": "hepatomegaly", "weight": 4 }
        ],
        "management": "ICU admission. IV furosemide 1 mg/kg. Inotropes (milrinone, dobutamine). Mechanical ventilation if needed. Identify and treat underlying cause."
      },
      {
        "id": "chronic_compensated_hf",
        "name": "Chronic Compensated Heart Failure",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
          { "feature": "chronic_tachypnea", "weight": 4 },
          { "feature": "failure_to_thrive", "weight": 4 },
          { "feature": "hepatomegaly", "weight": 3 },
          { "feature": "exercise_intolerance", "weight": 4 }
        ],
        "management": "Oral diuretics (furosemide, spironolactone). ACE inhibitors (enalapril). Beta-blockers (carvedilol). Nutritional support with high-calorie feeds. Surgical correction of underlying CHD if possible."
      }
    ],

    "mimics": [
      {
        "diseaseId": "pneumonia",
        "discriminators": ["fever", "cough", "consolidation_on_xray", "normal_heart_size"]
      },
      {
        "diseaseId": "bronchiolitis",
        "discriminators": ["wheezing", "hyperinflation", "viral_symptoms", "no_hepatomegaly"]
      },
      {
        "diseaseId": "sepsis",
        "discriminators": ["fever", "positive_blood_culture", "no_murmur", "normal_echo"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Pulse oximetry", "priority": "immediate", "yield": 0.7, "indication": "oxygen saturation" },
        { "name": "ECG", "priority": "immediate", "yield": 0.5, "indication": "rhythm, ischemia, hypertrophy" }
      ],
      "laboratory": [
        { "name": "BNP/NT-proBNP", "priority": "immediate", "yield": 0.9, "indication": "confirm HF, guide therapy" },
        { "name": "Troponin", "priority": "high", "yield": 0.4, "indication": "myocardial injury" },
        { "name": "Serum electrolytes", "priority": "high", "yield": 0.5, "indication": "renal function, electrolyte balance" },
        { "name": "LFTs", "priority": "medium", "yield": 0.4, "indication": "congestive hepatopathy" },
        { "name": "Blood gas", "priority": "high", "yield": 0.5, "indication": "acidosis, oxygenation" }
      ],
      "imaging": [
        { "name": "Echocardiogram", "priority": "immediate", "yield": 0.95, "indication": "assess function, anatomy, rule out effusion" },
        { "name": "Chest X-ray", "priority": "immediate", "yield": 0.8, "indication": "cardiomegaly, pulmonary congestion" }
      ]
    },

    "management": {
      "protocolReference": "ISHLT Guidelines for Pediatric Heart Failure",
      "pathways": [
        {
          "severity": "ross_i_ii",
          "criteria": "Mild tachypnea, no feeding difficulty, adequate growth",
          "treatment": "Oral diuretics (furosemide 1-3 mg/kg/day). ACE inhibitor (enalapril 0.1 mg/kg/day). Monitor weight, input/output. Arrange definitive surgical repair if CHD."
        },
        {
          "severity": "ross_iii_iv",
          "criteria": "Severe tachypnea, poor feeding, hepatomegaly, growth failure",
          "treatment": "Hospitalize. IV furosemide. IV milrinone/dobutamine. NG tube feeds with high-calorie formula. Consider mechanical ventilation. Inhaled nitric oxide if pulmonary hypertension. ECMO/VAD for refractory cases. List for transplant if no surgical option."
        }
      ]
    },

    "pathophysiology": [
      "reduced_myocardial_contractility",
      "volume_overload",
      "pressure_overload",
      "neurohormonal_activation",
      "fluid_retention",
      "pulmonary_congestion"
    ],

    "complications": [
      {
        "diseaseId": "cardiogenic_shock",
        "probability": 0.2,
        "lagDays": [0, 30],
        "severityBoost": 0.6,
        "clues": ["hypotension", "poor_perfusion", "oliguria"]
      },
      {
        "diseaseId": "hepatic_dysfunction",
        "probability": 0.2,
        "lagDays": [30, 365],
        "severityBoost": 0.3,
        "clues": ["hepatomegaly", "elevated_lfts", "coagulopathy"]
      },
      {
        "diseaseId": "cardiac_cachexia",
        "probability": 0.15,
        "lagDays": [90, 730],
        "severityBoost": 0.3,
        "clues": ["weight_loss", "muscle_wasting", "persistent_hf"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "high",
    "diagnosticClues": ["tachypnea_without_fever", "poor_feeding", "hepatomegaly", "sweating_during_feeding", "cardiomegaly"],
    "exclusionClues": ["normal_bnp", "normal_echo", "no_hepatomegaly", "fever_present"]
  }
}
