        { "name": "ECG", "priority": "immediate", "yield": 0.7, "indication": "LVH, Q waves, arrhythmias" }
      ],
      "laboratory": [
        { "name": "BNP/NT-proBNP", "priority": "high", "yield": 0.85, "indication": "heart failure marker, monitoring" },
        { "name": "Troponin", "priority": "high", "yield": 0.5, "indication": "myocardial injury marker" },
        { "name": "Genetic testing panel", "priority": "medium", "yield": 0.6, "indication": "identify sarcomeric mutations" },
        { "name": "Metabolic screening", "priority": "medium", "yield": 0.3, "indication": "inborn errors of metabolism" }
