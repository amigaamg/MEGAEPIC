          { "feature": "reduced_systolic_function", "weight": 5 },
          { "feature": "heart_failure_symptoms", "weight": 4 }
        ],
        "management": "ACE inhibitors, beta-blockers, diuretics. Anticoagulation if EF <25%. Cardiac resynchronization therapy if wide QRS. Heart transplant listing for end-stage."
      },
      {
        "id": "hypertrophic_cardiomyopathy",
        "name": "Hypertrophic Cardiomyopathy",
        "prevalenceModifier": 0.35,
        "keyFeatures": [
          { "feature": "left_ventricular_hypertrophy", "weight": 5 },
          { "feature": "dynamic_outflow_obstruction", "weight": 4 },
          { "feature": "family_history_hcm", "weight": 4 }
        ],
        "management": "Beta-blockers first-line. Avoid dehydration and inotropes. ICD implantation for high-risk patients. Genetic counseling. Myectomy if refractory outflow obstruction."
      },
      {
        "id": "restrictive_cardiomyopathy",
        "name": "Restrictive Cardiomyopathy",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
          { "feature": "restricted_filling_pattern", "weight": 5 },
          { "feature": "preserved_systolic_function", "weight": 3 },
          { "feature": "severe_diastolic_dysfunction", "weight": 5 }
        ],
        "management": "Diuretics cautiously. Avoid bradycardia. Heart transplant early consideration due to poor prognosis. Anticoagulation for atrial arrhythmias."
      }
    ],

    "mimics": [
      {
        "diseaseId": "myocarditis",
        "discriminators": ["acute_onset_viral_prodrome", "elevated_troponin", "less_severe_remodeling"]
