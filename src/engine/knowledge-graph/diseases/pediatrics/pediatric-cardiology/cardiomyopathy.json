        { "name": "Cardiac MRI", "priority": "high", "yield": 0.9, "indication": "fibrosis (LGE), myocarditis, precise function" },
        { "name": "Chest X-ray", "priority": "high", "yield": 0.6, "indication": "cardiomegaly, pulmonary congestion" }
      ]
    },

    "management": {
      "protocolReference": "AHA/ACC Guidelines for Pediatric Cardiomyopathy",
      "pathways": [
        {
          "severity": "stable",
          "criteria": "Compensated HF, no arrhythmias, EF >35%",
          "treatment": "ACE inhibitor (enalapril 0.1-0.5 mg/kg/day), beta-blocker (carvedilol), salt restriction, close follow-up with echo every 3-6 months."
        },
        {
          "severity": "decompensated",
          "criteria": "Pulmonary edema, shock, EF <25%, arrhythmias",
          "treatment": "ICU admission. IV inotropes (milrinone, dobutamine). Diuretics. Mechanical ventilation if needed. Mechanical circulatory support (ECMO/VAD). Heart transplant evaluation."
        }
      ]
    },

    "pathophysiology": [
      "genetic_mutation_sarcomere",
