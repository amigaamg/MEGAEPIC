          { "feature": "syncope", "weight": 4 },
          { "feature": "weak_thready_pulse", "weight": 4 }
        ],
        "management": "IM Epinephrine first line. IV NS 20 mL/kg bolus. IV epinephrine infusion if refractory 0.05-0.1 mcg/kg/min. Trendelenburg position. Monitor cardiac rhythm."
      }
    ],

    "mimics": [
      {
        "diseaseId": "asthma_exacerbation",
        "discriminators": ["no_urticaria_or_angioedema", "no_allergen_exposure", "chronic_asthma"]
      },
      {
        "diseaseId": "vasovagal_syncope",
        "discriminators": ["bradycardia_not_tachycardia", "pallor_sweating", "no_urticaria", "no_respiratory_symptoms"]
      },
      {
        "diseaseId": "angioedema_hereditary",
        "discriminators": ["no_urticaria", "family_history", "no_response_to_epinephrine", "c1_esterase_inhibitor_deficiency"]
      }
    ],

    "investigations": {
      "bedside": [],
      "laboratory": [
        { "name": "Serum tryptase", "priority": "medium", "yield": 0.6, "indication": "elevated 1-6h after onset, confirm anaphylaxis" }
      ],
      "imaging": []
    },

    "management": {
      "protocolReference": "AAAAI/ACAAI Anaphylaxis Guidelines",
      "pathways": [
        {
          "severity": "mild_moderate",
          "criteria": "Urticaria, mild angioedema, no respiratory distress, no hypotension",
          "treatment": "IM epinephrine 0.01 mg/kg (max 0.3 mg child, 0.5 mg adolescent). Oral antihistamine (cetirizine). Monitor for 4-6 hours for biphasic reaction. Prescribe epinephrine autoinjector."
        },
        {
          "severity": "severe",
          "criteria": "Respiratory distress, stridor, wheeze, hypotension, or altered consciousness",
          "treatment": "IM epinephrine immediately. ABC. Oxygen. IV NS 20 mL/kg bolus. Nebulized albuterol. H1 + H2 antihistamines (diphenhydramine + ranitidine). IV methylprednisolone 1-2 mg/kg. ICU admission. Epinephrine infusion if refractory. Observe 24h for biphasic."
        }
      ]
    },

    "pathophysiology": [
      "ige_mediated_hypersensitivity",
      "mast_cell_degranulation",
      "histamine_release",
      "bronchoconstriction",
      "vasodilation",
      "increased_vascular_permeability",
      "laryngeal_edema"
    ],

    "complications": [
      {
        "diseaseId": "biphasic_anaphylaxis",
        "probability": 0.1,
        "lagDays": [0, 1],
        "severityBoost": 0.4,
        "clues": ["symptoms_recur_1_12h_after_resolution", "severe_initial_reaction"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "high",
    "diagnosticClues": ["sudden_onset_urticaria_angioedema", "respiratory_distress", "hypotension", "trigger_exposure"],
