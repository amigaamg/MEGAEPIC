        "noDangerSigns": true
      },
      "severityLabel": "If respiratory compromise or hypotension -> SEVERE; else -> NON-SEVERE (mild reaction)"
    },

    "historyFeatures": [
      { "symptomId": "sudden_onset_mins_to_hours", "weight": 5 },
