    ],

    "subtypes": [
      {
        "id": "anaphylaxis_respiratory_predominant",
        "name": "Anaphylaxis with Respiratory Predominance",
        "prevalenceModifier": 0.5,
        "keyFeatures": [
          { "feature": "laryngeal_edema_stridor", "weight": 5 },
          { "feature": "bronchospasm_wheezing", "weight": 5 },
          { "feature": "dysphonia_hoarseness", "weight": 4 }
        ],
        "management": "IM Epinephrine (1:1000) 0.01 mg/kg (max 0.5 mg) anterolateral thigh. Repeat q5-15min PRN. Oxygen. Inhaled albuterol for bronchospasm. Consider IV epinephrine if refractory."
      },
      {
        "id": "anaphylaxis_hypotension_predominant",
        "name": "Anaphylaxis with Hypotension/CV Predominance",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
