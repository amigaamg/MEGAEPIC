{
  "disease": {
    "id": "septic-shock",
    "name": "Septic Shock (Pediatric)",
    "system": "PAED",
    "agePeak_months": [0, 60],
    "note": "Life-threatening organ dysfunction due to dysregulated host response to infection. Leading cause of pediatric mortality worldwide. Early recognition and treatment critical.",
    "prevalenceWeight": 0.4,
    "syndromeTags": ["shock", "sepsis", "pediatric_emergency"],

    "severityAssessment": {
      "immediateDangerSigns": [
        { "sign": "hypotension_after_fluid_resuscitation", "weight": 10 },
        { "sign": "altered_consciousness", "weight": 10 },
        { "sign": "respiratory_failure", "weight": 10 },
        { "sign": "cardiac_arrest", "weight": 10 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "capillary_refill_>3_seconds", "weight": 8 },
          { "sign": "lactate_>4_mmol_L", "weight": 8 },
          { "sign": "mottled_cold_extremities", "weight": 7 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": true,
        "noDangerSigns": true
      },
      "severityLabel": "If fluid-refractory hypotension, altered consciousness, or lactate >4 -> SEVERE (cold or warm shock); else -> NON-SEVERE (suspected sepsis)"
    },

    "historyFeatures": [
      { "symptomId": "fever_or_hypothermia", "weight": 5 },
      { "symptomId": "lethargy_irritability", "weight": 5 },
      { "symptomId": "poor_feeding_refusal_to_feed", "weight": 4 },
      { "symptomId": "reduced_urine_output", "weight": 4 },
      { "symptomId": "vomiting_diarrhea", "weight": 3 },
      { "symptomId": "difficulty_breathing", "weight": 4 },
      { "symptomId": "rash_petechiae_purpura", "weight": 4, "note": "Meningococcemia" },
      { "symptomId": "known_infection_source", "weight": 3 }
    ],

    "examFeatures": [
      { "signId": "hypotension_age_appropriate", "baseWeight": 5, "doubleWeight": true },
      { "signId": "tachycardia", "baseWeight": 5 },
      { "signId": "prolonged_capillary_refill_>2s", "baseWeight": 5 },
      { "signId": "mottled_cold_extremities_warm_erythematous", "baseWeight": 4 },
      { "signId": "fever_or_hypothermia", "baseWeight": 4 },
      { "signId": "altered_mental_status", "baseWeight": 5 },
      { "signId": "weak_pulses_or_bounding_pulses", "baseWeight": 4 },
      { "signId": "petechial_rash_purpura", "baseWeight": 4 },
      { "signId": "tachypnea", "baseWeight": 4 }
    ],

    "riskFactors": [
      { "id": "age_<1_year", "multiplier": 3.0 },
      { "id": "immunodeficiency", "multiplier": 3.0 },
      { "id": "malnutrition", "multiplier": 2.5 },
      { "id": "indwelling_catheter_line", "multiplier": 3.0 },
      { "id": "mechanical_ventilation", "multiplier": 2.5 },
      { "id": "recent_surgery", "multiplier": 2.0 },
      { "id": "asplenia", "multiplier": 3.5 }
    ],

    "subtypes": [
      {
        "id": "cold_shock",
        "name": "Cold Shock (Vasoconstricted)",
        "prevalenceModifier": 0.5,
        "keyFeatures": [
          { "feature": "cold_extremities", "weight": 5 },
          { "feature": "prolonged_capillary_refill_>3s", "weight": 5 },
          { "feature": "narrow_pulse_pressure", "weight": 4 },
          { "feature": "hypotension_late_sign", "weight": 4 }
        ],
        "management": "IV fluids 20 mL/kg NS boluses up to 60 mL/kg. Epinephrine infusion 0.05-0.3 mcg/kg/min. Central line. Monitor ScvO2. Consider dobutamine."
      },
      {
        "id": "warm_shock",
        "name": "Warm Shock (Vasodilated)",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "warm_erythematous_extremities", "weight": 5 },
          { "feature": "brisk_capillary_refill", "weight": 4 },
          { "feature": "wide_pulse_pressure", "weight": 4 },
          { "feature": "hypotension_earlier_sign", "weight": 5 }
        ],
        "management": "IV fluids (may need less aggressive volume). Norepinephrine infusion 0.05-0.3 mcg/kg/min. Vasopressin if refractory. Central line monitoring."
      }
    ],

    "mimics": [
      {
        "diseaseId": "cardiogenic_shock",
        "discriminators": ["murmur", "hepatomegaly", "gallop_rhythm", "low_ef_on_echo"]
      },
      {
        "diseaseId": "hypovolemic_shock",
        "discriminators": ["history_of_vomiting_diarrhea_blood_loss", "responds_rapidly_to_fluids", "normal_contractility_on_echo"]
      },
      {
        "diseaseId": "anaphylaxis",
        "discriminators": ["rash_urticaria", "wheezing", "allergen_exposure", "rapid_onset"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Blood glucose", "priority": "immediate", "yield": 0.5, "indication": "hypoglycemia" }
      ],
      "laboratory": [
        { "name": "Blood culture", "priority": "immediate", "yield": 0.4, "indication": "identify pathogen" },
        { "name": "CBC", "priority": "immediate", "yield": 0.5, "indication": "WBC, platelets, Hb" },
        { "name": "CRP and Procalcitonin", "priority": "high", "yield": 0.8, "indication": "infection markers" },
        { "name": "Lactate", "priority": "immediate", "yield": 0.85, "indication": "tissue perfusion marker, severity" },
        { "name": "Blood gas", "priority": "immediate", "yield": 0.7, "indication": "acidosis, oxygenation" },
        { "name": "Electrolytes, renal function", "priority": "high", "yield": 0.5, "indication": "organ function" }
      ],
      "imaging": [
        { "name": "Chest X-ray", "priority": "high", "yield": 0.4, "indication": "pneumonia source" }
      ]
    },

    "management": {
      "protocolReference": "SSC Pediatric Sepsis Bundle / WHO Emergency Triage Guidelines",
      "pathways": [
        {
          "severity": "suspected_sepsis_no_shock",
          "criteria": "Clinical concern for infection, normal perfusion, normal BP",
          "treatment": "IV/IO access. Blood culture. Start empiric antibiotics (ceftriaxone + vancomycin). Fluid bolus if signs of hypoperfusion develop. Monitor q15min."
        },
        {
          "severity": "septic_shock",
          "criteria": "Hypotension or poor perfusion after 40 mL/kg fluids, or lactate >4",
          "treatment": "IV fluids 20 mL/kg x 3 (max 60 mL/kg). Immediate antibiotics (ceftriaxone + vancomycin + gentamicin if <3 months). Vasoactive: epinephrine (cold shock) or norepinephrine (warm shock). ICU. Central line. ScvO2 monitoring. Consider steroids (hydrocortisone 2 mg/kg)."
        }
      ]
    },

    "pathophysiology": [
      "systemic_infection",
      "dysregulated_immune_response",
      "endothelial_dysfunction",
      "vasodilation_or_vasoconstriction",
      "capillary_leak",
      "tissue_hypoperfusion",
      "multiorgan_dysfunction",
      "metabolic_acidosis"
    ],

    "complications": [
      {
        "diseaseId": "multiorgan_dysfunction_syndrome",
        "probability": 0.4,
        "lagDays": [0, 7],
        "severityBoost": 0.5,
        "clues": ["persistent_hypoperfusion", "abnormal_lfts", "aki", "coagulopathy"]
      },
      {
        "diseaseId": "acute_respiratory_distress_syndrome",
        "probability": 0.3,
        "lagDays": [0, 3],
        "severityBoost": 0.4,
        "clues": ["severe_hypoxia", "bilateral_infiltrates", "low_compliance"]
      },
      {
        "diseaseId": "disseminated_intravascular_coagulation",
        "probability": 0.2,
        "lagDays": [0, 3],
        "severityBoost": 0.6,
        "clues": ["petechiae", "prolonged_pt_aptt", "low_fibrinogen", "thrombocytopenia"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "high",
    "diagnosticClues": ["fever_hypothermia", "poor_perfusion", "hypotension", "altered_consciousness", "lactate_>2"],
    "exclusionClues": ["normal_perfusion", "normal_bp", "normal_lactate", "well_appearing"]
  }
}
