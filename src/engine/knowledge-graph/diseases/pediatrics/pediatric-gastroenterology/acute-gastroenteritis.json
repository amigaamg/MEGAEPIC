    "management": {
      "protocolReference": "WHO/UNICEF Guidelines for Acute Diarrhea Management",
      "pathways": [
        {
          "severity": "no_dehydration_plan_a",
          "criteria": "Well, normal thirst, no signs of dehydration",
          "treatment": "Home management: ORS after each loose stool, zinc 20 mg x 14 days, continued feeding, extra fluids. Return immediately if worsens."
        },
        {
          "severity": "some_dehydration_plan_b",
          "criteria": "Restless/irritable, sunken eyes, thirsty, skin pinch slow",
          "treatment": "ORS 75 mL/kg over 4 hours under observation. Reassess after 4h. Continue breastfeeding. If child vomits, wait 10 min then resume slowly."
        },
        {
          "severity": "severe_dehydration_plan_c",
          "criteria": "Lethargic/unconscious, unable to drink, very slow skin pinch",
          "treatment": "IV Ringer's lactate 100 mL/kg over 3-6 hours (30 mL/kg in first 30 min, then 70 mL/kg over 2.5h). Monitor urine output. Switch to ORS when drinking."
        }
      ]
    },

    "pathophysiology": [
