    "management": {
      "protocolReference": "APSNA / BAPS Guidelines for Meckel's Diverticulum Management",
      "pathways": [
        {
          "severity": "bleeding Meckel's (stable)",
          "criteria": "Painless hematochezia, hemodynamically stable, positive Meckel scan",
          "treatment": "Laparoscopic diverticulectomy or segmental small bowel resection with primary anastomosis. Pre-operative localization with Meckel scan. IV fluids. Blood transfusion if Hb <8."
        },
        {
          "severity": "bleeding Meckel's (unstable / massive bleeding)",
          "criteria": "Massive hematochezia, hemodynamic instability, tachycardia, hypotension",
          "treatment": "IV fluids and blood transfusion. Emergency laparotomy/laparoscopy with small bowel resection. Pre-operative localization if feasible but do not delay surgery."
        },
        {
          "severity": "incidental Meckel's diverticulum",
          "criteria": "Found incidentally at laparotomy/laparoscopy for another indication",
          "treatment": "Resect if: palpable ectopic tissue, male, age <50, diverticulum length >2cm, narrow neck, or fibrous band present. Otherwise, leave in situ."
        }
      ]
