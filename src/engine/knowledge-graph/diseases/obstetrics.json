        {
          "severity": "acute_seizure",
          "criteria": "Active generalised seizure in pregnancy with hypertension and proteinuria",
          "treatment": [
            "ABC: airway, breathing, circulation",
            "Left lateral position to improve uterine perfusion",
            "IV Magnesium sulphate 4 g loading over 5-10 min, then 1 g/hour IV infusion for 24 hours",
