    "management": {
      "protocolReference": "ASPEN Clinical Guidelines, ESPEN Guidelines on Parenteral Nutrition, NICE Guidelines on Nutritional Support (CG32)",
      "pathways": [
        {
          "severity": "pn_initiation",
          "criteria": "patient NPO >7 days or malnourished, enteral route not feasible",
          "treatment": "Assess refeeding risk. Correct electrolytes. Start TPN at 50% goal if high risk. Central vs peripheral based on osmolality. Standard macronutrients: dextrose 3-5g/kg/day, amino acids 1-1.5g/kg/day, lipids 0.5-1g/kg/day. MVI/ETE daily."
        },
        {
          "severity": "metabolic_complication",
          "criteria": "glucose >180, phosphorus <2.5, potassium <3.5, triglycerides >400",
          "treatment": "Reduce dextrose infusion rate, add insulin to bag or sliding scale. Replete phosphorus (15-30mmol IV), potassium (10-20mEq/h), magnesium. Hold lipids if triglycerides >400. Recheck labs in 4-6h."
        },
        {
          "severity": "suspected_clabsi",
          "criteria": "fever, chills, erythema at exit site, positive blood cultures",
          "treatment": "Draw cultures from line and peripheral. Start empiric antibiotics (vancomycin + antipseudomonal beta-lactam). Remove line if confirmed. Insert new line after 24-48h of negative cultures. Consider ethanol lock therapy for recurrent infections."
        }
      ]
    },
