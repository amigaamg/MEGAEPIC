          { "feature": "high_vitamin_k_foods", "weight": 3 },
          { "feature": "enzyme_inducing_drugs", "weight": 4 }
        ],
        "management": "Increase warfarin dose by 5-20%. Recheck INR in 3-7 days. Address dietary causes. Review interacting medications."
      }
    ],

    "investigations": {
      "laboratory": [
        { "name": "INR/PT", "priority": "immediate", "yield": 0.95, "indication": "monitor anticoagulation effect" },
