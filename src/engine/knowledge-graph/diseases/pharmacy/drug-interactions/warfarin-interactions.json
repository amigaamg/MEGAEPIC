    "management": {
      "protocolReference": "BCSH Guidelines for Warfarin Management",
      "pathways": [
        {
          "severity": "INR 1.5-3.0 (therapeutic)",
          "criteria": "INR in target range for indication",
          "treatment": "Continue current dose. Recheck INR at interval per stability."
        },
        {
          "severity": "INR 3.1-4.5 (mild elevation)",
          "criteria": "INR above range, no bleeding",
          "treatment": "Reduce dose by 10-20%. Recheck in 1-2 weeks."
