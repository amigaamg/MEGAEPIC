          { "feature": "antibiotics_added", "weight": 4 },
          { "feature": "dietary_change_low_vitamin_k", "weight": 3 }
        ],
        "management": "Hold warfarin. If INR >8 with bleeding: IV Vitamin K 5-10 mg + FFP/PCC. If INR >8 no bleeding: hold warfarin, give oral Vitamin K 1-5 mg. If 4.5-8: hold 1-2 doses and reduce dose."
      },
      {
        "id": "inr_decrease",
        "name": "Decreased INR (Sub-therapeutic)",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
