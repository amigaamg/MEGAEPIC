          { "sign": "hypoglycemia_unawareness", "weight": 6 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If severe hypoglycemia -> CRITICAL; if glucose 54-69 -> NON-CRITICAL (treat immediately)"
