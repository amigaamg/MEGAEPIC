    "management": {
      "protocolReference": "ADA Standards of Care, Institute for Safe Medication Practices (ISMP) Guidelines",
      "pathways": [
        {
          "severity": "hypoglycemia_severe",
          "criteria": "glucose <54 mg/dL with altered mental status, unable to take oral",
          "treatment": "IM glucagon 1mg (adult) or IV D50 25g (12.5g if elderly/renal). Recheck glucose in 15 min. If still <70, repeat. Once stabilized, give complex carbohydrate. Identify root cause."
        },
        {
          "severity": "hypoglycemia_mild_moderate",
          "criteria": "glucose 54-69 mg/dL, conscious, able to swallow",
          "treatment": "Rule of 15: 15g fast-acting CHO, recheck in 15 min. Repeat if still <70. Once >70, assess cause and adjust insulin regimen. Document in MAR."
        },
        {
          "severity": "prevention_routine",
          "criteria": "no hypoglycemia, insulin managed for stable diabetes",
          "treatment": "Standardized order sets. Basal-bolus regimen preferred over sliding scale alone. CGM if appropriate. Regular review of glucose trends. Patient education on hypoglycemia recognition and management."
        }
      ]
    },
