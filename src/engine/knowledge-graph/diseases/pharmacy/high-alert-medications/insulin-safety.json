    "system": "PHARM",
    "agePeak_months": [12, 960],
    "note": "Insulin is a high-alert medication with significant risk of hypoglycemia. Human factors: look-alike/sound-alike products (U-100 vs U-500), route confusion (IV vs SQ), and dosing errors (units vs mL). Standardized order sets, independent double-checks, and hypoglycemia protocols reduce harm.",
    "prevalenceWeight": 0.8,
    "syndromeTags": ["high_alert_medication", "hypoglycemia", "medication_safety"],
    "severityAssessment": {
