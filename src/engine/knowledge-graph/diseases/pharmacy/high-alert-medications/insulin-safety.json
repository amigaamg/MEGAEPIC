    ],
    "subtypes": [
      {
        "id": "dosing_error",
        "name": "Insulin Dosing Errors",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
          { "feature": "tenfold_dosing_errors_u_100_vs_u_500", "weight": 5 },
          { "feature": "look_alike_products_novolog_novolin_rapid_short", "weight": 4 },
          { "feature": "wrong_route_iv_instead_of_sq", "weight": 5 },
          { "feature": "programming_error_on_insulin_pump", "weight": 4 },
          { "feature": "sliding_scale_misinterpretation", "weight": 3 }
        ],
        "management": "Independent double-check for all insulin doses. Use smart pump with drug library. Tall-man lettering for look-alike names. Separate storage for U-500. Standardized order sets with default dosing units (units, not mL)."
      },
      {
        "id": "hypoglycemia_unawareness",
        "name": "Hypoglycemia Unawareness",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "recurrent_hypoglycemia_blunting_counterregulatory", "weight": 5 },
          { "feature": "no_autonomic_symptoms_at_low_glucose", "weight": 5 },
          { "feature": "diabetes_duration_gt_10_years", "weight": 4 },
          { "feature": "cgm_use_shows_extended_hypoglycemia", "weight": 4 }
        ],
        "management": "Relax glycemic targets for 2-6 weeks (avoid hypoglycemia to restore awareness). CGM with alarms. Structured education (Blood Glucose Awareness Training). Review and reduce insulin doses. Consider adjuncts (GLP-1 RA, SGLT2i) to reduce insulin needs."
      },
      {
        "id": "transition_of_care_errors",
        "name": "Transition of Care Insulin Errors",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "discharge_insulin_regimen_differs_from_admission", "weight": 5 },
          { "feature": "conversion_from_iv_to_sq_insulin", "weight": 5 },
          { "feature": "NPO_to_oral_feeding_transition", "weight": 4 },
          { "feature": "steroid_dose_changes_affecting_insulin_needs", "weight": 3 }
        ],
        "management": "IV to SQ transition: calculate 80% of total daily IV requirement, give 50% as basal + 50% as bolus. Overlap SQ insulin 2h before stopping IV. Discharge: review dose, ensure patient education. Provide glucose meter, prescription, follow-up."
      }
    ],
