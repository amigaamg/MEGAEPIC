      {
        "id": "warfarin_management",
        "name": "Warfarin Safety and INR Management",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "inr_therapeutic_range_2_0_3_0_most_indications", "weight": 5 },
          { "feature": "inr_gt_4_0_increases_bleeding_risk_significantly", "weight": 5 },
          { "feature": "drug_interactions_narrow_therapeutic_window", "weight": 4 },
          { "feature": "dietary_vitamin_k_fluctuations", "weight": 3 }
        ],
        "management": "INR <5, no bleeding: hold warfarin, restart at lower dose when INR therapeutic. INR 5-9, no bleeding: hold warfarin, consider vitamin K 1-2.5mg PO. INR >9, no bleeding: hold warfarin, vitamin K 2.5-5mg PO. Any INR with bleeding: hold + 4F-PCC + vitamin K 10mg IV."
      },
      {
        "id": "doac_safety",
        "name": "DOAC Safety (Apixaban, Rivaroxaban, Edoxaban, Dabigatran)",
        "prevalenceModifier": 0.35,
        "keyFeatures": [
          { "feature": "renal_dosing_critical_apixaban_crcl_lt_25_avoid", "weight": 5 },
          { "feature": "rivaroxaban_avoid_crcl_lt_15", "weight": 4 },
          { "feature": "dabigatran_avoid_crcl_lt_30", "weight": 4 },
          { "feature": "no_need_for_routine_lab_monitoring", "weight": 4 },
          { "feature": "reversal_agent_andexanet_for_anti_xa", "weight": 4 }
        ],
        "management": "Assess renal function before prescribing and annually. Use CHADS2-VASc + HAS-BLED for risk assessment. Dabigatran: idarucizumab (Praxbind) 5g IV for reversal. Factor Xa inhibitors (apixaban, rivaroxaban, edoxaban): andexanet alfa (Andexxa) or 4F-PCC as alternative."
      },
      {
        "id": "heparin_lmwh_management",
        "name": "Heparin/LMWH Safety",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "uFH_aptt_monitoring_every_6h_until_therapeutic", "weight": 5 },
          { "feature": "hIT_type_2_risk_with_uFH_gt_lmwh", "weight": 4 },
          { "feature": "renal_dosing_lmwh_enoxaparin_crcl_lt_30_dose_reduce", "weight": 4 },
          { "feature": "protamine_reversal_different_for_uFH_vs_lmwh", "weight": 3 }
        ],
        "management": "UFH: weight-based protocol. Check aPTT q6h, adjust per nomogram. Monitor platelets q2-3d for HIT. LMWH: no routine monitoring except pregnancy/renal/obesity. HIT: stop heparin, start argatroban or fondaparinux. Protamine: 1mg protamine per 100U UFH; partial reversal only for LMWH."
      },
      {
        "id": "perioperative_bridging",
        "name": "Perioperative Anticoagulation Bridging",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
          { "feature": "mechanical_heart_valve_high_thromboembolic_risk", "weight": 5 },
          { "feature": "afib_with_chads2_vas_gt_5_or_stroke_within_3mo", "weight": 5 },
          { "feature": "recent_vte_within_3_months", "weight": 4 },
          { "feature": "brIDGE_trial_for_afib_no_benefit_of_bridging", "weight": 4 }
        ],
        "management": "Low risk (AFib CHADS2 <4, VTE >12mo): no bridging, hold anticoagulant 1-2 days pre-op. High risk (mechanical valve, stroke <3mo, VTE <3mo): UFH or LMWH bridge. Resume therapeutic anticoagulation post-op when hemostasis achieved."
      }
