      { "name": "Blood cultures (2 sets)", "priority": "if febrile", "yield": 0.5, "indication": "bacteraemia in sepsis" },
      { "name": "Arterial blood gas", "priority": "immediate", "yield": 0.75, "indication": "acidosis suggests ischemia" },
      { "name": "Crossmatch (Group and Save)", "priority": "preoperative", "yield": 0.9, "indication": "prepare for potential emergency surgery" },
      { "name": "Coagulation profile", "priority": "preoperative", "yield": 0.4, "indication": "preoperative assessment" }
