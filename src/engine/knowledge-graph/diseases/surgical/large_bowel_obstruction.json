    "advanced": [
      { "name": "Flexible sigmoidoscopy + detorsion", "indication": "therapeutic for non-ischemic sigmoid volvulus", "priority": "urgent" },
      { "name": "Colonoscopy (post-op)", "indication": "if obstructing cancer suspected, after recovery", "priority": "elective" }
    ]
  },
  "management": {
    "protocolReference": "WSES Guidelines for Large Bowel Obstruction 2024",
    "pathways": [
      {
        "severity": "resuscitation",
        "criteria": "All patients with suspected LBO on arrival",
        "treatment": [
          "NBM — nil by mouth immediately",
          "Large-bore IV access x2 (16G minimum)",
          "IV crystalloid 30 mL/kg bolus then 125 mL/hr",
          "NG tube on free drainage",
          "Urinary catheter — hourly output monitoring",
          "Bloods: FBC, U&E, CRP, Lactate, ABG, Crossmatch, Coagulation",
          "Blood cultures if febrile",
          "IV antibiotics: Ceftriaxone 2g + Metronidazole 500mg",
          "Analgesia: IV Paracetamol 1g; avoid morphine until surgical assessment"
        ],
        "counselling": "Explain NBM status, planned investigations, and potential need for emergency surgery."
      },
      {
        "severity": "non_ischemic_volvulus",
        "criteria": "CT confirms sigmoid volvulus, no pneumatosis, lactate <2.5, no peritonitis",
        "treatment": [
          "Urgent flexible sigmoidoscopy + detorsion",
          "Insert flatus/rectal tube — leave in situ for 48 hours",
          "Serial abdominal X-rays to confirm decompression",
          "Bowel preparation (PEG) over 2 days",
          "Elective sigmoid resection with primary anastomosis (same admission — recurrence >50% without resection)"
        ],
        "counselling": "Explain that detorsion is temporising; definitive resection needed during same admission."
      },
      {
        "severity": "ischemic_or_perforated",
        "criteria": "Lactate >4, peritonitis, pneumatosis, free air, septic shock",
        "treatment": [
          "Emergency midline laparotomy",
          "Resection of non-viable bowel segment",
          "Hartmann's procedure (end colostomy + mucous fistula) if gangrenous/contaminated",
          "Sigmoid resection with primary anastomosis if viable and clean",
          "Abdominal lavage with warm saline",
          "Pelvic drain",
          "ICU admission post-operatively"
        ],
        "counselling": "Explain life-saving nature of surgery, high likelihood of stoma, ICU stay expected."
      },
      {
        "severity": "obstructing_cancer",
        "criteria": "CT shows obstructing colonic mass, no perforation, no metastases or potentially curable",
        "treatment": [
          "Resuscitation as per protocol",
          "Stenting as bridge to surgery (if suitable) OR emergency resection",
          "Right hemicolectomy (for right-sided obstruction)",
          "Left hemicolectomy with primary anastomosis (for left-sided, if viable)",
          "Hartmann's procedure (if unsafe for anastomosis)",
          "Stoma counselling pre-operatively if possible"
        ],
        "counselling": "Discuss cancer diagnosis, staging, MDT referral, stoma possibility, adjuvant therapy plan."
      }
    ],
    "specialConsiderations": {
      "wheeze_branch": "Elderly patients may have COPD — optimise respiratory function pre-op",
      "HIV_exposed": "Check HIV status in endemic areas; manage perioperative ART",
      "SAM": "Malnourished patients need nutritional support; consider TPN if prolonged ileus"
    }
  },
