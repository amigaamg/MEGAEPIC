      { "name": "NG tube insertion", "priority": "immediate", "yield": 0.9, "indication": "gastric decompression, measure output" },
      { "name": "Urinary catheter", "priority": "immediate", "yield": 0.8, "indication": "monitor urine output" }
    ],
    "laboratory": [
      { "name": "Full blood count", "priority": "immediate", "yield": 0.7, "indication": "leukocytosis suggests ischemia; anaemia suggests cancer" },
      { "name": "Serum lactate", "priority": "immediate", "yield": 0.85, "indication": "key ischemia marker — >2 mmol/L raises concern" },
      { "name": "Urea and electrolytes", "priority": "immediate", "yield": 0.6, "indication": "dehydration, AKI, electrolyte disturbance" },
