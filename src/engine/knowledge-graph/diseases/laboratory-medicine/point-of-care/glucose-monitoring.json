        { "sign": "glucose_lt_40_mg_dl", "weight": 10 },
        { "sign": "glucose_gt_600_mg_dl", "weight": 9 },
        { "sign": "unconscious_or_seizure", "weight": 10 },
        { "sign": "ketosis_positive", "weight": 8 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "glucose_lt_54_mg_dl_severe_hypoglycemia", "weight": 8 },
          { "sign": "glucose_gt_500_with_dka_or_hhs_signs", "weight": 8 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If <54 or >500 with symptoms -> EMERGENT; else -> NON-EMERGENT"
