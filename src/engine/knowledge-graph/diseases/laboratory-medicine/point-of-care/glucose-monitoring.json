        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "autonomic_symptoms_sweating_tremor", "weight": 4 },
          { "feature": "neuroglycopenic_symptoms_confusion_seizure", "weight": 5 },
          { "feature": "poc_glucose_lt_70_mg_dl", "weight": 5 },
          { "feature": "symptoms_resolve_with_glucose_administration", "weight": 5 },
          { "feature": "causes_insulin_sulfonylurea_excess", "weight": 3 }
        ],
        "management": "Rule of 15: give 15g fast-acting carbohydrate, recheck in 15 min. If unconscious: IM glucagon (1mg) or IV D50 (25g). Identify cause (medication adjustment, missed meals, excess insulin, alcohol). Severe/recurrent: endocrine consult."
      },
      {
        "id": "diabetic_ketoacidosis",
        "name": "Diabetic Ketoacidosis (DKA)",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "hyperglycemia_gt_250_mg_dl", "weight": 5 },
          { "feature": "ketonemia_positive_beta_hydroxybutyrate", "weight": 5 },
          { "feature": "anion_gap_metabolic_acidosis", "weight": 5 },
          { "feature": "type_1_diabetes_most_common", "weight": 4 },
          { "feature": "precipitant_infection_missed_insulin", "weight": 3 }
        ],
        "management": "IV fluids (NS 1L bolus, then 250-500ml/h). IV insulin (0.1 U/kg bolus, then 0.1 U/kg/h infusion). Potassium replacement when K <5.3. Bicarbonate only if pH <7.0. Monitor glucose hourly, electrolytes q2-4h. Transition to SQ insulin when closed."
      },
      {
        "id": "hyperosmolar_hyperglycemic_state",
        "name": "Hyperosmolar Hyperglycemic State (HHS)",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
