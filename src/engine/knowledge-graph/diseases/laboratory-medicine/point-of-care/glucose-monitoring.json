    "management": {
      "protocolReference": "ADA Standards of Care in Diabetes, Joint British Diabetes Societies Guidelines",
      "pathways": [
        {
          "severity": "mild_hypoglycemia",
          "criteria": "glucose 54-69 mg/dL, conscious, can swallow",
          "treatment": "15g fast-acting CHO (glucose tabs, juice). Recheck in 15 min. If still <70, repeat. Once >70, give snack with protein if next meal >1h away."
        },
        {
          "severity": "severe_hypoglycemia",
          "criteria": "glucose <54 mg/dL or unconscious/seizure",
          "treatment": "IM glucagon (1mg adult, 0.5mg child) or IV D50 (25g). Recheck glucose in 15 min. If no IV access, SQ glucagon. Admit if prolonged or unknown cause."
        },
        {
          "severity": "dka",
          "criteria": "glucose >250, ketosis, acidosis (pH <7.3, HCO3 <18)",
          "treatment": "IV fluids, IV insulin, K+ replacement. ICU or stepdown. Hourly glucose, q2h electrolytes. Transition when glucose <200, HCO3 >18, pH >7.3."
        },
        {
          "severity": "hhs",
          "criteria": "glucose >600, osmolality >320, no significant ketosis",
          "treatment": "Aggressive fluid resuscitation. Lower dose insulin. ICU for monitoring. Correct electrolyte imbalances. Treat precipitant."
        }
      ]
    },
    "pathophysiology": [
