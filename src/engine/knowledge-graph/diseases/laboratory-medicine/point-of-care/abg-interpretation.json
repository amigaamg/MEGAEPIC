          { "feature": "acute_uncompensated_ph_lt_7_35_hco3_normal", "weight": 5 },
          { "feature": "chronic_compensated_ph_near_normal_hco3_elevated", "weight": 5 },
          { "feature": "expected_compensation_acute_hco3_up_1_per_10_paco2", "weight": 4 },
          { "feature": "chronic_hco3_up_3_to_5_per_10_paco2", "weight": 4 }
        ],
        "management": "Acute: Non-invasive or invasive ventilation. Treat underlying (COPD exacerbation, opioid overdose, neuromuscular weakness). Avoid high FiO2 in CO2 retainers. Chronic: optimize lung function, LTOT, smoking cessation, pulmonary rehab."
