          { "feature": "elevated_ph_gt_7_45", "weight": 5 },
          { "feature": "hyperventilation_cause", "weight": 4 },
          { "feature": "acute_hco3_decrease_minimal", "weight": 3 },
          { "feature": "chronic_hco3_lt_18", "weight": 3 }
        ],
        "management": "Treat underlying cause: anxiety/panic (rebreathing, benzodiazepine), PE (anticoagulate), sepsis (antibiotics), hepatic encephalopathy (lactulose), salicylate overdose (alkalinization). Symptomatic treatment for severe symptoms."
