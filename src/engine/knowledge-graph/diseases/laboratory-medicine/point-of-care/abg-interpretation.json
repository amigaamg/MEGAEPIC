    "management": {
      "protocolReference": "ACCP/ATS Guidelines for Acid-Base Disorders",
      "pathways": [
        {
          "severity": "mild_abnormality",
          "criteria": "pH 7.35-7.45 or 7.30-7.50 with stable patient, no danger signs",
          "treatment": "Investigate and treat underlying cause. Repeat ABG as needed for trending. No acute intervention required for acid-base itself."
        },
        {
          "severity": "moderate_severe",
          "criteria": "pH 7.2-7.3 or 7.5-7.6, some symptoms, abnormal compensation",
          "treatment": "Target specific therapy per primary disorder. Consider bicarbonate for severe metabolic acidosis if pH <7.2 with adequate ventilation. Consider NIV for acute hypercapnia."
        },
        {
          "severity": "critical",
          "criteria": "pH <7.2 or >7.6, severe hypoxia, hypercapnia with AMS, shock",
          "treatment": "ICU admission. Intubation and ventilation if needed (for acidosis with inadequate compensation or hypoxia). Correct reversible causes aggressively. Hemodialysis for severe refractory acidosis (e.g., toxins). Vasopressors for shock."
        }
