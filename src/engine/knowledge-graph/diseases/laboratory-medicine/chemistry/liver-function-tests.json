      ]
    },
    "management": {
      "protocolReference": "AASLD Practice Guidelines for Liver Chemistry Tests",
      "pathways": [
        {
          "severity": "mild_transaminitis",
          "criteria": "ALT/AST <3x ULN, no symptoms, normal bilirubin/albumin/PT",
          "treatment": "Exclude NAFLD (most common). Check for meds, alcohol. Repeat in 3-6 months. If persistent, check viral hepatitis, iron studies, autoimmune markers."
        },
        {
          "severity": "moderate_severe_injury",
          "criteria": "ALT/AST >5x ULN, symptomatic, elevated bilirubin",
          "treatment": "Hospital admission. Check acetaminophen level. Viral hepatitis serology. Autoimmune markers. Liver biopsy if indeterminate. N-acetylcysteine for acetaminophen. Steroids for AIH."
        },
        {
          "severity": "acute_liver_failure",
          "criteria": "encephalopathy + INR >1.5, rapid onset",
          "treatment": "ICU. N-acetylcysteine. Lactulose for encephalopathy. Avoid sedation. Monitor ICP. Liver transplantation evaluation. Transfer to transplant center."
        }
      ]
    },
