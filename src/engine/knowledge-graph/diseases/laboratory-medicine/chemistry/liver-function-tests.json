        { "name": "Ceruloplasmin (Wilson disease)", "priority": "medium", "yield": 0.2, "indication": "young patient with unexplained liver disease" },
        { "name": "Autoimmune markers (ANA, ASMA, Anti-LKM1)", "priority": "medium", "yield": 0.3, "indication": "suspected AIH" },
        { "name": "Serum protein electrophoresis", "priority": "low", "yield": 0.2, "indication": "suspected alpha-1 antitrypsin deficiency" }
      ],
      "imaging": [
