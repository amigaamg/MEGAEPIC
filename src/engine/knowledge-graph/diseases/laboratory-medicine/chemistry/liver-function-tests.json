      { "signId": "ast_alt_elevation_pattern", "baseWeight": 5, "doubleWeight": true },
      { "signId": "alp_elevation_with_gGT", "baseWeight": 5 },
      { "signId": "total_and_direct_bilirubin", "baseWeight": 4 },
      { "signId": "albumin_decreased", "baseWeight": 3 },
