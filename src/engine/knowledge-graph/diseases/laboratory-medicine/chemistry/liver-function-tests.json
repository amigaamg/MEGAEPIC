    "subtypes": [
      {
        "id": "hepatocellular_injury",
        "name": "Hepatocellular Injury Pattern",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "ast_alt_elevation_elevated", "weight": 5 },
          { "feature": "r_value_gt_5", "weight": 5 },
          { "feature": "ast_alt_ratio_gt_2_in_alcohol", "weight": 4 },
          { "feature": "transaminases_gt_10x_uln", "weight": 4 },
          { "feature": "viral_hepatitis_serology_positive", "weight": 4 }
        ],
        "management": "Check viral hepatitis serologies (HAV IgM, HBsAg, HBcIgM, HCV Ab/RNA). Review medications and toxins. Ultrasound to rule out hepatic steatosis. Autoimmune markers (ANA, ASMA, LKM-1). Acetaminophen level if suspected overdose."
      },
      {
        "id": "cholestatic_injury",
        "name": "Cholestatic Pattern",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "alp_elevation_predominant", "weight": 5 },
          { "feature": "gGT_elevated_parallel", "weight": 5 },
          { "feature": "r_value_lt_2", "weight": 5 },
          { "feature": "direct_hyperbilirubinemia", "weight": 4 },
          { "feature": "biliary_dilatation_on_ultrasound", "weight": 4 }
        ],
        "management": "Abdominal ultrasound: if biliary dilatation, refer for ERCP. If no dilatation: check AMA for PBC, MRCP for PSC. Review drugs causing cholestasis (amoxicillin-clavulanate, chlorpromazine)."
      },
      {
        "id": "synthetic_dysfunction",
        "name": "Synthetic Dysfunction (Low Albumin, High INR)",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "albumin_low_lt_3_0", "weight": 5 },
          { "feature": "inr_elevated_gt_1_3", "weight": 5 },
          { "feature": "total_protein_albumin_only_low", "weight": 3 },
          { "feature": "chronic_liver_disease_signs", "weight": 4 }
        ],
        "management": "Assess cirrhosis severity (Child-Pugh, MELD-Na). Screen for varices. Manage ascites (diuretics, paracentesis). HE prophylaxis (lactulose, rifaximin). Consider liver transplantation if decompensated."
      },
      {
        "id": "isolated_hyperbilirubinemia",
        "name": "Isolated Hyperbilirubinemia",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "elevated_bilirubin_normal_lft", "weight": 5 },
          { "feature": "unconjugated_predominant_gilberts", "weight": 4 },
          { "feature": "conjugated_elevated_dubin_johnson", "weight": 3 },
          { "feature": "hemolysis_markers", "weight": 3 }
        ],
        "management": "Gilberts: benign, no treatment. Dubin-Johnson/Rotor: benign. Check for hemolysis (LDH, haptoglobin, reticulocyte count). If conjugated and elevated LFTs, investigate for biliary obstruction."
      }
    ],
    "mimics": [
