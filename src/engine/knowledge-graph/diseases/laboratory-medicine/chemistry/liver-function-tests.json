        { "sign": "inr_gt_1_5_with_encephalopathy", "weight": 10 },
        { "sign": "severe_ast_alt_gt_5000", "weight": 9 },
        { "sign": "hypoglycemia_in_liver_failure", "weight": 9 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "bilirubin_gt_20_mg_dl", "weight": 7 },
          { "sign": "ascites_or_variceal_bleeding", "weight": 7 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If encephalopathy + coagulopathy -> ACUTE LIVER FAILURE; else -> NON-EMERGENT"
