        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "bun_cr_ratio_gt_20", "weight": 5 },
          { "feature": "fena_less_than_1_percent", "weight": 5 },
          { "feature": "urine_osmolality_gt_500", "weight": 4 },
          { "feature": "reversible_with_volume_resuscitation", "weight": 5 },
          { "feature": "clinical_dehydration_or_hypotension", "weight": 4 }
        ],
        "management": "Volume repletion (isotonic crystalloid). Hold NSAIDs, ACEi/ARBs if hypotensive. Treat underlying cause (diarrhea, vomiting, hemorrhage, heart failure). Monitor urine output and creatinine."
      },
      {
        "id": "intrinsic_renal_aki_atn",
        "name": "Intrinsic AKI (Acute Tubular Necrosis)",
        "prevalenceModifier": 0.35,
        "keyFeatures": [
          { "feature": "fena_gt_2_percent", "weight": 5 },
          { "feature": "muddy_brown_granular_casts_on_urinalysis", "weight": 5 },
          { "feature": "recent_ischemia_or_nephrotoxin_exposure", "weight": 4 },
          { "feature": "creatinine_rise_over_24_72h", "weight": 4 },
          { "feature": "renal_failure_index_gt_1", "weight": 3 }
        ],
        "management": "Remove nephrotoxin. Optimize hemodynamics. Avoid further insults. Supportive care. May require dialysis. Recovery over 1-3 weeks with diuretic phase."
      },
      {
        "id": "chronic_kidney_disease",
        "name": "Chronic Kidney Disease (Staging)",
        "prevalenceModifier": 0.35,
