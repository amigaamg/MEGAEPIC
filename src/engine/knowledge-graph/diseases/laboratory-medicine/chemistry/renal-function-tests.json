    "management": {
      "protocolReference": "KDIGO Clinical Practice Guideline for AKI and CKD",
      "pathways": [
        {
          "severity": "aki_stage_1",
          "criteria": "creatinine 1.5-1.9x baseline or UOP <0.5ml/kg/h for 6-12h",
          "treatment": "Discontinue nephrotoxins. Optimize volume status. Monitor creatinine daily. Renal ultrasound. Consider cause (prerenal, intrinsic, postrenal)."
        },
        {
          "severity": "aki_stage_2_3",
          "criteria": "creatinine 2-2.9x or >3x baseline; UOP <0.5 or <0.3ml/kg/h",
          "treatment": "Nephrology consultation. Strict I/O. Avoid contrast. Consider RRT if refractory hyperkalemia, acidosis, volume overload, or uremia. ICU if oliguric."
        },
        {
          "severity": "ckd_stable",
          "criteria": "eGFR <60 for >3 months, stable or slow progression",
          "treatment": "Nephrology referral. Manage BP, proteinuria, DM. Diet: low sodium, moderate protein. Vaccinations (Hep B, influenza, pneumococcal). Prepare for RRT if eGFR <20."
        }
      ]
    },
    "pathophysiology": [
