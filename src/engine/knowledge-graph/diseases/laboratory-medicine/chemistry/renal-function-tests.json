        { "name": "Urine output monitoring", "priority": "immediate", "yield": 0.8, "indication": "all AKI patients" }
      ],
      "laboratory": [
        { "name": "Serum creatinine with eGFR (CKD-EPI)", "priority": "immediate", "yield": 0.95, "indication": "all patients with known or suspected renal disease" },
        { "name": "BUN", "priority": "immediate", "yield": 0.7, "indication": "assess prerenal component, urea clearance" },
        { "name": "Electrolytes (Na, K, Cl, HCO3)", "priority": "immediate", "yield": 0.8, "indication": "monitor for hyperkalemia, acidosis" },
        { "name": "Urinalysis with microscopy", "priority": "high", "yield": 0.7, "indication": "casts, cells, protein, crystals" },
        { "name": "Urine electrolytes (FENa, FEUrea)", "priority": "high", "yield": 0.75, "indication": "differentiate prerenal vs intrinsic AKI" },
        { "name": "Urine ACR (albumin-to-creatinine ratio)", "priority": "medium", "yield": 0.8, "indication": "CKD staging, proteinuria quantification" },
        { "name": "Cystatin C", "priority": "low", "yield": 0.7, "indication": "alternative eGFR if creatinine unreliable" }
      ],
      "imaging": [
        { "name": "Renal Ultrasound", "priority": "high", "yield": 0.6, "indication": "hydronephrosis, kidney size, cortical thickness" }
      ]
