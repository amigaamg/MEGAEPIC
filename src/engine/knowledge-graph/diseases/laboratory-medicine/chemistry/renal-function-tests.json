          { "feature": "albuminuria_acr_gt_30", "weight": 5 },
          { "feature": "small_kidneys_on_ultrasound", "weight": 4 },
          { "feature": "anemia_of_chronic_disease", "weight": 3 },
          { "feature": "renal_osteodystrophy_labs", "weight": 3 }
        ],
        "management": "CKD staging (G1-G5) based on eGFR. Renoprotection: ACEi/ARB for proteinuria. BP target <130/80. SGLT2 inhibitors for proteinuric CKD. Manage complications: anemia (ESA), bone disease (vitamin D, phosphate binders), acidosis (bicarbonate)."
      }
    ],
