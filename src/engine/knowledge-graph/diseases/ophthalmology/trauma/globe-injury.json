    "management": {
      "protocolReference": "AAO / American Society of Ocular Trauma Guidelines",
      "pathways": [
        {
          "severity": "all_open_globe",
          "criteria": "confirmed full-thickness wound",
          "treatment": "Eye shield (NO pressure). NPO. IV broad-spectrum antibiotics (Vancomycin 1g + Ceftazidime 1g or Moxifloxacin 400mg). Tetanus prophylaxis. Anti-emetics. Urgent primary repair (within 24h). Avoid Valsalva. Definitive repair: 10-0 nylon for cornea, 8-0 for sclera. Post-op: topical + systemic antibiotics. Vitreoretinal surgery for posterior segment involvement."
        },
        {
          "severity": "post_repair",
          "criteria": "wound closed, no endophthalmitis",
          "treatment": "Topical antibiotics and steroids (after leak sealed). Systemic antibiotics 7 days. Monitor for endophthalmitis. Avoid eye rubbing. Follow-up: daily initially. Visual rehabilitation after healing (6-12 weeks). Secondary IOL if aphakic."
        }
      ]
    },

