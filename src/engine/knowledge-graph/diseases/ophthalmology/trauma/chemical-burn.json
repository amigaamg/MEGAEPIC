    "management": {
      "protocolReference": "American Academy of Ophthalmology - Chemical Ocular Burns",
      "pathways": [
        {
          "severity": "emergency_irrigation",
          "criteria": "all chemical exposures, immediate",
          "treatment": "STOP: remove contact lens. IRRIGATE immediately: Normal saline or Ringer's lactate 2L+ for 30 min minimum. Continue until fornix pH 7.0-7.4. Evert lids and sweep fornices for particles. Then assess severity."
        },
        {
          "severity": "mild_grade_I_II",
          "criteria": "clear cornea, no or minimal limbal ischemia, epithelial intact or focal loss",
          "treatment": "Topical antibiotics (Chloramphenicol/Ofloxacin qds). Cycloplegia (Cyclopentolate or Atropine). Artificial tears. Topical steroid (Prednisolone acetate 1% qds) for limited duration. Ascorbate 10% and Citrate topically. Pressure patch if epithelial defect. Oral analgesia."
        },
        {
          "severity": "severe_grade_III_IV",
          "criteria": "corneal opacification, >50% limbal ischemia, elevated IOP",
          "treatment": "Admit. Topical antibiotics. Cycloplegia (Atropine 1% tds). Topical steroid (Prednisolone q1-2h) - use with caution after first week due to corneal melting risk. Ascorbate 10% q1-2h. Citrate 10% q1-2h. IOP-lowering (Acetazolamide, Timolol). Oral Doxycycline (100mg BD) to reduce collagenase. AMG (amniotic membrane graft) for persistent defect. Surgical: limbal stem cell transplant, keratoprosthesis."
        }
      ]
    },

