    "management": {
      "protocolReference": "AAO Basic Ophthalmology / Preferred Practice Pattern",
      "pathways": [
        {
          "severity": "simple_small",
          "criteria": "<5mm, non-contact lens, no organic matter, no infection",
          "treatment": "Topical antibiotic (Chloramphenicol 0.5% qds or Ofloxacin 0.3% qds). Topical NSAID (Ketorolac 0.5% tds) for pain. Cycloplegic (Cyclopentolate 1%) if photophobia. DO NOT patch. Review in 24-48h."
        },
        {
          "severity": "contact_lens_related",
          "criteria": "any abrasion in contact lens wearer",
          "treatment": "Topical broad-spectrum antibiotic (Ofloxacin 0.3% q2h or Moxifloxacin 0.5% q2h). NO STEROIDS. Do not patch. Stop contact lens wear. Review in 24h. Consider swab for culture if infiltrate."
        },
        {
          "severity": "large_or_painful",
          "criteria": ">5mm, severe pain, central location",
          "treatment": "Topical antibiotic q1-2h. Cycloplegic. Oral analgesia (paracetamol, NSAID). Bandage contact lens for comfort (with antibiotic cover). Review in 24h. Do not patch (increases infection risk)."
        }
      ]
    },

    "pathophysiology": [
