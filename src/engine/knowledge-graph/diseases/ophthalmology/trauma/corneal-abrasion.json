        { "name": "Slit lamp examination", "priority": "immediate", "yield": 0.95, "indication": "size, depth, location" },
        { "name": "Visual acuity", "priority": "immediate", "yield": 0.7, "indication": "baseline" },
        { "name": "Everted lid exam (rule out foreign body)", "priority": "immediate", "yield": 0.8, "indication": "exclude subtarsal FB" }
