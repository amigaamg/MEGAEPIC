    "management": {
      "protocolReference": "AAO Preferred Practice Pattern - Primary Open Angle Glaucoma",
      "pathways": [
        {
          "severity": "early",
          "criteria": "MDU <0.5, early field loss, IOP <25",
          "treatment": "First-line: Prostaglandin analog (Latanoprost 0.005% nocte). Target IOP: 15-18 mmHg (or 25-30% reduction). Review in 6-12 weeks. If target not met: add second agent."
        },
        {
          "severity": "moderate",
          "criteria": "MDU 0.5-0.8, moderate field defects",
          "treatment": "Combination therapy (e.g., Latanoprost + Timolol or Dorzolamide+Timolol). Selective laser trabeculoplasty (SLT). Consider trabeculectomy if target IOP not achieved."
        },
        {
          "severity": "advanced",
          "criteria": "MDU >0.8, severe field loss, uncontrolled IOP",
          "treatment": "Trabeculectomy (augmented with Mitomycin-C). Tube shunt (Ahmed, Baerveldt) if failed trab. Low-target IOP (10-12 mmHg). Monitor for progression."
        }
      ]
    },

