      "pathways": [
        {
          "severity": "acute_attack",
          "criteria": "pain, high IOP >40, corneal edema, closed angle",
          "treatment": "ABC approach. Immediate medical therapy: Acetazolamide 500mg IV stat, topical Pilocarpine 2% (after IOP starts to drop), Timolol 0.5%, Brimonidine 0.2%, Mannitol 20% IV 1-2g/kg over 30min. Analgesia. After cornea clears: YAG laser peripheral iridotomy (LPI). Definite treatment."
        },
        {
          "severity": "post_attack_management",
          "criteria": "IOP controlled, cornea clear, LPI performed",
          "treatment": "Topical steroids for inflammation. Alpha-agonist (Brimonidine) to prevent IOP spike. Prophylactic LPI to fellow eye. Follow-up: IOP, gonioscopy, OCT. Consider lens extraction if angle closure persists."
        },
        {
          "severity": "fellow_eye_prophylaxis",
          "criteria": "asymptomatic, narrow angles, prophylactic",
          "treatment": "Prophylactic YAG laser iridotomy (LPI) for fellow eye (50% risk of acute attack within 5 years). Review after 1 week, then annually."
