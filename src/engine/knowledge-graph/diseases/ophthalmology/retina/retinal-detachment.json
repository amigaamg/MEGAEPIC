    "subtypes": [
      {
        "id": "rhegmatogenous_rd",
        "name": "Rhegmatogenous Retinal Detachment (RRD)",
        "prevalenceModifier": 0.85,
        "keyFeatures": [
          { "feature": "full_thickness_retinal_break", "weight": 5 },
          { "feature": "subretinal_fluid", "weight": 5 },
          { "feature": "PVD_present", "weight": 4 },
          { "feature": "most_common_type", "weight": 4 }
        ],
        "management": "Surgical repair: Pneumatic retinopexy (select suitable breaks). Scleral buckle. Pars plana vitrectomy (PPV) + gas/SO tamponade + laser/retinopexy."
      },
      {
        "id": "tractional_rd",
        "name": "Tractional Retinal Detachment",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
