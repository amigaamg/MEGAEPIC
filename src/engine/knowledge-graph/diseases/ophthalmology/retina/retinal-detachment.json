    "management": {
      "protocolReference": "AAO Preferred Practice Pattern - Retinal Detachment",
      "pathways": [
        {
          "severity": "macula_on_rd",
          "criteria": "retinal detachment not involving fovea, recent onset",
          "treatment": "Urgent surgery (within 24-48h). Options: PPV + gas/C3F8 + laser retinopexy +/- scleral buckle. Pneumatic retinopexy if superior tear <1 clock hour. Post-op positioning (face down for gas)."
        },
        {
          "severity": "macula_off_rd",
          "criteria": "fovea detached, <7 days duration",
          "treatment": "Surgery as soon as possible (within 1-7 days). Same surgical options. Visual prognosis depends on duration of macula detachment. Recovery may take months."
        },
        {
          "severity": "chronic_or_complex_rd",
          "criteria": "chronic >7 days, PVR, giant tear, multiple breaks",
          "treatment": "PPV + scleral buckle + perfluorocarbon liquid + laser + silicone oil tamponade (if long-term needed). Membrane peeling for PVR. Revision if redetachment."
        }
      ]
    },

    "pathophysiology": [
      "posterior_vitreous_detachment",
      "vitreous_liquefaction",
      "retinal_break_formation",
      "fluid_passage_into_subretinal_space",
      "photoreceptor_injury"
    ],

