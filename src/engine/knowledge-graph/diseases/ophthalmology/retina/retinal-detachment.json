          { "feature": "concave_contour", "weight": 4 },
          { "feature": "no_retinal_break", "weight": 4 },
          { "feature": "diabetes_history_common", "weight": 4 }
        ],
        "management": "PPV + membrane peel + laser. Often combined with cataract surgery."
      },
      {
        "id": "exudative_rd",
        "name": "Exudative Serous Retinal Detachment",
        "prevalenceModifier": 0.05,
        "keyFeatures": [
