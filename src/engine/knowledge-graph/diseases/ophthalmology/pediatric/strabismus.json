{
  "disease": {
    "id": "strabismus",
    "name": "Strabismus (Squint)",
    "system": "OPHTH",
    "agePeak_months": [0, 120],
    "note": "Misalignment of the eyes due to imbalance of extraocular muscles, neuromuscular dysfunction, or refractive error. Can be congenital or acquired. If untreated beyond the critical period, leads to amblyopia.",
    "prevalenceWeight": 0.03,
    "syndromeTags": ["pediatric_eye", "eye_misalignment", "pediatric_ophthalmology"],

    "severityAssessment": {
      "immediateDangerSigns": [
        { "sign": "acute_onset_strabismus_in_adult", "weight": 8, "note": "May indicate neurological cause" },
        { "sign": "diplopia_in_older_child_or_adult", "weight": 7 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "constant_strabismus", "weight": 6 },
          { "sign": "amblyopia_present", "weight": 7 },
          { "sign": "abnormal_head_posture_significant", "weight": 4 },
          { "sign": "vertical_or_complex_strabismus", "weight": 5 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "Constant strabismus with amblyopia or acute onset -> SEVERE (treat urgently)"
    },

    "historyFeatures": [
      { "symptomId": "eye_not_looking_in_same_direction", "weight": 5 },
      { "symptomId": "turned_in_esotropia_or_out_exotropia", "weight": 5 },
      { "symptomId": "head_tilt_or_turn", "weight": 4 },
      { "symptomId": "closing_one_eye_in_bright_light", "weight": 3, "note": "Intermittent exotropia" },
      { "symptomId": "diplopia_older_children", "weight": 3 },
      { "symptomId": "squint_worse_when_tired_or_distracted", "weight": 3 },
      { "symptomId": "family_history_of_strabismus", "weight": 3 },
      { "symptomId": "premature_birth_or_developmental_delay", "weight": 2 },
      { "symptomId": "onset_acutely_after_fever_or_trauma", "weight": 2 }
    ],

    "examFeatures": [
      { "signId": "corneal_light_reflex_asymmetric_Hirschberg", "baseWeight": 5, "doubleWeight": true },
      { "signId": "cover_test_positive_manifest_tropia", "baseWeight": 5 },
      { "signId": "cover_uncover_test_reveals_latent_phoria", "baseWeight": 4 },
      { "signId": "limited_eye_movement_in_one_or_more_directions", "baseWeight": 4 },
      { "signId": "abnormal_head_posture", "baseWeight": 3 },
      { "signId": "visual_acuity_reduced_in_deviating_eye", "baseWeight": 3 },
      { "signId": "intermittent_vs_constant_alignment", "baseWeight": 3 }
    ],

    "riskFactors": [
      { "id": "family_history_of_strabismus", "multiplier": 3.0 },
      { "id": "prematurity_under_32_weeks", "multiplier": 3.0 },
      { "id": "refractive_error_high_hyperopia", "multiplier": 3.0 },
      { "id": "neurological_conditions_cerebral_palsy", "multiplier": 4.0 },
      { "id": "Down_syndrome", "multiplier": 5.0 },
      { "id": "craniofacial_abnormalities", "multiplier": 3.0 }
    ],

    "subtypes": [
      {
        "id": "infantile_esotropia",
        "name": "Infantile Esotropia",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "onset_before_6_months", "weight": 5 },
          { "feature": "large_angle_constant", "weight": 5 },
          { "feature": "cross_fixation", "weight": 4 },
          { "feature": "no_refractive_error", "weight": 3 }
        ],
        "management": "Surgical correction (bilateral medial rectus recession) before age 2. Amblyopia treatment. Follow-up for residual deviation."
      },
      {
        "id": "accommodative_esotropia",
        "name": "Accommodative Esotropia",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "onset_2_to_4_years", "weight": 5 },
          { "feature": "high_hyperopia", "weight": 5 },
          { "feature": "intermittent_then_constant", "weight": 4 },
          { "feature": "improves_with_glasses", "weight": 5 }
        ],
        "management": "Full hyperopic correction with spectacles. If residual: bifocals. Amblyopia treatment. Surgery if non-accommodative component."
      },
      {
        "id": "intermittent_exotropia",
        "name": "Intermittent Exotropia",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "eye_drifts_out_when_tired", "weight": 5 },
          { "feature": "closes_one_eye_in_sun", "weight": 4 },
          { "feature": "diplopia_rare", "weight": 3 },
          { "feature": "worse_at_distance", "weight": 4 }
        ],
        "management": "Observation if good control. Occlusion therapy (part-time patching). Orthoptic exercises (convergence). Surgery if deteriorating control."
      }
    ],

    "mimics": [
      {
        "diseaseId": "pseudostrabismus",
        "discriminators": ["wide_epicanthal_folds", "symmetrical_light_reflex", "no_deviation_on_cover_test"]
      },
      {
        "diseaseId": "cranial_nerve_palsy",
        "discriminators": ["limited_ductions", "diplopia", "acute_onset_older"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Corneal light reflex (Hirschberg)", "priority": "immediate", "yield": 0.8, "indication": "angle estimation" },
        { "name": "Cover test (distance and near)", "priority": "immediate", "yield": 0.9, "indication": "type and angle" },
        { "name": "Prism cover test (measured in PD)", "priority": "high", "yield": 0.85, "indication": "quantification" }
      ],
      "laboratory": [],
      "imaging": [
        { "name": "Cycloplegic refraction", "priority": "essential", "yield": 0.95, "indication": "hyperopia, myopia, astigmatism" },
        { "name": "Fundus examination (dilated)", "priority": "medium", "yield": 0.5, "indication": "exclude organic pathology" },
        { "name": "MRI brain if acute/paresis", "priority": "low", "yield": 0.3, "indication": "if neurological cause suspected" }
      ]
    },

    "management": {
      "protocolReference": "AAO Pediatric Ophthalmology / Strabismus Preferred Practice Pattern",
      "pathways": [
        {
          "severity": "amblyogenic_strabismus",
          "criteria": "constant strabismus, children <8 years, vision reduced",
          "treatment": "Treat amblyopia first: patching or atropine penalization of fixing eye. Correct refractive error. Then strabismus surgery. Aim for alignment before age 7."
        },
        {
          "severity": "non_amblyogenic",
          "criteria": "intermittent, good vision, older child/adult",
          "treatment": "Observation. Orthoptic exercises. Prism glasses for diplopia. Surgery if cosmetically or functionally significant."
        },
        {
          "severity": "surgical",
          "criteria": "failed medical therapy, constant deviation >15 PD",
          "treatment": "Strabismus surgery: weakening (recession) and/or strengthening (resection) of extraocular muscles. Adjustable sutures in adults. Post-op orthoptic follow-up."
        }
      ]
    },

    "pathophysiology": [
      "imbalance_of_extraocular_muscle_tone",
      "refractive_error_driven_accommodation",
      "fusion_defect",
      "congenital_motor_abnormality"
    ],

    "complications": [
      {
        "diseaseId": "amblyopia",
        "probability": 0.4,
        "lagDays": [30, 365],
        "severityBoost": 0.4,
        "clues": ["vision_reduced_in_deviating_eye"]
      },
      {
        "diseaseId": "permanent_vision_loss",
        "probability": 0.1,
        "lagDays": [365, 1825],
        "severityBoost": 0.6,
        "clues": ["untreated_amblyopia_past_critical_period"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "medium",
    "diagnosticClues": ["eye_misalignment", "cover_test_positive", "abnormal_head_posture"],
    "exclusionClues": ["pseudostrabismus", "orthophoric_cover_test"]
  }
}
