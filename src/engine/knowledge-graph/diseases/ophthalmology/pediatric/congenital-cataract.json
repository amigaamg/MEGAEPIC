    "management": {
      "protocolReference": "AAO Pediatric Cataract Preferred Practice Pattern",
      "pathways": [
        {
          "severity": "visually_significant_unilateral",
          "criteria": "dense central cataract >3mm, unilateral, child <6 months",
          "treatment": "URGENT: Lens aspiration + posterior capsulotomy + vitrectomy within 2-4 weeks for unilateral. Contact lens for aphakia. Patching of good eye for amblyopia. IOL implantation deferred to age 2+."
        },
        {
          "severity": "visually_significant_bilateral",
          "criteria": "dense bilateral cataracts, child <3 months",
          "treatment": "URGENT: Surgery within 4-6 weeks for bilateral. Both eyes within 2 weeks of each other. Contact lenses/glasses for aphakia. No IOL until age 2. Amblyopia management."
        },
        {
          "severity": "partial_non_amblyogenic",
          "criteria": "small partial opacity, not in visual axis, good vision",
          "treatment": "Observation. Cycloplegic refraction. Monitor vision and cataract progression. Myopia management. Patching if amblyopia develops."
        }
      ]
