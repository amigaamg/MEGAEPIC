    "management": {
      "protocolReference": "AAO Preferred Practice Pattern - Amblyopia",
      "pathways": [
        {
          "severity": "mild_20124_to_2040",
          "criteria": "vision 20/40 or better, child >4 years",
          "treatment": "Correction of refractive error. Patching of sound eye 2 hours/day. Atropine 1% in sound eye (weekends initially). Monitor every 2-4 months until vision stable."
        },
        {
          "severity": "moderate_20125_to_20100",
          "criteria": "vision 20/50-20/100",
          "treatment": "Patching sound eye 4-6 hours/day. Atropine weekends. Optical correction. Follow-up every 1-2 months. If no response in 3 months: increase patching, consider Bangerter filter."
        },
        {
          "severity": "severe_20200_to_worse",
          "criteria": "vision <20/200",
          "treatment": "Patching sound eye 6-8 hours/day (all waking hours if tolerated). Atropine 1% daily. Full-time glasses. Close follow-up. Deprivation: urgent surgical intervention."
        },
        {
          "severity": "deprivation",
          "criteria": "cataract, ptosis, corneal scar",
          "treatment": "Urgent surgical removal of cataract (before 6 weeks in congenital). Prompt optical rehabilitation (CL, IOL). Patching of sound eye. Treat ptosis urgently. Early intervention critical for vision."
        }
      ]
