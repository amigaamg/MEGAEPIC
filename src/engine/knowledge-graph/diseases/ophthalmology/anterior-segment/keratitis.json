    "management": {
      "protocolReference": "AAO Preferred Practice Pattern - Bacterial Keratitis",
      "pathways": [
        {
          "severity": "mild_bacterial",
          "criteria": "<2mm infiltrate, peripheral, no hypopyon",
          "treatment": "Topical Moxifloxacin 0.5% q1h for 48h then q2h. Cycloplegic (Cyclopentolate 1% or Atropine 1%). Scraping for culture. Review daily."
        },
        {
          "severity": "severe_bacterial",
          "criteria": ">2mm, central, hypopyon, corneal thinning",
          "treatment": "Intensive fortified antibiotics (Cefazolin 5% + Gentamicin/Tobramycin 1.4% alternating q30min). Cycloplegics. Hospitalization if severe. Oral antibiotics if scleral extension. Consider therapeutic keratoplasty."
        },
        {
          "severity": "herpetic",
          "criteria": "dendritic ulcer",
          "treatment": "Topical Acyclovir 3% 5x/day or Ganciclovir 0.15% gel. No steroids. Debridement. Oral antivirals if frequent recurrences. Stromal disease: topical steroids + antiviral cover."
        }
      ]
    },

