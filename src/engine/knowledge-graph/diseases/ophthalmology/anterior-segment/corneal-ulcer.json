    "management": {
      "protocolReference": "AAO Preferred Practice Pattern for Corneal Ulcer",
      "pathways": [
        {
          "severity": "mild_superficial",
          "criteria": "small peripheral ulcer, no hypopyon, no stromal thinning",
          "treatment": "Topical broad-spectrum antibiotics (Moxifloxacin 0.5% or Ofloxacin 0.3% q1-2h). Cycloplegic (Cyclopentolate 1% tds). Do not patch. Review in 24h."
        },
        {
          "severity": "moderate_severe",
          "criteria": "central or large ulcer, hypopyon, stromal involvement",
          "treatment": "Fortified topical antibiotics (Cefazolin 5% + Gentamicin 1.4% alternating hourly). Cycloplegics. Scraping for culture. Hospitalization. Oral antibiotics if scleral involvement. Cyanoacrylate glue + bandage contact lens if impending perforation."
        },
        {
          "severity": "critical",
          "criteria": "perforated, endophthalmitis, melting",
          "treatment": "Therapeutic penetrating keratoplasty (TPK). Tissue adhesive (cyanoacrylate) for small perforations. Fortified antibiotics. ICU level monitoring."
        }
      ]
    },

