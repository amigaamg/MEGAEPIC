    "management": {
      "protocolReference": "Basic Ophthalmology / AAO Guidelines",
      "pathways": [
        {
          "severity": "viral",
          "criteria": "watery discharge, follicles, preauricular node",
          "treatment": "Supportive: artificial tears, cold compresses, lubrication. Hygiene (handwashing, separate towels). Avoid school/work for 7 days. No antibiotics. Review if not improving in 7-10 days."
        },
        {
          "severity": "bacterial",
          "criteria": "purulent discharge, papillary reaction",
          "treatment": "Topical antibiotic qds for 5-7 days. Warm compresses to remove crusting. Review if not improving in 48-72h. Consider swab for culture."
        },
        {
          "severity": "allergic",
          "criteria": "itching, bilateral, seasonal, chemosis",
          "treatment": "Antihistamine/mast cell stabilizer drops. Cool compresses. Avoid triggers. If severe: short course topical steroid (e.g., Fluorometholone 0.1% tds)."
        },
        {
          "severity": "neonatal_ophthalmia",
          "criteria": "infant <28 days, purulent discharge",
          "treatment": "Urgent ophthalmology referral. Swab for N. gonorrhoeae and C. trachomatis. Systemic antibiotics (ceftriaxone or erythromycin). Topical erythromycin. Prevent corneal perforation."
        }
      ]
    },

