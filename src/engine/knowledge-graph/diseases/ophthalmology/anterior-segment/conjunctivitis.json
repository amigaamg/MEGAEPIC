    "subtypes": [
      {
        "id": "viral_conjunctivitis",
        "name": "Viral Conjunctivitis",
        "prevalenceModifier": 0.5,
        "keyFeatures": [
          { "feature": "watery_discharge", "weight": 5 },
          { "feature": "preauricular_lymph_node", "weight": 4 },
          { "feature": "follicular_reaction", "weight": 4 },
          { "feature": "bilateral_often", "weight": 3 },
          { "feature": "mild_photophobia", "weight": 2 }
        ],
        "management": "Self-limiting (5-14 days). Artificial tears. Cold compresses. Hygiene to prevent spread. No antibiotics. If severe: topical steroids (after excluding herpes)."
      },
      {
        "id": "bacterial_conjunctivitis",
        "name": "Bacterial Conjunctivitis",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
