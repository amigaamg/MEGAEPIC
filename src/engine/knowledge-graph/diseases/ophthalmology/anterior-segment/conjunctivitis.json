          { "feature": "mattering_of_lashes", "weight": 4 },
          { "feature": "papillary_reaction", "weight": 3 },
          { "feature": "no_lymphadenopathy", "weight": 3 },
          { "feature": "acute_onset", "weight": 3 }
        ],
        "management": "Topical antibiotics: Chloramphenicol 0.5% qds or Fusidic acid 1% bd. Ofloxacin for contact lens wearers. Hygiene measures. Resolves in 3-7 days."
      },
      {
        "id": "allergic_conjunctivitis",
        "name": "Allergic Conjunctivitis",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "intense_itching", "weight": 5 },
          { "feature": "bilateral", "weight": 4 },
          { "feature": "allergy_history", "weight": 4 },
          { "feature": "seasonal_variation", "weight": 3 },
          { "feature": "chemosis", "weight": 3 },
          { "feature": "cobblestone_papillae", "weight": 3 }
        ],
        "management": "Avoid allergens. Artificial tears. Antihistamine drops (Levocabastine, Olopatadine). Mast cell stabilizers (Lodoxamide, Cromoglycate). Topical steroids if severe (short course)."
      }
