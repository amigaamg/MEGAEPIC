    "management": {
      "protocolReference": "Optic Neuritis Treatment Trial (ONTT) / MS Guidelines",
      "pathways": [
        {
          "severity": "typical_mild",
          "criteria": "acuity >20/40, mild pain, no severe scotoma",
          "treatment": "Observation. Spontaneous recovery expected. Reassurance. No steroids needed. Follow-up in 2-4 weeks. MRI brain for MS risk stratification."
        },
        {
          "severity": "typical_severe",
          "criteria": "acuity <20/200, severe pain, large scotoma",
          "treatment": "IV Methylprednisolone 1g IV daily x 3-5 days (speeds recovery, does not improve final outcome). Oral Prednisone taper after. NO oral prednisone alone (increases risk of recurrence). MS disease-modifying therapy if brain lesions."
        },
        {
          "severity": "atypical_or_refractory",
          "criteria": "bilateral, very severe, no improvement, NMO/MOG positive",
          "treatment": "IV Methylprednisolone 1g daily x 5 days. Plasma exchange if no response (5 sessions). Immunosuppression for NMO/MOG. Rituximab or Mycophenolate."
        }
      ]
    },

