          { "feature": "worse_on_downgaze", "weight": 4 },
          { "feature": "head_tilt_to_fellow_shoulder", "weight": 4 },
          { "feature": "hypertropia_on_exam", "weight": 5 }
        ],
        "management": "Trauma or microvascular most common. Prism glasses. Strabismus surgery if >6 months and symptomatic. BP/glucose control."
      },
      {
        "id": "cn6_palsy",
        "name": "Abducens (CN VI) Palsy",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "horizontal_diplopia", "weight": 5 },
          { "feature": "inability_to_abduct", "weight": 5 },
          { "feature": "esotropia", "weight": 4 },
          { "feature": "worse_at_distance", "weight": 3 }
        ],
        "management": "Microvascular (most common) vs intracranial mass vs raised ICP. MRI brain if no improvement in 3 months. Prisms. Botox to medial rectus. Strabismus surgery if >6 months."
      },
      {
        "id": "multiple_ocular_motor_nerve_palsies",
        "name": "Multiple Cranial Nerve Palsies (Cavernous Sinus)",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
