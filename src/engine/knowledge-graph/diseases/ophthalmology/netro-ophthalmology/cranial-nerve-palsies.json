          { "feature": "facial_pain_or_numbness", "weight": 4 },
          { "feature": "chemosis_orbital_signs", "weight": 4 }
        ],
        "management": "Urgent MRI brain + MRA/MRV + cavernous sinus imaging. Rule out carotid-cavernous fistula, cavernous sinus thrombosis, tumor, Tolosa-Hunt. Treat underlying cause."
      }
