    "management": {
      "protocolReference": "AAO / Neuro-ophthalmology Guidelines for Ocular Motor Nerve Palsies",
      "pathways": [
        {
          "severity": "pupil_involving_cn3",
          "criteria": "CN III palsy with dilated pupil, any age",
          "treatment": "EMERGENCY: CT angiogram or MRI/MRA to rule out PCOM aneurysm. Neurosurgery if aneurysm found. If negative, treat as microvascular."
        },
        {
          "severity": "isolated_microvascular",
          "criteria": "pupil-sparing CN3, CN4, or CN6 in patient >50 with vascular risk factors",
          "treatment": "Conservative. BP and glucose control. Prism glasses for diplopia. Eye patch if needed. Spontaneous recovery in 3-6 months. If no improvement in 3 months: neuroimaging."
        },
        {
          "severity": "traumatic_or_complex",
          "criteria": "trauma, multiple nerves, cavernous sinus, no recovery",
          "treatment": "MRI/MRA investigation. Treat underlying cause. Strabismus surgery after 6 months of stability. Botulinum toxin for temporary relief."
        }
      ]
    },

