    "subtypes": [
      {
        "id": "diffuse_toxic_goiter_graves",
        "name": "Diffuse Toxic Goiter (Graves' Disease)",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "diffuse_smooth_enlargement", "weight": 5 },
          { "feature": "hyperthyroidism", "weight": 5 },
          { "feature": "ophthalmopathy_tremor_tachycardia", "weight": 4 },
          { "feature": "tsh_receptor_antibodies", "weight": 4 }
        ],
        "management": "Medical: Antithyroid drugs (Carbimazole, PTU). Radioactive iodine (RAI) therapy. Surgery (total thyroidectomy) for large goiter, failed medical therapy, or patient preference."
      },
      {
        "id": "multinodular_goiter",
        "name": "Multinodular Goiter (MNG)",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
          { "feature": "multiple_nodules_in_enlarged_gland", "weight": 5 },
          { "feature": "long_history_gradual_enlargement", "weight": 4 },
          { "feature": "euthyroid_or_hyperthyroid", "weight": 3 },
          { "feature": "compressive_symptoms", "weight": 3 }
        ],
        "management": "Observation if asymptomatic. Levothyroxine to suppress TSH (controversial). Surgery (subtotal or total thyroidectomy) for compressive symptoms, large size, cosmetic concern, or suspicious nodules. RAI for toxic MNG in elderly."
      },
      {
        "id": "retrosternal_goiter",
        "name": "Retrosternal (Substernal) Goiter",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
          { "feature": "extension_below_sternal_notch", "weight": 5 },
          { "feature": "positive_pemberton_sign", "weight": 5 },
          { "feature": "dyspnea_dysphagia", "weight": 4 },
          { "feature": "svc_obstruction_signs", "weight": 3 }
        ],
        "management": "Total thyroidectomy via cervical approach (majority). Sternotomy if extension below aortic arch. All retrosternal goiters should be removed due to compressive risk."
      }
    ],

    "mimics": [
      {
