        {
          "severity": "compressive or toxic",
          "criteria": "dysphagia, dyspnea, tracheal compression, hyperthyroidism",
          "treatment": "Total or near-total thyroidectomy. Pre-op preparation with antithyroid drugs + Lugol's iodine for toxic goiter. RAI for elderly with toxic MNG."
        }
      ]
