    "management": {
      "protocolReference": "ATA/AACE Guidelines for Goiter Management",
      "pathways": [
        {
          "severity": "non-compressive euthyroid",
          "criteria": "no compressive symptoms, normal thyroid function, no suspicious nodules",
          "treatment": "Observation. Periodic clinical and US follow-up. Iodine supplementation if deficient."
