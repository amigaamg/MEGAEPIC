    "management": {
      "protocolReference": "AAES Guidelines for Primary Hyperparathyroidism",
      "pathways": [
        {
          "severity": "asymptomatic mild",
          "criteria": "calcium <1mg/dL above ULN, no renal stones, no osteoporosis, age >50",
          "treatment": "Observation. Monitor calcium, renal function, bone density every 1-2 years. Adequate hydration. Avoid thiazides and lithium."
        },
        {
          "severity": "symptomatic or meeting surgical criteria",
          "criteria": "calcium >1mg/dL above ULN, renal stones, osteoporosis, age <50, CrCl <60mL/min",
          "treatment": "Parathyroidectomy (MIP if localized, bilateral exploration if not). Intraoperative PTH monitoring (drop >50% at 10min)."
        },
        {
          "severity": "hypercalcemic crisis",
          "criteria": "calcium >14 mg/dL, confusion, dehydration, arrhythmia",
          "treatment": "Admit to ICU. Aggressive IV fluids (normal saline). Calcitonin. Bisphosphonates (Pamidronate or Zoledronic acid). Urgent parathyroidectomy once stabilized."
        }
      ]
