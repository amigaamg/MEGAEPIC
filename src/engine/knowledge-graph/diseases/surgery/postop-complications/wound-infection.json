          { "sign": "systemic_sepsis", "weight": 8 },
          { "sign": "crepitus", "weight": 9 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If sepsis/crepitus/wound dehiscence -> SEVERE (deep SSI or necrotizing); else -> NON-SEVERE (superficial SSI)"
