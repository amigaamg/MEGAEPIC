        { "name": "CRP", "priority": "high", "yield": 0.75, "indication": "elevated in infection" },
        { "name": "Blood cultures", "priority": "high", "yield": 0.4, "indication": "if systemic sepsis suspected" },
        { "name": "Lactate", "priority": "high", "yield": 0.5, "indication": "if sepsis suspected" }
      ],
      "imaging": [
        { "name": "Abdominal CT with IV contrast", "priority": "medium", "yield": 0.85, "indication": "suspected deep or organ/space SSI" },
        { "name": "Ultrasound wound", "priority": "medium", "yield": 0.7, "indication": "assess fluid collection depth" }
      ]
    },

    "management": {
      "protocolReference": "CDC/NHSN SSI Criteria; WSES Guidelines for Surgical Site Infections",
      "pathways": [
        {
          "severity": "superficial",
          "criteria": "localized erythema, purulent discharge, no systemic features",
          "treatment": "Open wound, drain pus, pack daily. Wound swab. Oral antibiotics (Flucloxacillin 500 mg QDS or Clindamycin if allergic). Review in 48 hours."
        },
        {
          "severity": "deep",
          "criteria": "fascial involvement, wound dehiscence, fever, elevated WBC/CRP",
          "treatment": "Urgent wound exploration in OR. Debridement. IV antibiotics (Piperacillin-Tazobactam 4.5 g QDS). NPWT consideration. ICU if septic."
        },
        {
          "severity": "organ_space",
          "criteria": "intra-abdominal collection on CT, persistent fever, ileus",
          "treatment": "CT-guided percutaneous drainage or re-laparotomy. IV antibiotics tailored to culture. Source control essential."
        }
      ]
    },

    "pathophysiology": [
