      { "id": "immunosuppression", "multiplier": 2.0 },
      { "id": "malnutrition", "multiplier": 1.6 }
    ],

    "subtypes": [
      {
        "id": "superficial_ssi",
        "name": "Superficial Incisional SSI",
        "prevalenceModifier": 0.7,
        "keyFeatures": [
          { "feature": "skin_subcutaneous_involvement", "weight": 5 },
          { "feature": "purulent_discharge_incision", "weight": 5 },
          { "feature": "erythema_limited_to_wound", "weight": 4 }
        ],
        "management": "Wound opening and drainage. Wound swab for culture. Daily packing with sterile dressing. Oral antibiotics if cellulitis (e.g., Flucloxacillin)."
      },
      {
        "id": "deep_ssi",
        "name": "Deep Incisional SSI",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "fascial_muscle_involvement", "weight": 5 },
          { "feature": "purulent_discharge_from_depth", "weight": 5 },
          { "feature": "wound_dehiscence", "weight": 5 },
          { "feature": "high_fever", "weight": 4 }
        ],
        "management": "Urgent wound exploration in OR. Debridement of necrotic tissue. IV broad-spectrum antibiotics (e.g., Piperacillin-Tazobactam). Negative pressure wound therapy (NPWT) may be considered."
      },
      {
        "id": "organ_space_ssi",
        "name": "Organ/Space SSI",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
          { "feature": "fever_persistent", "weight": 5 },
          { "feature": "abdominal_pain_persistent", "weight": 5 },
          { "feature": "ileus", "weight": 4 },
          { "feature": "purulent_drainage_from_drain", "weight": 5 }
        ],
        "management": "CT imaging to identify collection. Percutaneous drainage or re-operation. IV antibiotics tailored to culture. Sepsis resuscitation if indicated."
      }
    ],

    "mimics": [
      {
        "diseaseId": "wound_hematoma",
