        { "name": "Wound swab for culture and sensitivity", "priority": "immediate", "yield": 0.9, "indication": "all suspected SSI" },
        { "name": "Temperature", "priority": "immediate", "yield": 0.7, "indication": "all patients" },
        { "name": "Wound inspection with probing", "priority": "immediate", "yield": 0.85, "indication": "assess depth of involvement" }
      ],
      "laboratory": [
