    "management": {
      "protocolReference": "ERAS (Enhanced Recovery After Surgery) Guidelines for Ileus Prevention",
      "pathways": [
        {
          "severity": "physiologic",
          "criteria": "post-laparotomy day 1-3, distension mild, no peritonitis, stable vitals",
          "treatment": "NPO, NG tube PRN for vomiting. IV crystalloids. Correct electrolytes. Minimize opioid use (epidural preferable). Early mobilization. Chewing gum (evidence for sham feeding). Remove NG tube when output < 500 mL/day."
        },
        {
          "severity": "prolonged",
