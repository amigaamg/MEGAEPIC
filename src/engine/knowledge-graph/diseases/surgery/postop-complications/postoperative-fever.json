    "investigations": {
      "bedside": [
        { "name": "Temperature chart review", "priority": "immediate", "yield": 0.9, "indication": "pattern and timing assessment" },
        { "name": "Wound inspection", "priority": "immediate", "yield": 0.8, "indication": "signs of SSI" },
        { "name": "Urine dipstick", "priority": "immediate", "yield": 0.7, "indication": "nitrites/leukocytes for UTI" },
        { "name": "IV line site check", "priority": "immediate", "yield": 0.6, "indication": "phlebitis" }
      ],
      "laboratory": [
        { "name": "WBC count with differential", "priority": "high", "yield": 0.7, "indication": "leukocytosis/left shift infection marker" },
        { "name": "CRP", "priority": "high", "yield": 0.75, "indication": "rising trend warrants investigation" },
        { "name": "Procalcitonin", "priority": "high", "yield": 0.8, "indication": "differentiates bacterial infection from inflammatory response" },
        { "name": "Blood cultures (2 sets)", "priority": "high", "yield": 0.5, "indication": "fever > 38.5°C or rigors" },
        { "name": "Urine culture", "priority": "high", "yield": 0.7, "indication": "UTI suspected" },
        { "name": "Sputum culture", "priority": "medium", "yield": 0.6, "indication": "productive cough" },
        { "name": "Liver function tests", "priority": "medium", "yield": 0.4, "indication": "hepatobiliary causes" }
      ],
      "imaging": [
        { "name": "Chest X-ray", "priority": "high", "yield": 0.6, "indication": "atelectasis, pneumonia, effusion" },
        { "name": "CT Abdomen with IV contrast", "priority": "high", "yield": 0.9, "indication": "suspected intra-abdominal source (leak, abscess)" },
        { "name": "CT Pulmonary Angiography", "priority": "medium", "yield": 0.95, "indication": "suspected PE" },
        { "name": "Abdominal Ultrasound", "priority": "medium", "yield": 0.6, "indication": "biliary causes, fluid collections" }
      ]
    },

    "management": {
      "protocolReference": "Surgical Recall Postoperative Fever Workup; ACS NSQIP Guidelines",
      "pathways": [
        {
          "severity": "early_atelectatic",
          "criteria": "fever < 48h post-op, no focal signs, self-limiting, afebrile between spikes",
          "treatment": "Incentive spirometry, chest physiotherapy, mobilization. Antipyretics (Paracetamol) if symptomatic. No antibiotics. Observe."
        },
        {
          "severity": "infectious_source_identified",
          "criteria": "focal signs of infection (UTI, SSI, pneumonia, line infection)",
          "treatment": "Targeted antibiotics based on culture. Source control: wound opening, catheter removal, line removal, drain insertion as appropriate."
        },
        {
          "severity": "severe_sepsis_source_unknown",
          "criteria": "high fever > 39°C, rigors, hypotension, tachycardia, no obvious source",
          "treatment": "IV fluids resuscitation. Blood cultures, urine cultures. Empiric broad-spectrum IV antibiotics (Piperacillin-Tazobactam). Urgent CT imaging. Surgical consult to rule out leak/abscess. ICU if shock."
        }
      ]
    },

    "pathophysiology": [
