      { "symptomId": "cough_sputum", "weight": 3, "note": "Atelectasis or pneumonia" },
      { "symptomId": "dysuria_frequency", "weight": 3, "note": "UTI if catheterized" },
      { "symptomId": "wound_pain_discharge", "weight": 4, "note": "SSI" },
      { "symptomId": "leg_swelling_pain", "weight": 3, "note": "DVT" },
      { "symptomId": "shortness_of_breath", "weight": 3, "note": "PE or pneumonia" },
      { "symptomId": "abdominal_pain", "weight": 4, "note": "Anastomotic leak or intra-abdominal infection" }
