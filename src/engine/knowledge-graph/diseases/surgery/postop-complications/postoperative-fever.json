      "immediateDangerSigns": [
        { "sign": "septic_shock", "weight": 10 },
        { "sign": "generalized_peritonitis", "weight": 10 },
        { "sign": "meningism", "weight": 10 },
        { "sign": "avpu_abnormal", "weight": 10 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "fever_above_39", "weight": 7 },
          { "sign": "tachycardia_out_of_proportion", "weight": 7 },
          { "sign": "hypotension", "weight": 8 },
          { "sign": "rigors", "weight": 6 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If sepsis/shock/peritonitis -> SEVERE; else -> NON-SEVERE (self-limiting fever, minor atelectasis, drug fever)"
    },

    "historyFeatures": [
      { "symptomId": "fever", "weight": 5 },
