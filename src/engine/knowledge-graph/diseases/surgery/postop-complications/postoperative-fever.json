      { "id": "blood_transfusion", "multiplier": 1.3 }
    ],

    "subtypes": [
      {
        "id": "early_fever_48h",
        "name": "Early Fever (Within 48 hours)",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "fever_within_48h", "weight": 5 },
          { "feature": "atelectasis", "weight": 4 },
          { "feature": "self_limiting", "weight": 4 },
          { "feature": "no_focal_infection_signs", "weight": 3 }
        ],
        "management": "Chest physiotherapy, incentive spirometry, ambulation. Usually self-limiting. No antibiotics unless infection confirmed. Rule out urinary retention."
      },
      {
        "id": "middle_fever_48h_to_72h",
        "name": "Middle Fever (48-72 hours)",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "uti_if_catheterized", "weight": 5 },
          { "feature": "iv_line_infection", "weight": 4 },
          { "feature": "pneumonia_aspiration", "weight": 4 },
          { "feature": "surgical_site_infection_early", "weight": 3 }
        ],
        "management": "Urinalysis and culture, remove catheter if possible. Check IV sites for phlebitis. Chest X-ray. Wound inspection. Start empiric antibiotics if source identified."
      },
      {
        "id": "late_fever_72h",
        "name": "Late Fever (After 72 hours)",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "surgical_site_infection", "weight": 5 },
          { "feature": "anastomotic_leak", "weight": 5 },
          { "feature": "intra_abdominal_abscess", "weight": 5 },
          { "feature": "dvt_pe", "weight": 4 },
          { "feature": "drug_fever", "weight": 3 }
        ],
        "management": "Full septic workup: wound inspection, ultrasound/CT of abdomen, chest X-ray, urine culture, blood cultures, coagulation profile. Consider CT abdomen to exclude leak/abscess. Manage underlying cause."
      }
    ],

    "mimics": [
      {
