      { "signId": "pale_mucous_membranes", "baseWeight": 3 },
      { "signId": "cold_peripheries", "baseWeight": 3 },
      { "signId": "oliguria_anuria", "baseWeight": 4 },
      { "signId": "prolonged_capillary_refill", "baseWeight": 3 },
