{
  "disease": {
    "id": "postoperative_bleeding",
    "name": "Postoperative Hemorrhage",
    "system": "surgical",
    "agePeak_months": [],
    "note": "Bleeding occurring after surgery, classified by timing: reactionary (within 24h, often from slipped ligature or clot dislodgement) or secondary (after 24h, often from infection eroding vessel). Can be intraluminal or extra-luminal.",
    "prevalenceWeight": 0.05,
    "syndromeTags": ["postoperative_complication", "hemorrhage", "hypovolemic_shock"],

    "severityAssessment": {
