      { "id": "antiplatelet_therapy", "multiplier": 2.5 },
      { "id": "liver_cirrhosis", "multiplier": 2.5 },
      { "id": "complex_surgery", "multiplier": 2.0 },
      { "id": "emergency_surgery", "multiplier": 1.8 },
      { "id": "hypotension_during_surgery", "multiplier": 1.5 },
      { "id": "massive_blood_transfusion", "multiplier": 1.6 }
    ],

    "subtypes": [
      {
        "id": "reactionary_hemorrhage",
        "name": "Reactionary Hemorrhage (Early)",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
          { "feature": "onset_within_24h", "weight": 5 },
          { "feature": "slipped_ligature", "weight": 4 },
          { "feature": "clot_dislodgement", "weight": 4 },
          { "feature": "rapid_deterioration", "weight": 5 }
        ],
        "management": "Immediate assessment of drain output, vitals. Fluid resuscitation. Reversal of anticoagulation. Emergency re-exploration if hemodynamically unstable or ongoing hemorrhage."
      },
      {
        "id": "secondary_hemorrhage",
        "name": "Secondary Hemorrhage (Late)",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "onset_after_24h", "weight": 5 },
          { "feature": "wound_infection", "weight": 4 },
          { "feature": "erosion_of_vessel", "weight": 5 },
          { "feature": "sentinel_bleed", "weight": 4, "note": "Small bleed warning sign of impending massive hemorrhage" }
        ],
        "management": "Antibiotics for underlying infection. If sentinel bleed: urgent angiography or re-exploration. Often requires vessel ligation. Pack wound if necessary."
      }
    ],

    "mimics": [
      {
        "diseaseId": "anastomotic_leak",
        "discriminators": ["fever", "peritonitis", "elevated_crp", "drain_content_not_frank_blood"]
      },
