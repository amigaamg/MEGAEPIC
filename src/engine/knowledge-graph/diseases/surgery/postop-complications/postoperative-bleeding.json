      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Vital signs monitoring", "priority": "immediate", "yield": 0.9, "indication": "all patients for early decompensation" },
        { "name": "Drain output assessment", "priority": "immediate", "yield": 0.95, "indication": "drain in situ" },
        { "name": "Nasogastric tube aspirate", "priority": "immediate", "yield": 0.85, "indication": "suspected upper GI bleed" },
        { "name": "Urine output monitoring", "priority": "immediate", "yield": 0.8, "indication": "assess end-organ perfusion" }
      ],
      "laboratory": [
        { "name": "Full blood count", "priority": "immediate", "yield": 0.9, "indication": "Hb drop assessment" },
        { "name": "Coagulation profile (PT, aPTT, INR)", "priority": "immediate", "yield": 0.9, "indication": "coagulopathy screening" },
        { "name": "Cross-match blood", "priority": "immediate", "yield": 1.0, "indication": "in anticipation of transfusion" },
        { "name": "Lactate", "priority": "high", "yield": 0.7, "indication": "tissue hypoperfusion marker" },
        { "name": "Thromboelastography (TEG/ROTEM)", "priority": "medium", "yield": 0.85, "indication": "targeted coagulation management" }
      ],
      "imaging": [
        { "name": "CT Abdomen with IV contrast (arterial phase)", "priority": "high", "yield": 0.9, "indication": "hemodynamically stable; to locate bleeding source" },
        { "name": "CT Angiography", "priority": "high", "yield": 0.95, "indication": "active extravasation detection" },
        { "name": "Angiography with embolization", "priority": "medium", "yield": 0.9, "indication": "therapeutic diagnostic if stable" }
      ]
    },

    "management": {
      "protocolReference": "ATLS Massive Hemorrhage Protocol; WHO Surgical Safety Checklist",
      "pathways": [
        {
          "severity": "minor",
          "criteria": "stable vitals, Hb drop < 1 g/dL, minimal drain output",
          "treatment": "Conservative: IV fluids, close monitoring of vitals and Hb. If on anticoagulants, reverse appropriately. Consider tranexamic acid."
        },
        {
          "severity": "moderate",
          "criteria": "tachycardia, Hb drop 1-2 g/dL, drain bloody but no shock",
          "treatment": "IV fluids resuscitation. Type and cross-match. Reverse anticoagulation. CT angiography to locate source. Consider angioembolization."
        },
        {
          "severity": "severe",
          "criteria": "hypotension, Hb drop > 2 g/dL, frank blood from drain/wound, oliguria",
          "treatment": "Massive transfusion protocol. Emergency re-laparotomy. Surgical control of bleeding vessel. IV fluids + vasopressors. ICU admission."
        }
      ]
    },

    "pathophysiology": [
      "slipped_vascular_ligature",
