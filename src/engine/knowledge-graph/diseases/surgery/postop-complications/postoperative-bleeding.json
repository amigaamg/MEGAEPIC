        { "sign": "hypotension_refractory", "weight": 10 },
        { "sign": "cardiac_arrest", "weight": 10 },
        { "sign": "avpu_abnormal", "weight": 10 },
        { "sign": "massive_hematemesis", "weight": 10 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "tachycardia_persistent", "weight": 7 },
          { "sign": "falling_hemoglobin_drop_2gdl", "weight": 8 },
          { "sign": "oliguria", "weight": 7 },
          { "sign": "drain_bleeding_frank", "weight": 7 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If shock/refractory hypotension/frank drain blood -> SEVERE; else -> NON-SEVERE (minor ooze, stable vitals)"
    },

