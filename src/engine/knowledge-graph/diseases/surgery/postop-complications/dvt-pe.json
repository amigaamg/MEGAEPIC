    "management": {
      "protocolReference": "NICE Guidelines [NG158] for VTE Prevention and Management; ESC Guidelines for PE",
      "pathways": [
        {
          "severity": "low_risk_pe_dvt_only",
          "criteria": "hemodynamically stable, no RV strain, DVT alone or low-risk PE (PESI Class I-II)",
          "treatment": "LMWH (e.g., Enoxaparin 1.5 mg/kg daily) or Fondaparinux. Bridge to DOAC (Rivaroxaban 15 mg BD for 21 days then 20 mg OD) or Warfarin (target INR 2-3). Compression stockings for DVT. Early ambulation."
        },
        {
          "severity": "intermediate_risk_pe",
          "criteria": "hemodynamically stable but RV dysfunction on echo/CT, elevated troponin",
          "treatment": "Therapeutic anticoagulation as above. Close monitoring in HDU. Consider thrombolysis if deterioration."
        },
        {
          "severity": "high_risk_massive_pe",
          "criteria": "hypotension, shock, cardiac arrest, severe hypoxia",
          "treatment": "Resuscitation. IV fluids cautiously. Thrombolysis (Alteplase 100 mg IV over 2h). Embolectomy (catheter-based or surgical) if contraindication/failure of thrombolysis. ICU. IVC filter if anticoagulation contraindicated."
        }
      ]
    },

