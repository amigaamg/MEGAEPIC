          { "feature": "pain_increasing", "weight": 4 },
          { "feature": "no_peritonitis", "weight": 4 }
        ],
        "management": "Emergency repair. Attempt gentle reduction under sedation. If fails, open or laparoscopic exploration with bowel viability assessment. Resection if non-viable."
      },
      {
        "id": "strangulated_femoral_hernia",
        "name": "Strangulated Femoral Hernia",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
