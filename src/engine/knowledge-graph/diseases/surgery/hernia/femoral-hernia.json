          { "feature": "cough_impulse_present", "weight": 4 },
          { "feature": "no_pain", "weight": 4 }
        ],
        "management": "Elective repair (McVay or mesh repair). All femoral hernias should be repaired due to high strangulation risk."
      },
      {
        "id": "incarcerated_femoral_hernia",
        "name": "Incarcerated Femoral Hernia",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
