          { "feature": "signs_of_obstruction", "weight": 5 },
          { "feature": "peritonitis", "weight": 5 },
          { "feature": "lactic_acidosis", "weight": 4 }
        ],
        "management": "Emergency laparotomy/laparoscopy. Bowel resection if non-viable. Hernia repair (primary or mesh depending on contamination)."
      }
    ],

    "mimics": [
