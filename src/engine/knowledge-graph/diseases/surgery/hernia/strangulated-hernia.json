      "pathways": [
        {
          "severity": "strangulated without peritonitis",
          "criteria": "irreducible tender mass, no generalized peritonitis, early presentation",
          "treatment": "Emergency surgery. Attempt reduction. Assess bowel viability. Warm saline-soaked packs. If viable, repair with mesh. If non-viable, resect and primary tissue repair."
        },
