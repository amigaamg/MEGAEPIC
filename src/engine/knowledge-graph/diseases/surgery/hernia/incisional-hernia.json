      { "id": "chronic_cough_constipation", "multiplier": 1.5 }
    ],

    "subtypes": [
      {
        "id": "small_incisional_hernia",
        "name": "Small Incisional Hernia (<4cm)",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "defect_less_than_4cm", "weight": 5 },
          { "feature": "reducible", "weight": 4 },
          { "feature": "minimal_symptoms", "weight": 3 }
        ],
        "management": "Elective repair. Primary closure possible for very small defects. Mesh repair (onlay or sublay) recommended for all to reduce recurrence."
      },
      {
        "id": "large_complex_incisional_hernia",
        "name": "Large/Complex Incisional Hernia (>=4cm)",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
          { "feature": "defect_4cm_or_more", "weight": 5 },
          { "feature": "may_contain_multiple_organs", "weight": 4 },
          { "feature": "loss_of_domain", "weight": 5 },
          { "feature": "chronic_pain_distension", "weight": 3 }
        ],
        "management": "Elective repair with mesh (sublay or underlay preferred). Component separation for large defects. Pre-operative optimization (weight loss, smoking cessation). Botulinum toxin or progressive pneumoperitoneum for loss of domain. Emergency surgery if complicated."
      }
    ],

    "mimics": [
      {
        "diseaseId": "rectus_diastasis",
        "discriminators": ["midline_bulge_no_defect", "no_fascial_ring", "reduces_on_lying", "no_cough_impulse"]
      },
      {
        "diseaseId": "post_surgical_seroma",
        "discriminators": ["fluctuant", "no_cough_impulse", "history_of_recent_surgery", "ultrasound_confirms_fluid"]
      },
      {
        "diseaseId": "suture_granuloma",
        "discriminators": ["small_fixed_lump", "no_reduction", "no_cough_impulse", "local_inflammation"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Assess fascial defect", "priority": "high", "yield": 0.6, "indication": "measure size and reducibility" }
      ],
      "laboratory": [
        { "name": "WBC", "priority": "medium", "yield": 0.4, "indication": "if strangulation suspected" }
      ],
      "imaging": [
        { "name": "Abdominal Ultrasound", "priority": "high", "yield": 0.85, "indication": "defect size, contents, vascularity" },
        { "name": "CT Abdomen/Pelvis", "priority": "high", "yield": 0.95, "indication": "gold standard for complex hernias, loss of domain assessment" },
        { "name": "MRI", "priority": "medium", "yield": 0.8, "indication": "alternative if CT contraindicated" }
      ]
    },

    "management": {
      "protocolReference": "International Endohernia Society Guidelines for Incisional Hernia",
      "pathways": [
        {
          "severity": "elective small-medium",
          "criteria": "defect <10cm, no loss of domain, reducible",
          "treatment": "Mesh repair (open sublay, onlay, or laparoscopic IPOM). Component separation if rectus cannot be approximated. Elective surgery after optimization."
        },
        {
          "severity": "elective large/complex",
          "criteria": "defect >=10cm, loss of domain, multiple recurrences",
          "treatment": "Pre-operative optimization (weight loss, smoking cessation, diabetes control). Botulinum toxin A injections to abdominal wall muscles. Progressive pneumoperitoneum. Component separation with mesh reinforcement (sublay or TAR)."
        },
        {
          "severity": "emergency",
          "criteria": "incarceration, strangulation, obstruction",
          "treatment": "Emergency surgery. Bowel resection if non-viable. Mesh repair if clean-contaminated; primary repair if contaminated. Damage control surgery if required."
        }
      ]
    },

    "pathophysiology": [
      "failed_fascial_healing",
      "wound_dehiscence",
      "fascial_margin_separation",
      "increased_intra_abdominal_pressure",
      "herniation_through_scar",
      "progressive_enlargement",
      "incarceration",
