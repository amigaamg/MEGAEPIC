    "name": "Incisional Hernia",
    "system": "surgical",
    "agePeak_months": [360, 720],
    "note": "Herniation through a previous surgical incision. Most common long-term complication of abdominal surgery. Risk of incarceration and strangulation.",
    "prevalenceWeight": 0.3,
    "syndromeTags": ["abdominal_wall_mass", "previous_surgery", "hernia"],

