      { "signId": "cough_impulse", "baseWeight": 4 },
      { "signId": "defect_size_fascial_gap", "baseWeight": 4 },
      { "signId": "reducibility", "baseWeight": 3 },
      { "signId": "irreducibility_tenderness", "baseWeight": 4 },
      { "signId": "overlying_skin_changes", "baseWeight": 2 },
