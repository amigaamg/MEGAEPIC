          { "sign": "large_defect_with_domino_effect", "weight": 6 },
          { "sign": "skin_ulceration_ischemia", "weight": 7 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
