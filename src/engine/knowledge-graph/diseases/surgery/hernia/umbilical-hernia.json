          { "feature": "associated_with_obesity", "weight": 4 },
          { "feature": "may_contain_omentum_or_bowel", "weight": 4 },
          { "feature": "risk_of_incarceration", "weight": 3 }
        ],
        "management": "Elective surgical repair (open or laparoscopic). Small defects (<2cm): primary sutured repair (Mayo or simple closure). Larger defects (>2cm): mesh repair (onlay, sublay, or IPOM). Emergency repair if incarcerated/strangulated."
      }
    ],

    "mimics": [
