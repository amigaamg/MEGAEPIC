    "management": {
      "protocolReference": "International Endohernia Society Guidelines for Umbilical Hernia",
      "pathways": [
        {
          "severity": "infantile",
          "criteria": "age <5 years, reducible, asymptomatic",
          "treatment": "Observation. Most close by age 4-5. Repair if persists beyond age 5, enlarges, or becomes symptomatic."
        },
        {
          "severity": "adult elective",
          "criteria": "reducible, symptomatic or enlarging",
          "treatment": "Elective repair. Small defect (<2cm): Mayo repair or primary closure. Large defect: mesh repair (open onlay/sublay or laparoscopic IPOM)."
