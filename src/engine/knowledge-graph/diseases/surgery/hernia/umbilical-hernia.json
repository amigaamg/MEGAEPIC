        "id": "infantile_umbilical_hernia",
        "name": "Infantile Umbilical Hernia",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "present_by_age_1", "weight": 5 },
          { "feature": "reducible", "weight": 5 },
          { "feature": "defect_small", "weight": 3 },
          { "feature": "usually_spontaneously_resolves", "weight": 4 }
        ],
        "management": "Observe until age 4-5 years. Majority close spontaneously. Surgical repair if persists beyond age 5, enlarges, or becomes symptomatic. Small defects may be repaired earlier."
      },
      {
        "id": "adult_umbilical_hernia",
        "name": "Adult Umbilical Hernia",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
