        {
          "severity": "emergency",
          "criteria": "incarceration, strangulation, obstruction",
          "treatment": "Emergency repair. Assess bowel viability. Resection if non-viable. Mesh may be avoided if contamination present. Primary repair in contaminated field."
        }
      ]
