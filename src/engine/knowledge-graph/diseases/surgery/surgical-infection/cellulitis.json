    ],

    "subtypes": [
      {
        "id": "mild_cellulitis",
        "name": "Mild Localized Cellulitis",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
          { "feature": "localized_erythema_small_area", "weight": 5 },
          { "feature": "no_systemic_symptoms", "weight": 5 },
          { "feature": "no_comorbidities", "weight": 4 }
        ],
        "management": "Oral antibiotics (Flucloxacillin 500mg QID or Cephalexin 500mg QID). Elevation of affected limb. Analgesia. Review in 48h."
      },
      {
        "id": "severe_cellulitis",
        "name": "Severe/Systemic Cellulitis",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "extensive_rapid_spread", "weight": 5 },
          { "feature": "systemic_symptoms_fever", "weight": 5 },
          { "feature": "comorbidities", "weight": 4 },
          { "feature": "failed_oral_antibiotics", "weight": 4 }
        ],
        "management": "Admit. IV antibiotics (Flucloxacillin 2g QDS +/- Benzylpenicillin + Clindamycin for Strep). Mark erythema border. Elevation. Monitor for abscess formation. Surgical debridement if suspected necrotizing fasciitis."
      }
    ],

    "mimics": [
      {
        "diseaseId": "necrotizing_fasciitis",
        "discriminators": ["rapid_progression", "severe_pain_out_of_proportion", "systemic_toxicity", "crepitus", "bullae_hemorrhagic"]
      },
