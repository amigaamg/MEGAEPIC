        "diseaseId": "deep_vein_thrombosis",
        "discriminators": ["no_erythema_warmth", "no_fever", "positive_doppler", "homans_sign"]
      },
      {
        "diseaseId": "stasis_dermatitis",
        "discriminators": ["bilateral", "chronic", "no_fever", "varicose_veins", "brownish_pigmentation"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Mark erythema border", "priority": "immediate", "yield": 0.5, "indication": "monitor spread" }
      ],
      "laboratory": [
        { "name": "WBC count", "priority": "high", "yield": 0.5, "indication": "may be elevated" },
        { "name": "CRP", "priority": "high", "yield": 0.7, "indication": "elevated" },
        { "name": "Blood cultures", "priority": "medium", "yield": 0.2, "indication": "if febrile or immunocompromised" },
        { "name": "Lactate", "priority": "medium", "yield": 0.4, "indication": "if sepsis suspected" }
      ],
      "imaging": [
        { "name": "Ultrasound soft tissue", "priority": "medium", "yield": 0.5, "indication": "rule out abscess or DVT" },
        { "name": "CT/MRI", "priority": "low", "yield": 0.6, "indication": "if necrotizing fasciitis suspected" }
      ]
    },

    "management": {
      "protocolReference": "IDSA Guidelines for Skin and Soft Tissue Infections",
      "pathways": [
        {
          "severity": "mild",
          "criteria": "small area, afebrile, no comorbidities",
          "treatment": "Oral antibiotics (Flucloxacillin or Cephalexin). Limb elevation. Review in 48h."
        },
        {
          "severity": "moderate-severe",
          "criteria": "extensive, febrile, comorbidities, failed oral therapy",
          "treatment": "IV antibiotics (Flucloxacillin 2g QDS +/- Clindamycin). Mark spreading edge. Blood cultures. Daily review. Switch to oral when improving."
        }
      ]
    },

    "pathophysiology": [
