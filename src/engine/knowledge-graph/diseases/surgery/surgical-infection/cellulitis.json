      { "signId": "blistering_or_bullae", "baseWeight": 3 },
      { "signId": "lymphangitic_streaks", "baseWeight": 3 },
      { "signId": "regional_lymphadenopathy", "baseWeight": 3 },
      { "signId": "fever_tachycardia", "baseWeight": 3 },
