    "management": {
      "protocolReference": "Surviving Sepsis Campaign Guidelines",
      "pathways": [
        {
          "severity": "sepsis",
          "criteria": "suspected infection, qSOFA >=2, lactate >2, no refractory hypotension",
          "treatment": "IV antibiotics within 1h. Source control (drainage, debridement). 30mL/kg crystalloid. Lactate monitoring. ICU. Blood cultures before antibiotics if no delay."
        },
        {
          "severity": "septic shock",
          "criteria": "hypotension requiring vasopressors, lactate >2 after fluids, organ failure",
          "treatment": "ICU. IV antibiotics within 1h. Source control. Aggressive fluids. Norepinephrine. Steroids (Hydrocortisone 200mg/day). Organ support. Tight glucose. DVT and stress ulcer prophylaxis."
        }
      ]
    },

