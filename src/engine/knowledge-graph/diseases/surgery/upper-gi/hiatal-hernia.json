        { "sign": "incarceration", "weight": 9 },
        { "sign": "avpu_abnormal", "weight": 10 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "chest_pain_severe", "weight": 7 },
          { "sign": "dysphagia_complete", "weight": 6 },
          { "sign": "bleeding_anemia", "weight": 6 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "Incarcerated/strangulated/volvulus -> SEVERE; sliding hernia without complication -> NON-SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "heartburn", "weight": 4 },
      { "symptomId": "regurgitation", "weight": 3 },
      { "symptomId": "dysphagia", "weight": 3 },
      { "symptomId": "epigastric_or_retrosternal_pain", "weight": 3 },
      { "symptomId": "postprandial_fullness", "weight": 3 },
      { "symptomId": "shortness_of_breath", "weight": 2, "note": "Postprandial from compression of diaphragm" },
      { "symptomId": "iron_deficiency_anemia", "weight": 2, "note": "From Cameron ulcers in paraesophageal hernia" }
    ],

    "examFeatures": [
      { "signId": "epigastric_tenderness", "baseWeight": 2 },
      { "signId": "pallor", "baseWeight": 2, "note": "If anemic" },
      { "signId": "chest_auscultation_decreased_breath_sounds", "baseWeight": 1 },
      { "signId": "signs_of_strangulation", "baseWeight": 5, "note": "In incarcerated paraesophageal hernia" }
    ],

    "riskFactors": [
      { "id": "obesity", "multiplier": 2.5 },
      { "id": "age_over_50", "multiplier": 2.0 },
      { "id": "pregnancy", "multiplier": 1.8 },
      { "id": "chronic_constipation", "multiplier": 1.3 },
      { "id": "chronic_cough", "multiplier": 1.3 },
      { "id": "heavy_lifting", "multiplier": 1.2 }
    ],

    "subtypes": [
      {
        "id": "type_i_sliding_hernia",
        "name": "Type I (Sliding) Hiatal Hernia",
        "prevalenceModifier": 0.85,
        "keyFeatures": [
          { "feature": "gej_above_diaphragm", "weight": 5 },
          { "feature": "reflux_symptoms", "weight": 5 },
          { "feature": "reducible", "weight": 4 }
        ],
        "management": "Lifestyle modification (weight loss, avoid large meals). PPI therapy. Laparoscopic fundoplication (Nissen or Toupet) if refractory to medical therapy."
      },
      {
        "id": "type_ii_iii_iv_paraesophageal",
        "name": "Types II-IV (Paraesophageal) Hiatal Hernia",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "gej_in_normal_position", "weight": 3 },
          { "feature": "stomach_herniated_into_chest", "weight": 5 },
          { "feature": "risk_of_volvulus", "weight": 5 },
          { "feature": "postprandial_fullness_dyspnea", "weight": 4 }
        ],
        "management": "Surgical repair recommended for all symptomatic paraesophageal hernias. Laparoscopic hernia reduction, sac excision, crural repair with mesh, and fundoplication. Emergency surgery if acute gastric volvulus."
      }
    ],

    "mimics": [
      {
        "diseaseId": "angina_pectoris",
        "discriminators": ["ecg_changes", "cardiac_enzymes", "exertional_chest_pain", "normal_endoscopy"]
      },
      {
        "diseaseId": "peptic_ulcer_disease",
        "discriminators": ["epigastric_pain_not_retrosternal", "pain_relieved_by_food", "h_pylori_positive"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "ECG", "priority": "medium", "yield": 0.2, "indication": "rule out cardiac cause of chest pain" }
      ],
      "laboratory": [
        { "name": "CBC", "priority": "medium", "yield": 0.3, "indication": "anemia from Cameron ulcers" },
        { "name": "Iron studies", "priority": "low", "yield": 0.2, "indication": "iron deficiency from chronic blood loss" }
      ],
      "imaging": [
        { "name": "Barium Swallow", "priority": "high", "yield": 0.9, "indication": "best for demonstrating hernia anatomy" },
        { "name": "Upper GI Endoscopy (EGD)", "priority": "high", "yield": 0.85, "indication": "assess mucosa, Cameron ulcers, esophagitis" },
        { "name": "CT Chest/Abdomen", "priority": "medium", "yield": 0.8, "indication": "assess for complications, volvulus" },
        { "name": "Esophageal Manometry", "priority": "medium", "yield": 0.5, "indication": "pre-operative assessment" }
      ]
    },

    "management": {
      "protocolReference": "SAGES Guidelines for Hiatal Hernia Management",
      "pathways": [
        {
          "severity": "non-severe (sliding)",
          "criteria": "reflux symptoms, small sliding hernia, no complications",
          "treatment": "PPI therapy. Lifestyle modification (weight loss, head of bed elevation, avoid large meals). Laparoscopic fundoplication for PPI-refractory GERD."
        },
        {
          "severity": "severe (paraesophageal)",
          "criteria": "symptomatic paraesophageal hernia, incarceration, volvulus",
          "treatment": "Emergency surgery if acute (gastric volvulus, strangulation). Elective laparoscopic repair: hernia reduction, sac excision, crural repair, fundoplication. ICU for acute cases."
        }
      ]
    },

    "pathophysiology": [
      "widening_of_esophageal_hiatus",
      "weakening_of_phrenoesophageal_ligament",
      "herniation_of_abdominal_contents",
      "loss_of_anti_reflux_barrier",
      "gastroesophageal_reflux",
      "potential_for_volvulus_and_strangulation"
    ],

    "complications": [
