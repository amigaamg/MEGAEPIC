        { "name": "CT Abdomen with IV + oral contrast", "priority": "high", "yield": 0.9, "indication": "identify malignant cause, assess extent" },
        { "name": "Upper GI barium meal", "priority": "medium", "yield": 0.8, "indication": "demonstrate obstruction level" }
      ]
    },

    "management": {
      "protocolReference": "ASGE Guidelines for Gastric Outlet Obstruction",
      "pathways": [
        {
          "severity": "benign partial obstruction",
          "criteria": "peptic ulcer etiology, no malignancy, partial obstruction",
          "treatment": "Decompression with NG tube. IV fluids with KCl and electrolyte correction. IV PPI. Endoscopic balloon dilatation. H. pylori eradication. Surgical drainage if fails."
