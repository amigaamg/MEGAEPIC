    "subtypes": [
      {
        "id": "benign_goo",
        "name": "Benign Gastric Outlet Obstruction",
        "prevalenceModifier": 0.5,
        "keyFeatures": [
          { "feature": "history_of_peptic_ulcer", "weight": 5 },
          { "feature": "chronic_progressive_vomiting", "weight": 5 },
          { "feature": "succussion_splash", "weight": 5 },
          { "feature": "no_weight_loss_severe", "weight": 3 }
        ],
        "management": "NG tube decompression. Correction of dehydration and electrolyte imbalance (IV fluids + KCl). IV PPI. Balloon dilatation or surgical drainage (pyloroplasty, GJ). H. pylori eradication."
      },
      {
        "id": "malignant_goo",
        "name": "Malignant Gastric Outlet Obstruction",
        "prevalenceModifier": 0.5,
        "keyFeatures": [
