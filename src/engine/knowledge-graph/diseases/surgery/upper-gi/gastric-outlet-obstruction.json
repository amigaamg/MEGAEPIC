          { "feature": "palpable_epigastric_mass", "weight": 4 },
          { "feature": "older_age", "weight": 4 },
          { "feature": "anorexia_early_satiety", "weight": 4 }
        ],
        "management": "Staging CT. Palliative gastrojejunostomy (open or laparoscopic). Self-expanding metallic stent (SEMS) for inoperable cases. Chemotherapy if metastatic."
      }
    ],

    "mimics": [
