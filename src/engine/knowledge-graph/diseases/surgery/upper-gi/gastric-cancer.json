    "management": {
      "protocolReference": "NCCN Guidelines for Gastric Cancer",
      "pathways": [
        {
          "severity": "early stage (T1-T2, N0)",
          "criteria": "early gastric cancer, confined to mucosa/submucosa, no node involvement",
          "treatment": "Endoscopic mucosal resection (EMR) or endoscopic submucosal dissection (ESD) for select cases. Otherwise gastrectomy with D1 lymphadenectomy."
        },
        {
          "severity": "locally advanced (T2-T4, N+)",
          "criteria": "invasion beyond submucosa, node positive, no metastases",
          "treatment": "Perioperative chemotherapy (FLOT: 5-FU, Leucovorin, Oxaliplatin, Docetaxel). Total/subtotal gastrectomy with D2 lymphadenectomy."
        },
        {
          "severity": "metastatic (M1)",
          "criteria": "distant metastases, peritoneal carcinomatosis",
          "treatment": "Palliative chemotherapy. Palliative surgery for obstruction/bleeding. Palliative radiotherapy. Best supportive care."
        }
      ]
    },

