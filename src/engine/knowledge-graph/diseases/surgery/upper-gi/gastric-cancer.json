        { "name": "CBC", "priority": "high", "yield": 0.5, "indication": "anemia from chronic blood loss" },
        { "name": "LFTs", "priority": "high", "yield": 0.4, "indication": "elevated ALP suggests liver metastases" },
        { "name": "Tumor markers (CEA, CA19-9)", "priority": "medium", "yield": 0.5, "indication": "monitoring response, not diagnostic" },
