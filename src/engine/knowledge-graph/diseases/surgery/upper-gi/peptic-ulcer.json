        { "name": "NG tube aspirate", "priority": "immediate", "yield": 0.6, "indication": "if suspected upper GI bleed" }
      ],
      "laboratory": [
        { "name": "H. pylori testing (stool Ag or breath test)", "priority": "high", "yield": 0.9, "indication": "detect H. pylori infection" },
        { "name": "CBC", "priority": "high", "yield": 0.5, "indication": "assess anemia from chronic bleeding" },
        { "name": "Hemoglobin", "priority": "high", "yield": 0.6, "indication": "acute bleeding assessment" }
      ],
      "imaging": [
        { "name": "Upper GI Endoscopy (EGD)", "priority": "high", "yield": 0.95, "indication": "gold standard for diagnosis and biopsy" },
        { "name": "Barium swallow/meal", "priority": "low", "yield": 0.6, "indication": "alternative when endoscopy unavailable" }
      ]
    },

    "management": {
      "protocolReference": "ACG Clinical Guideline for Peptic Ulcer Disease",
      "pathways": [
        {
          "severity": "uncomplicated",
          "criteria": "no bleeding, no perforation, no obstruction",
          "treatment": "PPI therapy (Omeprazole 20mg daily for 4-8 weeks). H. pylori eradication therapy. Stop NSAIDs. Lifestyle modification."
        },
        {
          "severity": "bleeding ulcer",
          "criteria": "hematemesis, melena, hemoglobin drop, active bleeding on endoscopy",
          "treatment": "Resuscitation. Urgent EGD with endoscopic hemostasis (clips, adrenaline injection, thermal). IV PPI (high dose). Surgical intervention if endoscopic control fails."
        },
        {
          "severity": "perforated",
          "criteria": "acute severe pain, peritonitis, pneumoperitoneum",
          "treatment": "Emergency laparotomy. Omental patch repair (Graham patch). IV PPI. IV antibiotics."
        }
      ]
    },

    "pathophysiology": [
