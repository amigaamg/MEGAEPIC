    ],

    "subtypes": [
      {
        "id": "obstruction_due_to_cancer",
        "name": "Malignant Large Bowel Obstruction",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
          { "feature": "progressive_constipation", "weight": 5 },
          { "feature": "weight_loss", "weight": 4 },
          { "feature": "rectal_bleeding", "weight": 3 },
          { "feature": "palpable_abdominal_mass", "weight": 3 }
        ],
        "management": "Staging CT. Self-expanding metallic stent (SEMS) as bridge to surgery or palliation. Elective resection with primary anastomosis after decompression. Emergency surgery if perforation or failed stenting."
      },
      {
        "id": "pseudo_obstruction_ogilvies",
        "name": "Acute Colonic Pseudo-Obstruction (Ogilvie's)",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "massive_distension", "weight": 5 },
          { "feature": "no_mechanical_cause", "weight": 5 },
          { "feature": "hospitalized_elderly", "weight": 4 },
          { "feature": "recent_surgery_or_illness", "weight": 3 }
        ],
        "management": "Conservative: NBM, NG tube, rectal tube, correct electrolytes. Neostigmine (IV) if no improvement. Colonoscopic decompression. Surgical decompression if failed."
      }
    ],

    "mimics": [
      {
        "diseaseId": "small_bowel_obstruction",
        "discriminators": ["central_colicky_pain", "early_vomiting", "mild_distension", "air_fluid_levels_in_jejunum_ileum"]
      },
      {
        "diseaseId": "severe_constipation",
        "discriminators": ["passes_flatus", "no_pain", "distension_less", "responds_to_enemas"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Rectal exam", "priority": "immediate", "yield": 0.4, "indication": "palpate tumor, impaction" }
      ],
      "laboratory": [
        { "name": "Electrolytes", "priority": "high", "yield": 0.6, "indication": "dehydration assessment" },
        { "name": "Lactate", "priority": "high", "yield": 0.7, "indication": "ischemia marker" },
        { "name": "WBC count", "priority": "high", "yield": 0.6, "indication": "leukocytosis with strangulation" }
      ],
      "imaging": [
        { "name": "Abdominal X-Ray supine + erect", "priority": "immediate", "yield": 0.8, "indication": "dilated colon, haustra visible" },
        { "name": "CT Abdomen with IV contrast", "priority": "high", "yield": 0.95, "indication": "identify cause, site, and degree" },
        { "name": "Water-soluble contrast enema", "priority": "medium", "yield": 0.7, "indication": "if CT inconclusive" }
      ]
    },

    "management": {
      "protocolReference": "ASCRS Guidelines for Large Bowel Obstruction",
      "pathways": [
        {
          "severity": "non-severe",
          "criteria": "no peritonitis, no ischemia, no perforation",
          "treatment": "NBM, NG tube, IV fluids. SEMS for left-sided malignant obstruction. Elective single-stage resection. For pseudo-obstruction: conservative + Neostigmine."
        },
        {
          "severity": "severe",
          "criteria": "peritonitis, ischemia, perforation, cecal dilation >12cm",
          "treatment": "Emergency laparotomy. Resection with end colostomy (Hartmann) or primary anastomosis with covering stoma. IV antibiotics. ICU."
        }
      ]
    },

    "pathophysiology": [
