        { "sign": "colonic_perforation", "weight": 10 },
        { "sign": "avpu_abnormal", "weight": 10 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "cecal_dilation_more_than_12cm", "weight": 9 },
          { "sign": "lactate_elevated", "weight": 7 },
          { "sign": "signs_of_strangulation", "weight": 8 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "Perforation/ischemia/shock -> SEVERE; simple obstruction -> NON-SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "abdominal_distension", "weight": 5 },
      { "symptomId": "absolute_constipation", "weight": 5, "note": "No stool or flatus" },
      { "symptomId": "colicky_abdominal_pain", "weight": 4 },
      { "symptomId": "vomiting", "weight": 3, "note": "Late and often feculent" },
      { "symptomId": "weight_loss", "weight": 3, "note": "Suggests malignancy" },
      { "symptomId": "change_in_bowel_habit", "weight": 3, "note": "Prior to complete obstruction" },
      { "symptomId": "rectal_bleeding", "weight": 3, "note": "Suggests colorectal cancer" }
    ],

    "examFeatures": [
      { "signId": "massive_abdominal_distension", "baseWeight": 5, "doubleWeight": true },
      { "signId": "tympanic_percussion", "baseWeight": 4 },
      { "signId": "high_pitched_or_absent_bowel_sounds", "baseWeight": 4 },
      { "signId": "palpable_mass", "baseWeight": 3 },
      { "signId": "guarding_rigidity", "baseWeight": 3 },
      { "signId": "rectal_exam_reveals_tumor_or_impaction", "baseWeight": 4 },
