    "name": "Colorectal Bowel Obstruction",
    "system": "surgical",
    "agePeak_months": [480, 960],
    "note": "Mechanical obstruction of the large bowel. Most common causes: cancer, diverticulitis, volvulus. Presents with distension, constipation, and late vomiting.",
    "prevalenceWeight": 0.4,
    "syndromeTags": ["bowel_obstruction", "abdominal_distension", "constipation"],

