    "name": "Anal Fissure",
    "system": "surgical",
    "agePeak_months": [180, 480],
    "note": "Longitudinal tear in the anal canal distal to dentate line. Severe pain on defecation and bright red bleeding.",
    "prevalenceWeight": 0.35,
    "syndromeTags": ["anal_pain", "rectal_bleeding", "constipation"],

    "severityAssessment": {
