        "diseaseId": "perianal_abscess",
        "probability": 0.02,
        "lagDays": [3, 14],
        "severityBoost": 0.3,
        "clues": ["increasing_pain", "swelling", "fever"]
      }
    ],

    "mustNotMiss": false,
