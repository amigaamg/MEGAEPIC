        "id": "ibd_related_megacolon",
        "name": "Toxic Megacolon in IBD",
        "prevalenceModifier": 0.85,
        "keyFeatures": [
          { "feature": "history_of_ibd", "weight": 5 },
          { "feature": "colonic_dilation_greater_than_6cm", "weight": 5 },
          { "feature": "systemic_toxicity", "weight": 5 }
        ],
        "management": "Urgent colectomy. Total abdominal colectomy with end ileostomy. IV steroids. IV antibiotics. ICU care."
      },
      {
        "id": "infectious_megacolon",
        "name": "Infectious Toxic Megacolon",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "c_difficile_infection", "weight": 5 },
          { "feature": "recent_antibiotic_use", "weight": 4 },
          { "feature": "diarrhea_before_dilation", "weight": 4 }
        ],
        "management": "Antibiotics for C. difficile (Vancomycin + Metronidazole). Urgent colectomy if medical therapy fails. IV fluids. ICU."
      }
    ],

    "mimics": [
      {
        "diseaseId": "simple_colonic_dilation",
        "discriminators": ["no_systemic_toxicity", "no_ibd_history", "resolves_with_conservative_management"]
      },
      {
        "diseaseId": "bowel_obstruction",
        "discriminators": ["colicky_pain", "vomiting_early", "high_pitched_bowel_sounds", "no_ibd_history"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Abdominal X-Ray supine + erect", "priority": "immediate", "yield": 0.85, "indication": "colonic diameter >6cm, thumbprinting" },
        { "name": "qSOFA score", "priority": "immediate", "yield": 0.7, "indication": "assess sepsis severity" }
      ],
      "laboratory": [
        { "name": "WBC count", "priority": "immediate", "yield": 0.8, "indication": "leukocytosis or leukopenia" },
        { "name": "CRP", "priority": "immediate", "yield": 0.85, "indication": "markedly elevated" },
        { "name": "Lactate", "priority": "high", "yield": 0.7, "indication": "tissue hypoperfusion" },
        { "name": "Electrolytes", "priority": "high", "yield": 0.6, "indication": "electrolyte imbalance" },
        { "name": "Blood cultures", "priority": "high", "yield": 0.4, "indication": "guide antibiotics" },
        { "name": "Stool C. diff toxin", "priority": "high", "yield": 0.5, "indication": "rule out C. diff" }
      ],
      "imaging": [
        { "name": "Abdominal X-Ray", "priority": "immediate", "yield": 0.85, "indication": "monitor colonic diameter" },
        { "name": "CT Abdomen with IV contrast", "priority": "high", "yield": 0.9, "indication": "assess for perforation, colonic wall status" }
      ]
    },

    "management": {
      "protocolReference": "ASCRS Guidelines for Toxic Megacolon",
      "pathways": [
        {
          "severity": "fulminant without perforation",
          "criteria": "colonic dilation >6cm, systemic toxicity, no peritonitis",
          "treatment": "ICU admission. NBM, NG tube, rectal tube. IV fluids. IV steroids (Hydrocortisone 100mg QID). IV antibiotics. Close monitoring. If no improvement in 24-48h, urgent colectomy."
        },
        {
          "severity": "perforation or peritonitis",
          "criteria": "pneumoperitoneum, peritonitis, septic shock",
          "treatment": "Emergency laparotomy. Total abdominal colectomy with end ileostomy. Peritoneal lavage. IV broad-spectrum antibiotics. ICU. Vasopressors."
        }
      ]
    },

    "pathophysiology": [
      "severe_colonic_inflammation",
      "loss_of_colonic_motility",
      "colonic_dilation",
      "increased_intraluminal_pressure",
      "compromised_colonic_blood_flow",
      "mucosal_ischemia",
      "bacterial_translocation",
      "sepsis",
