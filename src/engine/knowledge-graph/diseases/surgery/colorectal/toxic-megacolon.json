      { "symptomId": "bloody_diarrhea_or_decreased_output", "weight": 4, "note": "Diarrhea may decrease as dilation worsens" },
      { "symptomId": "fever_rigors", "weight": 5 },
      { "symptomId": "recent_withdrawal_of_steroids_or_5_asa", "weight": 3, "note": "Precipitating factor" },
      { "symptomId": "recent_use_of_anticholinergics_or_opioids", "weight": 3, "note": "Can precipitate megacolon" }
    ],

    "examFeatures": [
      { "signId": "massive_abdominal_distension", "baseWeight": 5, "doubleWeight": true },
      { "signId": "tympanic_percussion", "baseWeight": 4 },
      { "signId": "absent_bowel_sounds", "baseWeight": 4 },
      { "signId": "guarding_rigidity", "baseWeight": 4 },
      { "signId": "tachycardia", "baseWeight": 5 },
      { "signId": "fever", "baseWeight": 5 },
      { "signId": "hypotension", "baseWeight": 4 },
