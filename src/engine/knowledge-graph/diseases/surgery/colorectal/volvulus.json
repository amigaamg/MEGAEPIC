      "pathways": [
        {
          "severity": "non-severe",
          "criteria": "no peritonitis, no ischemia, sigmoid volvulus",
          "treatment": "Endoscopic detorsion + rectal tube. Elective sigmoid resection during same admission with primary anastomosis."
        },
        {
          "severity": "severe",
          "criteria": "peritonitis, gangrene, failed endoscopic reduction, cecal volvulus",
          "treatment": "Emergency laparotomy. Resection of non-viable bowel. Hartmann procedure for sigmoid. Right hemicolectomy for cecal. ICU care."
