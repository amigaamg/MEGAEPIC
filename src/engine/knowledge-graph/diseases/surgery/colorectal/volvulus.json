          { "feature": "coffee_bean_sign", "weight": 5 },
          { "feature": "previous_episodes", "weight": 4 }
        ],
        "management": "Endoscopic detorsion (flexible sigmoidoscopy) + rectal tube. Elective sigmoid resection in same admission. Emergency surgery if peritonitis or failed endoscopic reduction."
      },
      {
        "id": "cecal_volvulus",
        "name": "Cecal Volvulus",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
          { "feature": "right_lower_quadrant_pain", "weight": 5 },
          { "feature": "distension_less_marked", "weight": 4 },
          { "feature": "early_vomiting", "weight": 3 },
          { "feature": "cecal_bubble_on_xray", "weight": 4 }
        ],
        "management": "Emergency laparotomy. Right hemicolectomy if non-viable. Cecopexy or cecostomy if viable. Endoscopic reduction less effective."
      },
      {
        "id": "transverse_colon_volvulus",
        "name": "Transverse Colon Volvulus",
        "prevalenceModifier": 0.05,
        "keyFeatures": [
          { "feature": "mid_abdominal_pain", "weight": 5 },
          { "feature": "distension", "weight": 4 },
          { "feature": "obstruction_symptoms", "weight": 4 }
        ],
        "management": "Emergency laparotomy. Resection with primary anastomosis. Endoscopic reduction rarely successful."
      }
    ],

    "mimics": [
