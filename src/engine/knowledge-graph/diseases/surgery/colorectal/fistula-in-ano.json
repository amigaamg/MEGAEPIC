        { "name": "Fistulography", "priority": "low", "yield": 0.5, "indication": "rarely used now" },
        { "name": "Examination Under Anesthesia (EUA)", "priority": "high", "yield": 0.85, "indication": "definitive assessment by experienced surgeon" }
      ]
    },

    "management": {
      "protocolReference": "ASCRS Practice Parameters for Fistula-in-Ano",
      "pathways": [
        {
          "severity": "simple (intersphincteric, low trans-sphincteric)",
          "criteria": "low fistula, <30% external sphincter involvement",
          "treatment": "Fistulotomy (lay-open). Fistulectomy. High cure rate, low recurrence."
        },
        {
          "severity": "complex (high trans-sphincteric, suprasphincteric, extrasphincteric, Crohn's)",
          "criteria": ">30% external sphincter, high tract, female anterior fistula, Crohn's",
          "treatment": "Non-cutting seton for drainage. LIFT procedure. Mucosal advancement flap. VAAFT. Fistula plug. Anti-TNF (Infliximab) for Crohn's. Stoma for refractory cases."
        }
      ]
    },

    "pathophysiology": [
      "perianal_gland_infection",
      "cryptoglandular_abscess",
      "spontaneous_drainage_or_incision",
      "persistent_epithelialized_tract",
      "chronic_infection",
      "extension_along_anatomical_planes"
    ],

