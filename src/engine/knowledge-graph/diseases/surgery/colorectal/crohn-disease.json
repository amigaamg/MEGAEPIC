    "management": {
      "protocolReference": "ECCO/ACG Guidelines for Crohn's Disease",
      "pathways": [
        {
          "severity": "mild-moderate",
          "criteria": "CDAI <220, no obstruction, no abscess, no fistula",
          "treatment": "Corticosteroids (Budesonide for ileocecal). Anti-TNF induction (Infliximab/Adalimumab). Azathioprine for maintenance."
        },
        {
          "severity": "severe/penetrating",
          "criteria": "abscess, fistula, obstruction, perforation, systemic illness",
          "treatment": "IV steroids. IV Anti-TNF (Infliximab). Percutaneous drainage of abscess. Surgical resection for stricture/fistula. Seton drainage for perianal fistula. Bowel resection with primary anastomosis."
        }
      ]
    },

