        "lagDays": [60, 720],
        "severityBoost": 0.1,
        "clues": ["fatigue", "pallor", "chronic_bleeding", "low_hemoglobin"]
      }
    ],

    "mustNotMiss": false,
    "emergencyPriority": "low",
    "diagnosticClues": ["painless_rectal_bleeding", "prolapse_on_straining", "pruritus", "confirmed_on_proctoscopy"],
    "exclusionClues": ["dark_blood", "weight_loss", "mucus_in_stool", "age_over_50_with_new_symptoms"]
  }
