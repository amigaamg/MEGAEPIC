    "management": {
      "protocolReference": "NCCN Guidelines for Colorectal Cancer",
      "pathways": [
        {
          "severity": "localized",
          "criteria": "tumour confined to bowel wall, no metastases",
          "treatment": "Surgical resection with lymphadenectomy. Adjuvant chemotherapy if high-risk features (T4, nodal involvement)."
        },
        {
          "severity": "metastatic",
          "criteria": "distant metastases (liver, lung, peritoneum)",
          "treatment": "Neoadjuvant chemotherapy. Consider resection of primary and metastases. Palliative chemotherapy if unresectable."
        },
        {
          "severity": "obstructed/perforated",
          "criteria": "acute obstruction or perforation",
          "treatment": "Emergency surgery (resection or diverting stoma). IV fluids. Broad-spectrum antibiotics. ICU if septic."
        }
      ]
