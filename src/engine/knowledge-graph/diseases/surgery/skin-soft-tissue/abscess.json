{
  "disease": {
    "id": "skin_abscess",
    "name": "Cutaneous / Skin Abscess",
    "system": "surgical",
    "agePeak_months": [120, 480],
    "note": "Localized collection of pus in the dermis or subcutaneous tissue. Painful, red, fluctuant swelling. Requires incision and drainage.",
    "prevalenceWeight": 0.5,
    "syndromeTags": ["skin_infection", "pus_collection", "painful_swelling"],

    "severityAssessment": {
      "immediateDangerSigns": [
        { "sign": "septic_shock", "weight": 10 },
        { "sign": "extensive_cellulitis", "weight": 7 },
        { "sign": "deep_abscess_compartment", "weight": 8 },
        { "sign": "avpu_abnormal", "weight": 10 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "size_large_more_than_5cm", "weight": 5 },
          { "sign": "diabetes_immunosuppressed", "weight": 6 },
          { "sign": "failed_previous_drainage", "weight": 5 },
          { "sign": "systemic_toxicity", "weight": 6 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "Large/systemic/immunosuppressed -> SEVERE; small superficial -> NON-SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "painful_red_lump", "weight": 5 },
      { "symptomId": "increasing_size_over_days", "weight": 4 },
      { "symptomId": "fever", "weight": 3 },
      { "symptomId": "history_of_folliculitis_or_pimple", "weight": 3 },
      { "symptomId": "skin_trauma_or_bite", "weight": 3 },
      { "symptomId": "previous_abscesses", "weight": 2 },
      { "symptomId": "diabetes", "weight": 3 }
    ],

    "examFeatures": [
      { "signId": "fluctuant_swelling", "baseWeight": 5, "doubleWeight": true },
      { "signId": "erythema_warmth", "baseWeight": 4 },
      { "signId": "pointing_pustule_or_necrosis", "baseWeight": 3 },
      { "signId": "tenderness", "baseWeight": 4 },
      { "signId": "surrounding_cellulitis", "baseWeight": 3 },
      { "signId": "regional_lymphadenopathy", "baseWeight": 2 }
    ],

    "riskFactors": [
      { "id": "diabetes_mellitus", "multiplier": 3.0 },
      { "id": "immunosuppression", "multiplier": 2.5 },
      { "id": "intravenous_drug_use", "multiplier": 3.0 },
      { "id": "obesity", "multiplier": 1.5 },
      { "id": "mrsa_colonization", "multiplier": 2.0 },
      { "id": "poor_hygiene", "multiplier": 1.5 }
    ],

    "subtypes": [
      {
        "id": "superficial_cutaneous_abscess",
        "name": "Superficial Cutaneous Abscess",
        "prevalenceModifier": 0.8,
        "keyFeatures": [
          { "feature": "skin_level_fluctuance", "weight": 5 },
          { "feature": "localized", "weight": 4 },
          { "feature": "no_systemic_symptoms", "weight": 4 }
        ],
        "management": "I&D under LA. Pus culture. Wound packing. Remove packing in 24-48h. Antibiotics only if surrounding cellulitis or immunocompromised."
      },
      {
        "id": "complex_deep_abscess",
        "name": "Complex/Deep (e.g., Perianal, Pilonidal, Hand)",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "deeper_location", "weight": 5 },
          { "feature": "may_have_extension", "weight": 4 },
          { "feature": "pain_disproportionate", "weight": 3 },
          { "feature": "often_requires_ga_evacuation", "weight": 4 }
        ],
        "management": "I&D under GA if extensive. Loculi breakdown. Pus culture. Wound packing. IV antibiotics. Consider MRI/CT for deep extension."
      }
    ],

    "mimics": [
      {
        "diseaseId": "cellulitis_without_abscess",
        "discriminators": ["no_fluctuance", "diffuse_erythema", "no_pus_on_aspiration"]
      },
      {
        "diseaseId": "sebaceous_cyst_infection",
        "discriminators": ["central_punctum", "prior_lump_history", "cheesy_material"]
      },
      {
        "diseaseId": "hidradenitis_suppurativa",
        "discriminators": ["axillary_groin_location", "multiple_sinus_tracts", "recurrent_chronic"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Needle aspiration", "priority": "high", "yield": 0.9, "indication": "confirm pus" }
      ],
      "laboratory": [
        { "name": "WBC count", "priority": "medium", "yield": 0.5, "indication": "if systemic symptoms" },
        { "name": "CRP", "priority": "medium", "yield": 0.5, "indication": "inflammation marker" },
        { "name": "Pus culture + sensitivity", "priority": "high", "yield": 0.8, "indication": "guide antibiotics" },
        { "name": "Blood cultures", "priority": "medium", "yield": 0.3, "indication": "if septic" }
      ],
      "imaging": [
        { "name": "Ultrasound Soft Tissue", "priority": "high", "yield": 0.85, "indication": "confirm abscess, depth, extension" },
        { "name": "CT/MRI", "priority": "medium", "yield": 0.9, "indication": "for deep/complex abscesses" }
      ]
    },

    "management": {
      "protocolReference": "IDSA Guidelines for Skin and Soft Tissue Abscess",
      "pathways": [
        {
          "severity": "small (<2cm)",
          "criteria": "superficial, no cellulitis, afebrile",
          "treatment": "Incision and drainage alone. No antibiotics. Pack wound."
        },
        {
          "severity": "moderate-large",
          "criteria": ">2cm, surrounding cellulitis, fever, failed I&D",
          "treatment": "I&D. Antibiotics covering Staph and Strep (Cephalexin, Clindamycin, TMP-SMX if MRSA risk). Wound culture."
        }
      ]
    },

    "pathophysiology": [
      "bacterial_inoculation",
      "neutrophil_infiltration",
      "tissue_necrosis",
      "pus_formation",
      "abscess_wall_formation",
      "increased_local_pressure",
      "spontaneous_drainage_or_extension"
    ],

    "complications": [
      {
        "diseaseId": "cellulitis_lymphangitis",
        "probability": 0.1,
        "lagDays": [1, 3],
        "severityBoost": 0.1,
        "clues": ["spreading_erythema", "red_streaks", "fever"]
      },
      {
        "diseaseId": "recurrence",
        "probability": 0.1,
        "lagDays": [14, 90],
        "severityBoost": 0.1,
        "clues": ["reaccumulation", "return_of_symptoms"]
      }
    ],

    "mustNotMiss": false,
    "emergencyPriority": "low",
    "diagnosticClues": ["painful_red_lump", "fluctuant", "pus_on_aspiration", "fever"],
    "exclusionClues": ["non_fluctuant", "no_pus", "normal_crp_wbc"]
  }
}
