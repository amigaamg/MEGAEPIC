    "subtypes": [
      {
        "id": "venous_ulcer",
        "name": "Venous Ulcer (Gaiter Area)",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "medial_malleolus_location", "weight": 5 },
          { "feature": "shallow_irregular_borders", "weight": 4 },
          { "feature": "venous_pigmentation_edema", "weight": 5 },
          { "feature": "present_pulses", "weight": 3 }
        ],
        "management": "Compression therapy (multi-layer bandaging). Leg elevation. Wound debridement and dressings. Endovenous ablation of incompetent veins. Skin grafting for large ulcers."
      },
      {
        "id": "arterial_ulcer",
        "name": "Arterial/Ischemic Ulcer",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "distal_tip_toes_webspace", "weight": 5 },
          { "feature": "punched_out_circular", "weight": 4 },
          { "feature": "absent_pulses_low_abi", "weight": 5 },
          { "feature": "severe_pain_cold_limb", "weight": 4 }
        ],
        "management": "Revascularization (endovascular or bypass). No compression. Wound care. Analgesia. Amputation if unsalvageable."
      },
      {
        "id": "diabetic_neuropathic_ulcer",
        "name": "Diabetic (Neuropathic) Ulcer",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
          { "feature": "plantar_foot_weight_bearing", "weight": 5 },
          { "feature": "callus_surrounding_ulcer", "weight": 4 },
          { "feature": "loss_of_sensation", "weight": 5 },
          { "feature": "foot_deformity_charcot", "weight": 3 }
        ],
        "management": "Offloading (total contact cast). Sharp debridement of callus. Infection control (antibiotics). Revascularization if PAD. Blood glucose control. Multidisciplinary foot team."
      }
    ],

    "mimics": [
