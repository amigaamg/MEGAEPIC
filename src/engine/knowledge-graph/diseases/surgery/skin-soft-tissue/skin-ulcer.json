      "pathways": [
        {
          "severity": "venous ulcer",
          "criteria": "gaiter area, shallow, present pulses, venous disease",
          "treatment": "Multi-layer compression bandaging. Leg elevation. Wound debridement. Dressings (hydrocolloid, foam). Endovenous ablation of incompetent veins."
        },
        {
          "severity": "arterial / diabetic ulcer",
          "criteria": "distal, absent pulses, low ABI, neuropathy",
          "treatment": "Vascular assessment. Revascularization. Offloading (total contact cast). Debridement. Infection control. Blood glucose control. Wound care MDT."
