    "management": {
      "protocolReference": "NCCN/ESMO Guidelines for Melanoma",
      "pathways": [
        {
          "severity": "in situ (Stage 0)",
          "criteria": "confined to epidermis, no invasion",
          "treatment": "Wide local excision with 0.5cm margins. No SLNB."
        },
        {
          "severity": "thin (Stage I: <1mm)",
          "criteria": "Breslow <1mm, no ulceration, no nodes",
          "treatment": "Wide local excision with 1cm margins. SLNB optional if high-risk features. No adjuvant therapy."
        },
        {
          "severity": "intermediate-thick (Stage II: 1-4mm)",
          "criteria": "Breslow 1-4mm, +/- ulceration",
          "treatment": "Wide local excision with 1-2cm margins. SLNB mandatory. Adjuvant immunotherapy if node-positive."
        },
        {
          "severity": "thick/metastatic (Stage III-IV)",
          "criteria": "Breslow >4mm, node metastases, distant metastases",
          "treatment": "Wide local excision + lymphadenectomy (if palpable nodes). Adjuvant immunotherapy (Pembrolizumab, Nivolumab) or targeted (Dabrafenib + Trametinib if BRAF+). Palliative therapy for M1."
        }
      ]
    },

