    "subtypes": [
      {
        "id": "grade_i_ii_pressure_ulcer",
        "name": "Grade I-II Pressure Ulcer",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
          { "feature": "non_blanchable_erythema_or_partial_thickness", "weight": 5 },
          { "feature": "intact_skin_or_shallow_ulcer", "weight": 4 },
          { "feature": "reversible_with_pressure_relief", "weight": 4 }
        ],
        "management": "Pressure relief (turning every 2h, special mattress). Moisture management. Nutritional support. Barrier creams. Regular repositioning."
      },
      {
        "id": "grade_iii_iv_pressure_ulcer",
        "name": "Grade III-IV Pressure Ulcer",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "full_thickness_skin_loss_to_fascia_or_bone", "weight": 5 },
          { "feature": "deep_tissue_necrosis", "weight": 5 },
          { "feature": "tunneling_undermining", "weight": 4 },
          { "feature": "high_risk_of_osteomyelitis", "weight": 4 }
        ],
        "management": "Surgical debridement (sharp or surgical). Wound culture and antibiotics. NPWT (negative pressure wound therapy). Pressure redistribution. Nutritional optimization. Reconstructive surgery (flap) for definitive closure. Osteomyelitis treatment if present."
      }
    ],

    "mimics": [
      {
        "diseaseId": "ischemic_ulcer",
        "discriminators": ["distal_leg", "absent_pulses", "low_abi", "not_over_bony_prominence"]
