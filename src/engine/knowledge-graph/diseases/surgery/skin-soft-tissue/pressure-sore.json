    "management": {
      "protocolReference": "NPUAP/EPUAP Guidelines for Pressure Ulcers",
      "pathways": [
        {
          "severity": "Grade I-II",
          "criteria": "intact skin or partial thickness, no deep necrosis",
          "treatment": "Pressure redistribution (q2h turning, special mattress). Moisture barrier. Nutritional support. Wound dressings (hydrocolloid, foam). No debridement needed."
        },
        {
          "severity": "Grade III-IV",
          "criteria": "full thickness, deep necrosis, exposed bone",
          "treatment": "Surgical debridement. NPWT. Antibiotics. Osteomyelitis treatment. Nutritional optimization. Reconstructive surgery (flap coverage). Pressure redistribution."
        }
      ]
    },

