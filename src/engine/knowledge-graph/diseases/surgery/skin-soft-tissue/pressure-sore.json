        { "name": "ESR (elevated in osteomyelitis)", "priority": "medium", "yield": 0.4, "indication": "bone infection suspicion" },
        { "name": "Wound swab / deep tissue culture", "priority": "high", "yield": 0.6, "indication": "guide antibiotics" }
      ],
      "imaging": [
