        { "sign": "rhabdomyolysis", "weight": 9 },
        { "sign": "avpu_abnormal", "weight": 10 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "motor_deficit_paralysis", "weight": 9 },
          { "sign": "sensory_loss", "weight": 8 },
          { "sign": "absent_doppler_signal_arterial", "weight": 8 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "Motor/sensory loss -> SEVERE (threatened limb); viable limb -> NON-SEVERE (Rutherford I)"
    },

    "historyFeatures": [
      { "symptomId": "sudden_onset_leg_pain", "weight": 5 },
      { "symptomId": "cold_leg", "weight": 4 },
