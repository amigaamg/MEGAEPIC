        ],
        "management": "Sclerotherapy (liquid or foam). Laser therapy. Compression stockings for associated symptoms."
      },
      {
        "id": "complicated_varicose_veins",
        "name": "Complicated Varicose Veins (Ulcer, Bleeding, Thrombophlebitis)",
        "prevalenceModifier": 0.1,
