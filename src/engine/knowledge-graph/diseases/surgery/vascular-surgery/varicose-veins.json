    "management": {
      "protocolReference": "ESVS Guidelines for Chronic Venous Disease",
      "pathways": [
        {
          "severity": "C1-C2 (telangiectasias / uncomplicated varicose veins)",
          "criteria": "reticular/telangiectasia or symptomatic varicose veins without complications",
          "treatment": "Compression stockings (class 1-2). Sclerotherapy for C1. Endovenous ablation (EVLA/RFA) + foam sclerotherapy for C2. Elevation, exercise."
        },
        {
          "severity": "C3-C6 (edema, skin changes, ulcer)",
          "criteria": "edema, pigmentation, lipodermatosclerosis, healed or active ulcer",
          "treatment": "Compression therapy (multi-layer bandaging for active ulcer). Endovenous ablation of incompetent veins. Ulcer care (debridement, dressings). Skin grafting for large ulcers. Surgery if endovenous not possible."
        }
      ]
