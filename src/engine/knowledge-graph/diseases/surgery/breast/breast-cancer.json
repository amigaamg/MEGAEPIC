    "management": {
      "protocolReference": "NCCN/St. Gallen Guidelines for Breast Cancer",
      "pathways": [
        {
          "severity": "early (T1-T2, N0)",
          "criteria": "tumor <5cm, node negative, no metastases",
          "treatment": "Breast-conserving surgery + sentinel node biopsy + whole breast RT. Mastectomy if multifocal or contraindication to RT. Adjuvant therapy per molecular subtype."
        },
        {
          "severity": "locally advanced (T3-T4, N+)",
          "criteria": "tumor >5cm, node positive, or chest wall/skin involvement",
          "treatment": "Neoadjuvant chemotherapy (anthracycline + taxane). Modified radical mastectomy. Post-mastectomy RT. Adjuvant endocrine therapy + targeted therapy."
        },
        {
          "severity": "metastatic (M1)",
          "criteria": "distant metastases (bone, lung, liver, brain)",
          "treatment": "Palliative systemic therapy. Endocrine therapy for ER+. Chemotherapy for triple negative. HER2-targeted therapy. Palliative RT. Surgical resection of primary only for symptom control."
        }
