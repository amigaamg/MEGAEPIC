          { "feature": "hard_irregular_mass", "weight": 5 },
          { "feature": "skin_involvement_common", "weight": 3 }
        ],
        "management": "Breast-conserving surgery (lumpectomy) + sentinel node biopsy + radiotherapy. Total mastectomy for large/multicentric. Adjuvant chemotherapy, endocrine therapy, targeted therapy per subtype."
