          { "feature": "cyclic_pain", "weight": 4 },
          { "feature": "no_hyperplasia", "weight": 5 },
          { "feature": "no_increased_cancer_risk", "weight": 4 }
        ],
        "management": "Reassurance. Well-fitted supportive bra. Analgesia (NSAIDs). Evening primrose oil. Avoid caffeine. Oral contraceptives if severe. Symptomatic cysts can be aspirated."
      },
      {
        "id": "proliferative_without_atypia",
        "name": "Proliferative without Atypia",
        "prevalenceModifier": 0.2,
