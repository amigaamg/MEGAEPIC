          { "feature": "4_5x_increased_breast_cancer_risk", "weight": 5 },
          { "feature": "may_have_family_history", "weight": 3 }
        ],
        "management": "Close surveillance: annual mammogram + MRI. Clinical exam every 6 months. Risk-reducing medications (Tamoxifen). Consider genetic counseling if family history."
      }
    ],

    "mimics": [
