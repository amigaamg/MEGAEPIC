          { "feature": "slightly_increased_cancer_risk_1_5_2x", "weight": 4 },
          { "feature": "sclerosing_adenosis", "weight": 3 }
        ],
        "management": "Reassurance. Regular follow-up. Clinical breast exam every 6-12 months. Annual imaging. Consider risk-reducing strategies if strong family history."
      },
      {
        "id": "atypical_hyperplasia",
        "name": "Atypical Ductal/Lobular Hyperplasia",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
