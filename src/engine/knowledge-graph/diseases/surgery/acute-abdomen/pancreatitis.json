        "diseaseId": "pancreatic_pseudocyst",
        "probability": 0.15,
        "lagDays": [14, 28],
        "severityBoost": 0.2,
        "clues": ["persistent_elevated_amylase", "palpable_mass", "early_satiety"]
      },
