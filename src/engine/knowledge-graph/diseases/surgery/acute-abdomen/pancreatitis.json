        "lagDays": [7, 21],
        "severityBoost": 0.4,
        "clues": ["persistent_fever", "worsening_sepsis", "gas_in_necrosis_on_ct"]
      },
      {
        "diseaseId": "multi_organ_failure",
        "probability": 0.1,
        "lagDays": [1, 5],
        "severityBoost": 0.5,
        "clues": ["hypotension", "renal_failure", "respiratory_failure"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "high",
    "diagnosticClues": ["epigastric_pain_radiating_to_back", "vomiting_not_relieving_pain", "elevated_lipase", "alcohol_or_gallstone_history"],
    "exclusionClues": ["rlq_pain", "bloody_diarrhea", "pain_relieved_by_antacids"]
  }
