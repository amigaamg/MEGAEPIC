        "lagDays": [1, 3],
        "severityBoost": 0.5,
        "clues": ["free_air", "worsening_sepsis", "generalized_peritonitis"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "high",
    "diagnosticClues": ["massive_distension", "coffee_bean_sign", "previous_episodes", "elderly_constipated_patient"],
