{
  "disease": {
    "id": "volvulus",
    "name": "Volvulus",
    "system": "surgical",
    "agePeak_months": [600, 960],
    "note": "Twisting of bowel around its mesentery causing closed-loop obstruction. Sigmoid most common, then cecal volvulus.",
    "prevalenceWeight": 0.3,
    "syndromeTags": ["acute_abdomen", "bowel_obstruction", "abdominal_distension"],

    "severityAssessment": {
      "immediateDangerSigns": [
