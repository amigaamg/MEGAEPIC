          { "sign": "rebound_tenderness", "weight": 7 },
          { "sign": "absent_bowel_sounds", "weight": 7 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If generalized peritonitis/shock -> SEVERE; else -> NON-SEVERE (contained perforation)"
    },

    "historyFeatures": [
      { "symptomId": "epigastric_pain", "weight": 5, "modifiers": [
          { "condition": "sudden_onset", "suspectTB": false }
        ]
      },
      { "symptomId": "nausea_vomiting", "weight": 3 },
      { "symptomId": "previous_dyspepsia", "weight": 4, "note": "History of peptic ulcer disease" },
      { "symptomId": "nsaid_use", "weight": 4, "note": "Common precipitant" },
      { "symptomId": "hematemesis", "weight": 2, "note": "May coexist with perforation" }
    ],

    "examFeatures": [
      { "signId": "epigastric_tenderness", "baseWeight": 5, "doubleWeight": true },
      { "signId": "board_like_rigidity", "baseWeight": 5, "doubleWeight": true },
      { "signId": "rebound_tenderness", "baseWeight": 4 },
      { "signId": "absent_bowel_sounds", "baseWeight": 3 },
      { "signId": "tachycardia", "baseWeight": 3 },
      { "signId": "guarding", "baseWeight": 4 }
