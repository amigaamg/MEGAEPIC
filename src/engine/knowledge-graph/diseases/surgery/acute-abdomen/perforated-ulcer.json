      { "id": "h_pylori_infection", "multiplier": 1.5 },
      { "id": "smoking", "multiplier": 1.3 },
      { "id": "corticosteroid_use", "multiplier": 1.5 },
      { "id": "previous_ulcer_history", "multiplier": 1.8 }
    ],

    "subtypes": [
      {
        "id": "anterior_duodenal_perforation",
        "name": "Anterior Duodenal Ulcer Perforation",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
          { "feature": "sudden_severe_epigastric_pain", "weight": 5 },
          { "feature": "board_like_rigidity", "weight": 5 },
          { "feature": "gas_under_diaphragm", "weight": 5 }
        ],
        "management": "Emergency laparotomy with omental patch repair (Graham patch). IV PPI. IV antibiotics."
      },
      {
        "id": "gastric_ulcer_perforation",
        "name": "Gastric Ulcer Perforation",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
