          { "feature": "vomiting", "weight": 4 },
          { "feature": "peritonitis", "weight": 5 },
          { "feature": "hematemesis", "weight": 3 }
        ],
        "management": "Emergency laparotomy. Ulcer excision or biopsy + closure. Rule out malignancy. IV PPI and antibiotics."
      }
    ],

    "mimics": [
      {
        "diseaseId": "acute_pancreatitis",
        "discriminators": ["serum_amylase_elevated", "pain_referred_to_back", "vomiting_prominent"]
      },
      {
        "diseaseId": "acute_appendicitis",
        "discriminators": ["pain_migration_to_rlq", "anorexia", "pain_not_relieved_by_antacids"]
      },
      {
        "diseaseId": "myocardial_infarction",
        "discriminators": ["ecg_changes", "cardiac_enzymes", "chest_pain_radiation"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Erect Chest X-Ray", "priority": "immediate", "yield": 0.85, "indication": "free gas under diaphragm" },
        { "name": "ECG", "priority": "immediate", "yield": 0.2, "indication": "rule out MI" }
      ],
      "laboratory": [
        { "name": "WBC count", "priority": "high", "yield": 0.8, "indication": "leukocytosis suggests perforation" },
        { "name": "CRP", "priority": "high", "yield": 0.7, "indication": "elevated in peritonitis" },
        { "name": "Serum Amylase", "priority": "high", "yield": 0.6, "indication": "rule out pancreatitis" },
        { "name": "Blood Gas", "priority": "high", "yield": 0.7, "indication": "assess metabolic acidosis and shock" }
      ],
      "imaging": [
        { "name": "Erect CXR", "priority": "immediate", "yield": 0.85, "indication": "pneumoperitoneum" },
        { "name": "CT Abdomen with IV contrast", "priority": "high", "yield": 0.98, "indication": "detect free gas and fluid, localize perforation" }
      ]
    },

    "management": {
      "protocolReference": "WSES Guidelines for Perforated Peptic Ulcer",
      "pathways": [
        {
          "severity": "severe",
          "criteria": "generalized peritonitis, board-like rigidity, shock",
          "treatment": "Emergency laparotomy. Resuscitation with IV fluids. Broad-spectrum IV antibiotics. Omental patch repair. Post-op ICU."
        },
        {
          "severity": "non-severe",
          "criteria": "localized tenderness, no peritonitis, contained perforation",
          "treatment": "Consider conservative management: NBM, NG tube, IV PPI, IV antibiotics. Close monitoring. Surgical intervention if deterioration."
        }
      ]
    },

    "pathophysiology": [
      "ulcer_penetration",
      "gastric_or_duodenal_content_leak",
      "chemical_peritonitis",
      "bacterial_contamination",
      "sepsis"
