    "management": {
      "protocolReference": "WSES Guidelines for Intra-Abdominal Abscess",
      "pathways": [
        {
          "severity": "non-severe",
          "criteria": "well-defined abscess, no sepsis, accessible percutaneously",
          "treatment": "CT-guided percutaneous drainage. IV antibiotics. Culture-directed antibiotic therapy. Monitor resolution with imaging."
        },
        {
          "severity": "severe",
          "criteria": "multiple abscesses, failed percutaneous drainage, sepsis, inaccessible location",
          "treatment": "Surgical drainage (laparoscopic or open). Source control. IV broad-spectrum antibiotics. ICU admission if septic."
        }
      ]
    },

    "pathophysiology": [
      "localized_infection",
      "purulent_collection",
      "fibrinous_wall_formation",
      "bacterial_proliferation",
      "systemic_inflammatory_response",
