        { "name": "Procalcitonin", "priority": "medium", "yield": 0.7, "indication": "bacterial infection marker" }
      ],
      "imaging": [
        { "name": "CT Abdomen with IV contrast", "priority": "immediate", "yield": 0.95, "indication": "gold standard for detection and localization" },
        { "name": "Abdominal Ultrasound", "priority": "high", "yield": 0.7, "indication": "useful for subphrenic and pelvic abscesses" },
        { "name": "MRI", "priority": "medium", "yield": 0.85, "indication": "alternative in pregnancy or contrast allergy" }
      ]
