        { "name": "Temperature chart", "priority": "immediate", "yield": 0.5, "indication": "fever pattern assessment" }
      ],
      "laboratory": [
        { "name": "WBC count", "priority": "high", "yield": 0.8, "indication": "leukocytosis" },
