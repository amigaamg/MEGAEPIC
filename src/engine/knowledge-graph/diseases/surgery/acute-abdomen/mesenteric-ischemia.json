          { "feature": "hypercoagulable_state", "weight": 4 },
          { "feature": "abdominal_distension", "weight": 3 }
        ],
        "management": "Anticoagulation (heparin then warfarin). Resection if infarction. Treat underlying hypercoagulable state."
      }
    ],

    "mimics": [
