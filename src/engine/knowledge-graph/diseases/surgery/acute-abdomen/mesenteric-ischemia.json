          { "feature": "gradual_onset_pain", "weight": 4 },
          { "feature": "weight_loss", "weight": 3 },
          { "feature": "diffuse_atherosclerosis", "weight": 4 }
        ],
        "management": "Emergency revascularization (bypass or endarterectomy). Resection of necrotic bowel. Second-look laparotomy."
      },
      {
        "id": "mesenteric_venous_thrombosis",
        "name": "Mesenteric Venous Thrombosis",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
