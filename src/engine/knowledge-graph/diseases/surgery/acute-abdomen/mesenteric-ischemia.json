          { "feature": "sudden_severe_pain", "weight": 5 },
          { "feature": "atrial_fibrillation", "weight": 5 },
          { "feature": "vomiting", "weight": 3 },
          { "feature": "early_emptying", "weight": 3 }
        ],
        "management": "Emergency laparotomy. Embolectomy. Resection of non-viable bowel. Second-look laparotomy in 24-48h. Anticoagulation."
      },
      {
        "id": "sma_thrombosis",
        "name": "SMA Thrombosis",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
