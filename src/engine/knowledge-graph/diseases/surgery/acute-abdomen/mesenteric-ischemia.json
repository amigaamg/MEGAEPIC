    "investigations": {
      "bedside": [
        { "name": "ECG", "priority": "immediate", "yield": 0.5, "indication": "detect atrial fibrillation or recent MI" },
        { "name": "Blood Gas", "priority": "immediate", "yield": 0.8, "indication": "metabolic acidosis indicates ischemia" }
      ],
      "laboratory": [
        { "name": "Lactate", "priority": "immediate", "yield": 0.85, "indication": "elevated in bowel ischemia" },
        { "name": "WBC count", "priority": "high", "yield": 0.75, "indication": "leukocytosis common" },
        { "name": "D-dimer", "priority": "medium", "yield": 0.6, "indication": "elevated but non-specific" },
        { "name": "Base deficit", "priority": "high", "yield": 0.8, "indication": "severity marker" }
      ],
      "imaging": [
        { "name": "CT Angiography Abdomen", "priority": "immediate", "yield": 0.95, "indication": "gold standard for diagnosis" },
        { "name": "Duplex Ultrasound", "priority": "medium", "yield": 0.6, "indication": "limited role in acute setting" }
      ]
    },

    "management": {
      "protocolReference": "WSES Guidelines for Acute Mesenteric Ischemia",
      "pathways": [
        {
          "severity": "early/embolic",
          "criteria": "no peritonitis, early presentation, CT findings limited to thrombus without infarction",
          "treatment": "Laparotomy with embolectomy. Consider endovascular aspiration. Anticoagulation. Second-look laparotomy."
        },
        {
          "severity": "established infarction",
          "criteria": "peritonitis, shock, acidosis, CT shows bowel necrosis",
          "treatment": "Emergency laparotomy. Resection of all non-viable bowel. Second-look laparotomy in 24-48h. ICU care. Broad-spectrum antibiotics."
        }
      ]
    },

    "pathophysiology": [
      "arterial_occlusion",
