          { "feature": "critical_illness", "weight": 5 },
          { "feature": "no_gallstones_on_imaging", "weight": 4 }
        ],
        "management": "Broad-spectrum antibiotics. Percutaneous cholecystostomy if surgical candidate high-risk."
      }
    ],

    "mimics": [
      {
        "diseaseId": "peptic_ulcer_perforation",
        "discriminators": ["epigastric_pain", "melena", "hematemesis"]
      },
      {
        "diseaseId": "hepatitis",
        "discriminators": ["hepatomegaly", "transaminitis", "viral_prodrome"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Murphy sign test", "priority": "immediate", "yield": 0.85, "indication": "all RUQ pain" }
      ],
      "laboratory": [
        { "name": "WBC count", "priority": "high", "yield": 0.7, "indication": "leukocytosis" },
        { "name": "CRP", "priority": "high", "yield": 0.7, "indication": "inflammatory marker" },
        { "name": "LFTs (AST, ALT, ALP, GGT, Bilirubin)", "priority": "high", "yield": 0.8, "indication": "obstructive pattern suggests CBD stones" },
        { "name": "Serum amylase/lipase", "priority": "high", "yield": 0.6, "indication": "rule out pancreatitis" }
      ],
      "imaging": [
        { "name": "Right Upper Quadrant Ultrasound", "priority": "immediate", "yield": 0.9, "indication": "gallstones, wall thickening, pericholecystic fluid, Murphy sign" },
        { "name": "HIDA scan", "priority": "medium", "yield": 0.88, "indication": "equivocal cases" },
        { "name": "MRCP", "priority": "medium", "yield": 0.85, "indication": "suspected CBD stones" }
      ]
    },

    "management": {
      "protocolReference": "Tokyo Guidelines 2018 (TG18) for Acute Cholecystitis",
      "pathways": [
        {
          "severity": "mild (Grade I)",
          "criteria": "mild inflammation, no organ dysfunction, no complications",
          "treatment": "IV antibiotics (Ceftriaxone + Metronidazole). Early laparoscopic cholecystectomy within 72 hours."
        },
        {
          "severity": "moderate (Grade II)",
          "criteria": "elevated WBC >18k, palpable tender mass, duration >72h, local complications",
          "treatment": "IV antibiotics. Urgent laparoscopic cholecystectomy. Consider percutaneous drainage if high surgical risk."
        },
        {
          "severity": "severe (Grade III)",
          "criteria": "organ dysfunction (CV, respiratory, renal, hepatic, neurological)",
          "treatment": "ICU admission. IV antibiotics. Organ support. Percutaneous cholecystostomy. Delayed cholecystectomy after recovery."
        }
      ]
    },

    "pathophysiology": [
      "cystic_duct_obstruction",
      "gallstone_impaction",
      "bile_stasis",
      "gallbladder_distension",
      "ischemia",
      "bacterial_translocation"
    ],

    "complications": [
