      "pathways": [
        {
          "severity": "Grade I (Mild)",
          "criteria": "TB 2-10 mg/dL, CRP <10, WBC <12,000, no organ failure",
          "treatment": "IV antibiotics (Piperacillin-Tazobactam or Ceftriaxone + Metronidazole). Fluid resuscitation. ERCP within 24-48h for biliary drainage."
        },
        {
          "severity": "Grade II (Moderate)",
          "criteria": "TB >10, CRP >10, WBC >12,000, organ failure mild",
          "treatment": "IV antibiotics. Urgent ERCP <24h. Biliary drainage. ICU monitoring."
        },
        {
          "severity": "Grade III (Severe)",
          "criteria": "organ dysfunction, septic shock, altered consciousness",
          "treatment": "ICU. IV broad-spectrum antibiotics. Vasopressors. Urgent ERCP <12h or PTC if ERCP fails. Biliary drainage. Fluid resuscitation."
        }
