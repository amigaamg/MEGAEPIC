      "pathways": [
        {
          "severity": "resectable",
          "criteria": "no arterial involvement, <=180 degree SMV/PV involvement, no metastases",
          "treatment": "Pancreaticoduodenectomy (Whipple) for head tumors. Distal pancreatectomy for body/tail. Adjuvant chemotherapy (FOLFIRINOX or Gemcitabine + Capecitabine)."
        },
        {
          "severity": "borderline resectable",
          "criteria": ">180 degree SMV/PV involvement, limited arterial abutment",
          "treatment": "Neoadjuvant FOLFIRINOX for 2-6 months. Restaging CT. Pancreaticoduodenectomy with vascular resection if downstaged."
        },
        {
          "severity": "unresectable / metastatic",
          "criteria": "distant metastases, arterial invasion, extensive SMV involvement",
          "treatment": "Palliative chemotherapy (FOLFIRINOX or Gemcitabine + Nab-paclitaxel). Biliary stenting. Celiac plexus block. Palliative gastrojejunostomy. Hospice care."
        }
