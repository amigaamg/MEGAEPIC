        { "sign": "generalized_peritonitis", "weight": 10 },
        { "sign": "gangrenous_cholecystitis", "weight": 9 },
        { "sign": "avpu_abnormal", "weight": 10 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "impacted_stone_in_neck", "weight": 6 },
          { "sign": "gallstone_pancreatitis", "weight": 7 },
          { "sign": "obstructive_jaundice", "weight": 7 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "Complicated stone disease (pancreatitis/cholangitis) -> SEVERE; asymptomatic or biliary colic -> NON-SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "right_upper_quadrant_pain", "weight": 5, "modifiers": [
          { "condition": "post_prandial", "suspectTB": false }
        ]
