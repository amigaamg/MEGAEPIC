        "lagDays": [1, 7],
        "severityBoost": 0.4,
        "clues": ["epigastric_pain_radiating_to_back", "elevated_amylase", "gallstones_on_us"]
      }
    ],

    "mustNotMiss": false,
    "emergencyPriority": "low",
    "diagnosticClues": ["right_upper_quadrant_post_prandial_pain", "gallstones_on_ultrasound", "fatty_food_intolerance"],
