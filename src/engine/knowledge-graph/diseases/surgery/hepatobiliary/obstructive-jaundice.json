    "management": {
      "protocolReference": "ASGE Guidelines for Obstructive Jaundice",
      "pathways": [
        {
          "severity": "benign (gallstones)",
          "criteria": "gallstones in CBD, dilated ducts, no mass",
          "treatment": "ERCP + sphincterotomy + stone extraction. Laparoscopic cholecystectomy after clearance. IV antibiotics if cholangitis present."
