        {
          "severity": "malignant obstruction",
          "criteria": "mass on imaging, progressive jaundice, weight loss",
          "treatment": "ERCP with biliary stent (plastic or metal). Staging CT/MRI. Resection if resectable (Whipple/distal pancreatectomy). Palliative treatment if unresectable."
        },
        {
          "severity": "cholangitis",
          "criteria": "fever, jaundice, RUQ pain, sepsis",
          "treatment": "IV antibiotics. Urgent ERCP with drainage. ICU if septic."
        }
      ]
