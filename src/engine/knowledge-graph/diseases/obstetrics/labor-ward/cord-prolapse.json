    "mimics": [],
    "investigations": {
      "bedside": [
        { "name": "Sterile vaginal examination", "priority": "immediate", "yield": 0.95, "indication": "confirm cord prolapse, assess cord pulsations" },
        { "name": "Cardiotocography (CTG)", "priority": "immediate", "yield": 0.9, "indication": "variable decelerations or bradycardia" }
      ],
      "laboratory": [],
