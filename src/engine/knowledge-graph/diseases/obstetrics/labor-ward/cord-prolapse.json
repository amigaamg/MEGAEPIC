    "management": {
      "protocolReference": "RCOG Green-top Guideline No. 50 - Umbilical Cord Prolapse",
      "pathways": [
        {
          "severity": "overt_with_bradycardia",
          "criteria": "cord palpable/visible, fetal bradycardia, cervix fully dilated",
          "treatment": "Immediate delivery: instrumental if fully dilated and feasible, otherwise category-1 C-section. Relieve cord pressure manually throughout. Avoid pushing."
        },
        {
          "severity": "overt_with_distress",
          "criteria": "cord prolapse, fetal heart rate abnormal, cervix not fully dilated",
          "treatment": "Category-1 C-section. Manual elevation of presenting part (two fingers in vagina). Knee-chest or Trendelenburg position. Bladder filling (500-700ml NS). Tocolysis (terbutaline 0.25mg SC). Arrange neonatal team."
        },
        {
          "severity": "occult_without_distress",
          "criteria": "variable decelerations, cord not palpable, reactive otherwise",
          "treatment": "Change position (left lateral, knee-chest). Monitor CTG. Vaginal exam to exclude overt prolapse. Prepare for emergency C-section."
        }
      ]
    },

    "pathophysiology": [
