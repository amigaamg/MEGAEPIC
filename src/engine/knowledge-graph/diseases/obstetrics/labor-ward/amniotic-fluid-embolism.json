    "management": {
      "protocolReference": "UKOSS / RCOG Guidelines on Amniotic Fluid Embolism",
      "pathways": [
        {
          "severity": "all_cases",
          "criteria": "cardiorespiratory collapse during labor or delivery",
          "treatment": "Multidisciplinary team response. High-flow oxygen / intubation and ventilation. CPR if cardiac arrest. IV fluids and vasopressors (noradrenaline, dobutamine). Treat DIC: transfusion of RBC, FFP, platelets, cryoprecipitate. Uterotonics for hemorrhage. Emergency delivery (C-section if not already delivered, preferably within 5 minutes of arrest). Consider ECMO in refractory cases. ICU admission. Discuss termination of pregnancy if antenatal."
        }
      ]
    },

