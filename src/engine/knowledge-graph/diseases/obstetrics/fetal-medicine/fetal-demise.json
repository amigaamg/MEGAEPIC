    "management": {
      "protocolReference": "RCOG Green-top Guideline No. 55 - Late Intrauterine Fetal Death and Stillbirth",
      "pathways": [
        {
          "severity": "uncomplicated_fetal_demise",
          "criteria": "recent demise, no DIC, no infection, no medical contraindication",
          "treatment": "Offer induction of labor (mifepristone 200mg PO, 24-48h later misoprostol 50mcg PV 4-hourly). Vaginal delivery preferred. Pain relief (epidural). Bereavement care: memory box, footprints, photos. Offer autopsy. Discuss future pregnancy planning."
        },
        {
          "severity": "complicated_fetal_demise",
          "criteria": "DIC, infection, or medical complication",
          "treatment": "Correct coagulopathy (FFP, cryoprecipitate). Treat infection (antibiotics). Induction of labor or evacuation (depending on gestation). Hysterotomy rarely needed. ICU if DIC/sepsis. Multidisciplinary approach."
        }
      ]
    },

