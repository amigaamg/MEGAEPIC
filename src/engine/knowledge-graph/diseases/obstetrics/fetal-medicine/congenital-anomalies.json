    "management": {
      "protocolReference": "NICE Guideline - Antenatal Care for Congenital Anomalies",
      "pathways": [
        {
          "severity": "minor_anomaly",
          "criteria": "isolated minor defect (e.g., single umbilical artery, choroid plexus cyst)",
          "treatment": "Counseling and reassurance. Follow-up scan in 4 weeks. No additional intervention required."
        },
        {
          "severity": "major_non_lethal",
          "criteria": "major defect compatible with life (e.g., spina bifida, CHD, diaphragmatic hernia)",
          "treatment": "Fetal medicine referral. Multidisciplinary meeting (obstetrics, neonatology, pediatric surgery, cardiology). Plan delivery at tertiary center with appropriate NICU. Offer termination if appropriate (within legal limits)."
        },
        {
          "severity": "lethal_anomaly",
          "criteria": "incompatible with life (e.g., anencephaly, bilateral renal agenesis, lethal skeletal dysplasia)",
          "treatment": "Counselling: offer termination of pregnancy. If continuing: perinatal palliative care plan. Comfort care at delivery. Avoid C-section. Bereavement support."
        }
      ]
    },

