      { "signId": "positive_ferning_pattern_on_microscopy", "baseWeight": 5 },
      { "signId": "positive_nitrazine_test", "baseWeight": 4 },
      { "signId": "decreased_amniotic_fluid_on_ultrasound", "baseWeight": 4 },
      { "signId": "fever", "baseWeight": 4 },
