    "name": "Preterm Premature Rupture of Membranes (PPROM)",
    "system": "OB",
    "agePeak_months": [240, 360],
    "note": "Rupture of fetal membranes before the onset of labor at <37 weeks of gestation. Major cause of preterm delivery. Risk of chorioamnionitis, cord prolapse, and neonatal complications.",
    "prevalenceWeight": 0.03,
    "syndromeTags": ["preterm_birth", "high_risk_pregnancy", "membrane_rupture"],

