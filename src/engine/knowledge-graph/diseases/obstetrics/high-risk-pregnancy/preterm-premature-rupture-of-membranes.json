        { "sign": "cord_prolapse", "weight": 10 },
        { "sign": "placental_abruption", "weight": 9 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "maternal_fever_over_38", "weight": 7 },
          { "sign": "fetal_tachycardia", "weight": 6 },
          { "sign": "uterine_tenderness", "weight": 7 },
          { "sign": "foul_smelling_discharge", "weight": 7 },
          { "sign": "significant_oligohydramnios", "weight": 5 },
          { "sign": "gestation_less_than_24_weeks", "weight": 7 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "Chorioamnionitis or <24 weeks -> SEVERE; Latent PPROM without infection -> NON-SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "sudden_gush_of_fluid_per_vaginum", "weight": 5 },
      { "symptomId": "constant_leakage_of_fluid", "weight": 5 },
      { "symptomId": "wet_pads_underwear", "weight": 4 },
      { "symptomId": "contractions_following_leak", "weight": 4 },
      { "symptomId": "fever", "weight": 3 },
      { "symptomId": "abdominal_pain", "weight": 3 },
      { "symptomId": "foul_smelling_discharge", "weight": 3 },
      { "symptomId": "reduced_fetal_movements", "weight": 2 },
      { "symptomId": "history_of_PPROM", "weight": 3 },
      { "symptomId": "previous_cervical_surgery", "weight": 2 }
    ],

    "examFeatures": [
