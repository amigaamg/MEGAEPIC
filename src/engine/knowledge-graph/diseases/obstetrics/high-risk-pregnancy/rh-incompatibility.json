          { "feature": "MCA_PSV_over_1_5_MoM", "weight": 5 },
          { "feature": "hydrops_on_ultrasound", "weight": 5 },
          { "feature": "previous_affected_pregnancy", "weight": 4 }
        ],
        "management": "Referral to fetal medicine. Intrauterine transfusion (IUT) via cordocentesis. Serial IUTs every 2-4 weeks. Plan delivery at 34-37 weeks. NICU team. Phototherapy and exchange transfusion for neonate."
      }
    ],

    "mimics": [
