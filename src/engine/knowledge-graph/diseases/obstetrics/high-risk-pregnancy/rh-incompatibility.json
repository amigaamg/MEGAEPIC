        "discriminators": ["family_history", "hemoglobin_electrophoresis", "no_antibodies"]
      }
    ],

    "investigations": {
      "bedside": [],
      "laboratory": [
        { "name": "Maternal blood group and Rh type", "priority": "immediate", "yield": 0.99, "indication": "first prenatal visit" },
        { "name": "Antibody screen (indirect Coombs)", "priority": "immediate", "yield": 0.95, "indication": "detect anti-D antibodies" },
        { "name": "Paternal blood group and genotype", "priority": "high", "yield": 0.8, "indication": "determine fetal Rh status risk" },
        { "name": "Fetal RhD genotyping from maternal blood (cfDNA)", "priority": "medium", "yield": 0.95, "indication": "non-invasive; if partner heterozygous" },
        { "name": "Amniotic fluid bilirubin (Delta OD450)", "priority": "historical", "yield": 0.7, "indication": "Liley curve; replaced by MCA Doppler" }
      ],
      "imaging": [
        { "name": "Middle cerebral artery Doppler PSV", "priority": "immediate", "yield": 0.9, "indication": "non-invasive assessment of fetal anemia" },
        { "name": "Fetal ultrasound for hydrops", "priority": "high", "yield": 0.8, "indication": "ascites, scalp edema, pleural/pericardial effusion" }
      ]
    },

    "management": {
      "protocolReference": "RCOG Green-top Guideline No. 22 - Haemolytic Disease of the Newborn",
      "pathways": [
        {
          "severity": "non_sensitized",
          "criteria": "Rh-negative, negative antibody screen",
          "treatment": "Rhogam (Anti-D 300mcg IM) at 28 weeks. Postpartum: Administer within 72h if baby Rh-positive. Administer after any sensitizing event (miscarriage, termination, invasive procedure, APH)."
        },
        {
          "severity": "sensitized_low_titer",
          "criteria": "antibodies detected, titer <1:16, normal MCA PSV",
          "treatment": "Monthly maternal antibody titers. Weekly MCA PSV from 24 weeks. If stable, allow spontaneous labor at term. Cord blood at delivery for Hb and bilirubin. Monitor neonate for jaundice."
        },
        {
          "severity": "sensitized_severe",
          "criteria": "titer >1:16, MCA PSV >1.5 MoM, hydrops, previous HDFN",
          "treatment": "Fetal medicine referral. Cordocentesis for fetal Hb. Intrauterine transfusion (IUT) of O-negative, CMV-negative, irradiated packed RBC. Serial IUTs until 34-37 weeks. Delivery by induction or C-section. NICU for anemia and jaundice. Exchange transfusion if severe."
        }
      ]
    },

    "pathophysiology": [
