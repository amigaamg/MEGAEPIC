    "subtypes": [
      {
        "id": "non_sensitized_rh_negative",
        "name": "Non-Sensitized Rh-Negative Mother",
        "prevalenceModifier": 0.85,
        "keyFeatures": [
          { "feature": "negative_antibody_screen", "weight": 5 },
          { "feature": "Rh_negative_blood_type", "weight": 5 },
          { "feature": "no_history_of_sensitization", "weight": 4 }
        ],
        "management": "Rhogam (Anti-D Ig) 300mcg IM at 28 weeks. Rhogam within 72h after delivery if baby Rh-positive. Also after miscarriage, termination, ectopic, invasive procedures, antepartum hemorrhage."
      },
      {
        "id": "sensitized_low_titer",
        "name": "Sensitized Mother with Low Antibody Titer",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
          { "feature": "anti_D_titers_1_1_to_1_8", "weight": 5 },
          { "feature": "no_hydrops", "weight": 4 },
          { "feature": "normal_MCA_PSV", "weight": 4 }
        ],
        "management": "Monthly antibody titers. Monitor MCA PSV weekly from 24 weeks. If titers rise to critical level (>1:16), refer for fetal therapy."
      },
      {
        "id": "sensitized_high_titer_with_anemia",
        "name": "Sensitized Mother with Fetal Anemia",
        "prevalenceModifier": 0.05,
        "keyFeatures": [
