    "management": {
      "protocolReference": "NICE Guideline NG133 - Hypertension in Pregnancy / WHO Guidelines",
      "pathways": [
        {
          "severity": "acute_seizure",
          "criteria": "active convulsion or post-ictal",
          "treatment": "ABC approach. Magnesium sulfate 4g IV over 5-10 min, then 1g/h infusion for 24h. Airway protection. Left lateral position. Oxygen. IV labetalol or hydralazine for BP >160/110. Diazepam 10mg IV if MgSO4 fails. Treat recurrence with 2g MgSO4 bolus."
        },
        {
          "severity": "post_stabilization",
          "criteria": "seizure controlled, BP stabilized",
          "treatment": "Plan delivery. If antepartum: deliver after stabilization regardless of gestation (C-section typically). Continue MgSO4 for 24h postpartum. IV antihypertensives until oral tolerated. ICU monitoring for 24h minimum."
        }
      ]
    },

