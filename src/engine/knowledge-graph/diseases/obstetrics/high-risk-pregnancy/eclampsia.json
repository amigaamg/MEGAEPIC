        { "name": "Urine protein dipstick", "priority": "high", "yield": 0.7, "indication": "proteinuria" },
        { "name": "Blood glucose", "priority": "immediate", "yield": 0.5, "indication": "rule out hypoglycemia" }
      ],
      "laboratory": [
        { "name": "Complete blood count", "priority": "immediate", "yield": 0.8, "indication": "platelet count" },
        { "name": "Liver function tests", "priority": "immediate", "yield": 0.8, "indication": "transaminases" },
        { "name": "Serum creatinine", "priority": "high", "yield": 0.7, "indication": "renal function" },
        { "name": "Coagulation profile", "priority": "high", "yield": 0.6, "indication": "DIC screen" },
