    "management": {
      "protocolReference": "ACOG / RCOG Guidelines for HELLP Syndrome",
      "pathways": [
        {
          "severity": "all_cases",
          "criteria": "confirmed HELLP syndrome",
          "treatment": "Stabilize: Magnesium sulfate for seizure prophylaxis. Antihypertensives for BP >160/110. Corticosteroids (Dexamethasone 10mg IV q12h) to improve platelet count (controversial). Delivery: the definitive treatment. Timing: Class 1: deliver immediately; Class 2: deliver within 24-48h; Class 3: deliver at 37w or if deteriorates. Anesthesia: avoid regional if platelets <75,000. Transfuse platelets if <20,000 or before surgical intervention."
        },
        {
          "severity": "postpartum_persistent",
          "criteria": "HELLP persisting >72h postpartum",
          "treatment": "Consider plasma exchange if not improving. Monitor for complications. Continue supportive care."
        }
      ]
