    "management": {
      "protocolReference": "NICE Guideline NG3 - Diabetes in Pregnancy",
      "pathways": [
        {
          "severity": "diet_controlled",
          "criteria": "fasting <5.3, 1h postprandial <7.8, 2h <6.7 mmol/L on diet alone",
          "treatment": "Medical nutrition therapy: low glycemic index diet, complex carbs, portion control. Exercise. Self-monitoring of BGL 4 times daily. Metformin if targets not met."
        },
        {
          "severity": "pharmacotherapy_required",
          "criteria": "fasting >5.3 or postprandial >7.8 despite diet",
          "treatment": "Metformin 500mg PO daily, titrate up to 2.5g/day. If not tolerated or insufficient, add or switch to insulin (NPH or long-acting for fasting, rapid-acting for meals). Glyburide second-line."
        },
        {
          "severity": "poorly_controlled",
          "criteria": "consistently high BGL, macrosomia, or polyhydramnios",
          "treatment": "Endocrinology referral. Intensive insulin therapy. Fetal surveillance (biophysical profile, Doppler). Increased antenatal monitoring. Plan delivery: induction at 38-39 weeks if on insulin. Avoid postterm pregnancy."
        }
      ]
    },

