    "subtypes": [
      {
        "id": "preeclampsia_without_severe_features",
        "name": "Preeclampsia Without Severe Features",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
          { "feature": "BP_140_90_to_159_109", "weight": 4 },
          { "feature": "proteinuria_over_300mg", "weight": 4 },
          { "feature": "no_end_organ_damage", "weight": 4 },
          { "feature": "maternal_and_fetal_stable", "weight": 3 }
        ],
        "management": "Outpatient monitoring if compliant. Twice-weekly BP and urine protein. Once-weekly platelet, LFT, creatinine. Fetal growth scans. Delivery at 37 weeks or earlier if deteriorates."
      },
      {
        "id": "preeclampsia_with_severe_features",
        "name": "Preeclampsia With Severe Features",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "BP_over_160_110", "weight": 5 },
          { "feature": "severe_headache", "weight": 4 },
          { "feature": "visual_disturbances", "weight": 4 },
          { "feature": "epigastric_pain", "weight": 4 },
          { "feature": "thrombocytopenia", "weight": 4 },
          { "feature": "impaired_liver_function", "weight": 4 }
        ],
        "management": "Hospital admission. Antihypertensives (labetalol, nifedipine, hydralazine). Magnesium sulfate seizure prophylaxis. Corticosteroids for fetal lung maturity if <34 weeks. Delivery planning (timing based on gestational age and severity)."
      }
    ],

    "mimics": [
      {
        "diseaseId": "chronic_hypertension",
        "discriminators": ["BP_elevated_before_20_weeks", "no_proteinuria"]
      },
      {
        "diseaseId": "gestational_hypertension",
        "discriminators": ["no_proteinuria", "no_end_organ_damage"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Blood pressure measurement", "priority": "immediate", "yield": 0.99, "indication": "diagnostic" },
        { "name": "Urine protein dipstick", "priority": "immediate", "yield": 0.8, "indication": "proteinuria screening" },
        { "name": "Weight measurement", "priority": "routine", "yield": 0.5, "indication": "assess fluid retention" }
      ],
      "laboratory": [
        { "name": "24-hour urine protein", "priority": "high", "yield": 0.9, "indication": "quantify proteinuria" },
        { "name": "Complete blood count", "priority": "high", "yield": 0.8, "indication": "platelet count, Hb, Hct" },
        { "name": "Liver function tests", "priority": "high", "yield": 0.8, "indication": "elevated transaminases" },
        { "name": "Serum creatinine", "priority": "high", "yield": 0.7, "indication": "renal function" },
        { "name": "Uric acid", "priority": "medium", "yield": 0.6, "indication": "elevated in preeclampsia" },
        { "name": "Coagulation profile", "priority": "medium", "yield": 0.5, "indication": "if severe or HELLP suspected" }
      ],
      "imaging": [
        { "name": "Fetal growth ultrasound", "priority": "medium", "yield": 0.7, "indication": "assess for IUGR" },
        { "name": "Umbilical artery Doppler", "priority": "medium", "yield": 0.6, "indication": "assess placental function" }
      ]
    },

    "management": {
      "protocolReference": "NICE Guideline NG133 - Hypertension in Pregnancy",
      "pathways": [
        {
          "severity": "without_severe_features",
          "criteria": "BP <160/110, no symptoms, normal labs, term or near-term",
          "treatment": "Antihypertensives (labetalol 100-200mg PO BD, nifedipine MR 10-20mg BD, or methyldopa). Twice-weekly monitoring. Delivery at 37-38 weeks. Magnesium sulfate not indicated."
        },
        {
          "severity": "with_severe_features",
          "criteria": "BP >160/110, severe headache, proteinuria, thrombocytopenia, elevated LFTs",
          "treatment": "Admit. IV labetalol (20mg IV then infusion) or oral nifedipine. Magnesium sulfate 4g IV loading then 1g/h infusion for 24h. Dexamethasone 12mg IM q12h x 2 doses if <34 weeks. Plan delivery (C-section or induction) after stabilization."
        },
        {
          "severity": "refractory",
          "criteria": "BP uncontrolled despite three agents, pulmonary edema, oliguric renal failure",
          "treatment": "ICU admission. IV hydralazine. Consider delivery regardless of gestational age. Invasive BP monitoring. Central line. Dialysis if AKI. Discuss with maternal-fetal medicine specialist."
        }
      ]
    },

    "pathophysiology": [
      "abnormal_placentation",
      "endothelial_dysfunction",
      "vasospasm",
      "increased_systemic_vascular_resistance",
      "imbalance_of_prostacyclin_and_thromboxane"
    ],

