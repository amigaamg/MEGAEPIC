        { "name": "Transvaginal ultrasound", "priority": "high", "yield": 0.95, "indication": "gold standard, safe when done carefully" },
        { "name": "MRI pelvis", "priority": "medium", "yield": 0.8, "indication": "if accreta spectrum suspected" }
      ]
