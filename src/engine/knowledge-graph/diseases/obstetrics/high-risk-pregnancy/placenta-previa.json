    "management": {
      "protocolReference": "RCOG Green-top Guideline No. 27 - Placenta Praevia",
      "pathways": [
        {
          "severity": "no_bleeding",
          "criteria": "asymptomatic, no current bleeding",
          "treatment": "Outpatient if compliant and reliable. Antenatal corticosteroids at 34-36 weeks (before planned CS). Avoid intercourse. Hospitalize if bleeding. Plan elective CS at 36-37 weeks for complete/partial, or 38-39 for marginal."
        },
        {
          "severity": "bleeding_stable",
          "criteria": "first bleed, stopped, mother and fetus stable",
          "treatment": "Admit for 24-48h observation. IV access. Cross-match blood. Betamethasone if 24-34 weeks. Monitor Hb. If stable, may discharge after 48h with activity restriction."
        },
        {
          "severity": "major_hemorrhage",
          "criteria": "heavy bleeding, unstable vitals, fetal distress",
          "treatment": "Emergency C-section regardless of gestation. IV fluids, blood transfusion. Multidisciplinary team (obstetric, anesthesiology, neonatalogy, blood bank). Consider uterine artery balloon occlusion. Hysterectomy if accreta."
        }
      ]
    },

    "pathophysiology": [
      "abnormal_placentation_in_lower_uterine_segment",
      "decidual_deficiency_in_upper_uterus",
      "impaired_migration_of_placenta",
