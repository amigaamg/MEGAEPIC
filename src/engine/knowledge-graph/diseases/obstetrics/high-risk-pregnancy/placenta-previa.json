          { "feature": "may_trial_of_labor_if_marginal", "weight": 3 }
        ],
        "management": "C-section typically. If marginal, may attempt vaginal delivery with caution."
      },
      {
        "id": "marginal_placenta_previa",
        "name": "Marginal Placenta Previa",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
