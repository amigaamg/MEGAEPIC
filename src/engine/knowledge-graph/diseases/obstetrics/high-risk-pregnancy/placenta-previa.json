          { "feature": "lower_risk_of_hemorrhage", "weight": 3 },
          { "feature": "vaginal_delivery_possible", "weight": 3 }
        ],
        "management": "May attempt vaginal delivery if bleeding minimal and fetal head well applied. Admit if bleeding. Steroids if preterm."
      },
      {
        "id": "low_lying_placenta",
        "name": "Low-Lying Placenta",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "placenta_in_lower_segment_but_os_not_covered", "weight": 4 },
          { "feature": "resolve_with_advancing_gestation", "weight": 3 },
          { "feature": "often_managed_expectantly", "weight": 3 }
        ],
        "management": "Repeat ultrasound at 32-36 weeks to assess resolution. If >2cm from os, vaginal delivery possible."
      }
