    "subtypes": [
      {
        "id": "complete_placenta_previa",
        "name": "Complete (Total) Placenta Previa",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "placenta_fully_covers_cervical_os", "weight": 5 },
          { "feature": "highest_risk_of_major_hemorrhage", "weight": 5 },
          { "feature": "always_requires_cs", "weight": 4 }
        ],
        "management": "Elective C-section at 36-37 weeks. Cross-match blood. Consider interventional radiology (uterine artery balloon). NICU team."
      },
      {
        "id": "partial_placenta_previa",
        "name": "Partial Placenta Previa",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
