    "management": {
      "protocolReference": "WHO / UNICEF Breastfeeding Guidelines",
      "pathways": [
        {
          "severity": "mild_to_moderate",
          "criteria": "bilateral fullness, mild pain, baby can still latch",
          "treatment": "Frequent breastfeeding (8-12 times/day). Ensure good latch. Warm compress before feeding. Cold compress after feeding. Gentle breast massage during feeds. Hand express if baby cannot latch."
        },
        {
          "severity": "severe",
          "criteria": "severe pain, flat nipples, baby unable to latch, skin tight",
          "treatment": "Express milk manually or with pump until soft enough for latch. Reverse pressure softening to exert nipple. Cold compresses between feeds. Analgesia (paracetamol, ibuprofen). Lactation consultant referral. Avoid stopping breastfeeding."
        }
      ]
    },

