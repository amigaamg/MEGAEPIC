{
  "disease": {
    "id": "mastitis",
    "name": "Lactational Mastitis",
    "system": "OB",
    "agePeak_months": [240, 360],
    "note": "Inflammation of breast tissue, usually due to milk stasis and bacterial infection (commonly Staphylococcus aureus). Occurs most frequently in the first 6 weeks postpartum.",
    "prevalenceWeight": 0.1,
    "syndromeTags": ["postpartum_infection", "breast_condition"],

    "severityAssessment": {
      "immediateDangerSigns": [
        { "sign": "septic_shock", "weight": 10 },
        { "sign": "abscess_formation", "weight": 8 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "high_fever_over_39", "weight": 7 },
          { "sign": "rigors", "weight": 6 },
          { "sign": "widespread_erythema", "weight": 5 },
          { "sign": "fluctuant_mass_abscess", "weight": 7 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "Abscess formation or sepsis -> SEVERE; Localized inflammation without abscess -> NON-SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "breast_pain_unilateral", "weight": 5 },
      { "symptomId": "breast_redness", "weight": 5 },
      { "symptomId": "breast_swelling", "weight": 4 },
      { "symptomId": "fever", "weight": 4 },
      { "symptomId": "rigors", "weight": 3 },
      { "symptomId": "malaise", "weight": 3 },
      { "symptomId": "nausea_vomiting", "weight": 2 },
      { "symptomId": "previous_mastitis", "weight": 2 },
      { "symptomId": "cracked_or_sore_nipple", "weight": 3 }
    ],

    "examFeatures": [
      { "signId": "breast_erythema_wedge_shaped", "baseWeight": 5, "doubleWeight": true },
      { "signId": "breast_tenderness_localized", "baseWeight": 4 },
      { "signId": "breast_warmth", "baseWeight": 4 },
      { "signId": "palpable_induration_or_mass", "baseWeight": 4 },
      { "signId": "fluctuance_abscess_suspected", "baseWeight": 5 },
      { "signId": "axillary_lymphadenopathy_tender", "baseWeight": 3 },
      { "signId": "fever", "baseWeight": 4 },
      { "signId": "nipple_fissure_or_crack", "baseWeight": 3 }
    ],

    "riskFactors": [
      { "id": "nipple_trauma_or_cracking", "multiplier": 3.0 },
      { "id": "previous_mastitis", "multiplier": 2.5 },
      { "id": "infrequent_feeding", "multiplier": 2.0 },
      { "id": "poor_latch_technique", "multiplier": 2.0 },
      { "id": "breast_engorgement", "multiplier": 2.0 },
      { "id": "milk_plugged_duct", "multiplier": 1.5 },
      { "id": "maternal_fatigue_or_stress", "multiplier": 1.3 },
      { "id": "immunosuppression", "multiplier": 2.0 }
    ],

    "subtypes": [
      {
        "id": "non_infectious_mastitis",
        "name": "Non-Infectious (Inflammatory) Mastitis",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "milk_stasis", "weight": 5 },
          { "feature": "no_systemic_symptoms", "weight": 4 },
          { "feature": "localized_breast_lump", "weight": 3 },
          { "feature": "symptoms_improve_with_feeding", "weight": 3 }
        ],
        "management": "Frequent breastfeeding from affected side first. Adequate emptying. Warm compresses before feeding. Cold compresses after. Analgesia (ibuprofen)."
      },
      {
        "id": "infectious_mastitis",
        "name": "Infectious Mastitis",
        "prevalenceModifier": 0.5,
        "keyFeatures": [
          { "feature": "fever_over_38_5", "weight": 5 },
          { "feature": "rigors", "weight": 4 },
          { "feature": "erythema_wedge_shaped", "weight": 5 },
          { "feature": "malaise_systemic", "weight": 4 }
        ],
        "management": "Antibiotics (Flucloxacillin 500mg QDS or Cephalexin 500mg QDS). Continue breastfeeding. Adequate rest and fluids. Analgesia."
      },
      {
        "id": "breast_abscess",
        "name": "Breast Abscess",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
          { "feature": "fluctuant_mass", "weight": 5 },
          { "feature": "persistent_fever_despite_antibiotics", "weight": 5 },
          { "feature": "severe_localized_pain", "weight": 5 },
          { "feature": "palpable_lump_3_cm", "weight": 4 }
        ],
        "management": "Incision and drainage (I&D) or needle aspiration under ultrasound guidance. Continue breastfeeding from unaffected breast. Antibiotics for 10-14 days. Wound care."
      }
    ],

    "mimics": [
      {
        "diseaseId": "breast_engorgement",
        "discriminators": ["bilateral", "no_fever", "diffuse_firmness", "early_postpartum"]
      },
      {
        "diseaseId": "inflammatory_breast_cancer",
        "discriminators": ["peau_d_orange", "no_fever", "non_lactational", "no_response_to_antibiotics"]
      }
    ],

    "investigations": {
      "bedside": [],
      "laboratory": [
        { "name": "Complete blood count", "priority": "medium", "yield": 0.6, "indication": "leukocytosis" },
        { "name": "CRP", "priority": "medium", "yield": 0.6, "indication": "elevated" },
        { "name": "Breast milk culture", "priority": "medium", "yield": 0.5, "indication": "identify pathogen if recurrent" },
        { "name": "Blood cultures", "priority": "low", "yield": 0.3, "indication": "if sepsis suspected" }
      ],
      "imaging": [
        { "name": "Breast ultrasound", "priority": "high", "yield": 0.9, "indication": "differentiate abscess from cellulitis" }
      ]
    },

    "management": {
      "protocolReference": "WHO / ABM Clinical Protocol on Mastitis",
      "pathways": [
        {
          "severity": "non_infectious",
          "criteria": "no fever, mild erythema, no systemic symptoms",
          "treatment": "Frequent effective milk removal. Continue breastfeeding. Warm compresses before nursing. Cold compresses after. Ibuprofen 400-800mg PO. Rest and hydration. Lactation consultation."
        },
        {
          "severity": "infectious",
          "criteria": "fever >38.5, rigors, systemic symptoms, wedge erythema",
          "treatment": "Flucloxacillin 500mg PO QDS (or Cephalexin if penicillin allergic). Continue breastfeeding from affected side (safe). Analgesia. Rest. Hydration. Review in 48h. If no improvement, consider abscess."
        },
        {
          "severity": "abscess",
          "criteria": "fluctuant mass on exam or ultrasound",
          "treatment": "Aspiration (needle or I&D) under ultrasound guidance. Culture of pus. IV antibiotics initially then oral. Continue breastfeeding from unaffected side; may continue from affected side if baby not distressed. Wound packing if I&D. Follow-up."
        }
      ]
    },

    "pathophysiology": [
      "milk_stasis",
      "bacterial_entry_via_nipple_fissure",
      "staphylococcus_aureus_colonization",
      "inflammatory_response"
    ],

    "complications": [
      {
        "diseaseId": "breast_abscess",
        "probability": 0.1,
        "lagDays": [2, 7],
        "severityBoost": 0.4,
        "clues": ["fluctuant_mass", "persistent_fever"]
      },
      {
        "diseaseId": "recurrent_mastitis",
        "probability": 0.15,
        "lagDays": [14, 365],
        "severityBoost": 0.2,
        "clues": ["same_or_contralateral_breast"]
      }
    ],

    "mustNotMiss": false,
    "emergencyPriority": "medium",
    "diagnosticClues": ["unilateral_breast_erythema", "fever", "lactating", "nipple_trauma"],
    "exclusionClues": ["bilateral_fullness_without_fever", "non_puerperal"]
  }
}
