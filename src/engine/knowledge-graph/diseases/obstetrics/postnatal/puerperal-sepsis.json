          { "feature": "flu_like_symptoms", "weight": 4 },
          { "feature": "palpable_mass", "weight": 4 }
        ],
        "management": "Antibiotics (Flucloxacillin or Cephalexin). Continue breastfeeding/expression. Ultrasound if abscess suspected. Incision and drainage if abscess."
      }
    ],

    "mimics": [
