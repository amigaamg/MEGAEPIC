    "subtypes": [
      {
        "id": "endometritis",
        "name": "Postpartum Endometritis",
        "prevalenceModifier": 0.5,
        "keyFeatures": [
          { "feature": "uterine_tenderness", "weight": 5 },
          { "feature": "foul_lochia", "weight": 5 },
          { "feature": "fever_within_48h_of_delivery", "weight": 5 },
          { "feature": "subinvolution", "weight": 3 }
        ],
        "management": "IV broad-spectrum antibiotics (Clindamycin + Gentamicin). IV fluids. Uterotonics if lochia heavy. Monitor for sepsis progression."
      },
      {
        "id": "wound_infection",
        "name": "Cesarean or Perineal Wound Infection",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
