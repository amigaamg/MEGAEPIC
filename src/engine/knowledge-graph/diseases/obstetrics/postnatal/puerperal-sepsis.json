        { "name": "Urine dipstick", "priority": "high", "yield": 0.5, "indication": "exclude UTI source" }
      ],
      "laboratory": [
        { "name": "Complete blood count", "priority": "immediate", "yield": 0.8, "indication": "WBC, platelets" },
        { "name": "CRP", "priority": "immediate", "yield": 0.8, "indication": "elevated" },
        { "name": "Blood cultures", "priority": "immediate", "yield": 0.6, "indication": "identify pathogen" },
        { "name": "Lactate", "priority": "immediate", "yield": 0.8, "indication": "tissue hypoperfusion marker" },
        { "name": "High vaginal swab culture", "priority": "high", "yield": 0.7, "indication": "identify organism" },
        { "name": "Wound swab culture", "priority": "medium", "yield": 0.7, "indication": "if wound infection" },
        { "name": "Urea and electrolytes", "priority": "high", "yield": 0.6, "indication": "renal function" }
      ],
      "imaging": [
        { "name": "Pelvic ultrasound", "priority": "medium", "yield": 0.6, "indication": "retained products, abscess" },
        { "name": "Chest X-ray", "priority": "medium", "yield": 0.4, "indication": "exclude pneumonia source" }
      ]
    },

    "management": {
      "protocolReference": "RCOG Green-top Guideline No. 64b - Sepsis in Pregnancy and Postpartum",
      "pathways": [
        {
          "severity": "localized_infection",
          "criteria": "focal wound infection or endometritis without systemic signs",
          "treatment": "Oral or IV antibiotics based on source. Wound care. Drain any collection. Monitor vital signs. Paracetamol for fever."
        },
        {
          "severity": "sepsis",
          "criteria": "qSOFA >=2, organ dysfunction, hypotension",
          "treatment": "Sepsis six: 1. High-flow oxygen. 2. Blood cultures. 3. IV broad-spectrum antibiotics (Piperacillin-Tazobactam or Meropenem + Gentamicin if severe). 4. IV fluids (30mL/kg crystalloid). 5. Check lactate. 6. Monitor urine output. Source control: wound debridement, drainage, D&C for retained products. ICU admission."
        },
        {
          "severity": "septic_shock",
          "criteria": "persistent hypotension despite fluid resuscitation, lactate >4",
          "treatment": "ICU. Vasopressors (Noradrenaline). Inotropes. Central line monitoring. Broad-spectrum IV antibiotics. Source control surgery. Multidisciplinary care (obstetric, ICU, microbiology)."
        }
      ]
    },

    "pathophysiology": [
      "ascending_infection_from_genital_tract",
      "wound_contamination",
      "bacterial_translocation",
      "systemic_inflammatory_response"
    ],

