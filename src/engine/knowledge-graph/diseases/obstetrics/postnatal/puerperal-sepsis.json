          { "feature": "wound_dehiscence", "weight": 4 },
          { "feature": "fever_localized", "weight": 3 }
        ],
        "management": "Wound exploration and drainage. Wound swab culture. Antibiotics according to culture results. Debridement if necrotic."
      },
      {
        "id": "mastitis_breast_abscess",
        "name": "Lactational Mastitis / Breast Abscess",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
