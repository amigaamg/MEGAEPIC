      { "signId": "vaginal_bleeding_heavy", "baseWeight": 5 },
      { "signId": "hypotension", "baseWeight": 5 },
      { "signId": "tachycardia", "baseWeight": 4 },
      { "signId": "pallor_conjunctival_palmar", "baseWeight": 4 },
      { "signId": "poor_capillary_refill", "baseWeight": 3 },
      { "signId": "oliguria", "baseWeight": 3 },
      { "signId": "signs_of_trauma_perineal_vaginal_cervical", "baseWeight": 4 }
    ],

    "riskFactors": [
