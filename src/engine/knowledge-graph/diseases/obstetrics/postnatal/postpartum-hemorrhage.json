{
  "disease": {
    "id": "postpartum_hemorrhage",
    "name": "Postpartum Hemorrhage",
    "system": "OB",
    "agePeak_months": [240, 360],
    "note": "Blood loss >500mL after vaginal delivery or >1000mL after cesarean section. Leading cause of maternal mortality worldwide. Most commonly due to uterine atony.",
    "prevalenceWeight": 0.05,
    "syndromeTags": ["postpartum_emergency", "maternal_hemorrhage"],

    "severityAssessment": {
      "immediateDangerSigns": [
        { "sign": "cardiac_arrest", "weight": 10 },
        { "sign": "hypovolemic_shock", "weight": 10 },
        { "sign": "unconsciousness", "weight": 10 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "blood_loss_over_1500ml", "weight": 9 },
          { "sign": "tachycardia_over_120", "weight": 7 },
          { "sign": "hypotension_systolic_below_90", "weight": 8 },
          { "sign": "oliguria", "weight": 7 },
          { "sign": "signs_of_shock", "weight": 8 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "Primary PPH: within 24h. Secondary PPH: 24h-12 weeks. Blood loss >1000mL or hemodynamic instability -> SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "heavy_vaginal_bleeding_postpartum", "weight": 5 },
      { "symptomId": "dizziness_lightheadedness", "weight": 4 },
