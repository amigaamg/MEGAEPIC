    "management": {
      "protocolReference": "NICE Guideline NG133 - Hypertension in Pregnancy",
      "pathways": [
        {
          "severity": "non-severe",
          "criteria": "BP 140-159/90-109, proteinuria, no severe features",
          "treatment": "Antihypertensives (labetalol, nifedipine, methyldopa). Twice weekly BP and protein monitoring. Fetal surveillance. Deliver at 37 weeks."
        },
        {
          "severity": "severe",
          "criteria": "BP >=160/110, or symptoms, or organ dysfunction",
          "treatment": "Urgent antihypertensive (IV labetalol or hydralazine, oral nifedipine). Magnesium sulfate for seizure prophylaxis. Corticosteroids for fetal lung maturity. Delivery after stabilization."
