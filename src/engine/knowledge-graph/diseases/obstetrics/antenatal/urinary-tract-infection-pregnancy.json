          { "feature": "frequency", "weight": 4 },
          { "feature": "suprapubic_pain", "weight": 3 },
          { "feature": "no_systemic_symptoms", "weight": 3 }
        ],
        "management": "Oral antibiotics: Nitrofurantoin (avoid in third trimester), Cephalexin, or Amoxicillin-clavulanate for 7 days."
      },
      {
        "id": "acute_pyelonephritis",
        "name": "Acute Pyelonephritis in Pregnancy",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
