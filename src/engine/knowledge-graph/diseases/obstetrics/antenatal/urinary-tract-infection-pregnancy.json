          { "feature": "CVA_tenderness", "weight": 5 },
          { "feature": "rigors", "weight": 4 },
          { "feature": "nausea_vomiting", "weight": 4 },
          { "feature": "dehydration", "weight": 3 }
        ],
        "management": "Hospital admission. IV fluids. IV antibiotics (Ceftriaxone 1-2g IV daily, or Cefazolin). Monitor for preterm labor. Switch to oral after 48h afebrile. Continue for 14 days."
