    "management": {
      "protocolReference": "ACOG Practice Bulletin on Urinary Tract Infections in Pregnancy",
      "pathways": [
        {
          "severity": "asymptomatic_bacteriuria",
          "criteria": "positive culture, no symptoms",
          "treatment": "Nitrofurantoin 100mg PO nocte x 7 days. Avoid in third trimester (risk of hemolytic anemia in newborn). Alternative: Cephalexin 500mg QID x 7 days."
        },
        {
          "severity": "cystitis",
          "criteria": "lower UTI symptoms, no fever or CVA tenderness",
          "treatment": "Oral antibiotics 7 days: Nitrofurantoin 100mg PO BD (first/second trimester) or Cephalexin 500mg PO QID. Urine culture after treatment."
        },
        {
          "severity": "pyelonephritis",
          "criteria": "fever, CVA tenderness, rigors, systemic symptoms",
          "treatment": "Admit. IV Ceftriaxone 1-2g daily. IV fluids. Antipyretics. Monitor fetal status. Switch to oral when afebrile 48h. Total 14-day course. Recurrent pyelonephritis: suppressive nitrofurantoin for rest of pregnancy."
        }
      ]
    },

