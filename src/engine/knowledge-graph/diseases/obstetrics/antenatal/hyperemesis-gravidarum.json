          { "condition": "onset_before_9_weeks", "suspectTB": false }
        ]
      },
      { "symptomId": "vomiting", "weight": 5 },
      { "symptomId": "inability_to_tolerate_food_or_fluids", "weight": 5 },
      { "symptomId": "weight_loss", "weight": 4 },
      { "symptomId": "fatigue", "weight": 3 },
      { "symptomId": "lightheadedness", "weight": 3 },
      { "symptomId": "reduced_urine_output", "weight": 3 },
      { "symptomId": "hypersalivation", "weight": 2 },
      { "symptomId": "food_aversions", "weight": 2 }
    ],

    "examFeatures": [
      { "signId": "dry_mucous_membranes", "baseWeight": 4, "doubleWeight": true },
      { "signId": "reduced_skin_turgor", "baseWeight": 4 },
      { "signId": "tachycardia", "baseWeight": 3 },
      { "signId": "hypotension_orthostatic", "baseWeight": 4 },
      { "signId": "ketonuria_on_dipstick", "baseWeight": 4 },
      { "signId": "poor_capillary_refill", "baseWeight": 3 }
    ],

    "riskFactors": [
      { "id": "primigravida", "multiplier": 1.5 },
      { "id": "family_history_hyperemesis", "multiplier": 2.0 },
