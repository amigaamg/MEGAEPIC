        "lagDays": [3, 7],
        "severityBoost": 0.4,
        "clues": ["confusion", "seizures", "lethargy"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "medium",
    "diagnosticClues": ["early_pregnancy_onset", "weight_loss", "ketonuria", "intractable_vomiting"],
    "exclusionClues": ["diarrhea_predominant", "fever", "abdominal_pain_severe", "vaginal_bleeding"]
  }
