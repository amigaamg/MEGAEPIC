        { "sign": "altered_consciousness", "weight": 10 },
        { "sign": "hypotension", "weight": 8 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "weight_loss_5_percent", "weight": 7 },
          { "sign": "ketonuria", "weight": 6 },
          { "sign": "electrolyte_imbalance", "weight": 7 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "Severe if dehydration, weight loss >5%, ketonuria, or electrolyte imbalance present"
    },

    "historyFeatures": [
