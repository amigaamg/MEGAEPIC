{
  "disease": {
    "id": "hyperemesis_gravidarum",
    "name": "Hyperemesis Gravidarum",
    "system": "OB",
    "agePeak_months": [240, 360],
    "note": "Severe nausea and vomiting in early pregnancy leading to dehydration, electrolyte imbalance, and weight loss. More severe than morning sickness.",
    "prevalenceWeight": 0.03,
    "syndromeTags": ["nausea_vomiting_pregnancy", "dehydration_pregnancy"],

    "severityAssessment": {
