        "management": "Bed rest, pelvic rest, avoid intercourse. Reassurance. Follow-up ultrasound in 1-2 weeks."
      },
      {
        "id": "inevitable_abortion",
        "name": "Inevitable Abortion",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "moderate_to_heavy_bleeding", "weight": 4 },
          { "feature": "open_cervical_os", "weight": 5 },
          { "feature": "painful_contractions", "weight": 4 },
          { "feature": "intact_membranes", "weight": 3 }
