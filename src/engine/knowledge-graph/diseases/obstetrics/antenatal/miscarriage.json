        { "name": "Speculum examination", "priority": "immediate", "yield": 0.9, "indication": "assess bleeding, os status, products of conception" }
      ],
      "laboratory": [
        { "name": "Serum beta-hCG", "priority": "immediate", "yield": 0.95, "indication": "quantitative, serial levels to assess viability" },
        { "name": "Complete blood count", "priority": "high", "yield": 0.8, "indication": "assess blood loss, infection" },
        { "name": "Blood group and Rh type", "priority": "high", "yield": 0.99, "indication": "Rhogam candidacy" },
        { "name": "CRP", "priority": "medium", "yield": 0.6, "indication": "if infection suspected" }
      ],
      "imaging": [
        { "name": "Transvaginal Ultrasound", "priority": "immediate", "yield": 0.95, "indication": "assess gestational sac, fetal pole, cardiac activity" }
      ]
    },

    "management": {
      "protocolReference": "NICE Guideline NG126 - Ectopic Pregnancy and Miscarriage",
      "pathways": [
        {
          "severity": "threatened",
          "criteria": "closed os, minimal bleeding, viable pregnancy",
          "treatment": "Reassurance, pelvic rest. Rhogam if Rh-negative. Serial beta-hCG in 48 hours if uncertain viability."
        },
        {
          "severity": "confirmed_miscarriage",
          "criteria": "open os, incomplete/missed/inevitable abortion",
          "treatment": "Surgical: D&C or MVA. Medical: Misoprostol 800mcg vaginally (single dose or repeat). Expectant: monitor for spontaneous passage. Rhogam for Rh-negative. Anti-D immunoglobulin."
        },
        {
          "severity": "septic",
          "criteria": "fever, foul discharge, uterine tenderness",
          "treatment": "IV broad-spectrum antibiotics (e.g., Piperacillin-Tazobactam or Clindamycin + Gentamicin). Urgent surgical evacuation. ICU admission for shock. Monitor for DIC."
        }
      ]
    },

