    "investigations": {
      "bedside": [
        { "name": "Clinical phenotyping and photography", "priority": "routine", "yield": 0.7, "indication": "all suspected — document Cushingoid features" }
      ],
      "laboratory": [
        { "name": "24-hour urinary free cortisol (UFC)", "priority": "first_line", "yield": 0.85, "indication": "screening — measure 2-3 collections" },
        { "name": "1 mg overnight dexamethasone suppression test (ODST)", "priority": "first_line", "yield": 0.9, "indication": "screening — cortisol <1.8 mcg/dL suppresses in normal" },
        { "name": "Late-night salivary cortisol", "priority": "screening", "yield": 0.85, "indication": "loss of circadian rhythm" },
        { "name": "Plasma ACTH", "priority": "high", "yield": 0.8, "indication": "differentiates ACTH-dependent vs independent" },
        { "name": "High-dose dexamethasone suppression test (HDDST)", "priority": "confirmatory", "yield": 0.8, "indication": "suppression >50% suggests pituitary origin" },
        { "name": "Serum electrolytes", "priority": "routine", "yield": 0.4, "indication": "hypokalaemia suggests ACTH-dependent" },
        { "name": "Fasting glucose and HbA1c", "priority": "routine", "yield": 0.5, "indication": "screen for secondary diabetes" },
        { "name": "Bone profile and vitamin D", "priority": "routine", "yield": 0.3, "indication": "assess osteoporosis risk" },
        { "name": "Lipid profile", "priority": "routine", "yield": 0.3, "indication": "dyslipidaemia screening" }
      ],
      "imaging": [
        { "name": "Pituitary MRI (thin-slice, with gadolinium)", "priority": "high", "yield": 0.7, "indication": "identify pituitary microadenoma (may be negative in 30%)" },
        { "name": "CRH stimulation test with bilateral inferior petrosal sinus sampling (BIPSS)", "priority": "if_MRI_negative", "yield": 0.9, "indication": "definitive differentiation pituitary vs ectopic ACTH" },
        { "name": "CT chest/abdomen", "priority": "if_ectopic_suspected", "yield": 0.6, "indication": "search for ectopic ACTH source (small cell lung, carcinoid)" },
        { "name": "DEXA scan (bone densitometry)", "priority": "to_assess_complications", "yield": 0.7, "indication": "assess osteoporosis severity" }
      ],
      "advanced": [
        { "name": "Inferior petrosal sinus sampling (IPSS)", "indication": "gold standard for pituitary vs ectopic ACTH", "priority": "tertiary" },
        { "name": "Genetic testing for MEN1", "indication": "if family history or other MEN features", "priority": "selective" }
      ]
    },
    "management": {
      "protocolReference": "Endocrine Society Clinical Practice Guideline — Cushing's Syndrome, 2024",
      "pathways": [
        {
          "severity": "mild_to_moderate",
          "criteria": "UFC mild elevation, gradual onset, no severe complications",
          "treatment": [
            "First-line: Transsphenoidal adenomectomy (TSS) by experienced neurosurgeon",
            "If TSS successful: monitor for secondary adrenal insufficiency (need steroid coverage)",
            "If TSS fails or not possible: medical therapy",
            "Steroidogenesis inhibitors: Ketoconazole 200 mg PO TID or Metapyrone 250-500 mg PO QID",
            "Titrate based on cortisol levels and tolerance"
          ],
          "reassessment": "Reassess 24h UFC and clinical features every 4-8 weeks"
        },
        {
          "severity": "severe_acute",
          "criteria": "Severe hypercortisolism, significant complications (psychosis, fractures, hypertension crisis)",
          "treatment": [
            "Admit for urgent management",
            "Ketoconazole + Metapyrone combination therapy for rapid cortisol reduction",
            "Mifepristone (RU-486) 300-600 mg PO daily if severe symptomatic Cushing's",
            "Treat complications: antihypertensives, insulin for diabetes, bisphosphonates for bone protection",
            "If life-threatening: bilateral adrenalectomy as definitive treatment",
            "Post-bilateral adrenalectomy: lifelong glucocorticoid and mineralocorticoid replacement"
          ]
        },
        {
          "severity": "post_operative",
          "criteria": "After successful pituitary surgery",
          "treatment": [
            "Hydrocortisone 10-15 mg/m2/day PO in 2-3 divided doses (stress dosing for illness)",
            "Taper hydrocortisone over 6-18 months as HPA axis recovers",
            "Monitor morning cortisol periodically to assess recovery",
            "Endocrinology follow-up every 3 months for first year"
          ]
        }
      ],
      "specialConsiderations": {
        "wheeze_branch": "Not applicable",
        "HIV_exposed": "Ketoconazole may interact with ARVs; check drug interactions",
        "SAM": "Not applicable"
      }
    },
    "treatmentResponseLogic": {
      "triggers": [
        {
          "timePoint": "2 weeks post-TSS",
          "ifNoImprovement": { "actions": ["Check morning cortisol and UFC", "If cortisol still elevated, check for residual adenoma", "Consider repeat MRI and/or medical therapy"] }
