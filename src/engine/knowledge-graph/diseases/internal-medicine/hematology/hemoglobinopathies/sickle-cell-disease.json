        { "sign": "aplastic_crisis", "weight": 9 },
        { "sign": "splenic_sequestration", "weight": 10 }
      ],
      "severeCriteria": {
        "anyDangerSign": true
      },
      "nonSevereCriteria": {
        "noDangerSigns": true,
        "pain_controlled": true
      },
      "severityLabel": "If crisis complications (ACS, stroke, sequestration) -> EMERGENCY; else -> URGENT"
    },

    "historyFeatures": [
      { "symptomId": "painful_crisis", "weight": 5, "note": "Dactylitis, bone pain, chest pain" },
