      { "symptomId": "dyspnea", "weight": 3 },
      { "symptomId": "jaundice", "weight": 3 },
      { "symptomId": "fever", "weight": 3 },
      { "symptomId": "leg_ulcers", "weight": 2 },
      { "symptomId": "recurrent_infections", "weight": 3 },
      { "symptomId": "stroke_tia", "weight": 2 },
      { "symptomId": "priapism", "weight": 2 }
    ],

    "examFeatures": [
      { "signId": "pallor", "baseWeight": 4 },
      { "signId": "jaundice", "baseWeight": 4 },
      { "signId": "splenomegaly", "baseWeight": 3, "note": "In young children; autosplenectomy in adults" },
      { "signId": "tachycardia", "baseWeight": 3 },
      { "signId": "leg_ulcers", "baseWeight": 2 },
      { "signId": "systolic_murmur", "baseWeight": 2 },
