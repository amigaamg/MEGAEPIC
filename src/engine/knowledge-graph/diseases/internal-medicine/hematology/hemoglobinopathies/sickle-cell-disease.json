    ],

    "subtypes": [
      {
        "id": "hbss",
        "name": "HbSS (Sickle Cell Anemia)",
        "prevalenceModifier": 0.65,
        "keyFeatures": [
          { "feature": "hemoglobin_s_only", "weight": 5 },
          { "feature": "most_severe_phenotype", "weight": 5 }
        ],
        "management": "Hydroxyurea first-line to reduce crisis frequency. Chronic transfusions for stroke prevention."
      },
      {
        "id": "hbsc",
        "name": "HbSC Disease",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
          { "feature": "milder_anemia", "weight": 3 },
          { "feature": "higher_risk_of_retinopathy", "weight": 3 }
        ],
        "management": "Hydroxyurea less effective. Symptomatic management."
      },
      {
        "id": "hbs_beta_thal",
        "name": "HbS/Beta Thalassemia",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
          { "feature": "variable_severity", "weight": 4 },
          { "feature": "microcytic_indices", "weight": 3 }
        ],
        "management": "Hydroxyurea. Transfusion if severe."
      }
    ],

    "mimics": [],

    "investigations": {
      "bedside": [
        { "name": "Full blood count", "priority": "immediate", "yield": 0.9, "indication": "Hb 6-9, reticulocytosis" },
        { "name": "Blood film", "priority": "immediate", "yield": 0.95, "indication": "Sickle cells, target cells, Howell-Jolly bodies" },
        { "name": "Sickle cell solubility test", "priority": "high", "yield": 0.9, "indication": "Rapid screening" }
      ],
      "laboratory": [
        { "name": "Hb electrophoresis / HPLC", "priority": "immediate", "yield": 0.99, "indication": "Confirm diagnosis and phenotype" },
        { "name": "Reticulocyte count", "priority": "high", "yield": 0.8, "indication": "High in steady state" },
        { "name": "Bilirubin, LDH, haptoglobin", "priority": "high", "yield": 0.7, "indication": "Hemolysis markers" },
        { "name": "Blood culture", "priority": "high", "yield": 0.3, "indication": "If febrile, rule out sepsis" }
      ],
      "imaging": [
        { "name": "Chest X-ray", "priority": "immediate", "yield": 0.6, "indication": "Rule out acute chest syndrome" },
        { "name": "Transcranial Doppler", "priority": "high", "yield": 0.7, "indication": "Stroke risk screening in children" }
      ]
    },

    "management": {
      "protocolReference": "NHLBI / BSH Guidelines for Sickle Cell Disease",
      "pathways": [
        {
          "severity": "vaso_occlusive_crisis",
          "criteria": "Acute pain, no complications",
          "treatment": "IV fluids, oxygen if hypoxic, NSAIDs and opioids. Antibiotics if febrile. Incentive spirometry. Hydroxyurea if recurrent crises."
        },
        {
          "severity": "acute_chest_syndrome",
          "criteria": "Fever, chest pain, hypoxia, new infiltrate on CXR",
          "treatment": "IV antibiotics (cephalosporin + macrolide). Transfusion (simple or exchange). Bronchodilators if wheezing."
        },
        {
          "severity": "splenic_sequestration",
          "criteria": "Rapid splenic enlargement, Hb drop >2",
          "treatment": "PRBC transfusion. Splenectomy if recurrent. Avoid palpating spleen to prevent rupture."
        }
      ]
    },

    "pathophysiology": [
      "hb_s_polymerization",
      "rbc_sickling",
      "vaso_occlusion",
      "hemolysis",
      "chronic_anemia",
      "endothelial_damage",
      "ischemia_reperfusion_injury"
    ],

    "complications": [
