      "pathways": [
        {
          "severity": "febrile_neutropenia_emergency",
          "criteria": "Temperature >38.3°C, ANC <500",
          "treatment": "IV broad-spectrum antibiotics (piperacillin-tazobactam) within 60 min. Blood and urine cultures. CXR. G-CSF. Hospitalize. Consider antifungal if persistent fever >4 days."
