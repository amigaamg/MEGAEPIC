        { "sign": "transformation_to_aml", "weight": 10 },
        { "sign": "severe_anemia_hb_below_6", "weight": 8 }
      ],
      "severeCriteria": {
        "anyDangerSign": true
      },
      "nonSevereCriteria": {
        "noDangerSigns": true,
        "stable_counts": true
      },
      "severityLabel": "If severe cytopenia or AML transformation -> EMERGENCY; else -> URGENT"
    },

    "historyFeatures": [
      { "symptomId": "fatigue", "weight": 5 },
      { "symptomId": "dyspnea", "weight": 3 },
      { "symptomId": "pallor", "weight": 4 },
      { "symptomId": "easy_bruising", "weight": 3 },
