          { "feature": "high_ipss_r_risk", "weight": 5 },
          { "feature": "high_aml_transformation_risk", "weight": 4 }
        ],
        "management": "Hypomethylating agents (azacitidine). Consider HSCT if fit. Clinical trials."
      }
    ],

    "mimics": [
