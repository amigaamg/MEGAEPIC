        "diseaseId": "vitamin_b12_folate_deficiency",
        "discriminators": ["normal_b12_folate", "normal_mcv_unless_mds_with_high_mcv", "no_hypersegmented_neutrophils"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Full blood count", "priority": "immediate", "yield": 0.9, "indication": "Cytopenias, macrocytosis" },
        { "name": "Blood film", "priority": "immediate", "yield": 0.85, "indication": "Dysplastic features, blasts if present" }
      ],
      "laboratory": [
        { "name": "Bone marrow aspirate and trephine", "priority": "immediate", "yield": 0.98, "indication": "Dysplasia, blast count, cellularity" },
        { "name": "Cytogenetics / FISH", "priority": "immediate", "yield": 0.8, "indication": "5q-, 7q-, -7, +8, complex karyotype" },
        { "name": "Iron stain (Prussian blue)", "priority": "high", "yield": 0.6, "indication": "Ring sideroblasts in MDS-RS" },
        { "name": "Serum erythropoietin", "priority": "medium", "yield": 0.5, "indication": "Predicts ESA response" }
      ],
      "imaging": []
    },

    "management": {
      "protocolReference": "NCCN / ELN Guidelines for MDS",
      "pathways": [
        {
          "severity": "low_risk_mds",
          "criteria": "IPSS-R very low, low, or intermediate",
          "treatment": "Supportive care. ESA if anemia and EPO <500. G-CSF if neutropenia and infections. Lenalidomide if 5q-."
