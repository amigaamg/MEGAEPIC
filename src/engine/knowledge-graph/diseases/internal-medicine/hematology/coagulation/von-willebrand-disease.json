{
  "disease": {
    "id": "von_willebrand_disease",
    "name": "Von Willebrand Disease",
    "system": "hematology",
    "agePeak_months": [12, 180, 360, 480],
    "note": "Most common inherited bleeding disorder. Caused by quantitative or qualitative deficiency of von Willebrand factor. Presents with mucocutaneous bleeding, menorrhagia, and prolonged bleeding after surgery.",
    "prevalenceWeight": 0.2,
    "syndromeTags": ["coagulopathy", "bleeding", "mucocutaneous"],

    "severityAssessment": {
      "immediateDangerSigns": [
        { "sign": "intracranial_hemorrhage", "weight": 10 },
        { "sign": "gi_bleeding", "weight": 8 },
        { "sign": "hemodynamic_instability", "weight": 9 },
        { "sign": "post_surgical_bleeding", "weight": 8 }
      ],
      "severeCriteria": {
        "anyDangerSign": true
      },
      "nonSevereCriteria": {
        "noDangerSigns": true,
        "skin_bleeding_only": true
      },
      "severityLabel": "If intracranial or major bleeding -> EMERGENCY; else -> NON-URGENT"
    },

    "historyFeatures": [
      { "symptomId": "epistaxis", "weight": 5 },
      { "symptomId": "easy_bruising", "weight": 4 },
      { "symptomId": "menorrhagia", "weight": 5, "note": "Often presenting feature in women" },
      { "symptomId": "prolonged_bleeding_after_dental_extraction", "weight": 4 },
      { "symptomId": "post_surgical_bleeding", "weight": 4 },
      { "symptomId": "gingival_bleeding", "weight": 3 },
      { "symptomId": "gi_bleeding", "weight": 2 },
      { "symptomId": "family_history_of_bleeding", "weight": 4 },
      { "symptomId": "hemarthrosis", "weight": 1, "note": "Only in severe type 3" }
    ],

    "examFeatures": [
      { "signId": "ecchymoses", "baseWeight": 4 },
      { "signId": "petechiae", "baseWeight": 3 },
      { "signId": "oral_mucosal_petechiae", "baseWeight": 2 },
      { "signId": "signs_of_gi_bleeding", "baseWeight": 2 }
    ],

    "riskFactors": [
      { "id": "family_history_vwd", "multiplier": 5.0 },
      { "id": "blood_group_o", "multiplier": 1.5 },
      { "id": "hypothyroidism", "multiplier": 1.5, "note": "Acquired vWD" },
      { "id": "aortic_stenosis", "multiplier": 1.3, "note": "Heyde syndrome" }
    ],

    "subtypes": [
      {
        "id": "type_1_vwd",
        "name": "Type 1 VWD",
        "prevalenceModifier": 0.7,
        "keyFeatures": [
          { "feature": "partial_quantitative_vwf_deficiency", "weight": 5 },
          { "feature": "autosomal_dominant", "weight": 4 },
          { "feature": "mild_to_moderate_bleeding", "weight": 4 }
        ],
        "management": "DDAVP trial. Tranexamic acid for mucosal bleeds. VWF-containing concentrates for major surgery."
      },
      {
        "id": "type_2_vwd",
        "name": "Type 2 VWD",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "qualitative_vwf_defect", "weight": 5 },
          { "feature": "autosomal_dominant", "weight": 3 },
          { "feature": "reduced_vwf_function_to_antigen_ratio", "weight": 4 }
        ],
        "management": "VWF-containing concentrates (not DDAVP-responsive in type 2B). Avoid DDAVP in type 2B (may worsen thrombocytopenia)."
      },
      {
        "id": "type_3_vwd",
        "name": "Type 3 VWD (Severe)",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
          { "feature": "complete_vwf_deficiency", "weight": 5 },
          { "feature": "autosomal_recessive", "weight": 4 },
          { "feature": "severe_bleeding_similar_to_hemophilia", "weight": 5 }
        ],
        "management": "VWF-containing factor concentrates. Tranexamic acid. Avoid DDAVP (ineffective). Genetic counseling."
      }
    ],

    "mimics": [
      {
        "diseaseId": "hemophilia_a",
        "discriminators": ["hemarthrosis_common", "low_fviii", "normal_vwf_antigen"]
      },
      {
        "diseaseId": "platelet_function_disorder",
        "discriminators": ["normal_vwf_studies", "abnormal_platelet_aggregation"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Bleeding time", "priority": "medium", "yield": 0.7, "indication": "Prolonged (outdated, but still used in some settings)" }
      ],
      "laboratory": [
        { "name": "vWF antigen", "priority": "immediate", "yield": 0.95, "indication": "Low in VWD" },
        { "name": "vWF activity (ristocetin cofactor)", "priority": "immediate", "yield": 0.95, "indication": "Low in VWD" },
        { "name": "Factor VIII activity", "priority": "high", "yield": 0.8, "indication": "May be low (FVIII stabilized by vWF)" },
        { "name": "aPTT", "priority": "high", "yield": 0.6, "indication": "May be prolonged if FVIII low" },
        { "name": "vWF multimer analysis", "priority": "medium", "yield": 0.8, "indication": "Differentiates type 1 vs type 2" },
        { "name": "Platelet count", "priority": "medium", "yield": 0.4, "indication": "May be low in type 2B" }
      ],
      "imaging": []
    },

    "management": {
      "protocolReference": "ASH / BSH Guidelines for von Willebrand Disease",
      "pathways": [
        {
          "severity": "major_bleeding_or_surgery",
          "criteria": "Active major bleeding or planned major surgery",
          "treatment": "VWF-containing factor concentrate (Humate-P). Target vWF activity >50-100%. Tranexamic acid adjunct."
        },
        {
          "severity": "mild_mucosal_bleeding",
          "criteria": "Epistaxis, menorrhagia, gingival bleeding",
          "treatment": "Tranexamic acid PO/IV. DDAVP if type 1. Nasal packing if epistaxis. Hormonal therapy for menorrhagia."
        }
      ]
    },

    "pathophysiology": [
      "vwf_gene_deletion_or_mutation",
      "reduced_vwf_levels_or_function",
      "impaired_platelet_adhesion",
      "reduced_factor_viii_stabilization",
      "mucocutaneous_bleeding_diathesis"
    ],

    "complications": [
      {
        "diseaseId": "severe_menorrhagia",
        "probability": 0.3,
        "severityBoost": 0.3,
        "clues": ["heavy_menstrual_bleeding", "low_ferritin", "iron_deficiency"]
      }
    ],

    "mustNotMiss": false,
    "emergencyPriority": "low",
    "diagnosticClues": ["mucocutaneous_bleeding", "low_vwf", "family_history", "prolonged_bleeding_time"],
    "exclusionClues": ["normal_vwf_studies", "abnormal_platelet_count"]
  }
}
