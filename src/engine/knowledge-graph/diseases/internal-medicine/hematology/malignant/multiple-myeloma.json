        { "name": "Serum calcium", "priority": "immediate", "yield": 0.5, "indication": "Hypercalcemia" }
      ],
      "laboratory": [
        { "name": "Serum protein electrophoresis (SPEP)", "priority": "immediate", "yield": 0.95, "indication": "M-spike in gamma region" },
        { "name": "Serum free light chains", "priority": "immediate", "yield": 0.9, "indication": "Abnormal kappa/lambda ratio" },
        { "name": "Immunofixation", "priority": "high", "yield": 0.98, "indication": "Confirm heavy and light chain type" },
        { "name": "Bone marrow aspirate and trephine", "priority": "immediate", "yield": 0.98, "indication": "Plasmacytosis >10%, CD138+" },
        { "name": "Beta-2 microglobulin", "priority": "high", "yield": 0.7, "indication": "Prognostic (ISS staging)" },
        { "name": "Creatinine and eGFR", "priority": "immediate", "yield": 0.5, "indication": "Renal function assessment" }
      ],
      "imaging": [
        { "name": "Whole body low-dose CT or PET-CT", "priority": "high", "yield": 0.85, "indication": "Lytic bone lesions" },
        { "name": "MRI spine/pelvis", "priority": "medium", "yield": 0.8, "indication": "If suspected cord compression" }
      ]
    },

    "management": {
      "protocolReference": "NCCN / IMWG Guidelines for Multiple Myeloma",
      "pathways": [
        {
          "severity": "transplant_eligible",
          "criteria": "Age <70, fit, no major comorbidities",
          "treatment": "Induction: VRd (bortezomib, lenalidomide, dexamethasone). Autologous HSCT. Maintenance lenalidomide."
        },
        {
          "severity": "transplant_ineligible",
          "criteria": "Age >70 or unfit",
          "treatment": "DRd (daratumumab, lenalidomide, dexamethasone) or VMP (bortezomib, melphalan, prednisone). Continuous therapy."
        },
        {
          "severity": "emergency_hypercalcemia_cord_compression",
          "criteria": "Calcium >3.5, cord compression, acute renal failure",
          "treatment": "IV hydration, bisphosphonates (zoledronic acid), dexamethasone. Urgent radiotherapy if cord compression. Hemodialysis if renal failure."
        }
      ]
