    "management": {
      "protocolReference": "NCCN / COG / UKALL Guidelines for ALL",
      "pathways": [
        {
          "severity": "induction",
          "criteria": "Newly diagnosed ALL",
          "treatment": "Multi-agent chemotherapy: vincristine, corticosteroid, anthracycline, L-asparaginase. CNS prophylaxis with IT methotrexate."
        },
        {
          "severity": "ph_positive_all",
          "criteria": "t(9;22) positive ALL",
          "treatment": "Add tyrosine kinase inhibitor (imatinib or dasatinib) to chemo. Consider HSCT in first remission."
        },
        {
          "severity": "relapsed",
          "criteria": "Relapsed/refractory ALL",
          "treatment": "Blinatumomab, inotuzumab ozogamicin, CAR-T therapy (tisagenlecleucel). HSCT if response achieved."
        }
      ]
    },

    "pathophysiology": [
