    "investigations": {
      "bedside": [
        { "name": "Full blood count", "priority": "immediate", "yield": 0.95, "indication": "Cytopenias, blasts, high WBC" },
        { "name": "Blood film", "priority": "immediate", "yield": 0.95, "indication": "Lymphoblasts, PAS positive" }
      ],
      "laboratory": [
        { "name": "Bone marrow aspirate", "priority": "immediate", "yield": 0.99, "indication": "Blasts >25%, immunophenotyping" },
        { "name": "Flow cytometry", "priority": "immediate", "yield": 0.99, "indication": "CD19, CD10, CD3, TdT" },
