    "management": {
      "protocolReference": "BSH Guidelines for PNH; International PNH Interest Group",
      "pathways": [
        {
          "severity": "mild_no_thrombosis",
          "criteria": "No thrombosis, LDH <3x ULN, Hb >10, mild symptoms",
          "treatment": "Observation. Folic acid 5mg PO daily. Iron supplementation if iron deficient. Vaccinations (meningococcal, pneumococcal, Hib) if eculizumab anticipated. Avoid oral contraceptives (increases thrombosis risk). Monitor clone size and LDH q3-6 months."
        },
        {
          "severity": "moderate_to_severe_or_thrombosis",
          "criteria": "LDH >3x ULN, Hb <9, fatigue, hemoglobinuria, thrombosis, or any complication",
          "treatment": "First-line: eculizumab (C5 inhibitor) IV: 600mg weekly x4, then 900mg q2 weeks. Meningococcal vaccination required before start (plus penicillin prophylaxis). Reduces hemolysis, transfusion need, and thrombosis risk. Ravulizumab (long-acting C5 inhibitor) is alternative: 300kg loading, then 600mg q8 weeks. If thrombosis: anticoagulation (warfarin or DOAC) + eculizumab. Supportive: blood transfusion, folic acid, iron. Hematopoietic stem cell transplant: only curative option; reserved for severe, refractory, or PNH-aplastic anemia syndrome."
        }
      ]
