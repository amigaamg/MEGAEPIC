    "management": {
      "protocolReference": "NPIS Guidelines / NICE Guideline NG251 / Rumack-Matthew Nomogram",
      "pathways": [
        {
          "severity": "early (<24h) with toxic level",
          "criteria": "paracetamol level above treatment line on nomogram, or staggered overdose >75mg/kg/24h",
          "treatment": "N-acetylcysteine (NAC): 150mg/kg in 200mL D5W over 1h, then 50mg/kg in 500mL over 4h, then 100mg/kg in 1000mL over 16h. Activated charcoal 50g if within 1h of ingestion (and airway protected). Repeat ALT/INR at end of NAC course. Continue NAC if rising ALT or INR."
        },
        {
          "severity": "late presentation or established hepatotoxicity",
          "criteria": "presentation >24h, or ALT >1000, or INR >1.5",
          "treatment": "Start NAC immediately regardless of level. Continue NAC until improvement (ALT falling, INR improving). Assess for liver transplant: Kings College Criteria (pH <7.3, INR >6.5, Cr >300, grade 3-4 encephalopathy). Transplant center referral if criteria met."
        }
      ]
