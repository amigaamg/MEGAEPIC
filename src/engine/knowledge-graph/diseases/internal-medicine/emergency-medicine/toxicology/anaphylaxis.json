      { "id": "food_allergy_children", "multiplier": 2.0 },
      { "id": "drug_allergy", "multiplier": 2.0 }
    ],

    "subtypes": [
      {
        "id": "anaphylactic_shock",
        "name": "Anaphylactic Shock",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "hypotension", "weight": 5 },
          { "feature": "collapse", "weight": 5 },
          { "feature": "poor_response_to_fluids", "weight": 4 }
        ],
        "management": "IM Epinephrine 0.01 mg/kg (max 0.5 mg) every 5-15 min. IV fluids bolus. IV epinephrine infusion if refractory. ICU admission."
      },
      {
        "id": "anaphylaxis_with_bronchospasm",
        "name": "Anaphylaxis with Bronchospasm",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
