        { "sign": "severe_hypoxia", "weight": 10 },
        { "sign": "cardiac_arrest", "weight": 10 }
      ],
      "severeCriteria": {
        "anyDangerSign": true
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If airway/breathing/circulation compromise -> ANAPHYLAXIS; skin only -> ALLERGIC REACTION (non-anaphylaxis)"
    },

    "historyFeatures": [
      { "symptomId": "sudden_onset_after_allergen", "weight": 5 },
      { "symptomId": "urticaria_itching", "weight": 4 },
      { "symptomId": "difficulty_breathing", "weight": 5 },
      { "symptomId": "swelling_lips_tongue_throat", "weight": 4 },
      { "symptomId": "nausea_vomiting_diarrhea", "weight": 3 },
      { "symptomId": "dizziness_syncope", "weight": 3 },
      { "symptomId": "known_allergen_exposure", "weight": 5 }
    ],

    "examFeatures": [
      { "signId": "urticaria", "baseWeight": 4 },
      { "signId": "angioedema", "baseWeight": 4 },
      { "signId": "wheezing", "baseWeight": 4 },
      { "signId": "stridor", "baseWeight": 5 },
      { "signId": "hypotension", "baseWeight": 5 },
      { "signId": "tachycardia", "baseWeight": 3 },
      { "signId": "widespread_pustular_urticaria", "baseWeight": 3 }
