          { "feature": "respiratory_distress", "weight": 5 },
          { "feature": "known_asthma", "weight": 3 }
        ],
        "management": "IM Epinephrine. Nebulized salbutamol. IV hydrocortisone. Consider intubation if refractory."
      }
    ],

    "mimics": [
      {
        "diseaseId": "vasovagal_syncope",
        "discriminators": ["no_urticaria", "no_angioedema", "bradycardia", "sweating"]
      },
      {
        "diseaseId": "septic_shock",
        "discriminators": ["fever", "slow_onset", "source_of_infection"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "ABCDE assessment", "priority": "immediate", "yield": 1.0, "indication": "all patients" },
        { "name": "Peak expiratory flow rate", "priority": "high", "yield": 0.7, "indication": "assess bronchospasm severity" }
      ],
      "laboratory": [
        { "name": "Serum tryptase", "priority": "medium", "yield": 0.8, "indication": "confirm anaphylaxis (within 2 hours)" },
        { "name": "FBC, U&E, Cr", "priority": "medium", "yield": 0.3, "indication": "baseline assessment" }
      ]
    },

    "management": {
      "protocolReference": "WAO/EAACI Guidelines for Anaphylaxis",
      "pathways": [
        {
          "severity": "anaphylaxis",
          "criteria": "airway/breathing/circulation compromise",
          "treatment": "Stop allergen. IM Epinephrine 0.01 mg/kg (max 0.5 mg) anterolateral thigh. Repeat every 5-15 min PRN. Oxygen. IV fluids 20 mL/kg. Nebulized salbutamol if wheeze. IV antihistamine (chlorphenamine). IV hydrocortisone. Monitor 6-24 hours."
        },
        {
          "severity": "refractory anaphylaxis",
          "criteria": "no response to 2-3 doses epinephrine",
          "treatment": "IV epinephrine infusion. ICU admission. Consider glucagon if on beta-blockers. Consider intubation."
        }
      ]
    },

    "pathophysiology": [
      "ige_mediated_hypersensitivity",
      "mast_cell_degranulation",
      "histamine_release",
      "vasodilation",
      "bronchoconstriction",
      "increased_capillary_permeability"
    ],

    "mustNotMiss": true,
    "emergencyPriority": "high",
    "diagnosticClues": ["acute_onset_skin_mucosal", "airway_breathing_circulation", "known_allergen"],
    "exclusionClues": ["gradual_onset", "no_skin_symptoms", "isolated_syncope"]
  }
