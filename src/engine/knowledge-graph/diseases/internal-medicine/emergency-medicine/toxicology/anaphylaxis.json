    "note": "Severe, life-threatening systemic hypersensitivity reaction. Rapid onset with airway, breathing, or circulatory compromise.",
    "prevalenceWeight": 0.5,
    "syndromeTags": ["allergic_emergency", "shock"],

    "severityAssessment": {
