      "pathways": [
        {
          "severity": "respiratory depression",
          "criteria": "RR <12, SpO2 <94%, unresponsive",
          "treatment": "Airway support: jaw thrust, OPA/NPA. Ventilate with BVM. Naloxone 0.4-2mg IV/IM (or 0.1mg increments if opioid-dependent to avoid withdrawal). Repeat PRN. Consider naloxone infusion (2/3 of effective dose per hour). Observe minimum 4-6 hours (longer for long-acting opioids like methadone)."
        },
        {
          "severity": "cardiac arrest (opioid-related)",
          "criteria": "pulseless, apnea, suspected opioid",
