      "pathways": [
        {
          "severity": "haemorrhagic shock",
          "criteria": "suspected active bleeding + tachycardia, hypotension, altered mental status",
          "treatment": "C: Circulation - direct pressure on external bleeding, pelvic binder, tourniquet for life-threatening extremity bleed. 2 large-bore IVs. Blood products: RBC:FFP:Platelets 1:1:1. Avoid crystalloid excess (permissive hypotension until surgical control). Tranexamic acid 1g over 10min then 1g over 8h (CRASH-2). Activate massive transfusion protocol if ongoing need. Damage control surgery."
        },
        {
          "severity": "resuscitated",
          "criteria": "haemorrhage controlled, normalizing vital signs",
          "treatment": "Restore normotension gradually. Correct coagulopathy. Rewarm. Reassess for ongoing bleeding. MDT approach."
        }
      ]
