    "management": {
      "protocolReference": "Brain Trauma Foundation Guidelines / NICE Head Injury Guideline",
      "pathways": [
        {
          "severity": "severe TBI (GCS <=8)",
          "criteria": "GCS <=8, unable to protect airway",
          "treatment": "Intubation and mechanical ventilation. Maintain PaCO2 35-40 (avoid hyperventilation). SBP >100, SpO2 >94%. Neurosurgical consultation. CT head stat. ICP monitoring if indicated. Elevate HOB 30 degrees. Sedation. Consider mannitol/hypertonic saline if herniation. Seizure prophylaxis."
        },
        {
          "severity": "moderate TBI (GCS 9-12)",
          "criteria": "GCS 9-12, stable airway",
          "treatment": "CT head stat. Neurosurgical review. Admit for observation. Monitor GCS. Repeat CT if deterioration. No anticoagulation."
        },
        {
          "severity": "mild TBI (GCS 13-15)",
          "criteria": "GCS 13-15, no immediate danger signs",
          "treatment": "CT head if per NICE/CHIP criteria. If normal CT and no risk factors, discharge with head injury advice. Observe 24 hours if on anticoagulation."
        }
      ]
    },
    "pathophysiology": [
