    "management": {
      "protocolReference": "Surviving Sepsis Campaign (SSC) 2024 / NICE NG51",
      "pathways": [
        {
          "severity": "sepsis",
          "criteria": "suspected infection + qSOFA >=2 or organ dysfunction (lactate >2, altered mental status, hypotension)",
          "treatment": "IV fluids 30mL/kg crystalloid within 3 hours. Blood cultures before antibiotics. Broad-spectrum IV antibiotics within 1 hour. Source control. Measure lactate. Monitor urine output."
        },
        {
          "severity": "septic shock",
          "criteria": "persistent hypotension requiring vasopressors to maintain MAP >=65 + lactate >2",
          "treatment": "All of the above. Norepinephrine as first-line vasopressor (target MAP 65). Add vasopressin if inadequate response. Consider IV hydrocortisone 50mg Q6H if refractory. ICU admission. Central line and arterial line."
        }
      ]
