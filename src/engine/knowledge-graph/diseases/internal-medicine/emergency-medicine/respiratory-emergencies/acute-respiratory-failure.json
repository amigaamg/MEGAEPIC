    "management": {
      "protocolReference": "BTS Guidelines for Acute Respiratory Failure / ERC Guidelines",
      "pathways": [
        {
          "severity": "acute hypoxemic failure (Type I)",
          "criteria": "PaO2 <60 on room air, SpO2 <90%, RR >25",
          "treatment": "High-flow oxygen (target SpO2 94-98%). Treat underlying cause (antibiotics for pneumonia, bronchodilators for asthma, diuretics for pulmonary oedema, anticoagulation for PE). Trial of NIV (CPAP) for pulmonary oedema or pneumonia if not exhausted. Intubate if refractory, worsening, or patient exhausted."
        },
        {
          "severity": "acute hypercapnic failure (Type II)",
          "criteria": "PaCO2 >50 + pH <7.35, RR <12 or >30, drowsiness, exhaustion",
          "treatment": "Controlled oxygen (target SpO2 88-92%). NIV (BiPAP) with IPAP/EPAP titration. ABG after 1h. Cease NIV and intubate if no improvement, pH drops, or consciousness deteriorates. ICU admission for invasive ventilation. Bronchodilators, steroids for COPD exacerbation. Antibiotics if infective."
        }
      ]
    },
