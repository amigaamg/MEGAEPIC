      "pathways": [
        {
          "severity": "primary PPH (active bleeding)",
          "criteria": "blood loss >500mL with ongoing bleeding or hemodynamic instability",
          "treatment": "ABC. Oxygen. 2 large-bore IVs. IV fluids/blood. Uterine massage. Oxytocin 5 IU slow IV + 40 IU in 500mL NS over 4h. Examine for cause: atony, genital tract trauma, retained tissue, coagulopathy. Empty bladder (catheter). Tranexamic acid 1g IV (WOMAN trial). Escalate to senior. Activate massive transfusion protocol if >1500mL or ongoing."
        },
        {
          "severity": "refractory PPH",
          "criteria": "ongoing bleeding despite uterotonics",
          "treatment": "Second-line uterotonics: ergometrine 0.5mg IM, carboprost 0.25mg IM Q15min (max 8 doses), misoprostol 800mcg PR. Intrauterine balloon tamponade (Bakri balloon 500mL saline). Uterine compression sutures (B-Lynch). Uterine artery embolization (IR). Hysterectomy as last resort."
        }
