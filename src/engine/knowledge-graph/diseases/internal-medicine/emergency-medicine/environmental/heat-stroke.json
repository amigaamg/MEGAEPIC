    "management": {
      "protocolReference": "ACSM Guidelines / NICE Heat-related Illness Guidelines",
      "pathways": [
        {
          "severity": "heat stroke",
          "criteria": "core temp >40C + CNS dysfunction (confusion, seizures, coma)",
          "treatment": "Immediate cooling: active cooling methods - cold water immersion (1-2C/min), or evaporative cooling (mist + fan). Ice packs to neck, axillae, groin. Cold IV fluids (4C). Cold gastric/peritoneal lavage if refractory. Cease cooling at 39C target. IVF resuscitation (caution with CHF). Monitor for rhabdomyolysis, AKI, DIC, hepatic failure. ICU admission."
        },
        {
          "severity": "heat exhaustion (precursor)",
          "criteria": "core temp <40C, no CNS changes, dehydration, weakness, dizziness",
          "treatment": "Remove from heat. Oral/IV rehydration. Rest. Monitor for progression. Cool environment."
        }
      ]
