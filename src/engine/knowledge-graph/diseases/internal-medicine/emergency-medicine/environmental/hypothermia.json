    "management": {
      "protocolReference": "ERC Guidelines / Wilderness Medical Society Guidelines",
      "pathways": [
        {
          "severity": "mild (32-35C) + conscious + shivering",
          "criteria": "core 32-35C, conscious, shivering, stable vitals",
          "treatment": "Passive external rewarming: warm environment, remove wet clothing, warm blankets, warm oral fluids. Active movement. Avoid rough handling (risk of VF)."
        },
        {
          "severity": "moderate (28-32C) + reduced consciousness",
          "criteria": "core 28-32C, reduced consciousness, no shivering",
          "treatment": "Active external rewarming: forced air warmer, warm blankets, warm IV fluids (40C). Handle gently. Cardiac monitoring. Warm humidified oxygen."
        },
        {
          "severity": "severe (<28C) or unconscious or unstable",
          "criteria": "core <28C, unconscious, hypotension, arrhythmia",
          "treatment": "Active core rewarming: warm IV fluids, warm humidified oxygen, pleural/peritoneal lavage (40-45C), ECMO (most effective). CPR if arrest (prolonged resuscitation). Defibrillation: limit to 3 shocks until core >30C. Advanced life support per protocol. Rewarm 0.5-2C/hour. ICU admission."
        }
      ]
    },
