        "probability": 0.2,
        "severityBoost": 0.6,
        "clues": ["prolonged_submersion", "gcs_less_than_5", "absent_pupillary_reflexes"]
      },
      {
        "diseaseId": "aspiration_pneumonia",
        "probability": 0.2,
        "severityBoost": 0.3,
        "clues": ["fever", "infiltrates", "leucocytosis"]
      }
    ],
    "mustNotMiss": true,
    "emergencyPriority": "high",
    "diagnosticClues": ["submersion_history", "respiratory_distress", "hypoxia", "frothy_sputum", "altered_consciousness", "hypothermia"],
    "exclusionClues": ["no_submersion_event", "normal_oxygenation", "normal_consciousness", "normal_cxr"]
  }
