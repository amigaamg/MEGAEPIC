    "management": {
      "protocolReference": "ESC Guidelines for STEMI / AHA/ACC STEMI Guidelines",
      "pathways": [
        {
          "severity": "STEMI within 12h of symptom onset",
          "criteria": "ST-elevation >=1mm in 2 contiguous leads (or new LBBB) + ischemic symptoms",
          "treatment": "MONA: Morphine 2.5-5mg IV (pain), Oxygen (if SpO2 <90%), Nitrates GTN 0.3-0.6mg SL (caution in inferior/RV STEMI), Aspirin 300mg chewed. Second antiplatelet (ticagrelor 180mg or prasugrel 60mg). Anticoagulation (heparin/enoxaparin). Primary PCI <120min from diagnosis. If PCI not available within 120min: thrombolysis (tenecteplase/alteplase) within 30min. Transfer to PCI centre post-thrombolysis."
        },
        {
          "severity": "STEMI with cardiogenic shock",
          "criteria": "SBP <90 + signs of hypoperfusion, in setting of STEMI",
          "treatment": "Urgent PCI (emergent revascularization). Norepinephrine for MAP >65. Do not bolus fluids excessively (risk of pulmonary oedema). Inotropic support. IABP or temporary mechanical circulatory support (Impella, ECMO). ICU."
        },
        {
          "severity": "cardiac arrest (VF/VT)",
          "criteria": "VF or pulseless VT in STEMI context",
          "treatment": "Defibrillation per ALS protocol. CPR. Post-ROSC: targeted temperature management. Emergency coronary angiography. PCI if appropriate."
        }
      ]
