        }
      }
    ],
    "mimics": [
      { "diseaseId": "chikungunya", "discriminators": ["severe joint pain", "rash more prominent", "no plasma leak", "no thrombocytopenia"] },
      { "diseaseId": "malaria", "discriminators": ["cyclic fever", "positive blood smear", "splenomegaly", "no retro-orbital pain"] },
      { "diseaseId": "leptospirosis", "discriminators": ["conjunctival suffusion", "calf tenderness", "jaundice", "renal impairment"] }
    ],
    "investigations": {
      "bedside": [
        { "name": "Tourniquet Test and Orthostatic BP", "priority": "first-line", "yield": 3, "indication": "capillary fragility and early shock" }
      ],
      "laboratory": [
        { "name": "NS1 Antigen Test", "priority": "first-line", "yield": 5, "indication": "early diagnosis day 0-5" },
        { "name": "Dengue IgM/IgG Serology", "priority": "essential", "yield": 4, "indication": "seroconversion day 5+" },
        { "name": "Complete Blood Count (serial)", "priority": "essential", "yield": 5, "indication": "platelet trend, hematocrit, WBC" },
        { "name": "Liver Function Tests and Coagulation", "priority": "routine", "yield": 3, "indication": "organ involvement" }
      ],
      "imaging": [
        { "name": "Chest X-ray or Abdominal Ultrasound", "priority": "if indicated", "yield": 4, "indication": "pleural effusion, ascites" }
      ]
    },
    "management": {
      "protocolReference": "WHO Dengue Guidelines 2009/2019; National Clinical Management Guidelines",
      "pathways": [
        {
          "severity": "group-a-outpatient",
          "criteria": "dengue without warning signs, adequate oral intake, normal urine output",
          "treatment": [
            "Paracetamol 10-15 mg/kg Q6H (avoid aspirin, NSAIDs, ibuprofen)",
            "Encourage oral fluids, monitor urine output target 1 mL/kg/h",
            "Instruct to return if: abdominal pain, vomiting, bleeding, lethargy",
            "Daily blood count (platelets, hematocrit) until afebrile"
          ]
        },
        {
          "severity": "group-b-inpatient",
          "criteria": "dengue with warning signs, or comorbidities, or social concerns",
          "treatment": [
            "Admit to ward, strict fluid balance, IV crystalloid at maintenance rate",
            "Repeat CBC and hematocrit Q4-6H in critical phase",
            "No prophylactic platelet transfusions (no evidence of benefit)",
            "Blood transfusion if severe bleeding or Hb drop with instability"
          ]
        },
        {
          "severity": "group-c-icu",
          "criteria": "severe dengue with shock, severe bleeding, or organ impairment",
          "treatment": [
            "ICU admission, IV crystalloid 10-20 mL/kg bolus, reassess",
            "Vasopressors if fluid-refractory shock",
            "Packed RBC 10 mL/kg if severe bleeding; platelet concentrate if bleeding with platelets <20K",
            "Correct electrolytes, monitor dextrose, mechanical ventilation if pulmonary edema"
          ]
        }
      ]
    },
    "pathophysiology": [
      "Dengue virus (DENV 1-4) transmitted by Aedes aegypti mosquito",
      "Antibody-dependent enhancement (ADE) in secondary infection increases viral load",
      "Plasma leak via endothelial dysfunction: cytokines increase capillary permeability",
      "Thrombocytopenia from bone marrow suppression and consumption",
      "Hemoconcentration from plasma leak is hallmark of critical phase (day 3-7)"
    ],
    "complications": [
      { "diseaseId": "dengue_shock_syndrome", "probability": 0.1, "severityBoost": 0.8, "lagDays": [3, 7] },
      { "diseaseId": "disseminated_intravascular_coagulation", "probability": 0.05, "severityBoost": 0.7 },
      { "diseaseId": "acute_kidney_injury", "probability": 0.05, "severityBoost": 0.4 }
    ]
