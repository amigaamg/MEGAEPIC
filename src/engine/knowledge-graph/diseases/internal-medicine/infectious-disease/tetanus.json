      "protocolReference": "WHO Tetanus Guidelines; CDC Tetanus Surveillance and Prevention",
      "pathways": [
        {
          "severity": "all-cases",
          "criteria": "any suspected or confirmed tetanus",
          "treatment": [
            "Human Tetanus Immunoglobulin (HTIG) 500 IU IM (or 3000-6000 IU IV for severe cases)",
            "Metronidazole 500 mg IV Q6H x 10-14 days (preferred over penicillin)",
            "Wound debridement — remove all necrotic tissue and foreign material",
            "Complete active immunization series (tetanus toxoid) given at separate site from HTIG",
            "Admit to ICU or closely monitored setting"
          ]
        },
        {
          "severity": "severe-critical",
          "criteria": "generalized tetanus, spasms, autonomic instability, or respiratory involvement",
          "treatment": [
            "ICU, dark quiet room, benzodiazepines (diazepam 10-30 mg IV PRN, up to 200 mg/day)",
            "Magnesium sulfate IV: loading 5 g, then 2-3 g/hr titrated to patellar reflex",
            "Neuromuscular blockade and mechanical ventilation if spasms refractory",
            "IV labetalol for hypertension, enteral nutrition, DVT and stress ulcer prophylaxis"
          ]
        },
        {
          "severity": "mild-localized",
          "criteria": "mild trismus, no generalized spasms, limited rigidity",
          "treatment": [
            "HTIG, metronidazole 400-500 mg PO Q6H",
            "Diazepam 5-10 mg PO/IV Q6H, wound debridement, active immunization",
            "Monitor for progression to generalized tetanus (first 72 hours most critical)"
          ]
        }
      ]
