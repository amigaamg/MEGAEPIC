    "investigations": {
      "bedside": [
        { "name": "Lumbar puncture with opening pressure", "priority": "immediate", "yield": 0.95, "indication": "all suspected cases, measure ICP" }
      ],
      "laboratory": [
        { "name": "CSF cryptococcal antigen (CrAg)", "priority": "immediate", "yield": 0.98, "indication": "highly sensitive and specific" },
        { "name": "CSF India ink stain", "priority": "high", "yield": 0.7, "indication": "encapsulated yeast" },
        { "name": "CSF fungal culture", "priority": "gold_standard", "yield": 0.95, "indication": "confirm and susceptibility" },
        { "name": "Serum CrAg", "priority": "high", "yield": 0.9, "indication": "screening in HIV with low CD4" },
        { "name": "HIV test (if status unknown)", "priority": "immediate", "yield": 0.99, "indication": "all patients" }
      ],
      "imaging": [
        { "name": "CT Brain before LP", "priority": "high", "yield": 0.5, "indication": "if focal signs or ICP concerns" }
      ]
    },

    "management": {
      "protocolReference": "WHO / IDSA Guidelines for Cryptococcal Meningitis",
      "pathways": [
        {
          "severity": "induction therapy",
          "criteria": "positive CSF CrAg/culture",
          "treatment": "Liposomal amphotericin B 3-4 mg/kg/day + Flucytosine 100mg/kg/day PO in 4 divided doses for 2 weeks. Then fluconazole 400-800mg/day for 8 weeks (consolidation)."
        },
        {
          "severity": "raised ICP management",
          "criteria": "opening pressure >25 cm H2O or symptoms of high ICP",
          "treatment": "Therapeutic LP daily to reduce pressure. Repeat until opening pressure <20 or symptoms improve. Acetazolamide NOT recommended."
        }
      ]
    },

    "pathophysiology": [
