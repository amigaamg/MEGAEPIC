      "protocolReference": "CDC Treatment Guidelines for Babesiosis; IDSA Guidelines",
      "pathways": [
        {
          "severity": "mild_to_moderate",
          "criteria": "Immunocompetent, parasitemia <10%, no severe symptoms, no organ failure",
          "treatment": "Atovaquone 750mg PO q12h + azithromycin 500mg IV/PO q24h (or 250mg PO x 3 then 250mg daily) x 7-10 days. Alternative: clindamycin 600mg PO q8h + quinine 650mg PO q8h x 7-10 days (higher side effects)."
        },
        {
          "severity": "severe_life_threatening",
          "criteria": "Parasitemia >10%, Hb <7, organ failure, asplenic, immunocompromised, elderly",
          "treatment": "Clindamycin IV 600mg q6h + quinine PO/IV 650mg q6-8h (or atovaquone + azithromycin IV). Exchange transfusion if parasitemia >10% and severe disease (Hb <7, pulmonary failure, organ failure). IV fluids, transfusion support. Treat minimum 7-10 days; longer until parasitemia cleared."
        }
