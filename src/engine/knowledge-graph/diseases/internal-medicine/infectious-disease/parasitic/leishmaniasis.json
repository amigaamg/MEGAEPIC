      "pathways": [
        {
          "severity": "visceral (kala-azar)",
          "criteria": "fever >2 weeks, splenomegaly, pancytopenia, positive serology/parasitology",
          "treatment": "Liposomal amphotericin B 3 mg/kg/day IV x 7 days. HIV co-infection: higher dose, longer course. Monitor for relapse."
