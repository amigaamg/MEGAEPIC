        "anyDangerSign": true
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If any WHO severe malaria criteria -> SEVERE; else -> UNCOMPLICATED"
    },

    "historyFeatures": [
