    ],

    "subtypes": [
      {
        "id": "tuberculoid_leprosy",
        "name": "Tuberculoid Leprosy (TT)",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "few_anesthetic_patches", "weight": 5 },
          { "feature": "well_demarcated_borders", "weight": 4 },
          { "feature": "positive_skin_smear", "weight": 2 }
        ],
        "management": "Rifampin 600mg monthly + Dapsone 100mg daily for 6 months. Single skin lesion: single dose ROM (Rifampin, Ofloxacin, Minocycline)."
      },
      {
        "id": "lepromatous_leprosy",
        "name": "Lepromatous Leprosy (LL)",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "multiple_symmetric_nodules_plaques", "weight": 5 },
          { "feature": "leonine_facies", "weight": 4 },
          { "feature": "positive_skin_smear_high_bacterial_index", "weight": 5 }
        ],
        "management": "Rifampin 600mg monthly + Clofazimine 300mg monthly (50mg daily) + Dapsone 100mg daily for 12 months."
      }
    ],

    "mimics": [
      {
        "diseaseId": "vitiligo",
        "discriminators": ["no_sensory_loss", "no_nerve_thickening", "margins_hyperpigmented"]
      },
      {
        "diseaseId": "skin_lymphoma",
        "discriminators": ["progressive", "not_anesthetic", "biopsy_positive"]
      }
    ],

    "investigations": {
      "laboratory": [
        { "name": "Skin slit smear (bacterial index)", "priority": "high", "yield": 0.85, "indication": "diagnosis and classification" },
        { "name": "Skin or nerve biopsy (Fite stain)", "priority": "gold_standard", "yield": 0.95, "indication": "histopathological confirmation" },
        { "name": "PCR for M. leprae", "priority": "medium", "yield": 0.9, "indication": "confirmation in difficult cases" }
      ]
    },

    "management": {
      "protocolReference": "WHO Multidrug Therapy (MDT) Guidelines for Leprosy",
      "pathways": [
        {
          "severity": "paucibacillary (tuberculoid)",
          "criteria": "skin smears negative, <5 lesions",
          "treatment": "Rifampin 600mg monthly + Dapsone 100mg daily for 6 months. Self-care for anesthesia. Monitor nerve function."
        },
        {
          "severity": "multibacillary (lepromatous)",
          "criteria": "skin smears positive, >=5 lesions",
          "treatment": "Rifampin 600mg monthly + Clofazimine 300mg monthly + 50mg daily + Dapsone 100mg daily for 12 months. Manage reactions."
        }
      ]
