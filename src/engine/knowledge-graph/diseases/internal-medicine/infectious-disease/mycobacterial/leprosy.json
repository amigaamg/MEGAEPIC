      { "symptomId": "endemic_area_residence", "weight": 4 }
    ],

    "examFeatures": [
      { "signId": "anesthetic_hypopigmented_patch", "baseWeight": 5, "doubleWeight": true },
      { "signId": "thickened_peripheral_nerves", "baseWeight": 4 },
      { "signId": "loss_of_sensation_in_distribution", "baseWeight": 4 },
      { "signId": "motor_weakness_ulnar_median_common_peroneal", "baseWeight": 3 },
      { "signId": "leonine_facies_facial_thickening", "baseWeight": 3 },
      { "signId": "nasal_ulceration_perforation", "baseWeight": 2 },
      { "signId": "claw_hand_foot_drop", "baseWeight": 3 }
    ],

    "riskFactors": [
