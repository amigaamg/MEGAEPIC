        { "sign": "laryngeal_involvement", "weight": 9 }
      ],
      "severeCriteria": {
        "anyDangerSign": true
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "Lepromatous / reactional -> MODERATE-SEVERE; tuberculoid -> MILD"
    },

    "historyFeatures": [
      { "symptomId": "hypopigmented_or_erythematous_skin_patches", "weight": 5 },
      { "symptomId": "numbness_loss_of_sensation", "weight": 5 },
      { "symptomId": "weakness_hand_foot_drop", "weight": 4 },
      { "symptomId": "skin_thickening_nodules", "weight": 3 },
      { "symptomId": "nasal_congestion_epistaxis", "weight": 2 },
      { "symptomId": "painless_wounds_ulcers_on_feet", "weight": 3 },
