    "management": {
      "protocolReference": "WHO / NICE Guidelines for Extrapulmonary TB",
      "pathways": [
        {
          "severity": "most EPTB (nodes, pleura, abdominal)",
          "criteria": "tissue or fluid confirmed",
          "treatment": "Standard 4-drug regimen (RIPE) for 2 months + RH for 4-7 months (total 6-9 months). Longer therapy for bone (12 months)."
        },
        {
          "severity": "CNS TB / military",
          "criteria": "meningitis, tuberculoma, spinal TB",
          "treatment": "RIPE + corticosteroids (dexamethasone 0.4 mg/kg/day taper). Total duration 9-12 months. Neurosurgery if hydrocephalus or tuberculoma."
        }
      ]
