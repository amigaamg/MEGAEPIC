    "investigations": {
      "laboratory": [
        { "name": "FNAC/biopsy with AFB stain + culture", "priority": "high", "yield": 0.8, "indication": "lymph node, tissue diagnosis" },
        { "name": "GeneXpert on tissue/fluid", "priority": "high", "yield": 0.85, "indication": "rapid diagnosis + resistance" },
        { "name": "CSF analysis (lymphocytes, protein, glucose)", "priority": "immediate", "yield": 0.8, "indication": "suspected meningitis" },
        { "name": "Adenosine deaminase (ADA) - fluid", "priority": "high", "yield": 0.85, "indication": "pleural/peritoneal TB" }
