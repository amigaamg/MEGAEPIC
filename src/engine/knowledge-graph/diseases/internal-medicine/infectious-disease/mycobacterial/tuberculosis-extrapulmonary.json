        ],
        "management": "Standard 4-drug regimen + corticosteroids (dexamethasone for 6-8 weeks). Monitor ICP. Treat for 12 months."
      },
      {
        "id": "tb_spondylitis_pott_disease",
        "name": "Pott Disease (Spinal TB)",
