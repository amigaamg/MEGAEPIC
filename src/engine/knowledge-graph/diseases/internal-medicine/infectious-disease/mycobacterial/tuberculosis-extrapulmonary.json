        { "name": "Spinal MRI", "priority": "high", "yield": 0.9, "indication": "Pott disease, cord compression" },
        { "name": "CT chest/abdomen", "priority": "medium", "yield": 0.7, "indication": "pleural, abdominal, nodal disease" }
      ]
