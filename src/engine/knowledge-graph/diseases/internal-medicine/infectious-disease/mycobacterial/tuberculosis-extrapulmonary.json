          { "feature": "back_pain_stiffness", "weight": 4 },
          { "feature": "paraplegia_nerve_root_signs", "weight": 4 }
        ],
        "management": "Standard anti-TB therapy 12 months. Spinal bracing. Surgical decompression if cord compression or instability."
