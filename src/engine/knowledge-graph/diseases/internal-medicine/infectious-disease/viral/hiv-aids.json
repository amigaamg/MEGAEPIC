      "pathways": [
        {
          "severity": "all HIV-positive",
          "criteria": "any CD4, any viral load",
          "treatment": "ART for all. First-line: TAF/TDF + FTC/3TC + DTG (or BIC/FTC/TAF as single tablet). Monitor VL at 6 months, then yearly."
