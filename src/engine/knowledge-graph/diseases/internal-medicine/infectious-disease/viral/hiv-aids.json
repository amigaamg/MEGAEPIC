          { "feature": "opportunistic_infection", "weight": 5 },
          { "feature": "wasting_syndrome", "weight": 3 }
        ],
        "management": "ART initiation. Treat OI first if TB/pneumonia/meningitis. Prophylaxis (TMP-SMX if CD4<200, Azithromycin if CD4<50)."
