          { "feature": "fever_rash_lymphadenopathy", "weight": 4 },
          { "feature": "recent_exposure_2_to_6_weeks", "weight": 5 }
        ],
        "management": "Start ART immediately. Regimen: TDF/TAF + FTC/3TC + DTG. Manage seroconversion symptoms. Risk reduction counseling."
      },
      {
        "id": "chronic_hiv",
        "name": "Chronic HIV Infection",
        "prevalenceModifier": 0.85,
        "keyFeatures": [
          { "feature": "positive_hiv_antibody", "weight": 5 },
          { "feature": "cd4_variable", "weight": 4 },
          { "feature": "asymptomatic_or_mild_symptoms", "weight": 3 }
        ],
        "management": "ART for all regardless of CD4. Monitor viral load and CD4 q6months. Prophylaxis for OIs if CD4 <200."
      },
      {
        "id": "aids",
        "name": "AIDS (CD4 <200 or AIDS-defining illness)",
