        {
          "severity": "AIDS / low CD4",
          "criteria": "CD4 <200 or OI",
          "treatment": "Start ART and OI prophylaxis. TMP-SMX if CD4<200. Azithromycin if CD4<50. Screen for TB. Treat OI before ART if indicated."
