        {
          "severity": "high risk or complicated",
          "criteria": "age <2/>65, pregnancy, chronic disease, or pneumonia",
          "treatment": [
            "Oseltamivir 75mg PO BD for 5 days. Renal adjustment: CrCl 30-60 -> 30mg BD; CrCl 10-30 -> 30mg daily.",
            "If oseltamivir resistance: Zanamivir 10mg inhaled BD for 5 days (avoid if reactive airway disease)",
            "If severe/ICU: Peramivir 600mg IV single dose, or 600mg daily for 5-10 days",
            "Antibiotics if bacterial superinfection: Amoxicillin-clavulanate or respiratory fluoroquinolone",
            "O2 to maintain SpO2 >=94%",
            "ICU if respiratory failure, shock, or multi-organ dysfunction"
          ]
        },
        {
          "severity": "hospitalization criteria",
          "criteria": "SpO2 <94% on room air, RR >30, hypotension, altered mental status, immunocompromised, unable to maintain oral hydration",
          "treatment": [
            "Admit to medical ward",
            "Start antivirals immediately (IV peramivir if unable to take oral)",
            "Monitor O2, respiratory status, mental status",
            "CXR and blood cultures on admission"
          ]
        },
        {
          "severity": "ICU criteria",
          "criteria": "PaO2/FiO2 <300, need for mechanical ventilation, septic shock, acute organ dysfunction",
          "treatment": [
            "ICU admission",
            "IV peramivir",
            "Broad-spectrum antibiotics pending cultures",
            "Organ support as indicated"
          ]
        }
      ],
      "specialConsiderations": {
        "chemoprophylaxis": "Close contacts at high risk: Oseltamivir 75mg PO daily for 10 days within 48h of exposure.",
        "pregnancy": "Oseltamivir safe in pregnancy; treat promptly as high risk.",
        "oseltamivir_resistance": "If no improvement at 48h on oseltamivir, consider resistance. Switch to zanamivir or peramivir."
      }
