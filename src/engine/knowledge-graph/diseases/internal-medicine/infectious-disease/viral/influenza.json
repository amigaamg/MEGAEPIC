    "management": {
      "protocolReference": "CDC/WHO Guidelines for Influenza",
      "pathways": [
        {
          "severity": "mild uncomplicated",
          "criteria": "no hypoxia, no comorbidities, able to tolerate oral",
          "treatment": "Rest, hydration, paracetamol/ibuprofen. Oseltamivir 75mg BD for 5 days if high risk or within 48h of onset. Monitor for worsening."
