    "management": {
      "protocolReference": "WHO Guidelines for Yellow Fever; CDC Yellow Book",
      "pathways": [
        {
          "severity": "mild_phase_1",
          "criteria": "Fever, myalgia, headache, no jaundice, no hemorrhage",
          "treatment": "Supportive care: antipyretics (avoid aspirin and NSAIDs due to bleeding risk), IV fluids, monitor for progression to intoxication phase. No specific antiviral therapy. Report to public health authorities. Mosquito precautions to prevent further transmission."
        },
        {
          "severity": "severe_intoxication_phase",
          "criteria": "Jaundice, hemorrhage (hematemesis, petechiae), renal failure, encephalopathy, shock",
          "treatment": "ICU admission. Aggressive supportive care: IV fluids for shock; blood product transfusion for hemorrhage (PRBC, platelets, FFP); renal replacement therapy for AKI; manage encephalopathy. Avoid hepatotoxic drugs. No specific antiviral. Ribavirin has no proven benefit. Passive immunization with YFV immune globulin not available. Case fatality rate 20-50%. Report to WHO under International Health Regulations."
        }
      ]
