        "probability": 0.25,
        "severityBoost": 0.3,
        "clues": ["papilledema", "bradycardia_hypertension", "abnormal_pupils"]
      },
      {
        "diseaseId": "hearing_loss",
        "probability": 0.2,
        "severityBoost": 0.2,
        "clues": ["pneumococcal", "severe_disease"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "high",
    "diagnosticClues": ["fever_neck_stiffness_altered_consciousness", "petechial_rash", "CSF_purulent"],
