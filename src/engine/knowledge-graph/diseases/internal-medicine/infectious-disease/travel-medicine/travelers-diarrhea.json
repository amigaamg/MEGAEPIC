          { "feature": "fever_and_systemic_symptoms", "weight": 4 },
          { "feature": "more_than_6_stools_per_day", "weight": 4 }
        ],
        "management": "Azithromycin 1g PO single dose (or 500mg OD x 3 days). Avoid loperamide if dysentery. ORS. Medical evaluation for persistent symptoms."
      }
    ],

    "mimics": [
