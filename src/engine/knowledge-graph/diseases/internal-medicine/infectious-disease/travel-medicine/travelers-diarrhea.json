        "prevalenceModifier": 0.75,
        "keyFeatures": [
          { "feature": "watery_stools_less_6_per_day", "weight": 4 },
          { "feature": "no_systemic_illness", "weight": 4 },
          { "feature": "self_limiting", "weight": 3 }
        ],
        "management": "Oral rehydration solution (ORS). Loperamide for symptom relief (if no fever/dysentery). Azithromycin 1g single dose if moderate."
      },
      {
        "id": "severe_dysenteric_td",
        "name": "Severe/Dysenteric Travelers Diarrhea",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
