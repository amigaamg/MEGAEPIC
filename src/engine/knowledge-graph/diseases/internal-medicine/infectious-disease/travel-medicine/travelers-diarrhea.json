      {
        "diseaseId": "cholera",
        "discriminators": ["profuse_rice_water_stool", "rapid_dehydration", "endemic_area"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Stool dipstick for fecal leukocytes", "priority": "medium", "yield": 0.6, "indication": "differentiate inflammatory" }
      ],
      "laboratory": [
        { "name": "Stool culture + sensitivity", "priority": "high", "yield": 0.7, "indication": "if bloody, persisting, or severe" },
        { "name": "Stool PCR panel (GI panel)", "priority": "high", "yield": 0.9, "indication": "comprehensive pathogen ID" }
      ]
    },

    "management": {
      "protocolReference": "CDC Yellow Book / WHO Travelers Diarrhea Guidelines",
      "pathways": [
        {
          "severity": "mild-moderate",
          "criteria": "<6 stools/day, no fever, no blood",
          "treatment": "ORS. Loperamide 4mg then 2mg after each loose stool (max 8mg/day). Bismuth subsalicylate 30ml Q6H. Azithromycin 1g single dose if disruptive."
        },
        {
          "severity": "severe/dysenteric",
          "criteria": "bloody stool, fever, >6 stools/day, or dehydration",
          "treatment": "Azithromycin 1g PO single dose or 500mg OD x 3 days. ORS aggressive. Avoid loperamide. Seek medical care if no improvement in 48h."
