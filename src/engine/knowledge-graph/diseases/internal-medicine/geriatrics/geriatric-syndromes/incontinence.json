      },
      "nonSevereCriteria": {
        "chronic_stable_leakage": true,
        "no_acute_cause": true
      },
      "severityLabel": "If acute retention, hematuria, or severe skin breakdown -> URGENT; chronic incontinence -> NON-URGENT"
    },

    "historyFeatures": [
