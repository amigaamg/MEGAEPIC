    "investigations": {
      "bedside": [
        { "name": "Bladder diary (frequency-volume chart)", "priority": "high", "yield": 0.9, "indication": "pattern assessment" },
        { "name": "Post-void residual ultrasound", "priority": "high", "yield": 0.85, "indication": "retention assessment" }
      ],
      "laboratory": [
        { "name": "Urinalysis and culture", "priority": "high", "yield": 0.5, "indication": "exclude UTI, hematuria" },
        { "name": "U&E, Cr, glucose", "priority": "medium", "yield": 0.3, "indication": "renal function, diabetes" }
      ],
      "imaging": [
        { "name": "Renal and bladder ultrasound", "priority": "medium", "yield": 0.6, "indication": "upper tract assessment" },
        { "name": "Urodynamic studies", "priority": "low", "yield": 0.8, "indication": "complex or refractory cases" }
      ]
    },

    "management": {
      "protocolReference": "NICE Guideline NG123 – Urinary incontinence in women / NICE Guideline CG97 – Lower urinary tract symptoms in men",
      "pathways": [
        {
          "severity": "stress_incontinence",
          "criteria": "leakage with cough, sneeze, exercise",
          "treatment": "Pelvic floor muscle training (PFMT). Lifestyle modifications (weight loss, fluid management). Consider duloxetine or surgery if refractory."
        },
        {
          "severity": "urge_incontinence",
          "criteria": "leakage with urgency, frequency, nocturia",
          "treatment": "Bladder retraining. Anticholinergics or mirabegron (caution in elderly). Review medications. Treat constipation."
        },
        {
          "severity": "overflow_incontinence",
          "criteria": "hesitancy, weak stream, incomplete emptying",
          "treatment": "Alpha-blockers (tamsulosin) for BPH. Consider catheterization if retention. Avoid anticholinergics."
        }
      ]
    },

    "pathophysiology": [
      "weakened_pelvic_floor_muscles",
      "detrusor_overactivity",
      "urethral_hypermobility",
      "impaired_bladder_contractility",
      "functional_and_mobility_barriers",
      "prostatic_obstruction"
    ],

    "complications": [
