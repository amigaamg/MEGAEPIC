    "note": "Involuntary loss of urine. Common and distressing geriatric syndrome. Not a normal part of aging.",
    "prevalenceWeight": 0.6,
    "syndromeTags": ["incontinence", "geriatric_giant", "functional_decline"],

    "severityAssessment": {
