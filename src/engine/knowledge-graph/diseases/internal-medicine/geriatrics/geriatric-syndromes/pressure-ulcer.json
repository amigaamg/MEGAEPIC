    "management": {
      "protocolReference": "NICE Guideline CG179 – Pressure ulcers prevention and management",
      "pathways": [
        {
          "severity": "active_ulcer",
          "criteria": "any stage pressure ulcer present",
          "treatment": "Offload pressure (specialized mattress, repositioning 2-hourly). Wound debridement if necrotic tissue. Moist wound healing dressings. Manage exudate and infection. Nutritional support (protein 1.2-1.5 g/kg). Pain management."
        },
        {
          "severity": "prevention",
          "criteria": "at risk (Waterlow >=10, Braden <=18)",
          "treatment": "Pressure-redistributing equipment. Regular repositioning. Skin inspection daily. Optimize nutrition and hydration. Manage incontinence. Mobilize if possible."
        }
      ]
