      ],
      "imaging": [
        { "name": "Abdominal X-ray", "priority": "medium", "yield": 0.6, "indication": "fecal loading or obstruction" },
        { "name": "CT abdomen", "priority": "low", "yield": 0.7, "indication": "if obstruction or mass suspected" }
      ]
    },

    "management": {
      "protocolReference": "NICE Guideline CG99 – Constipation in adults",
      "pathways": [
        {
          "severity": "fecal_impaction",
          "criteria": "hard rectal mass, inability to pass stool",
          "treatment": "Manual disimpaction. Enema (phosphate or arachis oil). Oral polyethylene glycol (Movicol) high dose. Review medications causing constipation."
        },
        {
          "severity": "chronic_constipation",
          "criteria": "Rome IV positive, no impaction",
          "treatment": "Increase dietary fiber (if no bloating) and fluids. Bulk-forming laxatives (ispaghula). Second-line: osmotic (lactulose, PEG). Third-line: stimulant (senna, bisacodyl) short-term. Review opioid use and anticholinergics."
        }
      ]
    },

    "pathophysiology": [
      "prolonged_colonic_transit",
      "impaired_defecatory_coordination",
      "poor_dietary_fiber_intake",
      "dehydration",
      "medication_side_effects",
      "pelvic_floor_dyssynergia"
