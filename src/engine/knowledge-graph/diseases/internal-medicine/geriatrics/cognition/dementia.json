{
  "disease": {
    "id": "dementia",
    "name": "Dementia (Alzheimer type)",
    "system": "geriatrics",
    "agePeak_months": [720, 1080],
    "note": "Progressive neurodegenerative disorder. Most common cause of dementia in older adults. Insidious onset.",
    "prevalenceWeight": 0.7,
    "syndromeTags": ["cognitive_decline", "memory_loss", "neurodegenerative"],

    "severityAssessment": {
      "immediateDangerSigns": [
        { "sign": "acute_confusion_superimposed", "weight": 8 },
        { "sign": "agitation_risk_of_harm", "weight": 7 },
        { "sign": "wandering_self_neglect", "weight": 6 },
        { "sign": "dehydration_or_malnutrition", "weight": 7 }
      ],
      "severeCriteria": {
        "anyDangerSign": true
      },
      "nonSevereCriteria": {
        "mild_cognitive_impairment_only": true,
        "independent_adl": true
      },
      "severityLabel": "If acute deterioration, agitation, or self-neglect -> EMERGENCY; mild stable -> NON-URGENT"
    },

    "historyFeatures": [
      { "symptomId": "progressive_memory_loss", "weight": 5 },
      { "symptomId": "difficulty_with_familiar_tasks", "weight": 4 },
      { "symptomId": "language_problems", "weight": 3 },
      { "symptomId": "disorientation", "weight": 4 },
      { "symptomId": "personality_changes", "weight": 3 },
      { "symptomId": "impaired_judgment", "weight": 3 }
    ],

    "examFeatures": [
      { "signId": "impaired_short_term_memory_on_moca", "baseWeight": 5, "doubleWeight": true },
      { "signId": "disorientation_to_time_or_place", "baseWeight": 4 },
      { "signId": "impaired_word_recall", "baseWeight": 4 },
      { "signId": "reduced_clock_drawing_test", "baseWeight": 3 },
      { "signId": "lack_of_insight", "baseWeight": 3 }
    ],

    "riskFactors": [
      { "id": "age_over_65", "multiplier": 2.0 },
      { "id": "apoe_epsilon4_carrier", "multiplier": 3.0 },
      { "id": "family_history", "multiplier": 1.5 },
      { "id": "hypertension", "multiplier": 1.3 },
      { "id": "diabetes", "multiplier": 1.3 },
      { "id": "low_educational_attainment", "multiplier": 1.4 },
      { "id": "hearing_loss", "multiplier": 1.4 }
    ],

    "mimics": [
      {
        "diseaseId": "delirium",
        "discriminators": ["acute_onset", "fluctuating_consciousness", "reversible_cause"]
      },
      {
        "diseaseId": "depression_pseudodementia",
        "discriminators": ["affective_symptoms", "motivational_deficit", "prior_depression", "cognitive_test_variable"]
      },
      {
        "diseaseId": "mild_cognitive_impairment",
        "discriminators": ["preserved_adl", "subjective_complaint_only", "no_functional_impairment"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "MoCA or MMSE", "priority": "immediate", "yield": 0.9, "indication": "cognitive screening" },
        { "name": "Clock drawing test", "priority": "immediate", "yield": 0.7, "indication": "visuospatial and executive function" }
      ],
      "laboratory": [
        { "name": "Vitamin B12, folate, TSH", "priority": "high", "yield": 0.3, "indication": "reversible causes" },
        { "name": "Syphilis serology, HIV", "priority": "medium", "yield": 0.1, "indication": "infectious causes" }
      ],
      "imaging": [
        { "name": "MRI brain", "priority": "high", "yield": 0.7, "indication": "atrophy pattern, exclude mass or vascular lesions" },
        { "name": "CT head", "priority": "medium", "yield": 0.5, "indication": "if MRI contraindicated" }
      ]
    },

    "management": {
      "protocolReference": "NICE Guideline NG97 – Dementia assessment and management",
      "pathways": [
        {
          "severity": "new_diagnosis",
          "criteria": "cognitive impairment affecting daily function",
          "treatment": "Cholinesterase inhibitors (donepezil, rivastigmine, galantamine) for mild-moderate. Memantine for moderate-severe. Multidisciplinary care. Driving advice. Advance care planning."
        },
        {
          "severity": "acute_deterioration",
          "criteria": "worsening confusion, agitation, behavioral change",
          "treatment": "Exclude delirium (infection, metabolic). Low-dose antipsychotics only if severe distress. Review medications. Caregiver support."
        }
      ]
    },

    "pathophysiology": [
      "amyloid_beta_plaque_deposition",
      "neurofibrillary_tangles",
      "neuronal_loss",
      "synaptic_dysfunction",
      "cholinergic_deficit",
      "cortical_atrophy"
    ],

    "complications": [
      {
        "diseaseId": "delirium",
        "probability": 0.3,
        "severityBoost": 0.5,
        "clues": ["acute_on_chronic_confusion", "infection", "medication_change"]
      },
      {
        "diseaseId": "malnutrition",
        "probability": 0.2,
        "severityBoost": 0.4,
        "clues": ["weight_loss", "forgetting_to_eat", "dysphagia"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "medium unless acute deterioration",
    "diagnosticClues": ["insidious_cognitive_decline", "memory_impairment_predominant", "no_acute_cause"],
    "exclusionClues": ["acute_onset", "normal_cognitive_screening", "reversible_cause_found"]
  }
}
