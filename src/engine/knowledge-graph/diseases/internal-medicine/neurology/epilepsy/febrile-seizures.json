      "laboratory": [
        { "name": "Blood glucose", "priority": "immediate", "yield": 0.3, "indication": "rule out hypoglycemic seizure" },
        { "name": "Lumbar puncture", "priority": "selective", "yield": 0.5, "indication": "if complex features, age <12 months, meningeal signs, or ill-appearing" }
      ],
      "imaging": [
        { "name": "CT/MRI Brain", "priority": "selective", "yield": 0.1, "indication": "only if complex features, microcephaly, abnormal neuro exam" }
      ]
    },
    "management": {
      "protocolReference": "NICE Guidelines for Febrile Seizures",
      "pathways": [
        {
          "severity": "simple (no risk factors)",
          "criteria": "generalized, <15 min, single, age 6-60 months, well after",
          "treatment": "Treat fever. Identify source. Parental reassurance. No investigations needed. No admission needed if well and source identified."
        },
        {
          "severity": "complex (risk factors)",
          "criteria": "focal, prolonged, recurrent, or ill-appearing",
          "treatment": "Admit for observation. Consider LP. EEG next day. MRI brain if focal. Monitor for recurrence. Explain red flags."
