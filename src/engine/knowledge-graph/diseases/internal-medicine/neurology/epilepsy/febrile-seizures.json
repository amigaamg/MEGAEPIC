          { "feature": "duration_less_15_min", "weight": 5 },
          { "feature": "single_in_24h", "weight": 4 }
        ],
        "management": "Reassure parents. Treat fever (paracetamol 15 mg/kg). Identify and treat source of fever. No AED needed. No imaging or EEG routinely."
      },
      {
        "id": "complex_febrile_seizure",
        "name": "Complex Febrile Seizure",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
