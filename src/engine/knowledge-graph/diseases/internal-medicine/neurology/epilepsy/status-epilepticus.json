    "investigations": {
      "bedside": [
        { "name": "ECG, Pulse oximetry, BP monitoring", "priority": "immediate", "yield": 0.9, "indication": "vital sign monitoring" },
        { "name": "EEG (urgent)", "priority": "immediate", "yield": 0.95, "indication": "confirm status, guide treatment" }
      ],
      "laboratory": [
        { "name": "Blood glucose (fingerstick)", "priority": "immediate", "yield": 0.9, "indication": "hypoglycemia treatment" },
        { "name": "U&E, Cr, Ca, Mg, PO4", "priority": "high", "yield": 0.5, "indication": "metabolic causes" },
        { "name": "AED levels", "priority": "high", "yield": 0.6, "indication": "noncompliance or subtherapeutic" },
        { "name": "Blood cultures, LP", "priority": "medium", "yield": 0.3, "indication": "if CNS infection suspected" }
      ],
      "imaging": [
        { "name": "CT Head", "priority": "once_stable", "yield": 0.3, "indication": "structural cause, hemorrhage" }
      ]
    },
    "management": {
      "protocolReference": "AES Guidelines for Status Epilepticus",
      "pathways": [
        {
          "severity": "0-5 min: stabilization",
          "criteria": "seizure ongoing at 5 min",
          "treatment": "ABC. Oxygen. IV access. Check glucose (thiamine 100 mg if alcoholic). Lorazepam 0.1 mg/kg IV (max 4 mg) or midazolam 10 mg IM (no IV). Repeat once after 5 min."
        },
        {
          "severity": "5-20 min: first-line AED",
          "criteria": "seizure persists after 2nd benzodiazepine",
          "treatment": "IV fosphenytoin 20 mg/kg (max 150 mg/min). Alternatives: IV valproate 30-40 mg/kg, IV levetiracetam 60 mg/kg. Monitor for hypotension, arrhythmia."
        },
        {
          "severity": "20-40 min: refractory status",
          "criteria": "seizure persists despite above",
          "treatment": "ICU admission. IV anesthetic: propofol 2 mg/kg bolus then 5-10 mg/kg/h infusion, or midazolam 0.2 mg/kg bolus then 0.05-2 mg/kg/h. Continuous EEG monitoring."
        }
      ]
    },
    "pathophysiology": [
      "excessive_excitation",
