      ],
      "laboratory": [
        { "name": "CSF analysis", "priority": "high", "yield": 0.8, "indication": "albuminocytologic dissociation (high protein, normal cells)" },
        { "name": "Anti-ganglioside antibodies (GM1, GD1a, GQ1b)", "priority": "medium", "yield": 0.5, "indication": "subtype identification" },
        { "name": "Campylobacter serology, CMV, EBV, Zika", "priority": "medium", "yield": 0.4, "indication": "identify antecedent infection" }
