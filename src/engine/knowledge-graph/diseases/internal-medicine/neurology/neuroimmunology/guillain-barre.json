    "management": {
      "protocolReference": "NICE Guidelines for Guillain-Barré Syndrome",
      "pathways": [
        {
          "severity": "all (disease-modifying)",
          "criteria": "confirmed GBS, within 4 weeks of onset, unable to walk independently",
          "treatment": "IVIG 0.4 g/kg/day for 5 days (total 2 g/kg). OR plasma exchange 5 sessions (if IVIG contraindicated). Do both only if poor response."
        },
        {
          "severity": "monitoring",
          "criteria": "all patients",
          "treatment": "Admit. FVC Q4-6h. Cardiac monitoring for autonomic instability. BP monitoring. DVT prophylaxis. Pain management (neuropathic: gabapentin, pregabalin). Avoid opiates."
        },
        {
          "severity": "respiratory failure",
          "criteria": "FVC <20 mL/kg or declining rapidly, bulbar weakness",
          "treatment": "ICU admission. Elective intubation when FVC <15 mL/kg or clinical signs of fatigue. Mechanical ventilation (may be prolonged). Tracheostomy if prolonged. PEG if dysphagia."
        }
      ]
    },
    "pathophysiology": [
