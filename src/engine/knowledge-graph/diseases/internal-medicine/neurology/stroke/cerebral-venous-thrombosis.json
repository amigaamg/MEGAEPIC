      ],
      "imaging": [
        { "name": "CT venography (CTV)", "priority": "immediate", "yield": 0.95, "indication": "empty delta sign, sinus occlusion" },
        { "name": "MRI/MRV brain", "priority": "high", "yield": 0.95, "indication": "ischemic changes not arterial territory, venous infarct, clot signal" },
        { "name": "Non-contrast CT Head", "priority": "immediate", "yield": 0.3, "indication": "cord sign, dense vein, hemorrhagic venous infarct" }
      ]
    },
    "management": {
      "protocolReference": "AHA/ASA Guidelines for Cerebral Venous Thrombosis",
      "pathways": [
        {
          "severity": "mild-moderate",
          "criteria": "no coma, no major hemorrhage, no herniation",
          "treatment": "Anticoagulation: LMWH (enoxaparin 1 mg/kg BD) followed by warfarin (INR 2-3) for 3-6 months if provoked, 6-12 if unprovoked. Treat underlying cause."
        },
        {
          "severity": "severe (coma, hemorrhage, herniation)",
          "criteria": "GCS <9, large hemorrhagic infarct, impending herniation",
          "treatment": "ICU admission. Anticoagulation even with hemorrhage (LMWH reduces mortality). Decompressive hemicraniectomy if malignant edema. Endovascular thrombectomy if deteriorating despite anticoagulation."
        }
      ]
    },
