    "management": {
      "protocolReference": "AHA/ASA Guidelines for Intracerebral Hemorrhage",
      "pathways": [
        {
          "severity": "all patients",
          "criteria": "ICH confirmed on CT",
          "treatment": "ICU admission. BP control: SBP 140-160 (IV labetalol or nicardipine). Reverse anticoagulation (vitamin K + PCC if warfarin; idarucizumab if dabigatran; andexanet if factor Xa). Seizure prophylaxis. ICP monitoring."
        },
        {
          "severity": "surgical candidate",
          "criteria": "cerebellar >3 cm, superficial lobar >30 mL with GCS 9-12, or brainstem compression",
          "treatment": "Neurosurgical evacuation. External ventricular drain if intraventricular extension. Decompressive hemicraniectomy if malignant edema."
        }
      ]
    },
