    "name": "Dermatomyositis",
    "system": "rheumatology",
    "agePeak_months": [300, 600],
    "note": "Idiopathic inflammatory myopathy characterized by proximal muscle weakness and characteristic skin manifestations. Associated with malignancy in adults. Part of the inflammatory myositis spectrum.",
    "prevalenceWeight": 0.2,
    "syndromeTags": ["inflammatory_myopathy", "autoimmune", "connective_tissue_disease", "myositis", "rash"],

    "severityAssessment": {
