        "probability": 0.15,
        "severityBoost": 0.7,
        "clues": ["age_over_50", "refractory_disease", "anti_tif1", "anti_nxp2"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "high if ILD, dysphagia, or respiratory weakness",
    "diagnosticClues": ["heliotrope_rash_gottron_papules", "proximal_weakness", "elevated_ck", "perifascicular_atrophy"],
    "exclusionClues": ["no_rash", "normal_ck", "distal_weakness_predominance", "no_inflammatory_biopsy"]
  }
