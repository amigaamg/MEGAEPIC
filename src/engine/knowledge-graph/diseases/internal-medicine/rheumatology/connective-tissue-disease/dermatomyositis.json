        { "sign": "interstitial_lung_disease", "weight": 8 },
        { "sign": "myocarditis", "weight": 8 },
        { "sign": "underlying_malignancy", "weight": 9 }
      ],
      "severeCriteria": {
        "anyDangerSign": true
      },
      "nonSevereCriteria": {
        "noDangerSigns": true
      },
      "severityLabel": "If respiratory weakness, dysphagia, or ILD -> URGENT; else -> NON-URGENT (malignancy screening mandatory)"
    },

    "historyFeatures": [
      { "symptomId": "proximal_muscle_weakness", "weight": 5 },
      { "symptomId": "heliotrope_rash_eyelids", "weight": 5 },
