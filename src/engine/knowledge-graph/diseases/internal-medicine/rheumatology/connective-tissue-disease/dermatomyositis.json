      { "symptomId": "photosensitive_rash", "weight": 3 },
      { "symptomId": "dysphagia", "weight": 4 },
      { "symptomId": "myalgia_tenderness", "weight": 3 },
      { "symptomId": "raynaud_phenomenon", "weight": 2 }
    ],

    "examFeatures": [
      { "signId": "heliotrope_rash", "baseWeight": 5, "doubleWeight": true },
      { "signId": "gottron_papules", "baseWeight": 5, "doubleWeight": true },
      { "signId": "proximal_muscle_weakness", "baseWeight": 5 },
      { "signId": "shawl_sign_rash_upper_back", "baseWeight": 4 },
      { "signId": "mechanic_hands", "baseWeight": 3 },
      { "signId": "periungual_telangiectasias", "baseWeight": 3 },
      { "signId": "calcinosis_cutis", "baseWeight": 2 }
    ],

    "riskFactors": [
