      "pathways": [
        {
          "severity": "mild",
          "criteria": "rash, arthralgia, serositis, no organ threat",
          "treatment": "Hydroxychloroquine. NSAIDs. Topical steroids. Sun protection."
        },
        {
          "severity": "moderate",
          "criteria": "persistent disease despite HCQ, mild hematologic",
          "treatment": "Hydroxychloroquine + low-dose corticosteroids. Consider azathioprine or mycophenolate."
        },
        {
          "severity": "severe",
          "criteria": "nephritis, CNS lupus, severe hematologic, vasculitis",
          "treatment": "High-dose corticosteroids. Mycophenolate mofetil or cyclophosphamide induction. Rituximab for refractory. Anticoagulation for antiphospholipid."
        }
      ]
    },

    "pathophysiology": [
