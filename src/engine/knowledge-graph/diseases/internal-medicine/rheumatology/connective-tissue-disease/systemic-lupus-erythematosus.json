      "laboratory": [
        { "name": "ANA", "priority": "high", "yield": 0.95, "indication": "highly sensitive screening test" },
        { "name": "Anti-dsDNA", "priority": "high", "yield": 0.7, "indication": "specific, correlates with disease activity" },
        { "name": "Anti-Smith (Sm)", "priority": "high", "yield": 0.3, "indication": "highly specific for SLE" },
        { "name": "C3 and C4 complement", "priority": "high", "yield": 0.7, "indication": "low levels suggest active disease" },
