        { "name": "Slit lamp eye exam", "priority": "high", "yield": 0.7, "indication": "anterior uveitis, hypopyon" }
      ],
      "laboratory": [
        { "name": "HLA-B51", "priority": "medium", "yield": 0.5, "indication": "supportive but not diagnostic" },
        { "name": "CRP and ESR", "priority": "medium", "yield": 0.6, "indication": "elevated during flares" }
      ],
      "imaging": [
        { "name": "Fundoscopy / fluorescein angiography", "priority": "high", "yield": 0.8, "indication": "retinal vasculitis" },
        { "name": "MR venography (if CNS suspected)", "priority": "high", "yield": 0.8, "indication": "cerebral venous thrombosis" },
        { "name": "CT angiography (if vascular)", "priority": "high", "yield": 0.9, "indication": "aneurysm, thrombosis" }
      ]
    },

    "management": {
      "protocolReference": "EULAR Recommendations for Behcet's Disease",
      "pathways": [
        {
          "severity": "mild",
          "criteria": "oral/genital ulcers, skin, arthralgia",
          "treatment": "Topical steroids. Colchicine. Apremilast. Oral steroids for flares."
        },
        {
          "severity": "moderate",
          "criteria": "persistent mucocutaneous, arthritis, mild eye",
          "treatment": "Azathioprine. Cyclosporine A. Anti-TNF if resistant."
        },
        {
          "severity": "severe",
          "criteria": "uveitis, vascular, CNS, GI ulceration",
          "treatment": "High-dose steroids. Cyclophosphamide for vascular/CNS. Anti-TNF (infliximab). Anticoagulation for thrombosis (with immunosuppression)."
        }
      ]
    },

    "pathophysiology": [
