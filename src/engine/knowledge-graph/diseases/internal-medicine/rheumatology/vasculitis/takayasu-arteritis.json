        "prevalenceModifier": 0.5,
        "keyFeatures": [
          { "feature": "subclavian_carotid_involvement", "weight": 5 },
          { "feature": "pulseless_arms", "weight": 5 },
          { "feature": "carotid_bruit_neck_pain", "weight": 4 }
        ],
        "management": "Corticosteroids. Methotrexate or mycophenolate. Revascularization for critical stenosis."
      },
      {
        "id": "type_v_extensive",
        "name": "Type V: Extensive Aortic Involvement",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
