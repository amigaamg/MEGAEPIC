          { "feature": "multiple_aneurysms_stenoses", "weight": 5 },
          { "feature": "most_severe_form", "weight": 4 }
        ],
        "management": "High-dose steroids. Cyclophosphamide for refractory. Surgical bypass or endovascular stenting."
      }
    ],

    "mimics": [
      {
        "diseaseId": "giant_cell_arteritis",
        "discriminators": ["age_over_50", "temporal_artery_involvement", "no_subclavian_steal", "jaw_claudication"]
      },
      {
        "diseaseId": "atherosclerotic_vascular_disease",
        "discriminators": ["older_age", "cardiovascular_risk_factors", "no_constitutional_symptoms", "normal_esr"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Four-limb BP measurement", "priority": "immediate", "yield": 0.9, "indication": "detect BP differential" },
        { "name": "Fundoscopy", "priority": "high", "yield": 0.4, "indication": "hypertensive retinopathy" }
      ],
      "laboratory": [
        { "name": "ESR and CRP", "priority": "high", "yield": 0.8, "indication": "elevated in active disease" },
        { "name": "FBC", "priority": "medium", "yield": 0.4, "indication": "anemia of chronic disease" }
      ],
      "imaging": [
        { "name": "MR angiography (MRA)", "priority": "high", "yield": 0.9, "indication": "wall thickening, stenosis, aneurysm" },
        { "name": "CT angiography", "priority": "high", "yield": 0.9, "indication": "vessel wall enhancement" },
        { "name": "PET-CT", "priority": "medium", "yield": 0.85, "indication": "metabolic activity in vessel wall" },
        { "name": "Digital subtraction angiography", "priority": "medium", "yield": 0.9, "indication": "stenosis grading, pre-intervention" }
      ]
    },

    "management": {
      "protocolReference": "EULAR Recommendations for Takayasu Arteritis",
      "pathways": [
        {
          "severity": "active",
          "criteria": "constitutional symptoms, elevated ESR, vessel inflammation on imaging",
          "treatment": "Prednisolone 0.5-1 mg/kg/day. Methotrexate or azathioprine as steroid-sparing. Tocilizumab for refractory."
        },
        {
          "severity": "severe_refractory",
          "criteria": "progressive stenosis, aneurysms, despite steroids",
          "treatment": "Cyclophosphamide. Anti-TNF (infliximab). Surgical bypass for critical stenoses."
        }
      ]
    },

    "pathophysiology": [
      "granulomatous_inflammation",
      "adventitial_thickening",
      "intimal_hyperplasia",
      "vessel_stenosis_occlusion",
      "aneurysm_formation",
      "vasa_vasorum_inflammation"
