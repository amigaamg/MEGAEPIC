        { "sign": "severe_hypertension_renal_artery", "weight": 8 },
        { "sign": "critical_limb_ischemia", "weight": 8 }
      ],
      "severeCriteria": {
        "anyDangerSign": true
      },
      "nonSevereCriteria": {
        "noDangerSigns": true
      },
      "severityLabel": "If ischemic, hypertensive, or aortic complication -> URGENT; else -> NON-URGENT"
    },

    "historyFeatures": [
      { "symptomId": "arm_claudication_exertion", "weight": 5 },
      { "symptomId": "blood_pressure_difference_arms", "weight": 5 },
      { "symptomId": "dizziness_syncope_subclavian_steal", "weight": 4 },
      { "symptomId": "constitutional_symptoms", "weight": 4 },
