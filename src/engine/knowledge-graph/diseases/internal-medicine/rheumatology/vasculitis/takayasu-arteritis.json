      { "signId": "aortic_regurgitation_murmur", "baseWeight": 3 },
      { "signId": "hypertension_upper_extremity", "baseWeight": 3 },
      { "signId": "livedo_reticularis", "baseWeight": 2 }
    ],

    "riskFactors": [
