      ]
    },

    "management": {
      "protocolReference": "EULAR/ACR Giant Cell Arteritis Guidelines",
      "pathways": [
        {
          "severity": "ischemic",
          "criteria": "visual symptoms, jaw claudication, amaurosis",
          "treatment": "High-dose IV methylprednisolone (500-1000 mg daily x 3). Then oral prednisolone 60 mg/day. Do NOT wait for biopsy. Aspirin 75 mg."
        },
        {
          "severity": "non_ischemic",
          "criteria": "headache, PMR, elevated ESR, no ischemia",
          "treatment": "Prednisolone 40-60 mg/day. Taper gradually over 12-18 months. Tocilizumab for steroid-sparing."
        }
      ]
    },

