        { "name": "FBC", "priority": "high", "yield": 0.4, "indication": "normocytic anemia, thrombocytosis" }
      ],
      "imaging": [
        { "name": "Temporal artery biopsy", "priority": "high", "yield": 0.85, "indication": "granulomatous inflammation, skip lesions" },
        { "name": "Temporal artery ultrasound", "priority": "high", "yield": 0.7, "indication": "halo sign, stenosis, occlusion" },
