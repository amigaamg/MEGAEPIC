    "investigations": {
      "bedside": [
        { "name": "Heel palpation and Windlass test", "priority": "immediate", "yield": 0.9, "indication": "reproduce plantar fascia pain" },
        { "name": "Squeeze test for stress fracture", "priority": "high", "yield": 0.5, "indication": "exclude calcaneal fracture" }
      ],
      "laboratory": [],
      "imaging": [
        { "name": "Foot X-ray", "priority": "medium", "yield": 0.3, "indication": "exclude fracture, calcaneal spur (incidental)" },
        { "name": "Foot ultrasound", "priority": "medium", "yield": 0.85, "indication": "thickened plantar fascia > 4 mm, hypoechogenicity" },
        { "name": "MRI foot", "priority": "low", "yield": 0.9, "indication": "edema, partial tears, exclude other pathology" }
