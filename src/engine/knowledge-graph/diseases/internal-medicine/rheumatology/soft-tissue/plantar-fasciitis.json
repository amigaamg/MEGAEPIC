          { "feature": "biomechanical_predisposition", "weight": 4 },
          { "feature": "responds_to_conservative_care", "weight": 4 }
        ],
        "management": "Stretching (gastrocnemius, plantar fascia). Orthotics. NSAIDs. Night splint."
      },
      {
