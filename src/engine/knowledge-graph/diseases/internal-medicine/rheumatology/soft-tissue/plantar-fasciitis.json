    "management": {
      "protocolReference": "Clinical Practice Guidelines for Plantar Fasciitis",
      "pathways": [
        {
          "severity": "mild",
          "criteria": "first step pain only, minimal activity impact",
          "treatment": "Calf and plantar fascia stretching. Supportive footwear. Ice massage. OTC orthotics."
        },
        {
          "severity": "moderate",
          "criteria": "persistent pain, difficulty standing for > 30 min",
          "treatment": "Night splint. Physical therapy (manual therapy, stretching). NSAIDs. Custom orthotics."
        },
        {
          "severity": "refractory",
          "criteria": "> 6 months, failed conservative therapy",
          "treatment": "Extracorporeal shockwave therapy. Steroid injection (caution: rupture risk). PRP injection. Plantar fasciotomy (last resort)."
        }
      ]
    },

    "pathophysiology": [
