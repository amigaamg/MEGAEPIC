      ],
      "severeCriteria": {
        "anyDangerSign": true
      },
      "nonSevereCriteria": {
        "noDangerSigns": true
      },
      "severityLabel": "If suspected fracture or rupture -> URGENT; else -> NON-URGENT"
    },

    "historyFeatures": [
