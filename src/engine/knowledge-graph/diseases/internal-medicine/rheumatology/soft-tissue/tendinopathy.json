{
  "disease": {
    "id": "tendinopathy",
    "name": "Tendinopathy",
    "system": "rheumatology",
    "agePeak_months": [360, 720],
    "note": "Overuse injury of tendons characterized by pain, swelling, and impaired performance. Involves degenerative changes (tendinosis) with or without inflammation (tendinitis). Common sites: Achilles, patellar, lateral epicondyle (tennis elbow).",
    "prevalenceWeight": 0.5,
    "syndromeTags": ["soft_tissue", "tendon", "overuse_injury", "musculoskeletal_pain"],

    "severityAssessment": {
