        { "sign": "tendon_rupture_acute", "weight": 8 },
        { "sign": "septic_tendinitis", "weight": 9 },
        { "sign": "compartment_syndrome", "weight": 10 }
      ],
      "severeCriteria": {
        "anyDangerSign": true
      },
      "nonSevereCriteria": {
        "noDangerSigns": true
      },
      "severityLabel": "If acute rupture or infection suspected -> URGENT; else -> NON-URGENT"
    },

    "historyFeatures": [
      { "symptomId": "tendon_site_pain_overuse", "weight": 5 },
      { "symptomId": "gradual_onset_tendon_pain", "weight": 5 },
      { "symptomId": "pain_with_eccentric_loading", "weight": 4 },
      { "symptomId": "morning_stiffness_tendon", "weight": 3 },
      { "symptomId": "swelling_nodularity_tendon", "weight": 3 },
      { "symptomId": "recent_change_in_activity_level", "weight": 4 }
    ],

    "examFeatures": [
      { "signId": "tendon_mid_substance_tenderness", "baseWeight": 5, "doubleWeight": true },
      { "signId": "reproducible_pain_loading", "baseWeight": 4 },
      { "signId": "tendon_thickening_nodule", "baseWeight": 3 },
      { "signId": "weakness_associated_muscle", "baseWeight": 2 },
      { "signId": "crepitus_tendon_sheath", "baseWeight": 2 }
    ],

    "riskFactors": [
