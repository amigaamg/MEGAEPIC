          { "feature": "cozen_test_positive", "weight": 4 },
          { "feature": "extensor_carpi_radialis_brevis", "weight": 4 }
        ],
        "management": "Activity modification. Brace. Physiotherapy (eccentric). Steroid injection short-term. PRP injection."
      },
      {
        "id": "patellar_tendinopathy",
        "name": "Patellar Tendinopathy (Jumper's Knee)",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "anterior_knee_patellar_tendon", "weight": 5 },
          { "feature": "jumping_sports", "weight": 4 },
          { "feature": "tenderness_patellar_apex", "weight": 4 }
        ],
        "management": "Eccentric squats on decline board. Physiotherapy. Load management."
      }
    ],

    "mimics": [
      {
        "diseaseId": "tendon_rupture",
        "discriminators": ["acute_event", "gap_on_exam", "positive_thompson_test", "loss_of_function"]
      },
      {
        "diseaseId": "enthesitis_related_arthritis",
        "discriminators": ["multiple_sites", "inflammatory_back_pain", "psoriasis", "hla_b27"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Palpation along tendon length", "priority": "immediate", "yield": 0.8, "indication": "localize tenderness, detect nodules" },
        { "name": "Resisted muscle testing", "priority": "immediate", "yield": 0.7, "indication": "reproduce pain, assess strength" }
      ],
      "laboratory": [],
      "imaging": [
        { "name": "Tendon ultrasound", "priority": "high", "yield": 0.9, "indication": "tendon thickness, echotexture, neovascularization" },
        { "name": "MRI", "priority": "medium", "yield": 0.85, "indication": "tendinosis, partial tears, paratenonitis" }
      ]
    },

    "management": {
      "protocolReference": "Clinical Practice Guidelines for Tendinopathy",
      "pathways": [
        {
          "severity": "mild",
          "criteria": "pain with activity, normal daily life unaffected",
          "treatment": "Relative rest. Activity modification. Ice. Eccentric exercises. NSAIDs PRN."
        },
        {
          "severity": "moderate",
          "criteria": "pain limits sport/work, morning stiffness",
          "treatment": "Physiotherapy (eccentric program). Shockwave therapy. Bracing/taping. Consider steroid injection carefully."
        },
        {
          "severity": "refractory",
          "criteria": "> 6 months, failed conservative therapy",
          "treatment": "PRP injection. Tenotomy. Surgical release/ debridement. Consider alternative diagnoses."
        }
      ]
    },

    "pathophysiology": [
      "collagen_disorganization",
      "increased_glycosaminoglycans",
      "neovascularization",
      "tenocyte_apoptosis",
      "failed_healing_response",
      "tendon_degeneration_tendinosis"
    ],

    "complications": [
      {
        "diseaseId": "tendon_rupture",
        "probability": 0.05,
        "severityBoost": 0.7,
        "clues": ["acute_severe_pain", "sudden_loss_of_function", "palpable_gap", "positive_special_test"]
      }
    ],

    "mustNotMiss": false,
    "emergencyPriority": "low (unless rupture)",
    "diagnosticClues": ["overuse_onset_tendon_pain", "localized_tenderness_tendon", "loading_pain_eccentric", "normal_xray"],
    "exclusionClues": ["tendon_rupture_gap", "joint_effusion", "systemic_inflammatory_arthritis", "infection"]
  }
