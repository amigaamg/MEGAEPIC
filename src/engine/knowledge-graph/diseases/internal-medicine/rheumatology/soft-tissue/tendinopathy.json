          { "feature": "morning_stiffness_resolves", "weight": 4 },
          { "feature": "running_running_sports", "weight": 4 }
        ],
        "management": "Eccentric exercises (Alfredson protocol). Shockwave therapy. Avoid steroid injection (rupture risk)."
      },
      {
        "id": "lateral_epicondylitis",
        "name": "Lateral Epicondylitis (Tennis Elbow)",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
