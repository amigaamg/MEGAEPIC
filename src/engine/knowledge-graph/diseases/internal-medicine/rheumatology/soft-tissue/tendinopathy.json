      { "id": "sudden_increase_training", "multiplier": 3.0 },
      { "id": "poor_ergonomics_technique", "multiplier": 2.5 },
      { "id": "age_over_40", "multiplier": 2.0 },
      { "id": "obesity", "multiplier": 1.5 },
      { "id": "diabetes", "multiplier": 2.0 },
      { "id": "fluoroquinolone_antibiotics", "multiplier": 3.0 }
    ],

    "subtypes": [
