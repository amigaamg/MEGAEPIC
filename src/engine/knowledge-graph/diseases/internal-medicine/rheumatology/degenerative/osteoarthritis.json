    "management": {
      "protocolReference": "OARSI/ACR Guidelines for OA Management",
      "pathways": [
        {
          "severity": "mild",
          "criteria": "intermittent pain, no functional limitation",
          "treatment": "Weight loss. Exercise. Patient education. Paracetamol PRN. Topical NSAIDs."
        },
        {
          "severity": "moderate",
          "criteria": "persistent pain, some functional limitation",
          "treatment": "Oral NSAIDs (with PPI). Physiotherapy. Intra-articular steroids. Supports/braces."
        },
        {
          "severity": "severe",
          "criteria": "severe pain, significant functional limitation, night pain",
          "treatment": "Intra-articular hyaluronic acid. Joint replacement surgery (TKR, THR). Analgesics including weak opioids."
        }
      ]
    },

    "pathophysiology": [
      "cartilage_degradation",
      "proteoglycan_loss",
      "collagen_network_disruption",
      "subchondral_bone_sclerosis",
      "osteophyte_formation",
      "synovial_inflammation_secondary"
