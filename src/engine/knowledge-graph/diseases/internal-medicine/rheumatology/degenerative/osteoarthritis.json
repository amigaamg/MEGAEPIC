    "investigations": {
      "bedside": [
        { "name": "ROM assessment and gait analysis", "priority": "immediate", "yield": 0.8, "indication": "joint function" }
      ],
      "laboratory": [
        { "name": "CRP", "priority": "medium", "yield": 0.2, "indication": "typically normal; if elevated, consider inflammatory arthropathy" }
      ],
      "imaging": [
        { "name": "Weight-bearing joint X-ray", "priority": "high", "yield": 0.9, "indication": "joint space narrowing, osteophytes, sclerosis, cysts" },
        { "name": "MRI", "priority": "low", "yield": 0.8, "indication": "cartilage loss, meniscal tears, bone marrow lesions" }
      ]
