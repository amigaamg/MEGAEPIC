    "management": {
      "protocolReference": "ACR/EULAR Guidelines for Rheumatoid Arthritis",
      "pathways": [
        {
          "severity": "active",
          "criteria": "DAS28 > 5.1, swollen and tender joints, elevated acute phase",
          "treatment": "Methotrexate + folic acid. Consider triple DMARD therapy (MTX + SSZ + HCQ). If inadequate response, add TNF inhibitor or alternative biologic."
        },
        {
          "severity": "moderate",
          "criteria": "DAS28 3.2-5.1, limited joint involvement",
          "treatment": "DMARD monotherapy (methotrexate or leflunomide). Taper to lowest effective dose."
        },
        {
          "severity": "remission",
          "criteria": "DAS28 < 2.6, no swollen joints, normal CRP",
          "treatment": "Maintain DMARD. Consider gradual de-escalation after sustained remission."
        }
      ]
