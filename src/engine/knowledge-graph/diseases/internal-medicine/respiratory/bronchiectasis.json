    "investigations": {
      "bedside": [
        {
          "name": "Pulse oximetry",
          "priority": "initial",
          "yield": 0.8,
          "indication": "all patients at diagnosis and exacerbation"
        },
        {
          "name": "MRC dyspnoea scale",
          "priority": "initial",
          "yield": 0.7,
          "indication": "baseline functional assessment"
        },
        {
          "name": "Sputum colour chart",
          "priority": "exacerbation",
          "yield": 0.6,
          "indication": "purulence indicates exacerbation"
        }
      ],
      "laboratory": [
        {
          "name": "Sputum microbiology (culture + sensitivity)",
          "priority": "initial and each exacerbation",
          "yield": 0.9,
          "indication": "identify pathogens: Pseudomonas, H. influenzae, S. aureus, NTM",
          "note": "ATS/ERS recommend sputum cultures at least annually and at each exacerbation"
        },
        {
          "name": "Serum immunoglobulins (IgG, IgA, IgM)",
          "priority": "initial diagnosis",
          "yield": 0.7,
          "indication": "screen for immunodeficiency"
        },
        {
          "name": "Aspergillus serology (IgE, IgG)",
          "priority": "initial diagnosis",
          "yield": 0.8,
          "indication": "screen for ABPA; total IgE and Aspergillus-specific IgE"
        },
        {
          "name": "FBC with differential",
          "priority": "baseline",
          "yield": 0.5,
          "indication": "eosinophilia suggests ABPA"
        },
        {
          "name": "CFTR genetic testing",
          "priority": "selected cases",
          "yield": 0.6,
          "indication": "young adults, unexplained bronchiectasis, male infertility"
        }
      ],
      "imaging": [
        {
          "name": "HRCT chest",
          "priority": "diagnostic gold standard",
          "yield": 1.0,
          "indication": "all suspected bronchiectasis",
          "typicalFindings": ["bronchial_dilation_signet_ring_sign", "tram_track_opacities", "lack_of_tapering", "airway_to_artery_ratio_greater_than_1", "mucoid_impaction"],
          "note": "HRCT with 1 mm slices; four patterns: cylindrical, varicose, cystic, traction"
