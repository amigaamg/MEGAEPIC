        {
          "name": "Pulmonary function tests (spirometry, DLCO)",
          "indication": "baseline and annual monitoring",
          "priority": "routine"
        }
      ]
    },

    "management": {
      "protocolReference": "BTS Guideline for Bronchiectasis (2019) / ATS/ERS Statement on Bronchiectasis",
      "pathways": [
        {
          "severity": "mild",
          "criteria": "few exacerbations, low BSI, FEV1 >50%, single organism",
          "treatment": [
            "Airway clearance physiotherapy (e.g., active cycle of breathing, positive expiratory pressure, oscillatory PEP)",
            "Bronchodilators if bronchial hyperreactivity present (inhaled beta-agonists PRN)",
            "Inhaled corticosteroids only in asthma/ABPA overlap",
            "Annual sputum surveillance and influenza/pneumococcal vaccination",
            "Prompt antibiotic treatment for exacerbations based on sensitivities"
          ],
          "followUp": "Annual review with spirometry"
        },
        {
          "severity": "moderate",
          "criteria": "BSI 5–8, FEV1 30–50%, 1–2 exacerbations/year, Pseudomonas colonisation possible",
          "treatment": [
            "All mild measures plus:",
            "Regular airway clearance twice daily with chest physiotherapy",
            "Long-term macrolide therapy (azithromycin 250–500 mg 3x/week or 250 mg daily) per BTS guidelines for exacerbation prevention",
            "Consider inhaled corticosteroids if significant bronchial hyperreactivity",
            "Treat exacerbations with antibiotics guided by sputum culture for 14 days",
            "Consider inhaled antibiotics if chronic Pseudomonas (colistin or tobramycin)"
          ],
          "followUp": "Six-monthly review with spirometry, annual HRCT"
        },
        {
          "severity": "severe",
          "criteria": "BSI ≥9, FEV1 <30%, ≥3 exacerbations/year, chronic Pseudomonas, frequent admissions",
          "treatment": [
            "All moderate measures plus:",
            "Long-term antibiotics (oral or nebulised) based on microbiology",
            "Oxygen therapy if hypoxaemic (LTOT if PaO2 <7.3 kPa)",
            "Pulmonary rehabilitation",
            "Bronchial artery embolisation for haemoptysis",
            "Consider lung volume reduction surgery if localised disease",
            "Lung transplant evaluation if progressive despite maximal therapy",
            "Monitor for NTM (MAC); treat with rifampicin, ethambutol, azithromycin per ATS/ERS guidelines"
          ],
          "escalation": "Refer to tertiary bronchiectasis centre. Evaluate for surgical resection if focal disease, lung transplant if diffuse."
        }
      ]
    },

    "pathophysiology": [
      "chronic_airway_inflammation",
      "impaired_mucociliary_clearance",
      "irreversible_bronchial_dilation",
