{
  "disease": {
    "id": "bronchiectasis",
    "name": "Bronchiectasis",
    "system": "respiratory",
    "note": "Chronic irreversible airway dilation with impaired mucociliary clearance. HRCT is diagnostic gold standard. ATS/ERS guidelines recommend ABPA and MAC screening at diagnosis.",
    "prevalenceWeight": 0.25,
    "syndromeTags": ["chronic_suppurative_lung_disease", "airway_dilation"],

    "severityAssessment": {
      "immediateDangerSigns": [
        { "sign": "massive_hemoptysis", "weight": 10, "description": ">200 mL/24h, may require bronchial artery embolisation" },
        { "sign": "acute_respiratory_failure", "weight": 10 },
        { "sign": "sepsis_shock", "weight": 9 },
        { "sign": "spo2_less_than_88", "weight": 9 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "frequent_exacerbations", "description": "≥3 per year", "weight": 7 },
          { "sign": "BSI_score_high", "description": "Bronchiectasis Severity Index ≥9", "weight": 7 },
          { "sign": "FEV1_less_than_30_percent", "weight": 6 },
          { "sign": "pseudomonas_colonisation", "weight": 6 }
        ]
      },
      "moderateCriteria": {
        "anyOf": [
          { "sign": "BSI_score_intermediate", "description": "BSI 5–8", "weight": 5 },
          { "sign": "FEV1_30_to_50_percent", "weight": 4 },
          { "sign": "exacerbations_1_to_2_per_year", "weight": 4 }
        ],
        "noDangerSigns": true
      },
      "mildCriteria": {
        "BSI_score_low": true,
        "FEV1_greater_than_50_percent": true,
        "infrequent_exacerbations": true
      }
    },

    "historyFeatures": [
      { "symptomId": "chronic_cough", "weight": 5, "note": "Daily productive cough most days over months to years" },
      { "symptomId": "sputum_production", "weight": 5, "qualitativeModifiers": [
          { "qualityKey": "purulent", "weightBoost": 2, "description": "Indicates active infection" },
          { "qualityKey": "large_volume", "weightBoost": 1 }
        ]
      },
      { "symptomId": "hemoptysis", "weight": 4, "note": "Ranges from blood-streaked to massive; BTS guidelines recommend bronchial artery embolisation for massive haemoptysis" },
      { "symptomId": "dyspnea", "weight": 3, "note": "Progressive over time" },
      { "symptomId": "recurrent_infections", "weight": 4, "note": "Frequent pneumonia or bronchitis episodes" },
      { "symptomId": "fatigue", "weight": 2 },
      { "symptomId": "chest_pain", "weight": 2, "note": "Pleuritic; may indicate exacerbation" },
      { "symptomId": "wheeze", "weight": 2, "note": "Associated with bronchial hyperreactivity" },
      { "symptomId": "night_sweats", "weight": 2, "note": "May indicate underlying ABPA or TB" },
      { "symptomId": "weight_loss", "weight": 2, "note": "Advanced or poorly controlled disease" }
    ],

    "examFeatures": [
      { "signId": "crackles", "baseWeight": 5, "doubleWeight": true, "note": "Coarse inspiratory crackles, often at lung bases" },
      { "signId": "wheeze", "baseWeight": 2 },
      { "signId": "clubbing", "baseWeight": 3, "note": "Present in advanced disease" },
      { "signId": "tachypnea", "baseWeight": 2 },
      { "signId": "hypoxia", "baseWeight": 3, "severityBoost": true },
      { "signId": "prolonged_expiration", "baseWeight": 2 },
      { "signId": "hyperinflation_signs", "baseWeight": 2 },
      { "signId": "digital_clubbing", "baseWeight": 2, "severityMarker": true }
    ],

    "riskFactors": [
      { "id": "previous_severe_pneumonia", "multiplier": 1.5, "note": "Especially TB, pertussis, measles" },
      { "id": "immunodeficiency", "multiplier": 1.6 },
      { "id": "ABPA", "multiplier": 1.8, "description": "Allergic bronchopulmonary aspergillosis" },
      { "id": "primary_ciliary_dyskinesia", "multiplier": 1.7 },
      { "id": "cystic_fibrosis", "multiplier": 2.0 },
      { "id": "rheumatoid_arthritis", "multiplier": 1.4 },
      { "id": "IBD", "multiplier": 1.3, "note": "Ulcerative colitis and Crohn disease associated" },
      { "id": "chronic_aspiration", "multiplier": 1.4 },
      { "id": "NTM_infection", "multiplier": 1.6, "description": "Non-tuberculous mycobacteria (MAC most common)" },
      { "id": "alpha1_antitrypsin_deficiency", "multiplier": 1.3 }
    ],

    "subtypes": [
      {
        "id": "cystic_fibrosis_bronchiectasis",
        "name": "CF-related Bronchiectasis",
        "typicalOrganisms": ["Pseudomonas aeruginosa", "Staphylococcus aureus", "Burkholderia cepacia complex"],
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "meconium_ileus_history", "weight": 5 },
          { "feature": "pancreatic_insufficiency", "weight": 4 },
          { "feature": "sinusitis", "weight": 3 },
          { "feature": "male_infertility", "weight": 3 }
        ],
        "management": "CFTR modulator therapy; Ivacaftor/Lumacaftor; aggressive airway clearance; antipseudomonal antibiotics"
      },
