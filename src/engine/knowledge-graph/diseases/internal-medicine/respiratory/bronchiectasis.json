          { "feature": "severe_pertussis_or_measles", "weight": 4 },
          { "feature": "recurrent_childhood_pneumonia", "weight": 4 }
        ],
        "imagingFeatures": ["upper_lobe_predominant", "traction_bronchiectasis"],
        "management": "Airway clearance; treat exacerbations; monitor for progression"
      },
      {
        "id": "ABPA_related",
        "name": "ABPA-related Bronchiectasis",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
          { "feature": "asthma_history", "weight": 5 },
          { "feature": "elevated_IgE", "weight": 5 },
          { "feature": "central_bronchiectasis", "weight": 5 },
          { "feature": "high_eosinophils", "weight": 4 }
        ],
        "imagingFeatures": ["central_bronchiectasis", "mucoid_impaction"],
        "management": "Oral corticosteroids; antifungal therapy (itraconazole/voriconazole)"
      },
      {
        "id": "traction_bronchiectasis_ILD",
        "name": "Traction Bronchiectasis (ILD-associated)",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
          { "feature": "UIP_fibrosis", "weight": 5 },
          { "feature": "restrictive_PFTs", "weight": 4 },
          { "feature": "dry_cough_predominant", "weight": 3 }
        ],
        "imagingFeatures": ["honeycombing", "traction_bronchiectasis", "reticulation"],
        "management": "Treat underlying ILD; antifibrotics if IPF"
      }
    ],

