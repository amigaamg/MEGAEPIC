    "adaptiveQuestioning": {
      "initialCoreQuestions": ["age_months?", "cough_duration?", "weight_loss?", "fever?", "tb_contact?", "hiv_risk?"],
      "branching": [
        {
          "if": "cough_duration_>=_14_days",
          "ask": ["weight_loss?", "night_sweats?", "tb_contact?", "hiv_test_done?"],
          "action": "TB highly likely – obtain CXR and GeneXpert."
        },
        {
          "if": "tb_contact_positive",
          "ask": ["type_of_contact?", "duration?", "contact_smear_status?"],
          "action": "Boost TB probability significantly; consider TB preventive therapy if child well."
        },
        {
          "if": "hiv_risk_or_exposure",
          "ask": ["hiv_test_result?", "previous_pcp_prophylaxis?", "oral_thrush?", "recurrent_infections?"],
          "action": "Test for HIV; TB and HIV often coexist."
        },
        {
          "if": "acute_onset_<_7_days",
          "ask": ["fever_high?", "crackles_focal?", "response_to_antibiotics?"],
          "action": "Pneumonia more likely; keep TB in differential if risk factors."
        },
        {
          "if": "wheeze_present",
          "ask": ["recurrent_episodes?", "family_atopy?", "bronchodilator_response?"],
          "action": "Asthma more likely if episodic; TB if chronic and weight loss."
