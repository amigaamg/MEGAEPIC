      "imaging": [
        {
          "name": "Chest X-ray PA and lateral",
          "priority": "high",
          "yield": 0.85,
          "indication": "all suspected cases",
          "typicalFindings": {
            "primary_tb": "hilar/mediastinal lymphadenopathy, consolidation",
            "miliary": "diffuse micronodules",
            "older_child_cavitation": "apical cavitation",
            "pleural_effusion": "blunted costophrenic angle"
          }
        }
      ],
      "advanced": [
        { "name": "CT chest", "indication": "diagnostic doubt, complications", "priority": "low" }
      ]
