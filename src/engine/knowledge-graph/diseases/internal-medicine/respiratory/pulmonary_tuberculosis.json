    "management": {
      "protocolReference": "Kenya National Guidelines for Management of Tuberculosis in Children",
      "standardRegimen": {
        "intensivePhase": "2 months RHZE (Rifampicin, Isoniazid, Pyrazinamide, Ethambutol) daily",
        "continuationPhase": "4 months RH (Rifampicin, Isoniazid) daily",
        "totalDuration": "6 months",
        "dosage": "Weight‑banded dosing per national guidelines"
      },
      "severeTBRegimen": {
        "indications": ["tb_meningitis", "miliary_tb", "severe_respiratory_compromise"],
        "treatment": "Standard intensive phase 2 months RHZE + continuation phase prolonged to 7–10 months (total 9–12 months)",
        "adjuncts": "Add corticosteroids (prednisolone 2 mg/kg/day) for TB meningitis; taper over 4–6 weeks"
      },
      "supportiveCare": [
        "Nutritional assessment and support",
        "HIV care if co‑infected (cotrimoxazole prophylaxis, ART timing)",
        "Directly Observed Therapy (DOT) recommended"
      ],
      "followUp": "Monthly weight, symptom review, adherence check. Repeat CXR if symptoms persist."
    },

    "treatmentResponseLogic": {
      "expectedImprovement": "Clinical improvement (weight gain, reduced cough) within 2–4 weeks. Weight gain often the best marker.",
      "noImprovementAfter4_8Weeks": {
        "actions": [
          "Check adherence",
          "Repeat GeneXpert and culture for drug susceptibility",
          "Exclude drug‑resistant TB",
          "Re‑evaluate for alternative diagnoses: malignancy, bronchiectasis, HIV‑related lung disease",
          "If still diagnostic of TB, switch to second‑line regimen"
        ]
      }
    },

    "differentialCompetition": {
