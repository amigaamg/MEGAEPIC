    "investigations": {
      "bedside": [
        { "name": "Weight chart review", "priority": "immediate", "yield": 0.9 },
        { "name": "Pulse oximetry", "priority": "if respiratory distress" }
      ],
      "laboratory": [
        { "name": "GeneXpert MTB/RIF on sputum or gastric aspirate", "priority": "highest", "yield": 0.95, "note": "Rapid molecular test; detects rifampicin resistance" },
        { "name": "AFB smear microscopy x 3", "priority": "high", "yield": 0.6, "note": "Low sensitivity in children" },
        { "name": "Mantoux tuberculin skin test (TST)", "priority": "high", "yield": 0.7, "interpretation": "≥10mm in non-HIV, ≥5mm in HIV" },
