      { "diseaseId": "heart_failure", "probability": 0.05, "severityBoost": 0.2, "clues": ["chronic_bradycardia", "low_output_symptoms"] }
    ],
    "mustNotMiss": true,
    "emergencyPriority": "high if high-grade",
    "diagnosticClues": ["bradycardia", "pr_prolongation", "dropped_qrs", "av_dissociation"],
