      "pathways": [
        {
          "severity": "unstable",
          "criteria": "hypotension, syncope, chest pain, heart failure",
          "treatment": "Synchronized cardioversion (100-200 J biphasic). IV adenosine if immediately available. Sedation if conscious."
        },
        {
          "severity": "stable",
          "criteria": "hemodynamically stable",
          "treatment": "Vagal maneuvers (Valsalva, carotid sinus massage). IV adenosine 6 mg rapid bolus (may repeat 12 mg). If converts: sinus rhythm. ECG post-conversion."
