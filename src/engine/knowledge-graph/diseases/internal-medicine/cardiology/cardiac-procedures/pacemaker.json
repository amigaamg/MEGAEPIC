    "management": {
      "protocolReference": "ESC Guidelines for Cardiac Pacing and CRT",
      "pathways": [
        {
          "severity": "implantation",
          "criteria": "standard elective implant",
          "treatment": "Local anesthesia +/- sedation. Cephalic or subclavian vein access. Lead placement. Pocket creation. Device programming. Chest X-ray post-op."
        },
        {
          "severity": "post-operative (uncomplicated)",
          "criteria": "successful implant, no complications",
          "treatment": "Immobilize arm for 24-48h. Antibiotic prophylaxis (cefazolin pre-op). ECG and CXR post-op. Device check before discharge. Wound care. Follow-up at 1, 3, 6 months."
        },
        {
          "severity": "infection management",
          "criteria": "pocket erythema, purulent discharge, fever, positive cultures",
          "treatment": "Blood cultures + pocket aspirate. IV antibiotics (vancomycin + ceftriaxone). Device and lead extraction (complete system removal). Contra-lateral re-implant after infection clearance."
        }
      ]
    },
