          { "feature": "biventricular_pacing", "weight": 5 },
          { "feature": "lbbb_qrs_greater_150", "weight": 5 }
        ],
        "management": "Indicated for HF with LVEF <35%, LBBB, QRS >150 ms. CRT-P if no ICD indication; CRT-D if also ICD indicated. Optimize AV/VV intervals."
      }
    ],
    "investigations": {
      "bedside": [
