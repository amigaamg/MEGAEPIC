    "subtypes": [
      {
        "id": "on_pump_cabg",
        "name": "On-Pump CABG (with CPB)",
        "prevalenceModifier": 0.6,
        "keyFeatures": [{ "feature": "cardiopulmonary_bypass_used", "weight": 5 }],
        "management": "Arrest heart with cardioplegia. Bypass grafts. Wean from CPB. Close sternum. ICU recovery. Post-op: protect grafts, control rhythm, prevent bleeding."
      },
      {
        "id": "off_pump_cabg",
        "name": "Off-Pump CABG (OPCAB)",
        "prevalenceModifier": 0.3,
        "keyFeatures": [{ "feature": "beating_heart_procedure", "weight": 5 }],
        "management": "Stabilizer device. Sequential grafting. Avoid CPB complications. Avoid manipulation of diseased aorta (no-touch technique)."
      },
      {
        "id": "minimally_invasive_cabg",
        "name": "Minimally Invasive CABG (MIDCAB/robotic)",
        "prevalenceModifier": 0.1,
        "keyFeatures": [{ "feature": "lateral_thoracotomy_not_sternotomy", "weight": 5 }],
        "management": "LIMA to LAD via small thoracotomy. Quicker recovery. Lower morbidity. Only for limited target vessel disease."
      }
    ],
    "investigations": {
      "bedside": [
        { "name": "ECG", "priority": "immediate", "yield": 0.7, "indication": "ischemia, arrhythmia, pacing" }
