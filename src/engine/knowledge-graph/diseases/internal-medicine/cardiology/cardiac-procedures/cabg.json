        { "name": "CT coronary angiogram", "priority": "medium", "yield": 0.9, "indication": "graft patency assessment if symptoms" }
      ]
    },
    "management": {
      "protocolReference": "ESC/EACTS Guidelines for Myocardial Revascularization",
      "pathways": [
        {
          "severity": "pre-operative",
          "criteria": "planned CABG",
          "treatment": "Aspirin continued. Stop DAPT before surgery (ticagrelor/clopidogrel 5d pre-op). Statin. Beta-blocker. Pulmonary function tests. EuroSCORE calculation."
        },
        {
          "severity": "post-operative recovery",
          "criteria": "uncomplicated surgery, extubated, stable",
          "treatment": "ICU 24-48h. Aspirin started 6h post-op if no bleeding. Beta-blocker + statin. Pain control. Wound care. Early mobilization. Cardiac rehab."
        },
        {
          "severity": "complicated - low cardiac output",
          "criteria": "inotropic requirement, IABP, prolonged ventilation",
          "treatment": "Inotropes (dobutamine, epinephrine). Consider IABP. Echocardiography for graft function, LV function, tamponade. Repeat revascularization if graft occlusion."
        }
      ]
    },
    "pathophysiology": [
