    "management": {
      "protocolReference": "ESC Guidelines for Congenital Heart Disease - Tetralogy of Fallot",
      "pathways": [
        {
          "severity": "neonatal - duct dependent",
          "criteria": "severe cyanosis, duct-dependent pulmonary flow",
          "treatment": "PGE1 infusion to maintain ductal patency. Balloon dilation or stent of RVOT. Modified BT shunt if anatomy unfavorable."
        },
        {
          "severity": "hypercyanotic spell",
          "criteria": "sudden increase in cyanosis, agitation, gasping",
          "treatment": "Knee-chest position. Oxygen 100%. Morphine 0.05-0.2 mg/kg IV. IV fluids (NS 10-20 mL/kg). Propranolol 0.1-0.2 mg/kg IV. Phenylephrine if hypotensive. Emergency surgery if refractory."
        },
        {
          "severity": "elective repair",
          "criteria": "stable, elective surgical repair",
          "treatment": "Complete repair at 3-6 months: VSD patch closure, RVOT muscle bundle resection, transannular patch if needed. Post-op: monitor for pulmonary regurgitation, RV dilation, arrhythmias. Long-term follow-up."
        }
      ]
    },
    "pathophysiology": [
