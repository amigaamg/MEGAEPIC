    "management": {
      "protocolReference": "ESC Guidelines for Congenital Heart Disease - Coarctation",
      "pathways": [
        {
          "severity": "critical neonatal",
          "criteria": "duct-dependent, shock, HF in first days",
          "treatment": "PGE1 10-20 ng/kg/min IV. Inotropic support. Correct acidosis. Emergency surgical repair (end-to-end anastomosis)."
        },
        {
          "severity": "stable child/adult",
          "criteria": "discrete coarctation, gradient >20 mmHg or hypertension",
          "treatment": "Surgical repair (if young age or complex anatomy) or percutaneous intervention (balloon angioplasty + stent). Pre-op and post-op BP management."
        },
        {
          "severity": "post-repair follow-up",
          "criteria": "lifelong after repair",
          "treatment": "Annual cardiac follow-up. BP monitoring. MRI for restenosis and aneurysm. Treat hypertension aggressively. Endocarditis prophylaxis if residual defect."
