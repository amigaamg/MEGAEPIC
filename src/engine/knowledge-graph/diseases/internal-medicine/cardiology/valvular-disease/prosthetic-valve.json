      "pathways": [
        {
          "severity": "thrombosis (obstructive)",
          "criteria": "NYHA III-IV, large thrombus, immobile leaflet",
          "treatment": "Urgent surgery: valve replacement or thrombectomy. If high surgical risk: fibrinolysis (alteplase). IV heparin. Optimize warfarin."
        },
        {
          "severity": "endocarditis",
          "criteria": "vegetation >10 mm, abscess, valve dehiscence, persistent fever despite antibiotics",
          "treatment": "Urgent surgical removal and re-replacement. IV antibiotics (vancomycin + gentamicin + rifampin). Blood cultures before antibiotics."
        },
        {
          "severity": "deterioration/leak",
          "criteria": "progressive stenosis or regurgitation, hemolysis, HF symptoms",
          "treatment": "Re-do SAVR or valve-in-valve TAVI for bioprosthetic. Percutaneous closure of paravalvular leak. Medical therapy if not redo candidate."
