{
  "disease": {
    "id": "mitral_regurgitation",
    "name": "Mitral Regurgitation",
    "system": "CARD",
    "agePeak_months": [540, 960],
    "note": "Leakage of blood from LV into LA during systole. Causes: primary (valve structural) or secondary (LV dilation).",
    "prevalenceWeight": 0.4,
    "syndromeTags": ["valvular_heart_disease", "left_heart_volume_overload"],
    "severityAssessment": {
      "immediateDangerSigns": [
