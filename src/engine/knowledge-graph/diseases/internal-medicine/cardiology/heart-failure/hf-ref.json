{
  "disease": {
    "id": "hf_ref",
    "name": "Heart Failure with Reduced Ejection Fraction",
    "system": "CARD",
    "agePeak_months": [600, 1080],
    "note": "LVEF ≤40%. Impaired systolic function. Guideline-directed medical therapy improves outcomes.",
    "prevalenceWeight": 0.5,
    "syndromeTags": ["heart_failure", "systolic_dysfunction"],
    "severityAssessment": {
      "immediateDangerSigns": [
        { "sign": "cardiogenic_shock", "weight": 10 },
        { "sign": "pulmonary_oedema", "weight": 9 },
        { "sign": "refractory_congestion", "weight": 8 }
      ],
      "severeCriteria": { "anyDangerSign": true },
      "nonSevereCriteria": { "hasIndrawingOrFastBreathing": false, "noDangerSigns": true },
      "severityLabel": "If shock/oedema/refractory -> ACUTE DECOMPENSATED HFrEF; else -> COMPENSATED HFrEF"
    },
    "historyFeatures": [
      { "symptomId": "dyspnea", "weight": 5, "modifiers": [{ "condition": "exertional_progressive", "suspectTB": false }] },
      { "symptomId": "orthopnea", "weight": 4 },
      { "symptomId": "paroxysmal_nocturnal_dyspnea", "weight": 4 },
      { "symptomId": "fatigue_weakness", "weight": 3 },
      { "symptomId": "lower_limb_swelling", "weight": 3 },
      { "symptomId": "nocturnal_cough", "weight": 2 },
      { "symptomId": "reduced_exercise_tolerance", "weight": 4 }
    ],
    "examFeatures": [
      { "signId": "bibasilar_crackles", "baseWeight": 4 },
      { "signId": "jugular_venous_distension", "baseWeight": 4, "doubleWeight": true },
      { "signId": "peripheral_oedema", "baseWeight": 3 },
      { "signId": "displaced_apex_beat", "baseWeight": 3 },
      { "signId": "s3_gallop", "baseWeight": 4, "doubleWeight": true },
      { "signId": "hepatomegaly", "baseWeight": 3 },
      { "signId": "hepatic_jugular_reflux", "baseWeight": 3 },
      { "signId": "tachycardia", "baseWeight": 2 }
    ],
    "riskFactors": [
      { "id": "coronary_artery_disease", "multiplier": 2.5 },
      { "id": "previous_mi", "multiplier": 2.5 },
      { "id": "hypertension", "multiplier": 1.5 },
      { "id": "diabetes", "multiplier": 1.8 },
      { "id": "alcohol_excess", "multiplier": 1.5 },
      { "id": "chemotherapy_exposure", "multiplier": 2.0 }
    ],
    "subtypes": [
      {
        "id": "mild_hfref",
        "name": "Mild HFrEF (LVEF 36-40%)",
        "prevalenceModifier": 0.3,
        "keyFeatures": [{ "feature": "ef_36_to_40", "weight": 5 }],
        "management": "ACEi/ARB + beta-blocker + MRA. SGLT2i. Titrate to target doses."
      },
      {
        "id": "moderate_hfref",
        "name": "Moderate HFrEF (LVEF 26-35%)",
        "prevalenceModifier": 0.4,
        "keyFeatures": [{ "feature": "ef_26_to_35", "weight": 5 }],
        "management": "ACEi/ARB + beta-blocker + MRA + SGLT2i. Consider ICD if >3 months on GDMT."
      },
      {
        "id": "severe_hfref",
        "name": "Severe HFrEF (LVEF ≤25%)",
        "prevalenceModifier": 0.3,
        "keyFeatures": [{ "feature": "ef_less_than_25", "weight": 5 }],
        "management": "Full GDMT. ICD for primary prevention. CRT if LBBB. Consider transplant evaluation or LVAD."
      }
    ],
    "mimics": [
      { "diseaseId": "hfpef", "discriminators": ["ef_greater_50", "diastolic_dysfunction", "small_lv_chamber"] },
      { "diseaseId": "copd_exacerbation", "discriminators": ["chronic_cough", "smoking_history", "normal_echo"] }
    ],
    "investigations": {
      "bedside": [
        { "name": "Pulse oximetry", "priority": "immediate", "yield": 0.7, "indication": "hypoxia assessment" },
        { "name": "6-minute walk test", "priority": "medium", "yield": 0.7, "indication": "functional capacity" }
      ],
      "laboratory": [
        { "name": "BNP/NT-proBNP", "priority": "high", "yield": 0.9, "indication": "diagnosis and monitoring" },
        { "name": "Serum creatinine and eGFR", "priority": "high", "yield": 0.6, "indication": "renal function, diuretic monitoring" },
        { "name": "Serum potassium", "priority": "high", "yield": 0.4, "indication": "MRA and ACEi monitoring" },
        { "name": "Troponin", "priority": "medium", "yield": 0.3, "indication": "myocardial injury" }
      ],
      "imaging": [
        { "name": "Echocardiography", "priority": "immediate", "yield": 0.98, "indication": "LVEF assessment, wall motion, valves" },
        { "name": "Cardiac MRI", "priority": "medium", "yield": 0.9, "indication": "accurate EF, fibrosis assessment" },
        { "name": "Coronary angiography", "priority": "medium", "yield": 0.6, "indication": "if ischemic etiology suspected" }
      ]
    },
    "management": {
      "protocolReference": "ESC Guidelines for Heart Failure 2021",
      "pathways": [
        {
          "severity": "compensated HFrEF",
          "criteria": "no congestion, no acute decompensation",
          "treatment": "ACEi/ARB (ramipril 2.5-10 mg). Beta-blocker (bisoprolol 1.25-10 mg). MRA (spironolactone 25 mg). SGLT2i (dapagliflozin 10 mg). Titrate to target doses."
        },
        {
          "severity": "acutely decompensated HFrEF",
          "criteria": "congestion, dyspnea at rest, JVD, oedema",
          "treatment": "IV furosemide 40-80 mg, titrate. Oxygen. Consider vasodilators (NTG). Inotropes if shock. ICU admission if severe."
        },
        {
          "severity": "advanced HFrEF",
          "criteria": "NYHA III-IV despite GDMT, frequent admissions",
          "treatment": "Maximize GDMT. Consider ICD/CRT. Heart transplant evaluation. LVAD as bridge or destination. Palliative care."
        }
      ]
    },
    "pathophysiology": [
      "reduced_contractility",
      "neurohormonal_activation",
      "renin_angiotensin_aldosterone_system",
      "sympathetic_nervous_system",
      "ventricular_dilation",
      "eccentric_hypertrophy",
      "myocardial_fibrosis"
    ],
    "complications": [
      { "diseaseId": "cardiogenic_shock", "probability": 0.05, "severityBoost": 0.5, "clues": ["hypotension", "oliguria", "altered_mental_status"] },
      { "diseaseId": "ventricular_arrhythmia", "probability": 0.08, "severityBoost": 0.4, "clues": ["syncope", "low_lvef", "palpitations"] },
      { "diseaseId": "cardiorenal_syndrome", "probability": 0.15, "severityBoost": 0.3, "clues": ["rising_creatinine", "refractory_congestion"] }
    ],
    "mustNotMiss": true,
    "emergencyPriority": "high if decompensated",
    "diagnosticClues": ["low_lvef_echo", "dyspnea_oedema", "raised_bnp"],
    "exclusionClues": ["normal_lvef", "normal_bnp", "alternative_cause"]
  }
}
