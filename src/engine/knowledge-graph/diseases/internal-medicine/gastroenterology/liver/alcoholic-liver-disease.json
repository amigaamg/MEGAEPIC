    "management": {
      "protocolReference": "EASL Clinical Practice Guidelines: Alcoholic Liver Disease",
      "pathways": [
        {
          "severity": "alcoholic_steatosis",
          "criteria": "Hepatomegaly, elevated AST/ALT <2x ULN, steatosis on US, no jaundice",
          "treatment": "Complete alcohol abstinence. Nutritional support (high protein, vitamin B1/folate). Reversible in weeks to months with abstinence."
        },
        {
          "severity": "mild_alcoholic_hepatitis",
          "criteria": "Jaundice + elevated AST/ALT + Maddrey DF <32",
          "treatment": "Abstinence. Nutritional therapy (35-40 kcal/kg, 1.5g/kg protein). Thiamine 100mg IV/PO. Multivitamins. Monitor for progression."
        },
        {
          "severity": "severe_alcoholic_hepatitis",
          "criteria": "Maddrey DF >=32, may have encephalopathy",
          "treatment": "Admit ICU. Prednisolone 40mg PO daily for 28 days (if no contraindications). Consider pentoxifylline if steroids contraindicated. Evaluate for liver transplant (Lille score at day 7). NAC may be beneficial."
        },
        {
          "severity": "alcoholic_cirrhosis",
          "criteria": "Decompensated with ascites, varices, encephalopathy",
          "treatment": "Abstinence. Manage complications (ascites, varices, encephalopathy, SBP). HCC surveillance. Evaluate for liver transplant if decompensated despite abstinence."
        }
      ]
    },

