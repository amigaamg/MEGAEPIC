    "investigations": {
      "bedside": [
        { "name": "Urine dip for bilirubin", "priority": "high", "yield": 0.7, "indication": "detect conjugated hyperbilirubinemia" }
      ],
      "laboratory": [
        { "name": "HBsAg (hepatitis B surface antigen)", "priority": "immediate", "yield": 0.99, "indication": "screening, diagnosis of active infection" },
        { "name": "HBsAb (anti-HBs)", "priority": "immediate", "yield": 0.9, "indication": "immunity status (vaccination or resolved)" },
        { "name": "HBcAb total and IgM (anti-HBc)", "priority": "immediate", "yield": 0.95, "indication": "IgM = acute/recent; IgG = past/resolved" },
        { "name": "HBeAg and anti-HBe", "priority": "high", "yield": 0.8, "indication": "replication activity, treatment decision" },
        { "name": "HBV DNA viral load", "priority": "high", "yield": 0.95, "indication": "quantification of viremia, treatment monitoring" },
        { "name": "LFTs (ALT, AST, bilirubin, ALP)", "priority": "immediate", "yield": 0.8, "indication": "liver injury assessment" },
        { "name": "Coagulation profile (INR)", "priority": "high", "yield": 0.6, "indication": "synthetic function, acute liver failure screening" }
      ],
      "imaging": [
        { "name": "Abdominal ultrasound", "priority": "high", "yield": 0.5, "indication": "liver morphology, HCC screening in chronic HBV" },
        { "name": "Transient elastography (FibroScan)", "priority": "high", "yield": 0.9, "indication": "fibrosis assessment in chronic HBV" },
        { "name": "Liver biopsy (rarely needed)", "priority": "low", "yield": 0.9, "indication": "if non-invasive tests discordant or co-infections suspected" }
      ]
    },

    "management": {
      "protocolReference": "EASL Clinical Practice Guidelines: Hepatitis B",
      "pathways": [
        {
          "severity": "acute_hepatitis_b",
          "criteria": "Positive IgM anti-HBc, HBsAg+, elevated ALT, acute symptoms",
          "treatment": "Supportive care. No antiviral therapy in most cases (90% of adults clear spontaneously). Monitor LFTs and serology for HBsAg seroconversion. Notify public health."
        },
        {
          "severity": "chronic_active",
          "criteria": "HBsAg+ >6 months, elevated ALT, HBV DNA >2000 IU/mL",
          "treatment": "Antiviral therapy (tenofovir disoproxil fumarate, tenofovir alafenamide, or entecavir). Monitor ALT, HBV DNA, HBeAg seroconversion q3-6m. HCC surveillance."
        },
        {
          "severity": "inactive_carrier",
          "criteria": "HBsAg+, normal ALT, HBV DNA <2000 IU/mL, no HBeAg",
          "treatment": "No antiviral therapy currently indicated. Monitor ALT and HBV DNA q6-12m. HCC surveillance (US + AFP q6m)."
        },
        {
          "severity": "acute_liver_failure",
          "criteria": "INR >1.5 + encephalopathy + acute HBV",
          "treatment": "Urgent transplant evaluation. Entecavir or tenofovir if high viremia. Supportive care in ICU. NAC may be considered."
        },
        {
          "severity": "pregnancy_prophylaxis",
          "criteria": "Pregnant + HBsAg+ + HBV DNA >200,000 IU/mL",
          "treatment": "Tenofovir disoproxil fumarate from 28-32 weeks. Infant: HBIG + HBV vaccine within 12h of birth."
        }
      ]
    },

    "pathophysiology": [
      "hbv_entry_via_natp_receptor",
