        { "name": "Serum ferritin", "priority": "immediate", "yield": 0.9, "indication": "iron stores; elevated in iron overload" },
        { "name": "HFE genotyping (C282Y, H63D)", "priority": "high", "yield": 0.99, "indication": "confirm genetic hemochromatosis" },
        { "name": "LFTs", "priority": "high", "yield": 0.6, "indication": "liver involvement" },
        { "name": "Fasting glucose / HbA1c", "priority": "high", "yield": 0.4, "indication": "screen for diabetes" }
      ],
      "imaging": [
