    "management": {
      "protocolReference": "EASL Clinical Practice Guidelines: Hemochromatosis",
      "pathways": [
        {
          "severity": "iron_overload_without_organ_damage",
          "criteria": "TSAT >45%, ferritin elevated, no cirrhosis, no diabetes, no cardiomyopathy",
          "treatment": "Phlebotomy: 500mL weekly until ferritin <50 ng/mL. Maintenance phlebotomy q2-4 months to keep ferritin <50-100. Screen family members."
        },
        {
          "severity": "iron_overload_with_organ_damage",
          "criteria": "Cirrhosis, diabetes, cardiomyopathy, arthropathy present",
          "treatment": "Aggressive phlebotomy (500mL 1-2x/week until ferritin <50). Treat complications (diabetes management, heart failure therapy, joint pain management). HCC surveillance if cirrhosis."
        },
        {
          "severity": "end_stage_iron_overload",
          "criteria": "Decompensated cirrhosis, severe cardiomyopathy, HCC",
          "treatment": "Therapeutic phlebotomy as tolerated. Liver transplant evaluation if decompensated cirrhosis. Manage cardiac complications. Monitor for HCC."
        }
      ]
    },

