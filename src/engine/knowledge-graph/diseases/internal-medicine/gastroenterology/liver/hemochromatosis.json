        { "name": "MRI cardiac T2*", "priority": "high", "yield": 0.9, "indication": "cardiac iron assessment if TSAT >70% or ferritin >1000" },
        { "name": "Abdominal ultrasound", "priority": "high", "yield": 0.5, "indication": "HCC surveillance if cirrhosis present" },
        { "name": "Liver biopsy with iron quantification", "priority": "selected", "yield": 0.97, "indication": "if non-invasive tests equivocal or additional liver disease suspected" }
