    "management": {
      "protocolReference": "WHO Guidelines for the Treatment of Diarrhea in Children",
      "pathways": [
        {
          "severity": "no_dehydration",
          "criteria": "Normal general condition, eyes not sunken, drinks normally, normal skin turgor",
          "treatment": "Plan A: Home management. Increased fluids, continued feeding. ORS as needed. Zinc supplementation (children 20mg/day for 10 days). Return if worsens."
        },
        {
          "severity": "some_dehydration",
          "criteria": "Restless/irritable, sunken eyes, thirsty/drinks eagerly, skin pinch goes back slowly",
          "treatment": "Plan B: ORS 75ml/kg over 4 hours under observation. Reassess after 4 hours. Continue breastfeeding. Zinc supplementation."
        },
        {
          "severity": "severe_dehydration",
          "criteria": "Lethargic/unconscious, very sunken eyes, unable to drink/drinks poorly, skin pinch goes back very slowly",
          "treatment": "Plan C: IV Ringer's Lactate (or NS) 100ml/kg over 3 hours (30ml/kg in first 30 min, then 70ml/kg over 2.5 hours). Reassess every 15-30 min."
        },
        {
          "severity": "dysentery",
          "criteria": "Blood in stool + fever + tenesmus",
          "treatment": "Antibiotics per local sensitivity (ciprofloxacin or azithromycin for Shigella). Avoid antimotility drugs. Rehydration as per dehydration status."
        }
      ]
    },

