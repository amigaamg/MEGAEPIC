    "investigations": {
      "bedside": [
        { "name": "Stool culture + microscopy", "priority": "immediate", "yield": 0.6, "indication": "rule out infectious cause" }
      ],
      "laboratory": [
        { "name": "CRP", "priority": "high", "yield": 0.8, "indication": "inflammatory marker, disease activity monitoring" },
        { "name": "Fecal calprotectin", "priority": "high", "yield": 0.9, "indication": "excellent marker for intestinal inflammation" },
        { "name": "FBC", "priority": "high", "yield": 0.6, "indication": "anemia, leukocytosis" },
        { "name": "Iron studies + B12 + folate", "priority": "medium", "yield": 0.5, "indication": "malabsorption assessment" }
      ],
      "imaging": [
        { "name": "Colonoscopy with ileoscopy + biopsies", "priority": "high", "yield": 0.97, "indication": "gold standard for diagnosis and differentiation" },
        { "name": "MR enterography", "priority": "high", "yield": 0.9, "indication": "small bowel Crohn's assessment, fistulas, abscesses" },
        { "name": "CT enterography", "priority": "medium", "yield": 0.85, "indication": "if MR unavailable, acute setting" }
      ]
    },

    "management": {
      "protocolReference": "ECCO Guidelines for Inflammatory Bowel Disease",
      "pathways": [
        {
          "severity": "mild_moderate_uc",
          "criteria": " < 4-6 bloody stools/day, no systemic symptoms",
          "treatment": "5-ASA compounds (mesalamine) oral + topical. Oral budesonide for left-sided disease."
        },
        {
          "severity": "severe_acute_uc",
          "criteria": " > 6 bloody stools/day, fever, tachycardia, high CRP",
          "treatment": "IV corticosteroids (hydrocortisone 100mg QID). Monitor for toxic megacolon. Consider IV cyclosporine or infliximab if no response in 3-5 days. Urgent colectomy if refractory."
        },
        {
          "severity": "mild_moderate_crohns",
          "criteria": "CDAI < 220, no complications",
          "treatment": "Oral budesonide (ileocecal) or systemic steroids. 5-ASA limited efficacy. Consider immunomodulator (azathioprine/6-MP) early."
        },
        {
          "severity": "severe_crohns",
          "criteria": "CDAI > 450, fistulizing, obstructive, or systemic symptoms",
          "treatment": "IV steroids. Anti-TNF therapy (infliximab/adalimumab). Surgical resection for complications (stricture, abscess, fistula)."
        }
      ]
    },

    "pathophysiology": [
