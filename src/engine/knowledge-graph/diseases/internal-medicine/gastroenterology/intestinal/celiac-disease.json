      ]
    },

    "management": {
      "protocolReference": "ACG Clinical Guidelines: Celiac Disease",
      "pathways": [
        {
          "severity": "new_diagnosis",
          "criteria": "Positive serology + biopsy-proven villous atrophy",
          "treatment": "Strict lifelong gluten-free diet. Refer to dietitian. Monitor for nutritional deficiencies. Screen first-degree relatives."
        },
        {
          "severity": "refractory_symptoms",
          "criteria": "Persistent symptoms despite >6 months of gluten-free diet",
          "treatment": "Re-evaluate dietary adherence (dietitian). Repeat serology + endoscopy. Consider type I (corticosteroid responsive) vs type II (aberrant T-cell, high risk of lymphoma)."
        },
        {
          "severity": "nutritional_deficiency",
          "criteria": "Iron, B12, folate, vitamin D, calcium deficiency",
          "treatment": "Supplement specific deficiencies. Monitor bone density (DEXA scan) due to osteoporosis risk. Calcium + vitamin D supplementation."
        }
      ]
    },

