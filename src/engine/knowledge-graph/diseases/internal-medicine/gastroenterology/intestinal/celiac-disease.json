      "laboratory": [
        { "name": "tTG IgA (tissue transglutaminase)", "priority": "immediate", "yield": 0.95, "indication": "first-line screening test" },
        { "name": "Total IgA level", "priority": "immediate", "yield": 0.3, "indication": "rule out IgA deficiency causing false negative tTG" },
        { "name": "EMA IgA (endomysial antibody)", "priority": "confirmatory", "yield": 0.98, "indication": "confirmatory if tTG equivocal" },
        { "name": "Deamidated gliadin peptide IgG", "priority": "if_iga_deficient", "yield": 0.9, "indication": "when total IgA low" },
        { "name": "HLA-DQ2/DQ8 typing", "priority": "medium", "yield": 0.99, "indication": "high negative predictive value; rule out disease" },
        { "name": "Iron, B12, folate, vitamin D", "priority": "high", "yield": 0.6, "indication": "assess malabsorption" }
