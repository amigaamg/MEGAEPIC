    "management": {
      "protocolReference": "ESMO / NCCN Guidelines for Small Bowel Tumors",
      "pathways": [
        {
          "severity": "localized small bowel tumor (any type)",
          "criteria": "Localized disease, no metastases, resectable",
          "treatment": "Segmental small bowel resection with lymphadenectomy. Endoscopic resection for select duodenal adenomas. Tissue diagnosis (IHC) essential pre-op for neoadjuvant planning."
        },
        {
          "severity": "metastatic carcinoid/NET",
          "criteria": "Liver or peritoneal metastases from small bowel NET",
          "treatment": "Somatostatin analogs (octreotide LAR 30mg or lanreotide 120mg monthly). Surgical debulking if feasible. PRRT (Lu-177 dotatate) for progressive disease. Everolimus for refractory disease."
        },
        {
          "severity": "advanced adenocarcinoma",
          "criteria": "Unresectable or metastatic small bowel adenocarcinoma",
          "treatment": "Palliative chemotherapy (FOLFOX or FOLFIRI). Palliative stenting for obstruction. Best supportive care."
        },
        {
          "severity": "small bowel lymphoma",
          "criteria": "Confirmed lymphoma on biopsy",
          "treatment": "R-CHOP for DLBCL. Surgical resection only for complications (obstruction, perforation, bleeding not controlled endoscopically). EATL: CHOP-based chemotherapy."
        }
      ]
