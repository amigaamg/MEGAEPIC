        "severityBoost": 0.5,
        "clues": ["recurrent_vomiting", "early_satiety", "weight_loss", "succussion_splash"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "high if bleeding/perforation; medium otherwise",
    "diagnosticClues": ["epigastric_pain_with_nocturnal_waking", "pain_relief_with_antacids", "h_pylori_positive", "ulcer_on_endoscopy"],
