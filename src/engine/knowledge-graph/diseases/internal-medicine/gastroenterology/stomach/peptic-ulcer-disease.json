      { "signId": "pallor", "baseWeight": 3, "note": "Chronic blood loss anemia" },
      { "signId": "fecal_occult_blood_positive", "baseWeight": 3 },
      { "signId": "succussion_splash", "baseWeight": 4, "note": "Gastric outlet obstruction" }
    ],

    "riskFactors": [
