      { "id": "stress", "multiplier": 1.3 },
      { "id": "zollinger_ellison_syndrome", "multiplier": 5.0 }
    ],

    "mimics": [
      {
        "diseaseId": "gerd",
        "discriminators": ["retrosternal_burning", "acid_regurgitation", "no_h_pylori", "ppi_response_partial"]
      },
      {
        "diseaseId": "gastritis",
        "discriminators": ["diffuse_epigastric_discomfort", "nausea_predominant", "no_ulcer_on_endoscopy"]
      },
      {
        "diseaseId": "gallstone_disease",
        "discriminators": ["right_upper_quadrant_pain", "post_prandial_fatty_food", "murphy_sign", "normal_upper_endoscopy"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Fecal occult blood test", "priority": "high", "yield": 0.6, "indication": "all suspected PUD" }
      ],
      "laboratory": [
        { "name": "H. pylori test (stool antigen/ UBT)", "priority": "immediate", "yield": 0.95, "indication": "all patients with PUD" },
        { "name": "FBC", "priority": "high", "yield": 0.5, "indication": "anemia from chronic/acute blood loss" },
        { "name": "LFTs", "priority": "medium", "yield": 0.2, "indication": "exclude biliary causes" },
        { "name": "Gastrin level", "priority": "if_suspected", "yield": 0.8, "indication": "suspected Zollinger-Ellison syndrome (multiple/recurrent ulcers)" }
      ],
      "imaging": [
        { "name": "Upper endoscopy (EGD)", "priority": "high", "yield": 0.98, "indication": "gold standard, allows biopsy of gastric ulcers to exclude malignancy" },
        { "name": "Upper GI barium series", "priority": "medium", "yield": 0.7, "indication": "if endoscopy unavailable" }
      ]
    },

    "management": {
      "protocolReference": "ACG Clinical Guideline: Peptic Ulcer Disease",
      "pathways": [
        {
          "severity": "h_pylori_positive",
          "criteria": "Ulcer on EGD + positive H. pylori test",
          "treatment": "Triple therapy: PPI + clarithromycin + amoxicillin (or metronidazole) for 14 days. Confirm eradication with stool antigen or UBT 4 weeks after therapy."
        },
        {
          "severity": "nsaid_related",
          "criteria": "Ulcer on EGD + NSAID/aspirin use",
          "treatment": "Stop NSAID. PPI for 8 weeks. H. pylori test and treat if positive. Consider misoprostol or COX-2 inhibitor if NSAID must continue."
        },
        {
          "severity": "bleeding_ulcer",
          "criteria": "Active bleeding, visible vessel, adherent clot on EGD",
          "treatment": "Endoscopic hemostasis (injection, cautery, clip). High-dose IV PPI bolus + continuous infusion for 72 hours. Re-endoscopy if rebleeding."
        },
        {
          "severity": "perforated_ulcer",
          "criteria": "Peritonitis, free air under diaphragm",
          "treatment": "Urgent surgical repair. IV PPI. Broad-spectrum antibiotics. Fluid resuscitation."
        }
      ]
    },

    "pathophysiology": [
      "h_pylori_colonization",
      "mucosal_barrier_disruption",
      "nsaid_inhibit_prostaglandin_synthesis",
      "gastric_acid_hypersecretion",
      "duodenal_defense_impaired",
      "ulcer_formation",
      "vascular_erosion_bleeding",
      "full_thickness_necrosis_perforation"
    ],

    "complications": [
