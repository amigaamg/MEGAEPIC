        { "sign": "hypovolemic_shock", "weight": 10 },
        { "sign": "gastric_outlet_obstruction", "weight": 8 }
      ],
      "severeCriteria": {
        "anyDangerSign": true
      },
      "nonSevereCriteria": {
        "noDangerSigns": true,
        "epigastric_pain_core": true
      },
      "severityLabel": "If bleeding, perforation, or obstruction -> EMERGENCY; else -> URGENT workup"
    },

    "historyFeatures": [
      { "symptomId": "epigastric_pain", "weight": 5 },
      { "symptomId": "nocturnal_pain_waking", "weight": 4 },
      { "symptomId": "pain_relieved_by_food", "weight": 3, "note": "More typical of duodenal ulcer" },
