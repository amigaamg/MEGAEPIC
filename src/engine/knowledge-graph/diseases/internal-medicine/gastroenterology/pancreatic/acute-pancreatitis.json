    "management": {
      "protocolReference": "IAP/APA Evidence-Based Guidelines for Acute Pancreatitis",
      "pathways": [
        {
          "severity": "mild_pancreatitis",
          "criteria": "No organ failure, no local complications, Ranson <3, APACHE II <8",
          "treatment": "Aggressive IV fluids (Ringer's lactate). Pain management (IV opioids). NPO initially, oral feeding as tolerated (low-fat diet). No routine antibiotics. Monitor vitals and labs."
        },
        {
          "severity": "severe_pancreatitis",
          "criteria": "Persistent organ failure >48h, pancreatic necrosis, Ranson >=3",
          "treatment": "ICU admission. Goal-directed fluid resuscitation (LR). Enteral nutrition (nasojejunal) within 24-48h. Pain management. Monitor for infection after 7 days. CT-guided fine needle aspiration for suspected infected necrosis."
        },
        {
          "severity": "infected_necrosis",
          "criteria": "Worsening after 7-10 days, fever, positive culture",
          "treatment": "Antibiotics (carbapenem preferred). Delay surgical/source control to at least 4 weeks if possible (step-up approach: percutaneous drainage then minimally invasive necrosectomy)."
        },
        {
          "severity": "biliary_pancreatitis_with_cholangitis",
          "criteria": "Fever + jaundice + biliary obstruction on imaging",
          "treatment": "Urgent ERCP with sphincterotomy within 24-48h. Cholecystectomy after resolution of pancreatitis (same admission for mild, delayed for severe)."
        }
      ]
    },

