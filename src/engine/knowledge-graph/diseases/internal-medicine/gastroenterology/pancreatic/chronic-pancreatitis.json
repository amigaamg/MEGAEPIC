    "management": {
      "protocolReference": "ACG Clinical Guideline: Chronic Pancreatitis",
      "pathways": [
        {
          "severity": "pain_management",
          "criteria": "Chronic epigastric pain, no complications",
          "treatment": "Abstinence from alcohol and smoking. Analgesic ladder (acetaminophen -> NSAIDs -> TCAs/gabapentinoids -> opioids). PPI. Pancreatic enzyme replacement (PERT) may help pain by reducing CCK stimulation."
        },
        {
          "severity": "exocrine_insufficiency",
          "criteria": "Steatorrhea, low fecal elastase, weight loss",
          "treatment": "Pancrelipase (PERT) with meals (25,000-50,000 units lipase/meal). Fat-soluble vitamin supplementation. Medium-chain triglyceride supplementation if severe."
        },
        {
          "severity": "endocrine_insufficiency",
          "criteria": "Diabetes mellitus (type 3c)",
          "treatment": "Insulin therapy (low dose, careful monitoring due to hypoglycemia risk). Avoid metformin. Diabetes education."
        },
        {
          "severity": "refractory_pain_complications",
          "criteria": "Failure of medical therapy, ductal obstruction/hypertension",
          "treatment": "ERCP with ductal drainage (stenting, stone extraction). EUS-guided celiac plexus block. Consider surgical options (Puestow procedure, distal pancreatectomy, Whipple)."
        }
      ]
    },

