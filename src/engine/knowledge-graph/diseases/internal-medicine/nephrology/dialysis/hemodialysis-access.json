    "subtypes": [
      {
        "id": "av_fistula_stenosis",
        "name": "AV Fistula Stenosis",
        "prevalenceModifier": 0.35,
        "keyFeatures": [
          { "feature": "decreased_thrill", "weight": 5 },
          { "feature": "high_pitched_bruit", "weight": 4 },
          { "feature": "prolonged_bleeding_after_needle_removal", "weight": 4 },
          { "feature": "elevated_venous_pressure_during_dialysis", "weight": 4 }
        ],
        "management": "Fistulogram with PTA (balloon angioplasty) of stenotic segment. Stent graft if recurrent stenosis. Surgical revision if PTA fails. Most commonly at anastomotic or draining vein site."
      },
      {
        "id": "av_fistula_thrombosis",
        "name": "AV Fistula Thrombosis",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "absent_thrill_bruit", "weight": 5 },
          { "feature": "dialysis_cannot_proceed", "weight": 5 },
          { "feature": "palpable_clot", "weight": 4 },
          { "feature": "sudden_onset", "weight": 4 }
        ],
        "management": "Urgent intervention: surgical thrombectomy or percutaneous pharmacomechanical thrombolysis (within 24-48h). Identify and treat underlying stenosis. Temporary dialysis catheter if needed. Consider access salvage."
      },
      {
        "id": "dialysis_catheter_related_infection",
        "name": "Tunneled Dialysis Catheter Related Infection",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "fever_chills_during_hemodialysis", "weight": 5 },
          { "feature": "erythema_pus_at_exit_site", "weight": 5 },
          { "feature": "tunnel_tenderness", "weight": 4 },
          { "feature": "positive_blood_cultures_same_organism_from_catheter", "weight": 5 }
        ],
        "management": "Blood cultures (peripheral and from catheter lumen). Empiric IV antibiotics covering Gram-pos (vancomycin) and Gram-neg (ceftazidime or gentamicin). Catheter removal if tunnel infection, persistent bacteremia, or septic shock. Catheter exchange over wire if exit site infection only. Antibiotic lock therapy."
      },
      {
        "id": "steal_syndrome",
        "name": "Dialysis Access Steal Syndrome",
        "prevalenceModifier": 0.05,
        "keyFeatures": [
          { "feature": "hand_pain_coldness_during_dialysis", "weight": 5 },
          { "feature": "finger_ischemia_ulceration", "weight": 5 },
          { "feature": "weak_or_absent_radial_ulnar_pulse", "weight": 4 },
          { "feature": "motor_sensory_deficit", "weight": 3 }
        ],
        "management": "Distal revascularization interval ligation (DRIL) procedure. Banding of fistula to reduce flow. Fistula ligation if severe tissue loss. Hand surgery consultation. Monitor closely in high-risk patients (diabetes, PVD)."
      }
    ],
    "mimics": [
