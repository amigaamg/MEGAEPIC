      "pathways": [
        {
          "severity": "mild-moderate (first episode, non-septic)",
          "criteria": "cloudy effluent with WBC >100, mild pain, no sepsis",
          "treatment": "Empiric IP antibiotics: Gram-pos (vancomycin or cefazolin) + Gram-neg (ceftazidime or gentamicin). Continue PD (intermittent dosing, longer dwell). Monitor effluent daily. Treat for 14-21 days. Outpatient management possible."
        },
        {
          "severity": "severe/refractory",
