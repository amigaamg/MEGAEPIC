      "pathways": [
        {
          "severity": "stage 1 (creatinine 1.5-1.9x baseline)",
          "criteria": "mild AKI, likely prerenal based on history/urine indices",
          "treatment": "IV fluid challenge (500-1000 mL NS). Discontinue nephrotoxins (ACEi, ARB, NSAIDs, diuretics). Correct underlying cause. Monitor creatinine, urine output q6-12h."
        },
        {
          "severity": "stage 2-3 (creatinine >2x baseline)",
          "criteria": "moderate-severe AKI, poor response to fluids",
          "treatment": "ICU if hemodynamic instability. Central line for CVP/volume assessment. NaHCO3 if severe acidosis. Nephrology consult. Diuretics if fluid overload (furosemide 80-240 mg IV). Consider RRT if refractory hyperkalemia/acidosis/fluid overload."
        }
      ]
