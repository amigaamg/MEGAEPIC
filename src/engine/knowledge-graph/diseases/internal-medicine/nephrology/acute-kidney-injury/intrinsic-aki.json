          { "feature": "sterile_pyuria_wbc_casts", "weight": 5 },
          { "feature": "fever_rash_eosinophilia_triad", "weight": 4 },
          { "feature": "eosinophiluria", "weight": 3 }
        ],
        "management": "Discontinue offending drug. Corticosteroids (prednisolone 0.5-1 mg/kg/day x 2-4 weeks, then taper) if severe or no improvement after drug removal. Supportive care. Recovery over weeks to months."
      },
      {
        "id": "rapidly_progressive_glomerulonephritis",
