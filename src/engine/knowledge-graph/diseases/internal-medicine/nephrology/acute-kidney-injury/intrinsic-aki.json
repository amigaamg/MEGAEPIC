          { "feature": "proteinuria", "weight": 3 },
          { "feature": "crescents_on_biopsy_more_than_50_percent", "weight": 5 }
        ],
        "management": "Urgent nephrology referral. Kidney biopsy for diagnosis. Pulse methylprednisolone 500-1000 mg IV x 3 days, then oral prednisolone. Cyclophosphamide or rituximab for ANCA vasculitis. Plasmapheresis for Goodpasture/ANCA with severe renal involvement. Treat hypertension. RRT if needed."
      }
