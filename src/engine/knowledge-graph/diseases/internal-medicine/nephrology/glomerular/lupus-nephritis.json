    "management": {
      "protocolReference": "KDIGO 2024 / EULAR/ERA-EDTA Guidelines for Lupus Nephritis",
      "pathways": [
        {
          "severity": "class I-II (minimal/mesangial)",
          "criteria": "mild hematuria/proteinuria, normal GFR",
          "treatment": "Hydroxychloroquine. ACEi/ARB if proteinuria. Treat extra-renal SLE. Monitor q3-6 months. No immunosuppression specifically for renal."
