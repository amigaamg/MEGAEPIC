          "severity": "class III/IV (proliferative) - induction",
          "criteria": "active nephritis, proteinuria >1 g/day, hematuria, rising creatinine",
          "treatment": "MMF 2-3 g/day (target AUC 30-45) or IV cyclophosphamide (Euro-Lupus: 500 mg q2wk x 6) + pulse MP 500-1000 mg x 3 then oral prednisolone 0.5-1 mg/kg/day, taper. Triple therapy: MMF + calcineurin inhibitor (voclosporin 23.7 mg BID or tacrolimus). Hydroxychloroquine 400 mg/day."
        },
        {
          "severity": "class III/IV - maintenance",
          "criteria": "response achieved (proteinuria improved, GFR stable)",
          "treatment": "MMF 1-2 g/day or azathioprine 1.5-2.5 mg/kg/day. Low-dose prednisolone (5-7.5 mg/day). Hydroxychloroquine. ACEi/ARB. Monitor for flares. Minimum 3-5 years of maintenance."
        },
        {
          "severity": "class V (membranous)",
          "criteria": "nephrotic proteinuria, normal GFR",
          "treatment": "ACEi/ARB. Anticoagulate if albumin <20 g/L. If nephrotic persists: MMF + steroids, CNI, or rituximab. Hydroxychloroquine."
