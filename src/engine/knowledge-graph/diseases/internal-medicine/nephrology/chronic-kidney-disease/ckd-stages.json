        { "name": "FBC (hemoglobin, iron studies)", "priority": "high", "yield": 0.7, "indication": "anemia of CKD, iron deficiency" },
        { "name": "HbA1c (if diabetic)", "priority": "high", "yield": 0.6, "indication": "glycemic control assessment" }
      ],
      "imaging": [
        { "name": "Renal Ultrasound", "priority": "high", "yield": 0.6, "indication": "kidney size (small kidneys suggest chronicity), cortical thickness, obstruction" }
      ]
    },
    "management": {
      "protocolReference": "KDIGO 2024 Guidelines for the Evaluation and Management of CKD",
      "pathways": [
        {
          "severity": "G1-G3a (eGFR >45), A1-A2",
          "criteria": "mild-moderate reduction, low albuminuria",
          "treatment": "ACEi/ARB if hypertension or diabetes. SGLT2i (dapagliflozin/empagliflozin). BP <130/80. Statin. Lifestyle modification. Annual monitoring. Avoid NSAIDs."
        },
        {
          "severity": "G3b-G4 (eGFR 15-44)",
          "criteria": "moderate-severe reduction, any albuminuria",
          "treatment": "Nephrology review. ACEi/ARB + SGLT2i (continue until dialysis). Finerenone (finerenone) if T2DM. Manage anemia, MBD, acidosis. Dietary counseling. RRT education. Vaccinations."
        },
        {
          "severity": "G5 (eGFR <15)",
          "criteria": "kidney failure, uremic symptoms or complications",
          "treatment": "Initiate RRT. Choose modality: HD (in-center or home), PD, or transplant. If conservative care: symptom management, diuretics, binders, ESAs. Advance care planning."
        }
      ]
    },
