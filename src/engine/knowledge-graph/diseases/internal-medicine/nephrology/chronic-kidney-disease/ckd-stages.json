    "subtypes": [
      {
        "id": "ckd_g1_g2_early",
        "name": "CKD Stage G1-G2 (Early)",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "egfr_above_60", "weight": 5 },
          { "feature": "often_asymptomatic", "weight": 4 },
          { "feature": "urine_acr_greater_than_30", "weight": 4 },
          { "feature": "detected_on_routine_screening", "weight": 3 }
        ],
        "management": "Treat underlying cause (ACEi/ARB for diabetes/proteinuria). BP target <130/80. Lifestyle: low salt diet, exercise, smoking cessation. Avoid nephrotoxins (NSAIDs). Annual eGFR and ACR monitoring. Statin therapy. Glycemic control (HbA1c target <7% for diabetes)."
      },
      {
        "id": "ckd_g3_g4_moderate_severe",
        "name": "CKD Stage G3-G4 (Moderate-Severe)",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "egfr_15_59", "weight": 5 },
          { "feature": "symptoms_emerging_fatigue_edema", "weight": 3 },
          { "feature": "complications_anemia_ckd_mbd_acidosis", "weight": 4 },
          { "feature": "progressive_decline", "weight": 3 }
        ],
        "management": "Nephrology referral (at G4 or earlier). Manage complications: iron/ESA for anemia, phosphate binders + vitamin D for CKD-MBD, NaHCO3 for metabolic acidosis. Prepare for RRT: education, access planning. Vaccinations (flu, pneumococcal, Hep B). Dietary counseling (potassium, phosphate, salt, protein restriction). SGLT2 inhibitors (dapagliflozin/empagliflozin) to slow progression."
      },
      {
        "id": "ckd_g5_kidney_failure",
        "name": "CKD Stage G5 (Kidney Failure)",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "egfr_under_15", "weight": 5 },
          { "feature": "uremic_symptoms_nausea_pruritus_anorexia", "weight": 4 },
          { "feature": "volume_overload_edema_dyspnea", "weight": 4 },
          { "feature": "rrt_planned_or_initiated", "weight": 5 }
        ],
        "management": "RRT: hemodialysis (center or home), peritoneal dialysis, or pre-emptive kidney transplant. Access creation (AVF/AVG for HD, PD catheter for PD). Symptoms: diuretics for fluid, phosphate binders, antihypertensives, ESAs. Diet: restrict K, P, Na, fluid. Advance care planning. If choosing conservative care: symptom management, hospice referral."
      }
    ],
    "mimics": [
