          { "feature": "anion_gap_type_or_non_ag", "weight": 4 }
        ],
        "management": "Treat underlying cause. High AG: insulin for DKA, resuscitation for shock, ethanol drip for methanol/ethylene glycol (plus fomepizole). Non-AG: NaHCO3 for severe acidosis (pH <7.1-7.2), treat diarrhea with rehydration, RTA with bicarbonate. Consider dialysis if refractory severe acidosis, methanol/ethylene glycol with high gap."
      },
      {
        "id": "metabolic_alkalosis",
        "name": "Metabolic Alkalosis",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "high_bicarbonate_over_28", "weight": 5 },
          { "feature": "high_ph_over_7_45", "weight": 5 },
          { "feature": "hypoventilation_as_compensation", "weight": 3 },
          { "feature": "saline_responsive_or_saline_unresponsive", "weight": 4 }
        ],
        "management": "Saline-responsive (UCl <20): 0.9% NS IV, correct K and Mg, stop diuretics. Saline-unresponsive (UCl >20): treat mineralocorticoid excess (spironolactone/eplerenone for Conn syndrome, amiloride for Liddle). Severe (pH >7.6): acetazolamide 250-500 mg IV, consider hemodialysis."
      },
      {
        "id": "respiratory_acidosis",
        "name": "Respiratory Acidosis",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
          { "feature": "high_paco2_over_45", "weight": 5 },
          { "feature": "low_ph_under_7_35", "weight": 5 },
          { "feature": "increased_hco3_as_renal_compensation_chronic", "weight": 4 },
          { "feature": "hypoventilation_copd_opioid_overdose", "weight": 4 }
        ],
        "management": "Improve ventilation: bronchodilators, steroids, BiPAP or intubation if severe. Naloxone for opioid overdose. Avoid high FiO2 in CO2 retainers (COPD). Treat underlying lung disease. Bicarbonate NOT indicated (worsens intracellular acidosis)."
      },
      {
        "id": "respiratory_alkalosis",
        "name": "Respiratory Alkalosis",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "low_paco2_under_35", "weight": 5 },
          { "feature": "high_ph_over_7_45", "weight": 5 },
          { "feature": "decreased_hco3_as_compensation_chronic", "weight": 4 },
          { "feature": "hyperventilation_causes", "weight": 4 }
        ],
        "management": "Treat underlying cause of hyperventilation (anxiety, pain, sepsis, PE, hypoxia, liver failure, psychogenic). Rebreathing mask for psychogenic hyperventilation. Address anxiety. Correct hypoxia. Manage sepsis/PE. No specific pharmacotherapy needed."
