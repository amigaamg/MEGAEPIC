    "management": {
      "protocolReference": "European Clinical Practice Guidelines (Hyponatremia) 2024 / KDIGO",
      "pathways": [
        {
          "severity": "severe symptomatic (<125 with seizures/coma)",
          "criteria": "life-threatening neurological symptoms",
          "treatment": "Hypertonic saline (3% NaCl) 100 mL IV bolus over 10 min x 1-2. Check Na after each bolus. Goal: 5 mmol/L increase in 1 hour. Stop when symptoms resolve. Limit rise to <10 mmol/L in first 24h (<8 in high-risk). Consider DDAVP to prevent overcorrection."
        },
        {
          "severity": "moderate symptomatic (125-129 with confusion, nausea)",
          "criteria": "neurological symptoms but no coma/seizures",
          "treatment": "Prompt treatment to raise Na. Hypertonic saline (3% NaCl) infusion 15-30 mL/h. Goal 4-6 mmol/L increase in 24h. Monitor Na q2-4h. Identify and correct underlying cause."
        },
        {
          "severity": "asymptomatic or mild (130-134)",
          "criteria": "no or minimal symptoms",
          "treatment": "Treat underlying cause. If SIADH: fluid restriction (800-1000 mL/day). Discontinue causative medications. If hypovolemic: 0.9% NS. If hypervolemic: fluid restriction + treat underlying condition."
        }
      ]
    },
