    "subtypes": [
      {
        "id": "hypovolemic_hyponatremia",
        "name": "Hypovolemic Hyponatremia",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
          { "feature": "signs_of_volume_depletion", "weight": 5 },
          { "feature": "urine_na_under_20_if_extra_renal_loss", "weight": 4 },
          { "feature": "vomiting_diarrhea_bleeding_history", "weight": 4 },
          { "feature": "skin_turgor_decreased", "weight": 3 }
        ],
        "management": "IV 0.9% normal saline (isotonic) to restore volume. Correct underlying cause. Stop diuretics. Monitor Na rise (no more than 8-10 mmol/L per 24h). Once euvolemic, reassess Na."
      },
      {
        "id": "euvolemic_hyponatremia_siadh",
        "name": "Euvolemic Hyponatremia (SIADH)",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "euvolemic_on_exam", "weight": 5 },
          { "feature": "urine_na_greater_than_40", "weight": 4 },
          { "feature": "urine_osmolality_greater_than_100", "weight": 4 },
          { "feature": "low_serum_uric_acid", "weight": 3 },
          { "feature": "normal_thyroid_adrenal", "weight": 3 }
        ],
        "management": "Fluid restriction (goal: fluid intake <500-1000 mL/day). Increase solute intake (urea, salt tablets). Demeclocycline (lithium alternative) if chronic refractory. Vasopressin receptor antagonists (vaptans: tolvaptan) for severe/persistent SIADH. Treat underlying cause (malignancy, lung disease, CNS disorder, drugs)."
      },
      {
        "id": "hypervolemic_hyponatremia",
        "name": "Hypervolemic Hyponatremia",
        "prevalenceModifier": 0.35,
        "keyFeatures": [
          { "feature": "edema_ascites_volume_expansion", "weight": 5 },
          { "feature": "heart_failure_cirrhosis_nephrotic", "weight": 5 },
          { "feature": "urine_na_under_20", "weight": 3 },
          { "feature": "low_effective_arterial_volume", "weight": 3 }
        ],
        "management": "Salt and fluid restriction. Loop diuretics to achieve negative fluid balance. Treat underlying condition (optimize HF, cirrhosis, nephrotic syndrome). Vaptans (tolvaptan) if severe and refractory. Avoid hypertonic saline unless life-threatening symptoms."
      }
    ],
