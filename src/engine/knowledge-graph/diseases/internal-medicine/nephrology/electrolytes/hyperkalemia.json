          { "feature": "oliguria", "weight": 3 },
          { "feature": "metabolic_acidosis", "weight": 3 },
          { "feature": "fluid_overload_may_be_present", "weight": 2 }
        ],
        "management": "Mild: dietary K restriction, stop hyperkalemic drugs, consider furosemide. Moderate: oral or rectal (PR) potassium-binding resin (patiromer, sodium zirconium cyclosilicate [SZC], or calcium resonium). Severe: emergency treatment (see below). Dialysis if refractory or severe AKI."
      },
      {
        "id": "hyperkalemia_from_medications",
        "name": "Hyperkalemia from Medications",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
