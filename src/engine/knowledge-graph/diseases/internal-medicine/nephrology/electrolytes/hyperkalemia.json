    "management": {
      "protocolReference": "KDIGO / European Resuscitation Council Hyperkalemia Guidelines",
      "pathways": [
        {
          "severity": "mild (K 5.2-5.9, no ECG changes)",
          "criteria": "asymptomatic, no ECG changes",
          "treatment": "Dietary K restriction (<50 mmol/day). Review and stop contributing medications. Furosemide if fluid tolerant and CKD. Potassium-binding resins: patiromer 8.4 g/day or SZC 10 g TID x 48h then daily."
        },
        {
          "severity": "moderate (K 6.0-6.4, may have peaked T waves)",
          "criteria": "ECG changes minimal or absent but K >6.0",
          "treatment": "IV calcium gluconate (10 mL of 10%) if ECG changes. IV insulin (10 units) + 50 mL of 50% dextrose (or 250 mL of 10% dextrose). Nebulized salbutamol 10-20 mg. IV NaHCO3 if acidotic. Potassium-binding resin. Furosemide. Monitor K and ECG q1-2h."
        },
        {
          "severity": "severe (K ≥6.5, or any K with significant ECG changes)",
          "criteria": "wide QRS, sine wave, ventricular arrhythmia, or cardiac arrest",
          "treatment": "Cardiac protection: 10 mL of 10% calcium gluconate (or chloride) IV over 2-5 min. Repeat if ECG persists. Insulin + dextrose (10U + 50 mL D50). Salbutamol neb. NaHCO3 (50 mEq) if acidotic. Dialysis (urgent HD). SZC or patiromer. Continuous ECG monitoring. ICU admission."
        }
      ]
    },
