    "management": {
      "protocolReference": "KDIGO Clinical Practice Guideline for Kidney Transplant Recipients",
      "pathways": [
        {
          "severity": "borderline/suspicious (Banff borderline)",
          "criteria": "mild infiltrate, minimal tubulitis, stable or mildly elevated Cr",
          "treatment": "Optimize maintenance immunosuppression (increase tacrolimus/MMF). Repeat biopsy in 2-4 weeks if no improvement. Consider pulse steroids if clinical concern."
        },
        {
          "severity": "acute cellular rejection Banff IA/IB",
          "criteria": "moderate tubulitis and interstitial infiltrate, rising Cr",
          "treatment": "IV methylprednisolone 500-1000 mg x 3 days. Increase maintenance. If steroid-resistant: ATG 1.5 mg/kg/day x 3-5 days. Monitor for complications (CMV, EBV, neutropenia)."
        },
        {
          "severity": "acute cellular Banff IIA/IIB (vascular)",
          "criteria": "intimal arteritis, more severe rejection",
          "treatment": "ATG first-line (steroid-resistant more likely). Complete course ATG. Monitor DSA. Consider AMR treatment if DSA+."
        },
        {
          "severity": "acute AMR",
          "criteria": "DSA+, microvascular inflammation, C4d+ or -",
          "treatment": "Pulse steroids + IVIG (2 g/kg) + plasmapheresis (5-7 sessions) + rituximab 375 mg/m2. Consider bortezomib or eculizumab for refractory. Optimize maintenance immunosuppression."
        }
