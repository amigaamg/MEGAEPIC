      "pathways": [
        {
          "severity": "transplant-eligible newly diagnosed",
          "criteria": "fit, age <70 or by physiological age",
          "treatment": "Induction: Dara-VRd or VRd x 4 cycles. Stem cell mobilization + high-dose melphalan (200 mg/m2) + autologous SCT. Consolidation. Lenalidomide maintenance until progression."
