    "management": {
      "protocolReference": "ESMO / NCCN Guidelines for GIST Management",
      "pathways": [
        {
          "severity": "localized resectable GIST",
          "criteria": "Localized tumor, R0 resection achievable, no metastases",
          "treatment": "Surgical resection with R0 margins. No routine lymphadenectomy (rare nodal mets). Minimally invasive if feasible. Risk stratification based on size, mitotic rate, and site."
        },
        {
          "severity": "high risk localized GIST (adjuvant)",
          "criteria": "High risk features: >5cm, mitotic rate >5/50 HPF, non-gastric site, rupture",
          "treatment": "Surgical resection + adjuvant imatinib 400mg daily for 3 years (high risk) or 36 months."
        },
        {
          "severity": "metastatic or unresectable GIST",
          "criteria": "Liver/peritoneal metastases or locally advanced unresectable",
          "treatment": "First-line: Imatinib 400mg daily (increase to 800mg for KIT exon 9 mutation). Assess response at 3 months with CT. Second-line: Sunitinib 50mg daily 4 weeks on/2 weeks off. Third-line: Regorafenib 160mg daily 3 weeks on/1 week off. Surgical resection of residual disease after maximal response."
        }
      ]
    },

