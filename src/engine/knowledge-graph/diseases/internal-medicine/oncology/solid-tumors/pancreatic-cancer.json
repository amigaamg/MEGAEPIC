        {
          "severity": "borderline resectable",
          "criteria": "abutment of SMA/SMV, <180 deg arterial involvement",
          "treatment": "Neoadjuvant FOLFIRINOX or gemcitabine-based chemo ± RT. Re-staging and surgical exploration if downstaged."
        },
        {
          "severity": "locally advanced unresectable",
          "criteria": ">180 deg SMA/celiac involvement, occluded SMV/PV",
          "treatment": "FOLFIRINOX or gemcitabine + nab-paclitaxel. Chemoradiation if no progression after induction. Palliative biliary stenting if jaundice."
        },
        {
          "severity": "metastatic",
          "criteria": "distant metastases (liver, peritoneum, lung)",
          "treatment": "FOLFIRINOX (if fit) or gemcitabine + nab-paclitaxel. Gemcitabine alone if poor performance. Palliative RT for pain. Biliary drainage if obstructed. Hospice referral."
        }
      ]
