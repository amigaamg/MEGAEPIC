      "pathways": [
        {
          "severity": "resectable",
          "criteria": "no arterial involvement, SMV/PV patent, no metastases",
          "treatment": "Pancreaticoduodenectomy (Whipple) for head, distal pancreatectomy + splenectomy for tail. Adjuvant mFOLFIRINOX or gemcitabine + capecitabine for 6 months."
