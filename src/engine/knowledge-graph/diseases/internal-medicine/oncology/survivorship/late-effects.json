          { "feature": "multitasking_difficulty", "weight": 4 },
          { "feature": "mental_fatigue", "weight": 3 },
          { "feature": "attention_concentration_deficits", "weight": 4 }
        ],
        "management": "Cognitive screening. Cognitive rehabilitation. Physical exercise. Mindfulness. Treat contributing factors (sleep, pain, depression). Medication review. Support groups. May improve over months to years."
      }
