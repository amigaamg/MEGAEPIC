          { "feature": "therapy_related_aml_mds_alkylating_topoisomerase", "weight": 5 },
          { "feature": "latency_period_often_5_10_years", "weight": 4 },
          { "feature": "breast_cancer_after_chest_rt", "weight": 4 }
        ],
        "management": "Surveillance per guidelines. Breast MRI + mammo starting 8 years post-chest RT (or age 25). Skin examination in RT fields. Low threshold for biopsy of new lesions. Smoking cessation. Healthy lifestyle. Genetic counseling if familial."
      },
      {
        "id": "endocrine_late_effects",
        "name": "Endocrine Late Effects",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
          { "feature": "hypothyroidism_after_neck_rt", "weight": 5 },
          { "feature": "growth_hormone_deficiency_cranial_rt", "weight": 4 },
          { "feature": "gonadal_dysfunction_infertility", "weight": 4 },
          { "feature": "metabolic_syndrome_insulin_resistance", "weight": 3 },
          { "feature": "osteoporosis_from_steroid_ai_gnrh_agonist", "weight": 3 }
        ],
        "management": "TSH + free T4 annually if neck RT. DXA bone density if on AI/steroids/GnRH agonist. Gonadotropin + sex hormone levels for hypogonadism. Fertility preservation counseling pre-treatment. Bone health: calcium, vitamin D, bisphosphonates if osteoporotic."
      },
