      "pathways": [
        {
          "severity": "mild pain (NRS 1-3)",
          "criteria": "pain does not interfere with function",
          "treatment": "Non-opioid analgesics (acetaminophen, NSAIDs). Consider adjuvants. Reassess regularly."
        },
        {
          "severity": "moderate pain (NRS 4-6)",
          "criteria": "pain interferes with function",
          "treatment": "Weak opioids (tramadol, codeine) or low-dose strong opioids. Continue non-opioids. Add adjuvants if neuropathic. Manage constipation (senna, docusate)."
        },
        {
          "severity": "severe pain (NRS 7-10)",
          "criteria": "pain severely limits function",
          "treatment": "Strong opioids (morphine, oxycodone, hydromorphone, fentanyl). Immediate-release for titration. Extended-release for baseline. Breakthrough doses at 1/6 of daily dose. Antiemetics. Laxatives. Adjuvants. Interventional procedures if inadequate."
        }
      ]
