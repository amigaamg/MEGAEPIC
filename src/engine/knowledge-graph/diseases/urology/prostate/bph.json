    "management": {
      "protocolReference": "EAU Guidelines on Non-Neurogenic Male LUTS",
      "pathways": [
        {
          "severity": "mild (IPSS 0-7)",
          "criteria": "mild symptoms, no bother",
          "treatment": "Watchful waiting. Lifestyle modification (fluid timing, caffeine/alcohol reduction). Annual review."
        },
        {
          "severity": "moderate (IPSS 8-19)",
          "criteria": "moderate symptoms, bothersome",
          "treatment": "Alpha-blocker (tamsulosin 0.4 mg OD) or 5-alpha-reductase inhibitor (finasteride 5 mg OD) if large prostate. Combination if both."
        },
        {
          "severity": "severe (IPSS 20-35) or refractory",
          "criteria": "severe symptoms, failed medical therapy, retention",
          "treatment": "Surgery: TURP (gold standard), laser therapy, or open prostatectomy if very large. Continue medical therapy while waiting."
        }
      ]
    },

    "pathophysiology": [
