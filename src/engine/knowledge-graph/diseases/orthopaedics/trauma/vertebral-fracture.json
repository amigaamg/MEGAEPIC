        "prevalenceModifier": 0.5,
        "keyFeatures": [
          { "feature": "anterior_wedge_collapse", "weight": 5 },
          { "feature": "posterior_wall_intact", "weight": 4 },
          { "feature": "neurologically_intact", "weight": 3 }
        ],
        "management": "Brace (TLSO) for 6-12 weeks. Analgesia. Physical therapy. Consider kyphoplasty/vertebroplasty for painful osteoporotic fractures."
      },
      {
        "id": "burst_fracture",
        "name": "Burst Fracture",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
          { "feature": "both_anterior_and_posterior_wall_involved", "weight": 5 },
          { "feature": "retropulsion_into_spinal_canal", "weight": 5 },
          { "feature": "±neurologic_deficit", "weight": 4 }
        ],
        "management": "Neurologically intact with <50% canal compromise: TLSO brace. Neurologic deficit or >50% canal compromise: posterior stabilization with pedicle screws ± decompression."
      }
    ],

    "mimics": [
      {
        "diseaseId": "disc_herniation",
        "discriminators": ["normal_xray", "mri_shows_disc_herniation", "focal_nerve_root_symptoms"]
      }
    ],

    "investigations": {
      "bedside": [],
      "laboratory": [],
      "imaging": [
        { "name": "Spine X-ray AP and lateral", "priority": "immediate", "yield": 0.8, "indication": "screening" },
        { "name": "CT spine", "priority": "high", "yield": 0.95, "indication": "bony detail, canal compromise" },
        { "name": "MRI spine", "priority": "high", "yield": 0.9, "indication": "neurologic deficit, ligamentous injury" }
      ]
    },

    "management": {
      "protocolReference": "AO Spine Fracture Classification Guidelines",
      "pathways": [
        {
          "severity": "stable_no_deficit",
          "criteria": "Compression or non-displaced, no neurologic deficit, stable on imaging",
          "treatment": "Brace (TLSO/cervical collar depending on level). Activity restriction. Serial X-rays. Pain management."
        },
        {
          "severity": "unstable_or_deficit",
          "criteria": "Burst with retropulsion, dislocation, flexion-distraction, neurologic deficit",
          "treatment": "Spinal precautions (log roll). Methylprednisolone protocol per surgeon. Urgent neurosurgery/ortho spine consultation. Operative stabilization with pedicle screw fixation ± decompression."
        }
      ]
