        { "sign": "spinal_shock", "weight": 10 },
        { "sign": "unstable_fracture_burst_flexion_distraction", "weight": 9 },
        { "sign": "cauda_equina_syndrome", "weight": 10 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "retropulsion_into_canal", "weight": 8 },
          { "sign": "loss_of_vertebral_height_>50_percent", "weight": 7 },
          { "sign": "kyphosis_>30_degrees", "weight": 7 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If neurologic deficit or unstable pattern -> SEVERE; else NON-SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "high_energy_trauma_mva_fall", "weight": 5 },
      { "symptomId": "back_pain_midline_tenderness", "weight": 5 },
      { "symptomId": "numbness_weakness_limbs", "weight": 5 },
      { "symptomId": "loss_of_bladder_bowel_control", "weight": 4 },
      { "symptomId": "osteoporosis_history_low_energy", "weight": 3 }
    ],

    "examFeatures": [
      { "signId": "midline_back_tenderness_and_step_off", "baseWeight": 5, "doubleWeight": true },
      { "signId": "neurologic_exam_motor_sensory", "baseWeight": 5, "doubleWeight": true },
      { "signId": "spinal_deformity_kyphosis", "baseWeight": 4 },
      { "signId": "bruising_swelling_over_spine", "baseWeight": 3 }
    ],

    "riskFactors": [
