        { "sign": "bucket_handle_tear_displaced", "weight": 8 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "associated_acl_tear", "weight": 6 },
          { "sign": "tear_in_red_white_zone", "weight": 5 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If locked knee or bucket handle -> SEVERE; else NON-SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "twisting_injury_knee", "weight": 4 },
      { "symptomId": "knee_pain_joint_line", "weight": 5 },
      { "symptomId": "mechanical_symptoms_locking_catching", "weight": 5 },
      { "symptomId": "knee_giving_way", "weight": 3 },
      { "symptomId": "effusion_delayed_24h", "weight": 3 }
    ],

    "examFeatures": [
