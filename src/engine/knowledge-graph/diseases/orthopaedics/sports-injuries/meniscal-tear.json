      { "id": "acl_deficiency", "multiplier": 3.0 },
      { "id": "age_>40", "multiplier": 2.0 }
    ],

    "subtypes": [
      {
        "id": "traumatic_meniscal_tear",
        "name": "Traumatic Meniscal Tear (Young Athlete)",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "bucket_handle_or_vertical_tear", "weight": 4 },
          { "feature": "associated_acl_tear_often", "weight": 3 }
        ],
        "management": "Arthroscopic repair (inside-out, all-inside, or outside-in) for red-zone tears. Partial meniscectomy if non-repairable. Post-op bracing and physiotherapy."
      },
      {
        "id": "degenerative_meniscal_tear",
        "name": "Degenerative Meniscal Tear (Older Adult)",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "horizontal_or_complex_tear", "weight": 4 },
          { "feature": "associated_osteoarthritis", "weight": 3 }
        ],
        "management": "Conservative: physiotherapy, activity modification. Arthroscopic partial meniscectomy if mechanical symptoms. Consider meniscal transplant if young and post-meniscectomy."
      }
    ],

    "mimics": [
      {
        "diseaseId": "patellofemoral_syndrome",
        "discriminators": ["anterior_knee_pain", "patellar_tenderness", "negative_mcmurray"]
      }
    ],

    "investigations": {
      "bedside": [],
      "laboratory": [],
      "imaging": [
        { "name": "Knee X-ray", "priority": "high", "yield": 0.2, "indication": "rule out fracture, assess OA" },
        { "name": "MRI knee", "priority": "high", "yield": 0.95, "indication": "confirm size, location, repairability" }
      ]
    },

    "management": {
      "protocolReference": "AAOS Meniscal Tears Guidelines",
      "pathways": [
        {
          "severity": "repairable_non_locking",
          "criteria": "Red-white zone, vertical longitudinal, stable knee, no locking",
          "treatment": "Arthroscopic meniscal repair. Post-op: partial weight bearing 4-6 weeks, brace in extension, limited range of motion."
        },
        {
          "severity": "non_repairable_or_degenerative",
          "criteria": "White zone, complex/horizontal, degenerative, locked knee",
          "treatment": "Arthroscopic partial meniscectomy. Immediate weight bearing. Physiotherapy. Return to sports 4-6 weeks."
        }
      ]
