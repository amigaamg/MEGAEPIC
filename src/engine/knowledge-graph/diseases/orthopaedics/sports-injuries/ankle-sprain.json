      { "id": "poor_proprioception", "multiplier": 2.0 }
    ],

    "subtypes": [
      {
        "id": "grade_1_mild",
        "name": "Grade I (ATFL Stretch)",
        "prevalenceModifier": 0.5,
        "keyFeatures": [
          { "feature": "mild_swelling", "weight": 3 },
          { "feature": "full_weight_bearing_possible", "weight": 3 },
          { "feature": "no_instability", "weight": 4 }
        ],
        "management": "RICE protocol. Functional rehabilitation. Return to sport in 1-2 weeks."
      },
      {
        "id": "grade_2_moderate",
        "name": "Grade II (ATFL Partial Tear ± CFL)",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "moderate_swelling_bruising", "weight": 4 },
          { "feature": "some_instability_on_testing", "weight": 4 },
          { "feature": "difficulty_weight_bearing", "weight": 3 }
        ],
        "management": "RICE, walking boot or ankle brace, early protected weight bearing, PT for proprioception and strength. Return to sport in 3-6 weeks."
      },
      {
        "id": "grade_3_severe",
        "name": "Grade III (Complete ATFL+CFL ± PTFL Tear)",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "severe_swelling_bruising", "weight": 5 },
          { "feature": "gross_instability_positive_drawer", "weight": 5 },
          { "feature": "unable_to_weight_bear", "weight": 4 }
        ],
        "management": "RICE, walking boot/cast NWB for 2 weeks, then progressive WB in boot. PT for range of motion, strength, proprioception. Surgery if recurrent instability after rehab."
      }
    ],

    "mimics": [
      {
        "diseaseId": "ankle_fracture",
        "discriminators": ["bony_tenderness", "positive_xray", "cannot_weight_bear_at_all"]
      },
      {
        "diseaseId": "peroneal_tendon_dislocation",
        "discriminators": ["retromalleolar_pain", "snapping_sensation", "tendon_subluxation_test"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Ottawa ankle rules", "priority": "immediate", "yield": 0.85, "indication": "determine need for X-ray" }
      ],
      "laboratory": [],
      "imaging": [
        { "name": "Ankle X-ray (if Ottawa positive)", "priority": "high", "yield": 0.6, "indication": "rule out fracture" },
        { "name": "MRI ankle", "priority": "low", "yield": 0.9, "indication": "refractory cases, suspected osteochondral injury" }
      ]
    },

    "management": {
      "protocolReference": "Ottawa Ankle Rules / AAOS Ankle Sprain Guidelines",
      "pathways": [
        {
          "severity": "acute_phase",
          "criteria": "<48 hours from injury, regardless of grade",
          "treatment": "RICE: Rest, Ice (15 min q2-3h), Compression (ACE bandage), Elevation. NSAIDs. Protected weight bearing based on pain. Crutches if needed."
        },
        {
          "severity": "rehabilitation_phase",
          "criteria": "After acute phase (>48h-72h), pain controlled",
          "treatment": "Range of motion exercises (alphabet, towel curls). Proprioceptive training (single leg stance, wobble board). Peroneal strengthening. Return to sport when full ROM and strength achieved."
        }
      ]
    },

    "pathophysiology": ["inversion_and_plantarflexion", "atfl_rupture_first", "cf_then_ptfl", "hemarthrosis_and_edema"]
