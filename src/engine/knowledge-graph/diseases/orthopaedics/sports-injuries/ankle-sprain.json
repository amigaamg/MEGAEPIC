        "additionalCriteria": [
          { "sign": "anterior_drawer_positive", "weight": 6 },
          { "sign": "inability_to_weight_bear_>4_weeks", "weight": 5 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If gross instability or recurrent sprains -> SEVERE; else NON-SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "inversion_twisting_injury", "weight": 5 },
      { "symptomId": "pop_or_tear_sensation", "weight": 3 },
      { "symptomId": "immediate_pain_and_swelling", "weight": 5 },
      { "symptomId": "difficulty_weight_bearing", "weight": 4 },
      { "symptomId": "recurrent_sprains", "weight": 3 }
    ],

    "examFeatures": [
      { "signId": "lateral_ankle_swelling", "baseWeight": 5 },
      { "signId": "tenderness_over_atfl_cf", "baseWeight": 5 },
      { "signId": "ecchymosis", "baseWeight": 3 },
      { "signId": "anterior_drawer_test_positive", "baseWeight": 4 },
      { "signId": "talar_tilt_test_positive", "baseWeight": 4 },
      { "signId": "weight_bearing_status", "baseWeight": 3 }
