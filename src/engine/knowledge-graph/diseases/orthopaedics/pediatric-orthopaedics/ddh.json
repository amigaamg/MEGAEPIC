{
  "disease": {
    "id": "ddh",
    "name": "Developmental Dysplasia of the Hip",
    "system": "ORTHO",
    "agePeak_months": [0, 6],
    "note": "Spectrum of hip instability from mild acetabular dysplasia to frank dislocation. Early detection and treatment critical for normal hip development.",
    "prevalenceWeight": 0.2,
    "syndromeTags": ["pediatric_hip", "congenital_dysplasia"],

    "severityAssessment": {
      "immediateDangerSigns": [],
      "severeCriteria": {
        "anyDangerSign": false,
        "additionalCriteria": [
          { "sign": "dislocated_hip_not_reducible", "weight": 7 },
          { "sign": "avascular_necrosis_head", "weight": 9 },
          { "sign": "high_riding_dislocation_walking_age", "weight": 7 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If irreducible dislocation or late presentation -> SEVERE; else NON-SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "breech_presentation", "weight": 4 },
      { "symptomId": "family_history_ddh", "weight": 4 },
      { "symptomId": "oligohydramnios", "weight": 3 },
      { "symptomId": "leg_length_discrepancy_noted", "weight": 3 },
      { "symptomId": "limited_hip_abduction_parent_noticed", "weight": 3 },
      { "symptomId": "limp_in_toddler", "weight": 4 }
    ],

    "examFeatures": [
      { "signId": "positive_ortolani_maneuver", "baseWeight": 5, "doubleWeight": true },
      { "signId": "positive_barlow_maneuver", "baseWeight": 5 },
      { "signId": "limited_hip_abduction_<60_degrees", "baseWeight": 4 },
      { "signId": "leg_length_discrepancy_galeazzi_sign", "baseWeight": 4 },
      { "signId": "asymmetric_gluteal_thigh_folds", "baseWeight": 3 },
      { "signId": "limp_or_trendelenburg_gait_walking_age", "baseWeight": 4 }
    ],

    "riskFactors": [
      { "id": "female_gender", "multiplier": 4.0 },
      { "id": "breech_presentation", "multiplier": 4.0 },
      { "id": "family_history_ddh", "multiplier": 4.0 },
      { "id": "first_birth", "multiplier": 2.0 },
      { "id": "oligohydramnios", "multiplier": 2.0 },
      { "id": "left_hip_more_common", "multiplier": 1.5 }
    ],

    "subtypes": [
      {
        "id": "newborn_screening",
        "name": "Newborn - Clinical and US Screening",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
          { "feature": "positive_ortolani_or_barlow", "weight": 5 },
          { "feature": "abnormal_ultrasound_graf_type_2c_or_worse", "weight": 5 }
        ],
        "management": "Pavlik harness if reducible (Ortolani positive) and age <6 months. US-guided management. Wean once stable on exam and US normal."
      },
      {
        "id": "late_presentation_walking_age",
        "name": "Late Presentation (Walking Age)",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "limp_trendelenburg_gait", "weight": 5 },
          { "feature": "limited_abduction", "weight": 4 },
          { "feature": "unreducible_at_exam_age_>6_months", "weight": 5 }
        ],
        "management": "Closed or open reduction ± femoral/pelvic osteotomy. Age-dependent. Post-op spica cast for 6-12 weeks. Complications: AVN."
      }
    ],

    "mimics": [
      {
        "diseaseId": "cerebral_palsy_hip",
        "discriminators": ["spasticity", "other_neurologic_signs", "history_of_prematurity"]
      },
      {
        "diseaseId": "septic_arthritis_hip_sequelae",
        "discriminators": ["history_of_infection", "destructive_changes_on_xray"]
      }
    ],

    "investigations": {
      "bedside": [],
      "laboratory": [],
      "imaging": [
        { "name": "Hip Ultrasound (Graf method)", "priority": "high", "yield": 0.95, "indication": "screening <6 months" },
        { "name": "Hip X-ray (AP pelvis)", "priority": "high", "yield": 0.8, "indication": ">4-6 months old, follow-up" }
      ]
    },

    "management": {
      "protocolReference": "AAOS / AAP DDH Screening and Management Guidelines",
      "pathways": [
        {
          "severity": "infant_<6_months",
          "criteria": "Ortolani/Barlow positive, reducible, US confirms",
          "treatment": "Pavlik harness for 6-12 weeks (23h/day). US at 2 weeks to confirm reduction. Wean once stable. Follow with X-ray at 6-12 months."
        },
        {
          "severity": "older_infant_>6_months",
          "criteria": "Dislocated, not reducible, or late presentation",
          "treatment": "Closed reduction under anesthesia + hip spica cast. If failed: open reduction ± acetabuloplasty/femoral shortening osteotomy. Spica for 6-12 weeks."
        }
      ]
    },

    "pathophysiology": ["acetabular_dysplasia", "ligamentous_laxity", "femoral_head_subluxation_or_dislocation", "abnormal_hip_development"]
  }
}
