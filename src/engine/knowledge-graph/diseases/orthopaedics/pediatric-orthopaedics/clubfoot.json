{
  "disease": {
    "id": "clubfoot",
    "name": "Congenital Clubfoot (Talipes Equinovarus)",
    "system": "ORTHO",
    "agePeak_months": [0, 3],
    "note": "Congenital deformity: equinus, varus, adductus, cavus. Idiopathic most common. Ponseti method of serial casting is gold standard.",
    "prevalenceWeight": 0.2,
    "syndromeTags": ["congenital_foot_deformity", "pediatric_orthopaedics"],

    "severityAssessment": {
