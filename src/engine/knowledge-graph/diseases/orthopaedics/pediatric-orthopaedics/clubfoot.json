          { "sign": "syndromic_associated", "weight": 6 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If rigid or syndromic -> SEVERE; else NON-SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "foot_deformity_noted_at_birth", "weight": 5 },
      { "symptomId": "family_history_clubfoot", "weight": 3 },
      { "symptomId": "associated_anomalies_spina_bifida", "weight": 3 }
    ],

    "examFeatures": [
      { "signId": "equinus_ankle_plantarflexion", "baseWeight": 5, "doubleWeight": true },
      { "signId": "hindfoot_varus_heel_inverted", "baseWeight": 5 },
      { "signId": "forefoot_adductus", "baseWeight": 4 },
      { "signId": "midfoot_cavus_high_arch", "baseWeight": 3 },
      { "signId": "pirani_score_total", "baseWeight": 4 }
    ],

    "riskFactors": [
