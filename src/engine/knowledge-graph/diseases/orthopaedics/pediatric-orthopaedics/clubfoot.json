      { "id": "male_gender", "multiplier": 2.5 },
      { "id": "neural_tube_defect_myelomeningocele", "multiplier": 5.0 }
    ],

    "subtypes": [
      {
        "id": "idiopathic_clubfoot",
        "name": "Idiopathic Clubfoot",
        "prevalenceModifier": 0.85,
        "keyFeatures": [
          { "feature": "otherwise_healthy_infant", "weight": 4 },
          { "feature": "pirani_score_1_to_6", "weight": 4 }
        ],
        "management": "Ponseti method: serial long-leg plaster casts starting within 2 weeks of birth, changed weekly for 5-8 weeks. Percutaneous Achilles tenotomy in most. Foot abduction brace (Denis Browne) for 3-4 months full time, then night-time until 4-5 years."
      },
      {
        "id": "syndromic_clubfoot",
        "name": "Syndromic/Teratologic Clubfoot",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "associated_with_other_congenital_anomalies", "weight": 5 },
          { "feature": "stiffer_harder_to_correct", "weight": 4 }
        ],
        "management": "May require more casts. Often needs surgical release (posteromedial release). Treat underlying condition."
      }
    ],

    "mimics": [
      {
        "diseaseId": "metatarsus_adductus",
        "discriminators": ["only_forefoot_adducted", "no_equinus_or_varus", "resolves_spontaneously"]
      },
      {
        "diseaseId": "positional_calcaneovalgus",
        "discriminators": ["foot_dorsiflexed", "normal_with_manipulation"]
      }
    ],

    "investigations": {
      "bedside": [],
      "laboratory": [],
      "imaging": []
    },

    "management": {
      "protocolReference": "Ponseti Method Guidelines / ICFSG Consensus",
      "pathways": [
        {
          "severity": "standard_ponseti",
          "criteria": "Idiopathic, Pirani <5, no prior treatment",
          "treatment": "Serial long-leg casting weekly (Ponseti technique: manipulate, cast in correction, no need to force). Tenotomy at 5-8 weeks. Foot abduction brace (FAB) 23h/day for 3-4 months, then nocturnal wear until 4-5 years."
        },
        {
          "severity": "residual_or_relapsed",
          "criteria": "Incomplete correction after casting, or relapse after bracing",
          "treatment": "Recasting or Ponseti revision. Anterior tibialis tendon transfer for dynamic supination. Extensive soft tissue release for rigid relapsed deformity."
        }
      ]
    },

    "pathophysiology": ["genetic_multifactorial", "intrauterine_positioning", "abnormal_development_of_talar_neck", "medial_soft_tissue_contracture"]
  }
