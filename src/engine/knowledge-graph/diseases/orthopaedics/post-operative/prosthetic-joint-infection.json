        { "name": "Joint aspiration for culture, cell count, differential", "priority": "high", "yield": 0.85, "indication": "confirm infection" },
        { "name": "Blood culture", "priority": "high", "yield": 0.3, "indication": "if fever/systemic" },
        { "name": "Intraoperative tissue cultures (≥3 samples)", "priority": "high", "yield": 0.95, "indication": "definitive diagnosis" }
