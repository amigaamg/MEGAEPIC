          { "feature": "sinus_tract", "weight": 5 },
          { "feature": "elevated_crp_esr", "weight": 4 }
        ],
        "management": "Two-stage exchange: remove prosthesis and cement, implant antibiotic-impregnated cement spacer (PMMA with vancomycin + gentamicin). IV antibiotics for 6 weeks guided by culture. Reimplantation after normalization of CRP."
      }
