        "keyFeatures": [
          { "feature": "wound_drainage_erythema", "weight": 5 },
          { "feature": "fever", "weight": 4 },
          { "feature": "elevated_crp", "weight": 4 }
        ],
        "management": "DAIR: Debridement, antibiotics, implant retention. Open joint debridement with liner exchange. IV antibiotics for 6 weeks then oral suppression."
      },
      {
        "id": "chronic_late_infection",
        "name": "Chronic Late Infection (>4 weeks)",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
