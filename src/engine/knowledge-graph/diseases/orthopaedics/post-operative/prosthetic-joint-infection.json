    "management": {
      "protocolReference": "AAOS / IDSA Periprosthetic Joint Infection Guidelines",
      "pathways": [
        {
          "severity": "early_acute",
          "criteria": "Symptoms <4 weeks from index arthroplasty, well-fixed implant",
          "treatment": "DAIR: Debridement, polyethylene liner exchange, copious irrigation. IV antibiotics for 6 weeks (gram-positive coverage initially, then culture-directed). Monitor CRP."
        },
        {
          "severity": "chronic_late",
          "criteria": "Symptoms >4 weeks, loose implant, sinus tract, or failed DAIR",
          "treatment": "Stage 1: removal of all components, cement, and membranes. Antibiotic cement spacer insertion. IV antibiotics 6 weeks. Stage 2: reimplantation after clinical and lab resolution. 4-12 week interval."
        }
      ]
    },

    "pathophysiology": ["bacterial_adhesion_to_implant", "biofilm_formation", "resistance_to_antibiotics_and_immune_response", "osteolysis", "implant_loosening"]
