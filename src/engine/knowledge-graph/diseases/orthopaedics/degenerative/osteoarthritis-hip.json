      "imaging": [
        { "name": "Hip X-ray (AP pelvis, cross-table lateral)", "priority": "high", "yield": 0.95, "indication": "joint space narrowing, osteophytes, sclerosis, cysts" },
        { "name": "MRI hip", "priority": "medium", "yield": 0.9, "indication": "early OA, AVN, labral tear" }
      ]
    },

    "management": {
      "protocolReference": "AAOS Osteoarthritis of the Hip Guidelines",
      "pathways": [
        {
          "severity": "conservative",
          "criteria": "Mild-moderate OA, pain controlled with medication, functional",
          "treatment": "Activity modification, PT (strengthening, ROM), NSAIDs/acetaminophen, weight loss, walking aids (cane in opposite hand). Intra-articular steroid injection if pain exacerbation."
        },
        {
          "severity": "surgical",
          "criteria": "Severe pain, functional limitation, failed conservative treatment, advanced X-ray changes",
          "treatment": "Total hip arthroplasty (cementless or hybrid). Spinal/epidural anesthesia. Post-op: immediate WBAT, hip precautions, VTE prophylaxis."
