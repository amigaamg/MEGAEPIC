        "name": "Mild-Moderate Hip OA",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
          { "feature": "preserved_joint_space", "weight": 4 },
          { "feature": "pain_with_activity_relieved_by_rest", "weight": 4 },
          { "feature": "no_deformity", "weight": 3 }
        ],
        "management": "Activity modification. Physical therapy (strengthening hip abductors/extensors). NSAIDs or acetaminophen. Intra-articular corticosteroid injection. Weight loss."
      },
      {
        "id": "severe_end_stage_oa",
        "name": "Severe End-Stage Hip OA",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
