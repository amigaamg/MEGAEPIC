          { "feature": "pain_on_stairs", "weight": 5 },
          { "feature": "pain_on_prolonged_flexion", "weight": 4 }
        ],
        "management": "Quadriceps strengthening. Patellar taping. Activity modification. Patellofemoral replacement if severe."
      }
