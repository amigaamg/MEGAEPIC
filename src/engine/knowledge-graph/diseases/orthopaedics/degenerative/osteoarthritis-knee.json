    "investigations": {
      "bedside": [
        { "name": "Knee examination (WOMAC score)", "priority": "immediate", "yield": 0.8, "indication": "all knee pain patients" }
      ],
      "imaging": [
        { "name": "Weight-bearing Knee X-ray (AP, Lateral, Skyline)", "priority": "high", "yield": 0.9, "indication": "joint space narrowing, osteophytes, subchondral sclerosis" },
        { "name": "MRI Knee", "priority": "medium", "yield": 0.85, "indication": "assess cartilage, menisci, ligaments if atypical features" }
      ]
    },

    "management": {
      "protocolReference": "NICE Guidelines for Osteoarthritis",
      "pathways": [
        {
          "severity": "mild",
          "criteria": "VAS 1-3, intermittent pain",
          "treatment": "Exercise (strengthening, aerobic). Weight loss if obese. Education and self-management. Paracetamol PRN."
        },
        {
          "severity": "moderate",
          "criteria": "VAS 4-7, daily pain, some functional limitation",
          "treatment": "Topical NSAIDs. Oral NSAIDs (short course). Physiotherapy. Walking aids. Intra-articular corticosteroids."
        },
        {
          "severity": "severe",
          "criteria": "VAS 8-10, significant disability, failed conservative",
          "treatment": "Total knee arthroplasty. Pre-operative optimization. Post-operative physiotherapy."
        }
      ]
    },

    "pathophysiology": [
      "articular_cartilage_degradation",
