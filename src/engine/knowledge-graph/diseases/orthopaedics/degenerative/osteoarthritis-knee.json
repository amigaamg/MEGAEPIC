          { "feature": "varus_deformity", "weight": 4 }
        ],
        "management": "Physiotherapy, weight loss, bracing, NSAIDs. High tibial osteotomy if young. Unicompartmental or total knee replacement."
      },
      {
        "id": "patellofemoral_oa",
        "name": "Patellofemoral Osteoarthritis",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
