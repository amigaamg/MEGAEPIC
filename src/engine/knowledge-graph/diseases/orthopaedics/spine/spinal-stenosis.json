        "id": "lumbar_stenosis",
        "name": "Lumbar Spinal Stenosis",
        "prevalenceModifier": 0.7,
        "keyFeatures": [
          { "feature": "neurogenic_claudication", "weight": 5 },
          { "feature": "bilateral_leg_symptoms", "weight": 4 },
          { "feature": "relief_with_sitting", "weight": 5 }
        ],
        "management": "Conservative: PT (flexion-based), NSAIDs, epidural injections. Surgical: decompressive laminectomy ± fusion if instability."
      },
      {
        "id": "cervical_stenosis",
        "name": "Cervical Spinal Stenosis",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "clumsy_hands", "weight": 5 },
          { "feature": "gait_disturbance", "weight": 5 },
          { "feature": "long_tract_signs", "weight": 5 }
        ],
        "management": "Surgical for myelopathy: ACDF or posterior decompression (laminoplasty/laminectomy + fusion). Non-myelopathic: observation."
      }
    ],

    "mimics": [
