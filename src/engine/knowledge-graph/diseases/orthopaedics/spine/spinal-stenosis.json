        "diseaseId": "vascular_claudication_pvd",
        "discriminators": ["absent_pulses", "relief_with_standing_not_bending", "abnormal_abi"]
      }
    ],

    "investigations": {
      "bedside": [],
      "laboratory": [],
      "imaging": [
        { "name": "Spine X-ray", "priority": "high", "yield": 0.4, "indication": "spondylolisthesis, degenerative changes" },
        { "name": "MRI spine", "priority": "high", "yield": 0.95, "indication": "canal dimensions, neural compression" },
        { "name": "CT myelogram", "priority": "medium", "yield": 0.9, "indication": "if MRI contraindicated or prior hardware" }
      ]
    },

    "management": {
      "protocolReference": "NASS Clinical Guidelines for Spinal Stenosis",
      "pathways": [
        {
          "severity": "mild_moderate",
          "criteria": "No myelopathy, walking distance >200m, tolerable pain",
          "treatment": "Physical therapy (flexion-based). NSAIDs. Epidural steroid injections. Activity modification. Walking aids (rollator walker)."
        },
        {
          "severity": "severe",
          "criteria": "Myelopathy, walking distance <200m, bowel/bladder, or failed conservative",
          "treatment": "Decompressive laminectomy. ± Fusion if instability or spondylolisthesis. Cervical: ACDF or laminoplasty."
        }
      ]
    },

