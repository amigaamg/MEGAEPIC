      { "signId": "neurologic_exam_may_be_normal_at_rest", "baseWeight": 3 },
      { "signId": "wide_based_gait_myelopathy", "baseWeight": 4 },
      { "signId": "long_tract_signs_cervical_stenosis", "baseWeight": 5 }
    ],

    "riskFactors": [
      { "id": "age_>60", "multiplier": 5.0 },
