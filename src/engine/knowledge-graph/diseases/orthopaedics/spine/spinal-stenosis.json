        { "sign": "acute_paraplegia", "weight": 10 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "neurogenic_claudication_unable_to_walk", "weight": 7 },
          { "sign": "motor_deficit_grade_3_5", "weight": 7 },
          { "sign": "bowel_bladder_dysfunction", "weight": 9 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If myelopathy, cauda equina, or significant motor deficit -> SEVERE; else NON-SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "leg_pain_cramping_with_walking", "weight": 5 },
      { "symptomId": "relief_with_sitting_forward_bending", "weight": 5, "note": "Neurogenic claudication classic" },
      { "symptomId": "numbness_heaviness_in_legs", "weight": 4 },
      { "symptomId": "balance_difficulty_myelopathy", "weight": 4 },
      { "symptomId": "no_pain_when_cycling_shopping_cart", "weight": 4 }
    ],

    "examFeatures": [
      { "signId": "normal_vascular_exam_pedal_pulses", "baseWeight": 4, "note": "Differentiates from vascular claudication" },
