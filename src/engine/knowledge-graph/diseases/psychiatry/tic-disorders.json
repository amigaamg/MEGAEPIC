    "management": {
      "protocolReference": "AACAP Practice Parameter for Tic Disorders",
      "pathways": [
        {
          "severity": "mild",
          "criteria": "YGTSS <15, no functional impairment",
          "treatment": "Psychoeducation. Regular monitoring. Most resolve spontaneously."
        },
        {
          "severity": "moderate",
          "criteria": "YGTSS 15-30, some distress or interference",
          "treatment": "Habit reversal therapy (HRT) / CBIT. Clonidine 0.05-0.2 mg/day or guanfacine 0.5-3 mg/day."
        },
        {
          "severity": "severe",
          "criteria": "YGTSS >30, marked impairment, self-injurious",
          "treatment": "Alpha-2 agonist plus antipsychotic (aripiprazole 2-15 mg, risperidone 0.5-4 mg). Topiramate adjunct. DBS for refractory adults."
        }
      ]
