    ],
    "investigations": {
      "bedside": [
        { "name": "COWS (Clinical Opiate Withdrawal Scale)", "priority": "serial", "yield": 0.9, "indication": "withdrawal monitoring" },
        { "name": "Naloxone challenge test", "priority": "selective", "yield": 0.8, "indication": "before buprenorphine induction" }
      ],
      "laboratory": [
        { "name": "Urine toxicology", "priority": "high", "yield": 0.9, "indication": "confirm opioid use, detect polysubstance" },
        { "name": "Hepatitis C, HIV, HBV serology", "priority": "high", "yield": 0.3, "indication": "IV drug users, baseline screening" },
