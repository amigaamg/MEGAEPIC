        ],
        "management": "Buprenorphine/naloxone (Suboxone) induction. Outpatient MAT. Counseling. Monitor for relapse. Naloxone kit provided."
      },
      {
        "id": "opioid_dependence_severe",
        "name": "Severe Opioid Use Disorder",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
          { "feature": "6_or_more_criteria", "weight": 5 },
          { "feature": "iv_drug_use", "weight": 4 },
