    "management": {
      "protocolReference": "NICE Guidelines for Opioid Dependence / ASAM Criteria",
      "pathways": [
        {
          "severity": "overdose",
          "criteria": "respiratory depression, unresponsiveness, pinpoint pupils",
          "treatment": "NALOXONE 0.4-2 mg IV/IM/IN. Repeat Q2-3min PRN. Call 911. Airway support. Observe for renarcotization (naloxone half-life shorter than opioids)."
        },
        {
          "severity": "withdrawal management",
          "criteria": "COWS >12, seeking detox",
          "treatment": "Methadone 20-30 mg daily (titrate) OR buprenorphine 4-16 mg SL daily. Alpha-2 agonists (clonidine 0.1-0.2 mg Q4-6h) for autonomic symptoms. Loperamide for diarrhea. Supportive care."
        },
        {
          "severity": "maintenance",
          "criteria": "clinically stable on MAT",
          "treatment": "Methadone 60-120 mg daily (in clinic) or buprenorphine 8-24 mg SL daily (take-home). Regular toxicology. Psychotherapy. Relapse prevention. Naloxone kit. Peer support."
        }
      ]
    },
    "pathophysiology": [
      "mu_opioid_receptor_agonism",
      "reward_pathway_dopamine_activation",
      "tolerance_receptor_downregulation",
      "withdrawal_noradrenergic_rebound",
      "genetic_predisposition_ophrm1"
