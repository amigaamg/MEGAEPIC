          { "feature": "clear_precipitating_events", "weight": 5 },
          { "feature": "acute_onset", "weight": 4 }
        ],
        "management": "Low-dose antipsychotic (olanzapine 2.5-5 mg or risperidone 0.5-2 mg) for symptom control. Taper and discontinue after symptom resolution. Supportive psychotherapy."
      },
      {
        "id": "without_marked_stressor",
        "name": "Brief Psychotic Disorder without Marked Stressor",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "no_clear_trigger", "weight": 4 },
          { "feature": "full_recovery", "weight": 5 }
        ],
        "management": "Same pharmacotherapy. Rule out organic causes. Monitor for future mood or psychotic episodes. Psychotherapy."
      }
    ],
    "mimics": [
      { "diseaseId": "schizophrenia", "discriminators": ["duration_over_1_month", "negative_symptoms", "functional_decline", "prodromal_period"] },
      { "diseaseId": "substance_induced_psychosis", "discriminators": ["positive_tox", "temporal_relationship_with_use", "resolution_with_abstinence"] },
      { "diseaseId": "acute_mania", "discriminators": ["elevated_mood", "decreased_sleep_need", "pressured_speech", "grandiosity"] }
    ],
    "investigations": {
