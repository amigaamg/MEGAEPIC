        { "sign": "severe_self_neglect", "weight": 8 }
      ],
      "severeCriteria": { "anyDangerSign": true },
      "nonSevereCriteria": { "hasIndrawingOrFastBreathing": false, "noDangerSigns": true },
      "severityLabel": "If danger signs or severe distress -> INPATIENT; else -> OUTPATIENT with close follow-up"
