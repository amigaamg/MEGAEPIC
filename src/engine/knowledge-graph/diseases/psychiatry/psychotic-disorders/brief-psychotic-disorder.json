        { "name": "Psychiatric interview with collateral", "priority": "immediate", "yield": 0.9, "indication": "all patients" }
      ],
      "laboratory": [
        { "name": "Urine toxicology", "priority": "immediate", "yield": 0.5, "indication": "exclude substance-induced psychosis" },
        { "name": "TSH, FBC, U&E, LFT, glucose", "priority": "high", "yield": 0.3, "indication": "rule out medical causes" },
        { "name": "Blood alcohol level", "priority": "medium", "yield": 0.3, "indication": "if alcohol use suspected" }
      ],
      "imaging": [
        { "name": "CT/MRI Brain", "priority": "medium", "yield": 0.1, "indication": "if first episode, atypical features, neurological signs" }
      ]
    },
    "management": {
      "protocolReference": "NICE Guidelines for Psychosis and Schizophrenia",
      "pathways": [
        {
          "severity": "acute with risk",
          "criteria": "danger to self/others, severe disorganization, catatonia",
          "treatment": "Inpatient admission. Antipsychotic: olanzapine 5-10 mg or haloperidol 2-5 mg IM if needed. Benzodiazepines for agitation. Safety plan."
        },
        {
          "severity": "mild-moderate, low risk",
          "criteria": "no danger signs, good social support",
          "treatment": "Outpatient management. Low-dose antipsychotic (olanzapine 2.5-5 mg or risperidone 0.5-2 mg). Supportive psychotherapy. Close follow-up. Anticipate full recovery <1 month."
