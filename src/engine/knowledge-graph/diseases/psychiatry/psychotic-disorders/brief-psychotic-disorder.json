      { "symptomId": "acute_onset_days", "weight": 3 }
    ],
    "examFeatures": [
      { "signId": "disorganized_or_catatonic_behavior", "baseWeight": 4 },
      { "signId": "intense_anxiety_or_agitation", "baseWeight": 4 },
      { "signId": "delusional_beliefs_bizarre", "baseWeight": 4 },
      { "signId": "hallucinatory_behavior", "baseWeight": 3 },
      { "signId": "poor_insight_acute", "baseWeight": 3 }
    ],
    "riskFactors": [
      { "id": "acute_severe_stressor", "multiplier": 5.0 },
      { "id": "postpartum_period", "multiplier": 4.0 },
      { "id": "personality_disorder_cluster_a", "multiplier": 3.0 },
      { "id": "sleep_deprivation_extreme", "multiplier": 2.0 },
      { "id": "recent_immigration_or_trauma", "multiplier": 2.0 }
    ],
    "subtypes": [
      {
        "id": "with_marked_stressor",
        "name": "Brief Psychotic Disorder with Marked Stressor",
