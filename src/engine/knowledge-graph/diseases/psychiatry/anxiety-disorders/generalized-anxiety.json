{
  "disease": {
    "id": "generalized_anxiety_disorder",
    "name": "Generalized Anxiety Disorder",
    "system": "psychiatry",
    "agePeak_months": [240, 540],
    "note": "Excessive worry about multiple domains. More common in females. Often comorbid with depression.",
    "prevalenceWeight": 0.6,
    "syndromeTags": ["anxiety_disorder", "excessive_worry"],

    "severityAssessment": {
      "immediateDangerSigns": [
        { "sign": "suicidal_ideation", "weight": 10 },
        { "sign": "panic_attacks_with_chest_pain", "weight": 8 },
        { "sign": "severe_agitation", "weight": 8 }
      ],
      "severeCriteria": {
        "anyDangerSign": true
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If suicidal/panic with cardiac symptoms -> URGENT; else -> MILD/MODERATE (outpatient)"
    },

    "historyFeatures": [
      { "symptomId": "excessive_worry", "weight": 5 },
      { "symptomId": "restlessness", "weight": 3 },
      { "symptomId": "fatigue", "weight": 3 },
      { "symptomId": "irritability", "weight": 3 },
      { "symptomId": "muscle_tension", "weight": 3 },
      { "symptomId": "sleep_disturbance", "weight": 3 },
      { "symptomId": "poor_concentration", "weight": 3 },
      { "symptomId": "somatic_symptoms", "weight": 2 }
    ],

    "examFeatures": [
      { "signId": "anxious_appearance", "baseWeight": 3 },
      { "signId": "tremor", "baseWeight": 2 },
      { "signId": "tachycardia", "baseWeight": 2 },
      { "signId": "hyperventilation", "baseWeight": 2 },
      { "signId": "muscle_tension_on_exam", "baseWeight": 2 }
    ],

    "riskFactors": [
      { "id": "family_history_anxiety", "multiplier": 2.0 },
      { "id": "female_sex", "multiplier": 2.0 },
      { "id": "childhood_adversity", "multiplier": 1.8 },
      { "id": "stressful_life_events", "multiplier": 1.5 },
      { "id": "neurotic_personality", "multiplier": 1.5 }
    ],

    "mimics": [
      {
        "diseaseId": "hyperthyroidism",
        "discriminators": ["weight_loss", "heat_intolerance", "tremor", "abnormal_tsh"]
      },
      {
        "diseaseId": "panic_disorder",
        "discriminators": ["episodic_panic_attacks", "sudden_onset", "fear_of_dying"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "GAD-7 questionnaire", "priority": "immediate", "yield": 0.9, "indication": "all suspected anxiety" }
      ],
      "laboratory": [
        { "name": "TSH", "priority": "medium", "yield": 0.3, "indication": "rule out hyperthyroidism" },
        { "name": "Blood glucose", "priority": "medium", "yield": 0.2, "indication": "rule out hypoglycemia" }
      ]
    },

    "management": {
      "protocolReference": "NICE Guidelines for Generalized Anxiety Disorder",
      "pathways": [
        {
          "severity": "mild",
          "criteria": "GAD-7 <10, functional but struggling",
          "treatment": "Psychoeducation. Sleep hygiene. Relaxation techniques. Guided self-help (CBT-based). Exercise."
        },
        {
          "severity": "moderate",
          "criteria": "GAD-7 10-14, significant distress/impairment",
          "treatment": "CBT or SSRI (sertraline). Combined treatment most effective. Monitor weekly."
        },
        {
          "severity": "severe",
          "criteria": "GAD-7 15+, marked impairment, comorbidity",
          "treatment": "SSRI/SNRI. Specialist referral. Augmentation with pregabalin or buspirone. Consider psychiatric consultation."
        }
      ]
    },

    "pathophysiology": [
      "gaba_dysfunction",
      "serotonin_dysregulation",
      "amygdala_hyperactivity",
      "prefrontal_cortex_hypoactivity",
      "hpa_axis_dysregulation"
    ],

    "mustNotMiss": false,
    "diagnosticClues": ["excessive_worry_most_days", "6_months_duration", "somatic_anxiety_symptoms"],
    "exclusionClues": ["symptoms_due_to_medical_condition", "substance_use", "worry_about_one_domain_only"]
  }
}
