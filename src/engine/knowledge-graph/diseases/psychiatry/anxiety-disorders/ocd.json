      "pathways": [
        {
          "severity": "mild-moderate",
          "criteria": "Y-BOCS 8-23, 1-3 hours daily, functional impairment moderate",
          "treatment": "CBT including ERP (first-line). Self-help with guided ERP. SSRI if CBT declined or unavailable. Fluoxetine, fluvoxamine, sertraline, or escitalopram."
