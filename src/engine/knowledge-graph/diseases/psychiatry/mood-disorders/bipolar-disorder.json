      {
        "id": "bipolar_type_2",
        "name": "Bipolar II Disorder",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "hypomanic_episodes_only", "weight": 5 },
          { "feature": "predominant_depression", "weight": 5 }
        ],
        "management": "Depression: quetiapine, lamotrigine, lithium. Hypomania seldom requires treatment. Avoid antidepressant monotherapy. Maintenance: lamotrigine or lithium."
      },
      {
        "id": "rapid_cycling",
        "name": "Bipolar with Rapid Cycling",
        "prevalenceModifier": 0.1,
