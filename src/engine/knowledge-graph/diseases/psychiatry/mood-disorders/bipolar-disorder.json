    "management": {
      "protocolReference": "NICE Guidelines for Bipolar Disorder",
      "pathways": [
        {
          "severity": "acute mania",
          "criteria": "YMRS >20, psychotic features, agitation, risk",
          "treatment": "Lithium (target 0.6-1.2 mmol/L) + olanzapine 10-20 mg or haloperidol 5-15 mg. Valproate 20 mg/kg if mixed/rapid cycling. Inpatient if severe. IM if refusing."
        },
        {
          "severity": "bipolar depression",
          "criteria": "depressive episode in bipolar patient",
          "treatment": "Quetiapine 300-600 mg or lamotrigine 50-200 mg. Lithium. Avoid antidepressant monotherapy. ECT if severe/refractory."
        },
        {
          "severity": "maintenance",
          "criteria": "euthymic, prevent relapse",
          "treatment": "Lithium (first-line, also reduces suicide risk). Valproate or lamotrigine. Quetiapine. Monitor lithium levels and renal/thyroid function. Psychoeducation. Lifestyle regularity."
        }
      ]
    },
    "pathophysiology": [
