      { "diseaseId": "generalized_anxiety", "discriminators": ["no_trauma_history", "generalized_worry", "no_flashbacks_or_avoidance", "no_nightmares"] },
      { "diseaseId": "major_depressive_disorder", "discriminators": ["no_trauma_focus", "anhedonia_not_reactive", "no_hyperarousal", "no_avoidance"] }
    ],
    "investigations": {
