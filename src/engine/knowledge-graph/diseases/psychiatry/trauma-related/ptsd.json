        { "name": "CAPS-5 (Clinician-Administered PTSD Scale)", "priority": "high", "yield": 0.95, "indication": "diagnostic gold standard" }
      ],
      "laboratory": [
        { "name": "Urine toxicology", "priority": "medium", "yield": 0.3, "indication": "rule out substance-induced symptoms" }
