      { "symptomId": "exaggerated_startle_response", "weight": 3 },
      { "symptomId": "dissociative_symptoms", "weight": 3 },
      { "symptomId": "irritability_angry_outbursts", "weight": 3 },
      { "symptomId": "sleep_disturbance", "weight": 3 }
