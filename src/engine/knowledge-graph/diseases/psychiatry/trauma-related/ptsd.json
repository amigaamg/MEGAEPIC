    "management": {
      "protocolReference": "NICE/APA Guidelines for PTSD",
      "pathways": [
        {
          "severity": "mild-moderate",
          "criteria": "PCL-5 33-59, no danger signs, functional impairment present",
          "treatment": "Trauma-focused CBT (TF-CBT) or EMDR. 8-12 sessions. SSRIs (sertraline 50-200 mg or paroxetine 20-60 mg) if patient prefers medication or CBT not available."
        },
        {
          "severity": "severe/complex",
          "criteria": "PCL-5 >60, comorbid conditions, risk of self-harm, complex trauma history",
          "treatment": "Stabilization first (safety, coping skills). TF-CBT or EMDR (may be longer course). SSRIs. Prazosin 1-10 mg for nightmares. Adjunctive olanzapine or risperidone if aggression/psychosis. Case management. Trauma-informed care."
        }
      ]
    },
    "pathophysiology": [
      "amygdala_hyperreactivity",
      "prefrontal_cortex_hypofunction",
      "hippocampal_volume_reduction",
      "hpa_axis_dysregulation",
