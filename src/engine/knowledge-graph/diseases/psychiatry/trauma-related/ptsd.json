          { "feature": "depersonalization_or_derealization", "weight": 5 },
          { "feature": "dissociative_amnesia", "weight": 4 }
        ],
        "management": "Trauma-focused CBT. EMDR. SSRIs (sertraline or paroxetine). Prazosin for nightmares. Safety planning. Grounding techniques for dissociation."
      },
      {
        "id": "ptsd_delayed_expression",
        "name": "PTSD with Delayed Expression",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "symptom_onset_6_months_post_trauma", "weight": 5 },
          { "feature": "trigger_recent_life_stressor", "weight": 3 }
