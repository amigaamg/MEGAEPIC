    "management": {
      "protocolReference": "NICE Guideline CG156 - Fertility Problems",
      "pathways": [
        {
          "severity": "ovulatory_age_under_35",
          "criteria": "anovulatory, age <35, normal ovarian reserve",
          "treatment": "Lifestyle advice (weight loss if BMI >30). Ovulation induction with clomiphene 50-150mg days 2-6. Timed intercourse. Thyroid and prolactin correction. Refer to fertility specialist if >6 cycles fail."
        },
        {
          "severity": "tubal_or_uterine",
          "criteria": "tubal block, hydrosalpinx, or uterine abnormality",
          "treatment": "Surgical correction if feasible. Salpingectomy for hydrosalpinx then IVF. Uterine septum resection. IVF if bilateral tubal block."
        },
        {
          "severity": "advanced_age_or_low_reserve",
          "criteria": "age >40, low AMH, high FSH, or >3 years infertility",
          "treatment": "Prompt IVF referral. Donor eggs if poor response. Preimplantation genetic testing if indicated. Counseling on adoption/fostering."
        }
      ]
    },

    "pathophysiology": [
