      ],
      "imaging": [
        { "name": "Transvaginal ultrasound (follicle count)", "priority": "first_line", "yield": 0.8, "indication": "AFC, ovarian morphology" },
        { "name": "Hysterosalpingogram (HSG)", "priority": "first_line", "yield": 0.85, "indication": "tubal patency + uterine cavity" },
