    "subtypes": [
      {
        "id": "ovulatory_infertility",
        "name": "Ovulatory Infertility (WHO Group I, II, III)",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "oligomenorrhea_or_amenorrhea", "weight": 5 },
          { "feature": "anovulation_confirmed", "weight": 5 },
          { "feature": "PCOS_features_or_hypogonadism", "weight": 3 }
        ],
        "management": "Ovulation induction: Clomiphene citrate, Letrozole, Gonadotropins. Metformin if PCOS. Lifestyle modification if obese."
      },
      {
        "id": "tubal_infertility",
        "name": "Tubal Factor Infertility",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
