          { "feature": "hydrosalpinx", "weight": 4 },
          { "feature": "history_of_PID_or_ectopic", "weight": 4 }
        ],
        "management": "Laparoscopic tubal surgery (salpingostomy/neosalpingostomy) or salpingectomy if hydrosalpinx. IVF (most effective for tubal factor)."
      },
      {
        "id": "unexplained_infertility",
        "name": "Unexplained Infertility",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
          { "feature": "normal_ovulation", "weight": 4 },
          { "feature": "patent_tubes", "weight": 4 },
          { "feature": "normal_semen_analysis", "weight": 4 },
          { "feature": "no_uterine_abnormality", "weight": 4 }
        ],
        "management": "Expectant for 6 months if mild. Ovarian stimulation + IUI. IVF for more severe or prolonged."
      }
    ],

