    "management": {
      "protocolReference": "ESHRE/ASRM Rotterdam Consensus / NICE Guideline",
      "pathways": [
        {
          "severity": "does_not_desire_pregnancy",
          "criteria": "cycle control, hirsutism, and metabolic management",
          "treatment": "Lifestyle: weight loss, exercise, diet. COCP (Yasmin/Dianette for anti-androgen). Metformin if insulin resistance or prediabetes. Spironolactone for hirsutism (with COCP). Topical eflornithine. Electrolysis/laser."
        },
        {
          "severity": "desires_pregnancy",
          "criteria": "ovulation induction",
          "treatment": "Weight loss first. Letrozole 2.5-7.5mg days 3-7 (first line) or Clomiphene 50-150mg days 2-6. Metformin as adjunct. If unsuccessful: gonadotropins or laparoscopic ovarian drilling. IVF if all else fails."
        }
      ]
    },

    "pathophysiology": [
      "pulsatile_gnrh_dysregulation",
      "increased_lh_secretion",
      "ovarian_theca_cell_hyperplasia",
      "insulin_resistance_hyperinsulinemia",
      "increased_ovarian_androgen_production"
    ],

