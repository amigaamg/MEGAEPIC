        { "name": "Free androgen index or testosterone", "priority": "diagnostic", "yield": 0.8, "indication": "hyperandrogenism" },
        { "name": "LH, FSH", "priority": "medium", "yield": 0.6, "indication": "LH/FSH ratio >2 common" },
        { "name": "Random/fasting glucose", "priority": "high", "yield": 0.6, "indication": "insulin resistance screening" },
        { "name": "Lipid profile", "priority": "high", "yield": 0.5, "indication": "dyslipidemia" },
        { "name": "17-hydroxyprogesterone", "priority": "medium", "yield": 0.4, "indication": "exclude CAH" },
