      "protocolReference": "ESHRE Guideline on Premature Ovarian Insufficiency",
      "pathways": [
        {
          "severity": "new_diagnosis",
          "criteria": "confirmed POI, age <40",
          "treatment": "HRT: Transdermal estradiol 50-100mcg daily + micronized progesterone 200mg 12 days/month (or Mirena IUS if appropriate). Continue until average menopause age (51). Calcium and vitamin D. Weight-bearing exercise."
        },
        {
          "severity": "fertility_desired",
          "criteria": "POI with fertility desire",
          "treatment": "Immediate fertility counseling. Donor oocyte IVF with partner sperm. Adoption/surrogacy options. Spontaneous pregnancy possible but rare (5-10%). Do not delay referral."
        },
        {
          "severity": "autoimmune_associated",
          "criteria": "POI with autoimmune condition",
          "treatment": "HRT as above. Autoimmune disease management. Screen for adrenal insufficiency (especially before surgery). Thyroid monitoring."
        }
      ]
