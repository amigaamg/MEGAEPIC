          { "feature": "fishy_odor_amine", "weight": 5 },
          { "feature": "positive_whiff_test", "weight": 5 },
          { "feature": "clue_cells_over_20_percent", "weight": 5 },
          { "feature": "pH_over_4_5", "weight": 4 }
        ],
        "management": "Metronidazole 400mg PO BID x 7 days or Metronidazole 0.75% vaginal gel for 5 days. Clindamycin cream. Treat only if symptomatic."
      },
      {
        "id": "vulvovaginal_candidiasis",
        "name": "Vulvovaginal Candidiasis (VVC)",
        "prevalenceModifier": 0.35,
        "keyFeatures": [
          { "feature": "thick_white_curd_like_discharge", "weight": 5 },
          { "feature": "intense_vulvar_itching", "weight": 5 },
          { "feature": "vulvar_erythema_and_edema", "weight": 4 },
          { "feature": "normal_pH_under_4_5", "weight": 3 },
          { "feature": "hyphae_on_KOH_mount", "weight": 5 }
        ],
        "management": "Clotrimazole 500mg PV single dose or Fluconazole 150mg PO single dose. Recurrent: maintenance fluconazole weekly. Exclude diabetes."
      },
      {
        "id": "trichomoniasis",
        "name": "Trichomoniasis",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "frothy_yellow_green_discharge", "weight": 5 },
          { "feature": "malodor", "weight": 3 },
          { "feature": "strawberry_cervix", "weight": 4 },
          { "feature": "pH_over_5", "weight": 4 },
          { "feature": "motile_trichomonads_on_wet_mount", "weight": 5 }
        ],
        "management": "Metronidazole 2g PO single dose or 400mg PO BID x 7 days. Treat partner. Avoid alcohol. Screen for other STIs."
      },
      {
        "id": "atrophic_vaginitis",
        "name": "Atrophic Vaginitis (Postmenopausal)",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
