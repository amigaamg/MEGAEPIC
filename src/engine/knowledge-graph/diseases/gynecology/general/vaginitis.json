    "management": {
      "protocolReference": "CDC STD Treatment Guidelines / RCOG Guidelines",
      "pathways": [
        {
          "severity": "bv",
          "criteria": "Amsel criteria positive or Gram stain positive",
          "treatment": "Metronidazole 400mg PO BID x 7 days. Alternative: Metronidazole 0.75% gel PV at night x 5 days. Avoid alcohol."
        },
        {
          "severity": "vvc",
          "criteria": "symptoms + microscopy positive",
          "treatment": "Clotrimazole 500mg PV single pessary or Fluconazole 150mg PO single dose. Recurrent: 150mg weekly for 6 months."
        },
        {
          "severity": "trichomoniasis",
          "criteria": "symptoms + microscopy or NAAT positive",
          "treatment": "Metronidazole 2g PO single dose or 400mg BID x 7 days. Treat partner. STI screen. Advise abstinence until treatment completed."
        }
      ]
    },

