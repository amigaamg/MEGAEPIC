    "investigations": {
      "bedside": [
        { "name": "Vaginal pH testing", "priority": "immediate", "yield": 0.8, "indication": "normal <4.5, BV >4.5" },
        { "name": "Whiff test (amine test)", "priority": "immediate", "yield": 0.8, "indication": "positive in BV and trich" }
      ],
      "laboratory": [
        { "name": "Wet mount microscopy (saline)", "priority": "immediate", "yield": 0.8, "indication": "clue cells, trichomonads" },
        { "name": "10% KOH mount", "priority": "immediate", "yield": 0.8, "indication": "hyphae for Candida" },
        { "name": "Gram stain (Nugent score)", "priority": "medium", "yield": 0.85, "indication": "BV diagnosis" },
        { "name": "NAAT for Trichomonas", "priority": "medium", "yield": 0.9, "indication": "more sensitive than wet mount" },
        { "name": "High vaginal swab culture", "priority": "medium", "yield": 0.6, "indication": "if treatment failure" }
      ],
      "imaging": []
