          { "feature": "dryness_burning", "weight": 5 },
          { "feature": "thin_watery_discharge", "weight": 3 },
          { "feature": "no_infection_on_swab", "weight": 4 }
        ],
        "management": "Vaginal estrogen cream (conjugated estrogens 0.5g nightly x 2 weeks then twice weekly). Lubricants. Moisturizers (Replens)."
      }
    ],

    "mimics": [
