      "pathways": [
        {
          "severity": "mild_moderate",
          "criteria": "no abscess, mild symptoms, tolerating oral, no fever >38",
          "treatment": "Outpatient: Ceftriaxone 500mg IM single dose + Doxycycline 100mg PO BID x 14 days + Metronidazole 400mg PO BID x 14 days. Partner treatment. Abstinence until treatment complete."
