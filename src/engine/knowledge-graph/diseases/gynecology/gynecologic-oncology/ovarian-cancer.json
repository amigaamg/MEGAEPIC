    "management": {
      "protocolReference": "NCCN / FIGO Guidelines for Ovarian Cancer",
      "pathways": [
        {
          "severity": "early_stage_I_IIA",
          "criteria": "confined to ovary/pelvis, no ascites",
          "treatment": "Comprehensive surgical staging: TH+BSO+omentectomy+lymphadenectomy+peritoneal biopsies. Fertility-sparing (USO) for stage IA grade 1. Adjuvant chemotherapy (Carboplatin + Paclitaxel x 3-6 cycles) for high-risk early stage."
        },
        {
          "severity": "advanced_stage_III_IV",
          "criteria": "peritoneal spread, distant metastases",
          "treatment": "Primary cytoreductive surgery (if feasible, optimal <1cm residual). If not optimal candidate: neoadjuvant chemotherapy (3-4 cycles) then interval debulking. Adjuvant systemic therapy (Carboplatin + Paclitaxel x 6). PARP inhibitors for BRCA. Bevacizumab."
        },
        {
          "severity": "BRCA_associated",
          "criteria": "BRCA1/2 mutation carrier",
          "treatment": "As per stage. PARP inhibitor maintenance (Olaparib, Niraparib). Risk-reducing salpingo-oophorectomy at age 35-40 (or after childbearing). Family counseling and cascade testing."
        }
      ]
