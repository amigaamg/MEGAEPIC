    "management": {
      "protocolReference": "NCCN / FIGO Guidelines for Vulvar Cancer",
      "pathways": [
        {
          "severity": "early_stage_I_II",
          "criteria": "T1-T2, no nodal mets, <4cm",
          "treatment": "Wide local excision (1-2cm margins) or radical vulvectomy (if multifocal). Sentinel node biopsy for unifocal <4cm lesions. Ipsilateral inguinofemoral lymphadenectomy if sentinel positive."
        },
        {
          "severity": "locally_advanced_III",
          "criteria": "nodal involvement, T3 disease",
          "treatment": "Radical vulvectomy + bilateral inguinofemoral lymphadenectomy. Adjuvant radiotherapy (chemoradiation) to vulva and groins if multiple nodes or extracapsular spread."
        },
        {
          "severity": "stage_IV",
          "criteria": "fixed/ulcerated groin nodes, pelvic sidewall involvement, distant mets",
          "treatment": "Neoadjuvant chemoradiotherapy then surgical resection if resectable. Palliative chemotherapy (Cisplatin-based) + radiotherapy for unresectable or metastatic disease."
        }
      ]
    },

