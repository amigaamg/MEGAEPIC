      "pathways": [
        {
          "severity": "stage_1_2_asymptomatic",
          "criteria": "POP-Q stage I-II, minimal or no symptoms",
          "treatment": "Reassurance. Observation. Lifestyle advice (weight loss, avoid heavy lifting). PFMT. Estrogen cream if atrophic."
        },
        {
          "severity": "stage_2_3_symptomatic",
          "criteria": "bothersome symptoms, desire non-surgical",
          "treatment": "Vaginal pessary (ring or cube). Estrogen cream for vaginal health. PFMT. Regular follow-up for pessary care."
        },
        {
          "severity": "stage_3_4_or_failed_pessary",
          "criteria": "severe prolapse, failed medical therapy",
          "treatment": "Surgery: Anterior colporrhaphy, posterior colporrhaphy, vaginal hysterectomy + apical suspension, sacrocolpopexy (laparoscopic/robotic). Mesh use restricted (NICE guidance). Risk of recurrence and complications discussed."
        }
      ]
    },

