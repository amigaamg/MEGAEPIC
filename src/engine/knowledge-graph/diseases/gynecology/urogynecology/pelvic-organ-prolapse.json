          { "feature": "vaginal_apex_visible_on_exam", "weight": 5 }
        ],
        "management": "Pessary. Surgery: Hysteropexy (uterine sparing) or vaginal hysterectomy + apical suspension (sacrospinous ligament fixation, uterosacral ligament suspension, sacrocolpopexy)."
