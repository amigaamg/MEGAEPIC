    "subtypes": [
      {
        "id": "stress_urinary_incontinence",
        "name": "Stress Urinary Incontinence (SUI)",
        "prevalenceModifier": 0.5,
        "keyFeatures": [
          { "feature": "leakage_with_exertion", "weight": 5 },
          { "feature": "positive_cough_stress_test", "weight": 5 },
          { "feature": "urethral_hypermobility", "weight": 4 },
          { "feature": "no_urge_symptoms", "weight": 3 }
        ],
        "management": "Pelvic floor muscle training (PFMT) first line. Lifestyle: weight loss, smoking cessation. Duloxetine (SNRI). Surgical: Mid-urethral sling (TVT/TOT), Burch colposuspension, bulking agents."
      },
      {
        "id": "urge_urinary_incontinence",
        "name": "Urge Urinary Incontinence (Overactive Bladder)",
        "prevalenceModifier": 0.35,
        "keyFeatures": [
          { "feature": "sudden_urge_with_leakage", "weight": 5 },
          { "feature": "urinary_frequency_eight_or_more", "weight": 4 },
          { "feature": "nocturia_two_or_more", "weight": 4 },
          { "feature": "negative_cough_stress_test", "weight": 3 }
        ],
        "management": "Bladder training (timed voiding). PFMT. Anticholinergics (Oxybutynin, Tolterodine, Solifenacin). Mirabegron (beta-3 agonist). Botox intra-detrusor injections. Sacral neuromodulation."
      },
      {
        "id": "mixed_urinary_incontinence",
        "name": "Mixed Urinary Incontinence",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "both_stress_and_urge_components", "weight": 5 },
          { "feature": "complex_symptomatology", "weight": 4 },
          { "feature": "treat_dominant_component_first", "weight": 3 }
        ],
        "management": "Treat the most bothersome component first. Combined approach: PFMT + bladder training + lifestyle. Surgery for stress component if persistent."
      }
    ],

