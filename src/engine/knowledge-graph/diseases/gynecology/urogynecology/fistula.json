        "lagDays": [0, 365],
        "severityBoost": 0.2,
        "clues": ["social_isolation", "divorce_abandonment"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "medium",
    "diagnosticClues": ["continuous_vaginal_leakage", "history_of_surgery_trauma", "positive_dye_test"],
    "exclusionClues": ["intermittent_urinary_incontinence", "normal_vaginal_fluid"]
  }
