{
  "disease": {
    "id": "fistula",
    "name": "Obstetric-Gynecologic Fistula (Vesicovaginal / Rectovaginal)",
    "system": "GYN",
    "agePeak_months": [240, 480],
    "note": "Abnormal communication between the genital tract and urinary tract (vesicovaginal fistula) or rectum (rectovaginal fistula). Most commonly due to obstructed labor, surgical injury, radiotherapy, or malignancy.",
    "prevalenceWeight": 0.005,
    "syndromeTags": ["pelvic_floor_disorder", "urogynecology", "fecal_incontinence"],

    "severityAssessment": {
      "immediateDangerSigns": [
        { "sign": "sepsis_from_perineal_infection", "weight": 8 },
        { "sign": "renal_failure_from_obstruction", "weight": 7 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "large_fistula_over_4cm", "weight": 7 },
          { "sign": "radiotherapy_related_fistula", "weight": 8 },
          { "sign": "multiple_recurrent_fistula", "weight": 7 },
          { "sign": "complete_urinary_incontinence", "weight": 6 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "Radiotherapy-related, large, or recurrent fistula -> SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "constant_leakage_of_urine_from_vagina", "weight": 5, "note": "Vesicovaginal fistula" },
      { "symptomId": "passage_of_flatus_or_stool_per_vaginam", "weight": 5, "note": "Rectovaginal fistula" },
      { "symptomId": "continuous_leak_uncontrolled", "weight": 4 },
      { "symptomId": "absence_of_urge_sensation", "weight": 3 },
      { "symptomId": "chafing_irritation_of_vulva", "weight": 3 },
      { "symptomId": "recurrent_urinary_tract_infections", "weight": 3 },
      { "symptomId": "history_of_prolonged_obstructed_labor", "weight": 4 },
      { "symptomId": "history_of_pelvic_surgery_especially_hysterectomy", "weight": 4 },
      { "symptomId": "history_of_pelvic_radiotherapy", "weight": 4 },
      { "symptomId": "pelvic_malignancy", "weight": 3 },
      { "symptomId": "social_isolation_depression", "weight": 3 }
    ],

    "examFeatures": [
      { "signId": "pooling_of_urine_in_vagina", "baseWeight": 5, "doubleWeight": true },
      { "signId": "visible_fistula_tract_on_speculum", "baseWeight": 5 },
      { "signId": "methylene_blue_test_positive", "baseWeight": 5 },
      { "signId": "vaginal_soiling_or_stool", "baseWeight": 4 },
      { "signId": "vaginal_excoriation_and_inflammation", "baseWeight": 3 },
      { "signId": "palpable_fistula_on_vaginal_exam", "baseWeight": 4 },
      { "signId": "digital_rectal_exam_reveals_defect", "baseWeight": 3 },
      { "signId": "urethral_or_bladder_neck_involvement", "baseWeight": 3 }
    ],

    "riskFactors": [
      { "id": "prolonged_obstructed_labor", "multiplier": 10.0 },
      { "id": "abdominal_hysterectomy", "multiplier": 5.0 },
      { "id": "pelvic_radiotherapy", "multiplier": 8.0 },
      { "id": "pelvic_malignancy_cervical_vaginal", "multiplier": 5.0 },
      { "id": "episiotomy_or_third_degree_tear", "multiplier": 3.0 },
      { "id": "inflammatory_bowel_disease_crohns", "multiplier": 4.0 },
      { "id": "previous_pelvic_surgery_multiple", "multiplier": 2.0 },
      { "id": "forceps_delivery", "multiplier": 2.0 }
    ],

    "subtypes": [
      {
        "id": "vesicovaginal_fistula",
        "name": "Vesicovaginal Fistula (VVF)",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
          { "feature": "continuous_urinary_leakage_per_vaginam", "weight": 5 },
          { "feature": "normal_voiding_still_present", "weight": 3 },
          { "feature": "positive_methylene_blue_test", "weight": 5 },
          { "feature": "tissue_necrosis_or_surgical_injury", "weight": 4 }
        ],
        "management": "Conservative: Catheter drainage for small fistula (6-8 weeks). Surgical: Transvaginal or transabdominal repair (Latzko, O'Conor). Timing: 3-6 months after injury or after radiotherapy."
      },
      {
        "id": "rectovaginal_fistula",
        "name": "Rectovaginal Fistula (RVF)",
        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "flatus_or_stool_per_vaginam", "weight": 5 },
          { "feature": "fecal_incontinence", "weight": 4 },
          { "feature": "perineal_irritation_chafing", "weight": 3 },
          { "feature": "visible_mucosa_on_vaginal_exam", "weight": 4 }
        ],
        "management": "Surgical repair: Transvaginal, transanal, or transperineal approach with layered closure +/- interposition graft (Martius graft, gracilis flap). Diverting colostomy for large or radiotherapy-related fistulas."
      },
      {
        "id": "ureterovaginal_fistula",
        "name": "Ureterovaginal Fistula",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
          { "feature": "continuous_leak_after_hysterectomy", "weight": 5 },
          { "feature": "preserved_voiding_volume", "weight": 3 },
          { "feature": "positive_indigo_carmine_or_IVP", "weight": 5 }
        ],
        "management": "Ureteral stenting (initial). If fails: ureteric reimplantation (ureteroneocystostomy). Percutaneous nephrostomy if obstruction."
      }
    ],

    "mimics": [
      {
        "diseaseId": "severe_urinary_incontinence",
        "discriminators": ["intermittent_leak", "urge_symptoms", "no_tract_on_exam"]
      },
      {
        "diseaseId": "bacterial_vaginosis_discharge",
        "discriminators": ["no_history", "negative_dye_test", "odor_not_urine_or_stool"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Methylene blue test (tampon test)", "priority": "immediate", "yield": 0.9, "indication": "confirm VVF and location" },
        { "name": "Double dye test (phenazopyridine + methylene blue)", "priority": "high", "yield": 0.85, "indication": "differentiate VVF from UVF" }
      ],
      "laboratory": [
        { "name": "Urinalysis and culture", "priority": "high", "yield": 0.5, "indication": "recurrent UTI" },
        { "name": "Urea and creatinine", "priority": "medium", "yield": 0.4, "indication": "exclude obstructive uropathy" },
        { "name": "Biopsy of fistula tract", "priority": "medium", "yield": 0.6, "indication": "if malignancy suspected" }
      ],
      "imaging": [
        { "name": "Cystoscopy + retrograde pyelogram", "priority": "high", "yield": 0.9, "indication": "locate VVF, assess ureters" },
        { "name": "IVU (intravenous urogram)", "priority": "medium", "yield": 0.7, "indication": "ureteric involvement" },
        { "name": "CT urogram", "priority": "medium", "yield": 0.8, "indication": "modern alternative to IVU" },
        { "name": "MRI pelvis", "priority": "medium", "yield": 0.7, "indication": "fistula delineation, especially if radiotherapy" },
        { "name": "Fistulogram", "priority": "low", "yield": 0.6, "indication": "delineate RVF tract" }
      ]
    },

    "management": {
      "protocolReference": "RCOG / FIGO Guidelines for Fistula Repair",
      "pathways": [
        {
          "severity": "small_vvf_under_5mm",
          "criteria": "small simple fistula, recent surgical injury",
          "treatment": "Continuous catheter drainage (Foley 18-20Fr) for 6-8 weeks. Anticholinergics to reduce detrusor spasms. Spontaneous closure rate 15-20%. If fails, surgical repair."
        },
        {
          "severity": "vvf_surgical_repair",
          "criteria": "failed conservative or larger fistula",
          "treatment": "Surgical repair after 3-6 months (tissue healing). Transvaginal approach (Latzko, layer closure) for low fistulas. Transabdominal (O'Conor) for high/complex. Interposition graft (Martius flap) for radiotherapy-related."
        },
        {
          "severity": "rvf_surgical",
          "criteria": "confirmed rectovaginal fistula",
          "treatment": "Layered closure (vaginal + rectal mucosa + sphincter if involved). Episiotomy or perineal body repair. Martius or gracilis graft if complex. Diverting colostomy for large or radiated fistula."
        },
        {
          "severity": "ureterovaginal",
          "criteria": "confirmed ureteric fistula",
          "treatment": "Ureteric stent (retrograde) for 6 weeks. If fails: ureteric reimplantation with psoas hitch or Boari flap. Percutaneous nephrostomy initially if obstructed."
        }
      ]
    },

    "pathophysiology": [
      "pressure_necrosis_from_prolonged_labor",
      "surgical_devascularization",
      "radiation_endarteritis",
      "tumor_invasion",
      "infection_abscess"
    ],

    "complications": [
