  "investigations": {
    "imaging": [
      {
        "name": "Chest X-ray (PA or AP upright)",
        "findings": ["visible pleural line", "absent lung markings", "lung collapse", "mediastinal shift (tension)"],
        "indication": "all suspected"
      },
      {
        "name": "Chest CT",
        "indication": "complex, recurrent, or to guide management"
      }
    ],
    "bedside": [
      "SpO2 continuous monitoring",
      "clinical airway and breathing assessment (do NOT delay intervention for imaging in tension)"
    ]
  },
  "managementProtocols": [
    {
      "condition": "mild",
      "steps": [
        "Small pneumothorax (<20%) without respiratory distress: observe with high-flow oxygen",
        "Repeat CXR in 4-6 hours to confirm stability",
        "Monitor: SpO2 continuous, RR, HR Q4H",
        "Avoid positive pressure ventilation if possible"
      ]
    },
    {
      "condition": "moderate",
      "steps": [
        "Needle decompression: 2nd ICS midclavicular line with 14G/16G cannula if enlarging or distress",
        "Definitive: Chest tube insertion (4th-5th ICS midaxillary line, size 12-16F for children)",
        "Connect to underwater seal drainage (no suction initially)",
        "CXR to confirm tube position and lung re-expansion",
        "Monitor: chest drain output, air leak, SpO2, RR, BP Q1H"
      ]
    },
    {
      "condition": "severe (TENSION PNEUMOTHORAX)",
      "steps": [
        "EMERGENCY: Do NOT wait for imaging – immediate needle decompression",
        "Insert large-bore cannula into 2nd ICS midclavicular line (or 4th/5th ICS anterior axillary line)",
        "Immediate chest tube insertion after decompression",
        "High-flow oxygen (target SpO2 >94%)",
        "IV fluids if hypotensive",
        "Monitor continuously: SpO2, BP, HR, tracheal position, chest drain output",
        "Prepare for thoracotomy if persistent air leak >5-7 days"
      ]
    }
  ],
  "responseToTreatment": {
    "expected": "lung re-expansion and clinical improvement within hours after drainage",
    "warningSignsFailure": [
      "persistent air leak >48 hours",
      "no lung re-expansion on CXR",
      "worsening hypoxia or respiratory distress",
      "recurrent pneumothorax after tube removal"
    ],
    "escalation": "Consider bronchopleural fistula, underlying cavitary lung disease (TB, bullae), or need for surgical pleurodesis"
