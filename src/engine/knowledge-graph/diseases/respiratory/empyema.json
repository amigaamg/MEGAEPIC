  "managementProtocols": [
    {
      "condition": "moderate",
      "steps": [
        "IV antibiotics: Ceftriaxone 80 mg/kg IV OD (max 2g) + Metronidazole 7.5 mg/kg IV TDS",
        "Chest tube drainage under ultrasound guidance",
        "Analgesia: Paracetamol 15 mg/kg Q6H PRN",
        "Monitor: drain output, SpO2, vital signs Q4H"
      ]
    },
    {
      "condition": "severe",
      "steps": [
        "IV antibiotics: Ceftriaxone + Metronidazole (adjust based on culture when available)",
        "Chest tube drainage (large bore) — consider intrapleural fibrinolytics (urokinase) if loculated",
        "IV fluids to maintain hydration",
        "Nutritional support (high protein)",
        "If no improvement in 48–72 h: refer for VATS (video-assisted thoracoscopic surgery) or surgical decortication",
        "Monitor: drain output hourly, SpO2 continuous, RR, HR, temperature Q4H"
      ]
    }
  ],
  "failureNode": {
    "description": "If no clinical improvement in 48–72 hours (persistent fever, no lung re-expansion, thick loculated fluid)",
