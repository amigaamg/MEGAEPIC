      "pathways": [
        {
          "severity": "mild",
          "criteria": "P/F 200-300, bilateral infiltrates on CXR",
          "treatment": "Treat underlying cause. Lung-protective ventilation if intubated (TV 6 mL/kg PBW, plateau pressure <30). Conservative fluid strategy."
        },
        {
          "severity": "moderate-severe",
          "criteria": "P/F <200",
          "treatment": "Intubation and LPVS. PEEP according to PEEP-FiO2 table. Prone positioning for P/F <150. Neuromuscular blockade for 48h if severe. Rescue therapies if refractory."
