    "investigations": {
      "bedside": [
        { "name": "PEFR (Peak Expiratory Flow Rate)", "priority": "immediate", "yield": 0.85, "indication": "severity assessment, <33% predicted = severe" },
        { "name": "Pulse oximetry", "priority": "immediate", "yield": 0.9, "indication": "continuous monitoring" }
      ],
      "laboratory": [
        { "name": "ABG (PaO2, PaCO2, pH)", "priority": "immediate", "yield": 0.9, "indication": "life-threatening: normal/high PaCO2 = exhaustion" },
        { "name": "FBC, CRP", "priority": "high", "yield": 0.4, "indication": "infection marker" },
        { "name": "Serum potassium, magnesium", "priority": "high", "yield": 0.4, "indication": "metabolic assessment" }
      ],
      "imaging": [
        { "name": "Chest X-ray", "priority": "high", "yield": 0.5, "indication": "pneumothorax, pneumonia, pneumomediastinum" }
      ]
    },

    "management": {
      "protocolReference": "BTS/SIGN or GINA Guidelines for Acute Asthma",
      "pathways": [
        {
          "severity": "severe (ICU criteria)",
          "criteria": "PEFR 33-50%, unable to complete sentences, RR >25, HR >110",
          "treatment": "High-flow O2. Back-to-back salbutamol nebulizers (5mg). IV hydrocortisone 200mg or prednisolone 40-50mg. Ipratropium 0.5mg. Consider IV magnesium sulfate 2g. IV salbutamol or aminophylline if life-threatening."
        },
        {
          "severity": "life-threatening / near-fatal",
          "criteria": "silent chest, cyanosis, exhaustion, PaCO2 normal/elevated, PEFR <33%",
          "treatment": "Immediate ICU. Continuous salbutamol nebulization. IV magnesium. IV salbutamol. Consider ketamine. Intubation if deteriorating (low threshold). Lung-protective ventilation. Sedation + paralysis."
        }
      ]
    },

    "pathophysiology": [
