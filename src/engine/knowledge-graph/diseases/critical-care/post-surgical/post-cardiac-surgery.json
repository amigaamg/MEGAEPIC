    "management": {
      "protocolReference": "STS/SCA Guidelines for Post-Cardiac Surgery ICU Management",
      "pathways": [
        {
          "severity": "low cardiac output syndrome",
          "criteria": "CI <2.0, hypotension, elevated lactate, cool peripheries",
          "treatment": "Optimize preload. Inotropes: dobutamine or milrinone. Vasopressors: norepinephrine if vasoplegia. IABP if refractory. TEE to exclude tamponade. Atrial pacing for bradycardia."
        },
        {
          "severity": "post-op bleeding / tamponade",
          "criteria": "chest tube output >200 mL/h, hypotension, rising CVP, echo shows tamponade",
          "treatment": "Reverse heparin (protamine). Check ACT. Transfuse per protocol. Re-exploration if massive or tamponade. TEG-guided component therapy. Evans blue if chyle leak."
        }
      ]
    },

