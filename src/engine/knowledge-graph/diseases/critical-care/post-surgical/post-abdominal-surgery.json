    "investigations": {
      "bedside": [
        { "name": "Intra-abdominal pressure (IAP) measurement", "priority": "high", "yield": 0.8, "indication": "suspected ACS, IAP >12 mmHg" }
      ],
      "laboratory": [
        { "name": "FBC, CRP, Procalcitonin", "priority": "high", "yield": 0.6, "indication": "infection monitoring" },
        { "name": "Lactate, ABG", "priority": "high", "yield": 0.7, "indication": "hypoperfusion" },
        { "name": "U&E, Cr", "priority": "high", "yield": 0.5, "indication": "renal function" }
      ],
      "imaging": [
        { "name": "CT Abdomen with IV and oral contrast", "priority": "high", "yield": 0.85, "indication": "suspected leak, abscess, collection" }
      ]
    },

    "management": {
      "protocolReference": "WSES / Enhanced Recovery After Surgery (ERAS) Guidelines",
      "pathways": [
        {
          "severity": "routine post-op ICU",
          "criteria": "hemodynamically stable, no signs of leak or ACS",
          "treatment": "Fluid resuscitation (balanced crystalloid). Early enteral nutrition if tolerated. Pain control (epidural recommended). Antibiotics if peritonitis. Monitor IAP. Ambulation asap. DVT prophylaxis."
        },
        {
          "severity": "suspected complication",
          "criteria": "tachycardia, fever, increasing abdominal pain, rising WBC/lactate, or elevated IAP",
          "treatment": "CT abdomen. Broad-spectrum antibiotics (piperacillin-tazobactam or meropenem). Surgical re-exploration if leak/abscess/ischemia. Decompress abdomen if ACS. ICU organ support."
        }
      ]
    },

    "pathophysiology": [
