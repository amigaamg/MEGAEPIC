    "system": "critical_care",
    "agePeak_months": [0, 960],
    "note": "Elevated pressure within the skull. Causes: TBI, stroke, tumor, meningitis, hepatic encephalopathy. ICP >22 mmHg requires treatment. Cerebral perfusion pressure (CPP = MAP - ICP) target 60-70.",
    "prevalenceWeight": 0.4,
    "syndromeTags": ["neuro_critical_care", "intracranial_hypertension", "brain_injury"],

    "severityAssessment": {
