      { "signId": "papilledema", "baseWeight": 4 },
      { "signId": "pupillary_abnormalities", "baseWeight": 5, "doubleWeight": true },
      { "signId": "cushing_triad_hypertension_bradycardia_irregular_breathing", "baseWeight": 5 },
      { "signId": "motor_posturing", "baseWeight": 4 },
      { "signId": "sixth_nerve_palsy", "baseWeight": 3 }
    ],

