    ],

    "subtypes": [
      {
        "id": "intracranial_hypertension_from_tbi",
        "name": "Post-TBI Raised ICP",
        "prevalenceModifier": 0.5,
        "keyFeatures": [
          { "feature": "trauma_history", "weight": 5 },
          { "feature": "ct_findings_edema_contusion_hematoma", "weight": 5 },
          { "feature": "elevated_icp_on_monitoring", "weight": 5 }
        ],
        "management": "ICP monitoring (EVD or bolt). Elevate head 30 degrees. Sedation (propofol/midazolam). CSF drainage if EVD in situ. Osmotherapy (mannitol 0.5-1g/kg or hypertonic saline). Decompressive craniectomy if refractory."
      },
      {
        "id": "raised_icp_from_fulminant_hepatic_failure",
        "name": "Raised ICP from Fulminant Hepatic Failure",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
          { "feature": "liver_failure_acute", "weight": 5 },
          { "feature": "asterixis_encephalopathy", "weight": 4 },
          { "feature": "elevated_ammonia", "weight": 4 }
        ],
        "management": "ICP monitoring. Mannitol/hypertonic saline. Barbiturate coma if refractory. Lactulose/rifaximin for ammonia. Liver transplant evaluation."
      }
    ],

    "mimics": [
      {
        "diseaseId": "status_epilepticus",
        "discriminators": ["ictal_activity_on_eeg", "responding_to_antiepileptics"]
      },
      {
        "diseaseId": "locked_in_syndrome",
        "discriminators": ["aware_but_paralyzed", "vertical_eye_movement_preserved"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "ICP monitoring (EVD or parenchymal bolt)", "priority": "gold_standard", "yield": 0.95, "indication": "if GCS <=8 and risk of raised ICP" }
      ],
      "laboratory": [
        { "name": "ABG (PaCO2 target 35-40)", "priority": "high", "yield": 0.7, "indication": "PaCO2 affects cerebral blood flow" },
        { "name": "Serum Na and Osmolality", "priority": "high", "yield": 0.6, "indication": "guide hypertonic saline therapy" }
      ],
      "imaging": [
        { "name": "CT Head (non-contrast)", "priority": "immediate", "yield": 0.85, "indication": "mass effect, midline shift, hemorrhage" },
        { "name": "CT/MRI brain with contrast", "priority": "medium", "yield": 0.8, "indication": "tumor, infection, abscess" }
      ]
    },

    "management": {
      "protocolReference": "Brain Trauma Foundation / Neurocritical Care Society Guidelines",
      "pathways": [
        {
          "severity": "mild-moderate (ICP 22-30)",
          "criteria": "ICP 22-30 mmHg, CPP >60, no herniation signs",
          "treatment": "Elevate head 30 degrees. Sedation (propofol). CSF drainage if EVD. Osmotherapy (hypertonic saline 3% 30-60mL bolus). Maintain PaCO2 35-40. Normothermia."
        },
        {
          "severity": "severe-refractory (ICP >30 or herniation)",
          "criteria": "ICP >30, CPP <60, or herniation signs",
          "treatment": "Increase sedation/paralysis. Bolus hypertonic saline 23.4%. Therapeutic hyperventilation (PaCO2 30-35) short-term. Barbiturate coma. Decompressive craniectomy. Targeted temperature management."
        }
      ]
    },

    "pathophysiology": [
