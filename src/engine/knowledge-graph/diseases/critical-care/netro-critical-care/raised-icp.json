        { "sign": "decerebrate_or_decorticate_posturing", "weight": 9 },
        { "sign": "loss_of_brainstem_reflexes", "weight": 10 }
      ],
      "severeCriteria": {
        "anyDangerSign": true
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "ICP <22 -> mild-moderate; 22-30 -> severe; >30 with signs -> critical"
    },

    "historyFeatures": [
      { "symptomId": "headache_worsening", "weight": 4 },
      { "symptomId": "nausea_vomiting_projectile", "weight": 3 },
      { "symptomId": "decreased_consciousness", "weight": 5 },
      { "symptomId": "blurred_double_vision_diplopia", "weight": 3 },
      { "symptomId": "seizures", "weight": 3 },
      { "symptomId": "traumatic_brain_injury_or_stroke_or_tumor", "weight": 5 }
    ],

    "examFeatures": [
