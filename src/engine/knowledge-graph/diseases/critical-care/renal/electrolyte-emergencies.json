        { "sign": "respiratory_muscle_weakness", "weight": 8 }
      ],
      "severeCriteria": {
        "anyDangerSign": true
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "Life-threatening ECG changes/seizures/coma -> CRITICAL; severe lab abnormalities -> MODERATE-SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "palpitations_chest_discomfort", "weight": 3 },
