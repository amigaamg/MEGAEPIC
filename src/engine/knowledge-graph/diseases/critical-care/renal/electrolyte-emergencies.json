    "name": "Electrolyte Emergencies",
    "system": "critical_care",
    "agePeak_months": [0, 960],
    "note": "Life-threatening derangements of potassium, sodium, calcium, magnesium, and phosphate. Require immediate recognition and correction in ICU setting.",
    "prevalenceWeight": 0.5,
    "syndromeTags": ["metabolic_emergency", "electrolyte_disorder", "critical_care"],

