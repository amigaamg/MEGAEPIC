      { "symptomId": "seizures", "weight": 4 },
      { "symptomId": "nausea_vomiting", "weight": 2 },
      { "symptomId": "polyuria_or_oliguria", "weight": 3 },
      { "symptomId": "history_of_renal_disease_or_diuretics", "weight": 3 }
    ],

    "examFeatures": [
      { "signId": "ecg_changes_arrhythmia", "baseWeight": 5 },
      { "signId": "altered_consciousness", "baseWeight": 4 },
