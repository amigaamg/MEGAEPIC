    "management": {
      "protocolReference": "Surviving Sepsis Campaign Hour-1 Bundle 2021",
      "pathways": [
        {
          "severity": "hour-1 bundle",
          "criteria": "suspected sepsis + qSOFA >=2 or lactate >2 or organ dysfunction",
          "treatment": "1. Measure lactate (re-measure if >2). 2. Blood cultures before antibiotics. 3. Broad-spectrum antibiotics within 1 hour. 4. Start 30 mL/kg crystalloid for hypotension/lactate >=4. 5. Vasopressors if hypotensive during or after fluids (MAP target >=65)."
        },
        {
          "severity": "septic shock (post-bundle)",
          "criteria": "persistent hypotension despite fluids, lactate >2",
          "treatment": "Norepinephrine first-line. Additional fluids guided by dynamic assessment. Central line. Consider hydrocortisone if vasopressor-dependent. ICU admission. Serial lactate clearance. Source control within 6-12 hours."
        }
      ]
    },

