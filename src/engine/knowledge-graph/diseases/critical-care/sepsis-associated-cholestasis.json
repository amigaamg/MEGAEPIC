{
  "disease": {
    "id": "sepsis_associated_cholestasis",
    "name": "Sepsis-Associated Cholestasis",
    "system": "critical_care",
    "agePeak_months": [0, 1080],
    "note": "Jaundice occurring in the setting of severe infection or sepsis without direct hepatic infection. Caused by inflammatory cytokines impairing bile acid transport at the canalicular membrane. Frequently seen in ICU patients. Early jaundice in sepsis is a marker of severity and is associated with higher mortality. Resolves with treatment of the underlying infection. Also called 'septic jaundice' or 'cholestasis of sepsis'.",
    "prevalenceWeight": 0.15,
    "syndromeTags": ["sepsis", "cholestasis", "jaundice", "icu", "liver_dysfunction"],

