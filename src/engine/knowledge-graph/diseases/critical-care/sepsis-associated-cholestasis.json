    "management": {
      "protocolReference": "Surviving Sepsis Campaign Guidelines; Critical Care Hepatology",
      "pathways": [
        {
          "severity": "all_cases",
          "criteria": "Sepsis-associated cholestasis at any severity",
          "treatment": "Treat the underlying infection: appropriate antibiotics per cultures and source control (drainage of abscess, removal of infected catheter, etc.). Resuscitate per sepsis guidelines (fluids, vasopressors). No specific treatment for cholestasis itself. Jaundice improves as infection resolves. Avoid hepatotoxic drugs. Biliary drainage not indicated. UDCA has no proven role. Monitor bilirubin as a marker of sepsis resolution — falling bilirubin indicates resolving infection and improving organ function."
        }
      ]
    },

