        { "sign": "rapidly_rising_bilirubin_greater_than_5", "weight": 7 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "icu_admission": true,
        "vasopressor_requirement": true
      },
      "nonSevereCriteria": {
        "mild_sepsis": true,
        "no_organ_failure": true,
        "mild_hyperbilirubinemia": true
      },
      "severityLabel": "Sepsis severity determines outcome; cholestasis is a marker of severity"
    },

    "historyFeatures": [
