    ],
    "syndromeTags": ["mood_disorder", "psychiatric_condition", "chronic_mental_illness"],
    "mustNotMiss": true,
    "diagnosticClues": ["episodic mood disturbance + periods of mania/hypomania + depressive episodes"],
    "exclusionClues": ["mood disturbance solely due to substance", "mood disturbance solely due to medical condition"],
    "investigations": {
      "bedside": [
        { "name": "Mental state examination", "priority": "immediate", "yield": 0.9, "indication": "all suspected — mood, speech, thought form, perception, cognition, insight" },
        { "name": "Suicide risk assessment", "priority": "immediate", "yield": 1.0, "indication": "all — plans, intent, means, protective factors" },
        { "name": "Mood disorder questionnaire (MDQ)", "priority": "screening", "yield": 0.7, "indication": "all suspected" },
        { "name": "Young Mania Rating Scale (YMRS)", "priority": "screening", "yield": 0.8, "indication": "assess mania severity" },
        { "name": "Hamilton Depression Rating Scale (HAM-D)", "priority": "screening", "yield": 0.8, "indication": "assess depressive severity" }
      ],
      "laboratory": [
        { "name": "Thyroid function tests", "priority": "high", "yield": 0.4, "indication": "rule out thyroid disorder mimicking mood symptoms" },
        { "name": "Full blood count", "priority": "routine", "yield": 0.2, "indication": "baseline before mood stabilisers" },
        { "name": "Serum electrolytes", "priority": "routine", "yield": 0.2, "indication": "baseline, especially before lithium" },
        { "name": "Serum creatinine", "priority": "high", "yield": 0.3, "indication": "baseline and monitoring for lithium therapy" },
        { "name": "Liver function tests", "priority": "high", "yield": 0.3, "indication": "baseline before valproate" },
        { "name": "Urine toxicology screen", "priority": "high", "yield": 0.5, "indication": "exclude substance-induced mood disorder" },
        { "name": "ECG", "priority": "high", "yield": 0.3, "indication": "baseline before starting antipsychotics or lithium" },
        { "name": "Pregnancy test", "priority": "if_female_reproductive_age", "yield": 0.5, "indication": "before starting valproate (teratogenic)" }
      ],
      "imaging": [
        { "name": "CT head or MRI brain", "priority": "if_atypical", "yield": 0.2, "indication": "first episode after age 40, focal signs, atypical features" }
      ]
    },
    "management": {
      "protocolReference": "International Society for Bipolar Disorders (ISBD) Guidelines, 2024",
      "pathways": [
        {
          "severity": "acute_mania",
          "criteria": "Elevated mood + 3+ manic symptoms lasting >1 week, significant functional impairment",
          "treatment": [
            "First-line: Lithium carbonate 300-600 mg PO TID (target serum level 0.6-1.2 mmol/L)",
            "Alternative/adjunct: Valproate 20 mg/kg/day PO (target level 50-125 mcg/mL)",
            "Severe agitation: add Olanzapine 5-10 mg PO OD or Risperidone 2-4 mg PO OD",
            "If severe or psychotic features: ECT (electroconvulsive therapy) considered",
            "Monitor: lithium levels Q1-2 weeks, renal function, thyroid function Q3 months",
            "Stop or taper antidepressants if present (can precipitate mania)",
            "Admit for safety if at risk to self or others"
          ],
          "reassessment": "Daily in acute phase; reassess symptom severity and side effects"
        },
        {
          "severity": "acute_depression",
          "criteria": "Depressed mood + 5+ depressive symptoms, functional impairment, no/hypomanic symptoms",
          "treatment": [
            "First-line: Quetiapine 150-300 mg PO nocte or Lamotrigine 25-100 mg/day PO (titrate slowly)",
            "Alternative: Lithium (level 0.6-1.2 mmol/L) or Valproate, but response may be slower",
            "Add psychotherapy: CBT, interpersonal therapy, family-focused therapy",
            "Avoid antidepressant monotherapy (risk of switching to mania)",
            "If refractory: consider ECT",
            "Suicide risk assessment at every visit"
          ]
        },
        {
          "severity": "maintenance_prophylaxis",
          "criteria": "Stable mood after acute episode — prevent relapse",
          "treatment": [
            "First-line: Lithium (level 0.6-0.8 mmol/L) — reduces suicide risk and relapse",
            "Alternative: Valproate or Lamotrigine (for depression prevention)",
            "Continue for minimum 2 years after single episode; lifelong if 2+ episodes",
            "Regular monitoring: lithium/valproate levels, renal function, thyroid, weight, metabolic panel",
            "Psychoeducation: sleep hygiene, stress management, early warning signs",
            "Relapse prevention plan; family involvement"
          ]
        }
      ],
      "specialConsiderations": {
        "wheeze_branch": "Not applicable",
        "HIV_exposed": "Monitor drug interactions with ARVs — especially protease inhibitors",
        "SAM": "Not applicable"
      }
    },
    "treatmentResponseLogic": {
      "triggers": [
        {
          "timePoint": "2 weeks",
          "ifNoImprovement": { "actions": ["Check drug levels (lithium/valproate)", "Optimise dose to therapeutic range", "Consider adding adjunctive medication", "Reassess diagnosis"] }
        },
        {
          "timePoint": "6 weeks",
          "ifStillSick": { "actions": ["Re-evaluate diagnosis and compliance", "Consider switching to alternative mood stabiliser", "Consider ECT if severe and refractory", "Reassess psychosocial factors"] }
        }
      ]
    },
    "adaptiveQuestioning": {
      "initialCoreQuestions": ["mood_changes?", "sleep_changes?", "energy_level_changes?", "episodic_nature?", "previous_treatment?"],
      "branching": [
        { "if": "mood_elevated", "ask": ["duration?", "grandiose_beliefs?", "decreased_sleep_need?", "impulsive_behaviours?", "increased_spending?"] },
        { "if": "mood_depressed", "ask": ["suicidal_thoughts?", "self_harm?", "hopelessness?", "appetite_changes?", "concentration?"] },
        { "if": "episodic", "ask": ["frequency_of_episodes?", "seasonal_pattern?", "duration_of_episodes?", "triggering_factors?"] },
        { "if": "psychotic_symptoms", "ask": ["hallucinations?", "delusions?", "mood_congruent?"] }
      ]
    },
    "pathophysiology": [
