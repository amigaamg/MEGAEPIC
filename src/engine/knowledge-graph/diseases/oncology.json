        { "name": "CA-125 (serum)", "priority": "first_line", "yield": 0.7, "indication": "all suspected — elevated in ~80% epithelial ovarian cancer", "note": "Can be normal in mucinous, borderline, and early-stage cancers" },
        { "name": "HE4 (serum)", "priority": "adjunct", "yield": 0.75, "indication": "improves specificity over CA125 alone" },
