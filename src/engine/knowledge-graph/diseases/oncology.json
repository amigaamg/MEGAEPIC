        { "name": "Carcinoembryonic antigen (CEA)", "priority": "if_colonic_metastasis_suspected", "yield": 0.4, "indication": "differentiate from colon cancer" },
        { "name": "Genetic testing (BRCA1/2)", "priority": "all_epithelial_ovarian_cancer", "yield": 0.9, "indication": "prognostic and therapeutic implications (PARP inhibitors)" }
      ],
      "imaging": [
        { "name": "Transvaginal ultrasound (TVUS)", "priority": "first_line", "yield": 0.85, "indication": "characterise adnexal mass — size, complexity, solid components, vascularity", "note": "Use IOTA simple rules for risk stratification" },
        { "name": "CT abdomen and pelvis (with IV and oral contrast)", "priority": "staging", "yield": 0.8, "indication": "preoperative staging — assess extent of disease, metastases, ascites" },
        { "name": "MRI pelvis", "priority": "problem_solving", "yield": 0.85, "indication": "indeterminate mass on ultrasound, local staging" },
        { "name": "PET-CT", "priority": "recurrence_surveillance", "yield": 0.8, "indication": "suspected recurrence with rising CA125 but normal CT" },
        { "name": "Chest CT or CXR", "priority": "staging", "yield": 0.6, "indication": "assess for pleural metastases and effusion" }
      ],
      "advanced": [
        { "name": "Diagnostic laparoscopy with biopsy", "indication": "tissue diagnosis when imaging inconclusive", "priority": "if_needed" },
        { "name": "Pleural fluid cytology", "indication": "if pleural effusion present", "priority": "if_needed" },
        { "name": "Ascitic fluid cytology", "indication": "if ascites present", "priority": "if_needed" }
      ]
    },
    "management": {
      "protocolReference": "FIGO Staging and NCCN Guidelines for Ovarian Cancer, 2024",
      "pathways": [
        {
          "severity": "early_stage_FIGO1_2A",
          "criteria": "Disease confined to ovaries/fallopian tubes, no ascites, good performance status",
          "treatment": [
            "Complete surgical staging: total abdominal hysterectomy + bilateral salpingo-oophorectomy + omentectomy + peritoneal biopsies + lymph node dissection",
            "Fertility-sparing surgery (USO + staging) for stage IA germ cell/early invasive if childbearing desired",
            "Adjuvant chemotherapy for high-risk early stage (stage IC, high grade, clear cell): Carboplatin AUC 5-6 + Paclitaxel 175 mg/m2 Q3W x 3-6 cycles",
            "Observation for stage IA low-grade with complete staging"
          ]
        },
        {
          "severity": "advanced_FIGO_2B_4",
          "criteria": "Disease beyond pelvis, peritoneal metastases, stage III-IV",
          "treatment": [
            "Neoadjuvant chemotherapy (NACT): Carboplatin AUC 5-6 + Paclitaxel 175 mg/m2 Q3W x 3 cycles",
            "Interval debulking surgery (IDS): goal R0 (no residual disease)",
            "Post-IDS: 3 additional cycles of Carboplatin + Paclitaxel (total 6 cycles)",
            "If BRCA-mutated: Olaparib 300 mg PO BID maintenance after complete/partial response",
            "Bevacizumab 15 mg/kg IV Q3W maintenance if high-risk (stage IV, suboptimal debulk)",
            "Consider HIPEC (hyperthermic intraperitoneal chemotherapy) for select patients at tertiary centres"
          ],
          "reassessment": "CA125 monitoring Q3 weeks during chemo; CT reassessment after 3 cycles and at completion"
        },
        {
          "severity": "recurrent",
          "criteria": "Rising CA125 and/or imaging-confirmed recurrence after completion of primary therapy",
          "treatment": [
            "Platinum-sensitive (relapse >6 months): re-treatment with Carboplatin + Paclitaxel or Carboplatin + Gemcitabine",
            "Platinum-resistant (relapse <6 months): single-agent therapy — Paclitaxel weekly, Topotecan, Pegylated liposomal doxorubicin, Gemcitabine",
            "PARP inhibitor (Olaparib/Niraparib) if BRCA-mutated and platinum-sensitive",
            "Bevacizumab added to chemotherapy for non-BRCA patients",
            "Palliative surgery for bowel obstruction if appropriate",
            "Consider palliative care consultation for symptom management"
          ]
        }
      ],
      "specialConsiderations": {
        "wheeze_branch": "Not applicable",
        "HIV_exposed": "No specific modification except standard precautions in immunosuppressed",
        "SAM": "Nutritional support essential during chemotherapy"
      }
    },
