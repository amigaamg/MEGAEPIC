        {
          "severity": "mild-moderate",
          "criteria": "infrequent attacks without significant hearing loss",
          "treatment": [
            "Reduced salt diet (<2 g/day sodium)",
            "Hydrochlorothiazide 25 mg PO OD or triamterene 37.5 mg PO OD",
            "Betahistine 16-48 mg PO divided TDS",
            "Avoid caffeine, alcohol, and tobacco"
          ]
        },
        {
          "severity": "severe-refractory",
          "criteria": "frequent attacks or progressive hearing loss despite medical therapy",
          "treatment": [
            "Intratympanic dexamethasone (4 mg/mL) injection",
            "Intratympanic gentamicin (40 mg/mL) titration for chemical ablation",
            "Consider endolymphatic sac decompression surgery",
            "Vestibular nerve section if intractable vertigo",
            "Labyrinthectomy if non-serviceable hearing"
          ]
        }
      ]
    },
    "pathophysiology": [
      "Endolymphatic hydrops — distention of endolymphatic compartment in membranous labyrinth",
