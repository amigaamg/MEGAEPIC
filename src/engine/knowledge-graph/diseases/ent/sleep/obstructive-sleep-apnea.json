    "management": {
      "protocolReference": "AASM Clinical Practice Guideline for OSA Management",
      "pathways": [
        {
          "severity": "mild",
          "criteria": "AHI 5-15, no comorbidities, Epworth <10",
          "treatment": "Weight loss (5-10% reduction). Positional therapy. Avoid alcohol/benzodiazepines. Oral appliance. Re-evaluate in 3-6 months."
        },
        {
          "severity": "moderate-severe",
          "criteria": "AHI >15, symptoms impacting QoL, comorbidities",
          "treatment": "CPAP/APAP (first-line). Heated humidification. Mask fitting and desensitization. Telemonitoring for adherence. Weight loss program. Bariatric surgery evaluation."
        },
        {
          "severity": "surgical candidate",
          "criteria": "CPAP intolerant or failed, correctable obstruction on DISE",
          "treatment": "Pharyngeal surgery: UPPP, tonsillectomy. Nasal surgery: septoplasty, turbinate reduction. Hypoglossal nerve stimulation (Inspire). Maxillomandibular advancement. Tracheostomy if life-threatening."
        }
      ]
    },

    "pathophysiology": [
