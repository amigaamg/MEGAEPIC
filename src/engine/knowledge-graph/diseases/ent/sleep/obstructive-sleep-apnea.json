        "id": "mild_osa",
        "name": "Mild Obstructive Sleep Apnea (AHI 5-15)",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "snoring", "weight": 4 },
          { "feature": "daytime_sleepiness_mild", "weight": 3 },
          { "feature": "few_witnessed_apneas", "weight": 2 }
        ],
        "management": "Lifestyle modification: weight loss, exercise, avoid alcohol before bed, positional therapy (avoid supine). Oral appliance (mandibular advancement device). CPAP if symptoms or comorbidities."
      },
      {
        "id": "moderate_osa",
        "name": "Moderate Obstructive Sleep Apnea (AHI 15-30)",
        "prevalenceModifier": 0.35,
        "keyFeatures": [
          { "feature": "loud_snoring", "weight": 4 },
          { "feature": "frequent_apneas", "weight": 4 },
          { "feature": "daytime_sleepiness_moderate", "weight": 4 },
          { "feature": "nocturnal_choking", "weight": 3 }
        ],
        "management": "CPAP (auto-titrating or fixed). Weight loss program. Oral appliance if CPAP intolerant. ENT evaluation for upper airway surgery if correctable obstruction."
      },
      {
        "id": "severe_osa",
        "name": "Severe Obstructive Sleep Apnea (AHI >30)",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
          { "feature": "very_loud_snoring", "weight": 5 },
          { "feature": "severe_desaturation", "weight": 5 },
          { "feature": "falls_asleep_driving", "weight": 5 },
          { "feature": "hypertension_resistant", "weight": 4 }
        ],
        "management": "CPAP/APAP (first-line). Weight loss surgery evaluation if BMI >40. Bilevel PAP if hypercapnia. ENT surgery (UPPP, tongue base reduction, hypoglossal nerve stimulation, maxillomandibular advancement). Oxygen therapy if persistent hypoxemia."
      }
    ],

