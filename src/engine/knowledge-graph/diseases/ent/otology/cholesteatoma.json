      { "symptomId": "facial_twitching_weakness", "weight": 4 },
      { "symptomId": "headache", "weight": 2, "note": "May suggest intracranial extension" }
    ],

    "examFeatures": [
      { "signId": "retraction_pocket", "baseWeight": 5, "doubleWeight": true },
      { "signId": "keratin_debris", "baseWeight": 5 },
      { "signId": "attic_perforation", "baseWeight": 5 },
      { "signId": "marginal_perforation", "baseWeight": 4 },
      { "signId": "granulation_polyp", "baseWeight": 3 },
      { "signId": "conductive_hearing_loss", "baseWeight": 4 },
