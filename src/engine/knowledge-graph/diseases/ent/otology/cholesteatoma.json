    ],

    "subtypes": [
      {
        "id": "congenital_cholesteatoma",
        "name": "Congenital Cholesteatoma",
        "prevalenceModifier": 0.05,
        "keyFeatures": [
          { "feature": "white_mass_behind_intact_TM", "weight": 5 },
          { "feature": "no_history_of_aom", "weight": 4 },
          { "feature": "conductive_hearing_loss", "weight": 4 }
        ],
        "management": "Tympanotomy with excision. Type I-IV tympanoplasty depending on extent. Ossicular chain reconstruction if eroded."
      },
      {
        "id": "acquired_cholesteatoma",
        "name": "Acquired Cholesteatoma",
        "prevalenceModifier": 0.95,
        "keyFeatures": [
          { "feature": "retraction_pocket", "weight": 5 },
          { "feature": "chronic_otorrhea", "weight": 4 },
          { "feature": "hearing_loss", "weight": 4 },
          { "feature": "csom_history", "weight": 4 }
        ],
        "management": "Cortical mastoidectomy with atticotomy. Canal wall up vs down technique. Complete sac removal. Ossiculoplasty. Second-look surgery in 6-12 months."
      }
    ],

    "mimics": [
      {
        "diseaseId": "csom_tubotympanic",
        "discriminators": ["central_perforation", "no_keratin_debris", "mucoid_discharge", "no_retraction_pocket"]
      },
      {
        "diseaseId": "middle_ear_granulation",
        "discriminators": ["no_keratin_pearls", "bleeds_easily", "medical_treatment_response"]
      },
      {
        "diseaseId": "middle_ear_tumor",
        "discriminators": ["glomus_tympanicum_pulsatile", "facial_nerve_schwannoma", "adenoma"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Otomicroscopy", "priority": "immediate", "yield": 0.9, "indication": "all cases - assess extent and retraction pockets" },
        { "name": "Tuning Fork Tests", "priority": "high", "yield": 0.7, "indication": "conductive vs sensorineural loss" }
      ],
      "laboratory": [],
      "imaging": [
        { "name": "High Resolution CT Temporal Bone", "priority": "high", "yield": 0.9, "indication": "evaluate bony erosion, ossicular chain, tegmen, facial canal, labyrinth" },
        { "name": "MRI with DWI", "priority": "medium", "yield": 0.85, "indication": "differentiate from granulation tissue, detect residual/recurrent disease" },
        { "name": "Pure Tone Audiometry", "priority": "high", "yield": 0.9, "indication": "baseline and post-op hearing assessment" }
      ]
    },

    "management": {
      "protocolReference": "EAONO/JOS Cholesteatoma Staging and Management Guidelines",
      "pathways": [
        {
          "severity": "limited",
          "criteria": "retraction pocket, no extension to mastoid, intact ossicles",
          "treatment": "Transcanal endoscopic ear surgery or atticotomy. Remove sac, reconstruct TM with cartilage. Follow-up imaging at 1 year."
        },
        {
          "severity": "extensive",
          "criteria": "mastoid extension, ossicular erosion, fistula risk",
          "treatment": "Cortical mastoidectomy with intact canal wall (canal wall up). Remove all sac. Ossiculoplasty with autograft or prosthesis. Second-look in 6-12 months."
        },
        {
          "severity": "complicated",
          "criteria": "labyrinthine fistula, facial nerve involvement, tegmen erosion, intracranial extension",
          "treatment": "Canal wall down mastoidectomy. Close fistula with bone dust/fascia. Decompress facial nerve if needed. Neurosurgical consultation. Long-term follow-up for cavity care."
        }
      ]
    },

    "pathophysiology": [
      "retraction_pocket_formation",
      "squamous_epithelial_migration",
      "keratin_accumulation",
      "enzymatic_bone_erosion",
      "inflammatory_osteolysis"
    ],

