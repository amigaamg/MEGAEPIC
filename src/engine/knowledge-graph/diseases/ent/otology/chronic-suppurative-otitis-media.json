        "probability": 0.05,
        "lagDays": [180, 1095],
        "severityBoost": 0.5,
        "clues": ["vertigo", "positive_fistula_sign", "sensorineural_hearing_loss"]
      },
      {
        "diseaseId": "facial_nerve_palsy",
        "probability": 0.03,
        "lagDays": [90, 730],
        "severityBoost": 0.6,
        "clues": ["facial_twitching", "gradual_weakness"]
      },
      {
        "diseaseId": "intracranial_abscess",
        "probability": 0.01,
        "lagDays": [180, 1460],
        "severityBoost": 0.7,
        "clues": ["headache", "fever", "neurological_deficits", "seizures"]
      }
    ],

    "mustNotMiss": true,
    "emergencyPriority": "medium",
    "diagnosticClues": ["chronic_otorrhea", "tm_perforation", "hearing_loss", "foul_discharge"],
    "exclusionClues": ["acute_onset", "tragal_tenderness", "intact_TM"]
  }
