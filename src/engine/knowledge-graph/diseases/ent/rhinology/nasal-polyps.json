    "management": {
      "protocolReference": "European Position Paper on Rhinosinusitis and Nasal Polyps (EPOS)",
      "pathways": [
        {
          "severity": "mild",
          "criteria": "limited polyps (grade 1), mild symptoms",
          "treatment": "Intranasal corticosteroid spray (Fluticasone or Mometasone) daily. Saline nasal irrigation. Avoid aspirin if AERD."
        },
        {
          "severity": "moderate",
          "criteria": "moderate polyps (grade 2), moderate-to-severe symptoms",
          "treatment": "Intranasal corticosteroids + oral corticosteroids (Prednisolone 30-40 mg daily for 7-14 days). Consider Doxycycline for anti-inflammatory effect."
        },
        {
          "severity": "refractory",
          "criteria": "extensive polyps (grade 3-4), failed medical therapy, recurrence after surgery",
          "treatment": "Endoscopic sinus surgery (complete ethmoidectomy with polyp removal). Continue medical therapy post-op. Biologics (Dupilumab 300 mg SC Q2W) for severe eosinophilic disease."
        }
      ]
    },

