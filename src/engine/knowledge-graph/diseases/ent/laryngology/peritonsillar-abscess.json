    "management": {
      "protocolReference": "AAO-HNS Clinical Practice Guideline: Peritonsillar Abscess",
      "pathways": [
        {
          "severity": "non-severe",
          "criteria": "localized PTA, no airway compromise, able to swallow",
          "treatment": "Needle aspiration or I&D under topical anesthesia. IV antibiotics (Penicillin G 4M U Q4H + Metronidazole 500 mg Q8H or Clindamycin 900 mg Q8H). IV fluids. Discharge with oral antibiotics for 7-10 days."
        },
        {
          "severity": "severe",
          "criteria": "large abscess, severe trismus, dehydration, extension to deep neck spaces",
          "treatment": "I&D under general anesthesia. Tonsillectomy (quinsy tonsillectomy) if recurrent or complicated. IV antibiotics. Admission for monitoring. CT neck to assess extension."
        },
        {
          "severity": "airway compromise",
          "criteria": "stridor, respiratory distress, impending airway loss",
          "treatment": "Secure airway (awake fiberoptic intubation or tracheostomy). Emergency I&D. IV antibiotics. ICU admission. CT neck."
        }
      ]
    },

