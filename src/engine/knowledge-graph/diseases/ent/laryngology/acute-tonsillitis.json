        "prevalenceModifier": 0.3,
        "keyFeatures": [
          { "feature": "sudden_severe_sore_throat", "weight": 5 },
          { "feature": "fever_over_38", "weight": 4 },
          { "feature": "tonsillar_exudate", "weight": 4 },
