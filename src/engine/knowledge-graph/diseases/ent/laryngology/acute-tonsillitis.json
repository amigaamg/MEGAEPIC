          { "feature": "palatal_petechiae", "weight": 3 },
          { "feature": "scarlatiniform_rash", "weight": 3 }
        ],
        "management": "Penicillin V 250-500 mg TID or Amoxicillin 50 mg/kg/day for 10 days. If PCN allergy: Cephalexin or Macrolide. Analgesics. Follow-up for complication monitoring."
