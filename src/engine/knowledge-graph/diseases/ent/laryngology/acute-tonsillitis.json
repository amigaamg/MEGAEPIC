    "management": {
      "protocolReference": "IDSA Clinical Practice Guideline for GAS Pharyngitis",
      "pathways": [
        {
          "severity": "mild",
          "criteria": "Centor score 0-1, no exudate, no fever",
          "treatment": "Symptomatic: analgesics, hydration, saline gargles. No testing or antibiotics needed."
        },
        {
          "severity": "moderate",
          "criteria": "Centor score 2-3, exudate, fever, lymphadenopathy",
          "treatment": "RADT or throat culture. If positive: Penicillin V or Amoxicillin for 10 days. Analgesics. Return if worsening."
        },
        {
          "severity": "severe",
          "criteria": "Centor 4, severe dysphagia, dehydration, suspected abscess",
          "treatment": "IV antibiotics (Penicillin G or Clindamycin). IV fluids. Corticosteroids (Dexamethasone 0.6 mg/kg). ENT referral if abscess suspected."
        }
      ]
