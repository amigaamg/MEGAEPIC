    "management": {
      "protocolReference": "AAO-HNS Clinical Practice Guideline: Acute Vestibular Syndrome",
      "pathways": [
        {
          "severity": "acute",
          "criteria": "first 72 hours of severe vertigo",
          "treatment": [
            "IV fluids if dehydrated from vomiting",
            "Ondansetron 4-8 mg IV/ODT for nausea",
            "Diazepam 5-10 mg IV/PO PRN for vestibular suppression (short course only)",
            "Prednisolone 1 mg/kg PO OD x 7-14 days if no contraindication",
            "Avoid prolonged bed rest — encourage early mobilization"
          ]
        },
        {
          "severity": "subacute",
          "criteria": "after 72 hours, improving but still imbalanced",
          "treatment": [
            "Taper corticosteroids over 1-2 weeks",
            "Start vestibular rehabilitation exercises (Cawthorne-Cooksey)",
            "Discontinue vestibular suppressants to allow central compensation",
            "Acyclovir 800 mg PO 5x/day x 7 days if VZV confirmed",
            "Fall prevention counseling"
          ]
        },
        {
          "severity": "recovery",
          "criteria": "stable, persistent mild imbalance",
          "treatment": [
            "Continue vestibular rehabilitation physiotherapy",
            "Return to driving and work when safe (often 4-6 weeks)",
            "Consider ENT follow-up for chronic vestibular hypofunction"
          ]
        }
      ]
    },
    "pathophysiology": [
      "Inflammation of vestibular nerve (vestibular neuritis) or labyrinth (labyrinthitis)",
      "Most commonly viral — HSV-1 reactivation in vestibular ganglia",
      "VZV reactivation causes Ramsay Hunt syndrome with geniculate ganglion involvement",
      "Bacterial labyrinthitis can complicate meningitis or otitis media",
      "Inflammation causes asymmetric vestibular input leading to acute vertigo and nystagmus"
