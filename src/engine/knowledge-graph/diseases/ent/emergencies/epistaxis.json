        { "name": "Nasal Endoscopy", "priority": "high", "yield": 0.9, "indication": "identify posterior source, evaluate for mass" }
      ],
      "laboratory": [
        { "name": "CBC", "priority": "high", "yield": 0.6, "indication": "assess blood loss, platelets" },
        { "name": "PT/PTT/INR", "priority": "high", "yield": 0.5, "indication": "coagulopathy assessment" },
        { "name": "Blood Type and Cross-match", "priority": "high", "yield": 0.3, "indication": "severe bleeding, hemodynamic instability" }
      ],
      "imaging": [
        { "name": "CT Sinuses/Nasal Cavity", "priority": "low", "yield": 0.5, "indication": "suspected tumor, trauma, recurrent epistaxis" },
        { "name": "Angiography", "priority": "low", "yield": 0.8, "indication": "if embolization planned, failed surgical ligation" }
      ]
    },

    "management": {
      "protocolReference": "AAO-HNS Clinical Practice Guideline: Epistaxis",
      "pathways": [
        {
          "severity": "mild anterior",
          "criteria": "self-limited, anterior source, no coagulopathy",
          "treatment": "Digital pressure for 10-15 min. Lean forward. Topical vasoconstrictor (oxymetazoline). Avoid nose-blowing for 24h. Nasal saline gel to prevent recurrence."
        },
        {
          "severity": "persistent anterior",
          "criteria": "active bleeding, visible anterior source, failed first aid",
          "treatment": "Topical lidocaine + oxymetazoline. Silver nitrate cautery (unilateral, avoid septum perforation). If fails: absorbable packing (Surgicel, Gelfoam, Floseal)."
        },
        {
          "severity": "severe/posterior",
          "criteria": "posterior bleed, hemodynamic instability, anticoagulated, failed packing",
          "treatment": "IV access, resuscitation. Reverse anticoagulation (Vitamin K, FFP, PCC). Posterior packing (balloon tamponade). ENT: sphenopalatine artery ligation via transnasal endoscopic approach. Embolization if surgical candidate unfit."
        }
      ]
    },

    "pathophysiology": [
      "mucosal_desiccation",
      "vessel_rupture",
      "little_area_vascular_plexus",
      "posterior_sphenopalatine_artery_bleed",
      "coagulation_impairment"
    ],

