      { "signId": "blood_in_oropharynx_posterior", "baseWeight": 4, "doubleWeight": true },
      { "signId": "anterior_septal_bleeding_point", "baseWeight": 3 },
      { "signId": "hypotension_tachycardia", "baseWeight": 4 },
      { "signId": "pallor", "baseWeight": 2 },
