    "name": "Epistaxis (Nosebleed)",
    "system": "ent",
    "agePeak_months": [24, 120, 600, 960],
    "note": "Bleeding from the nasal cavity. 90% are anterior (Little's area / Kiesselbach's plexus). Posterior bleeds are more severe and often require hospital admission.",
    "prevalenceWeight": 0.8,
    "syndromeTags": ["nasal_hemorrhage", "bleeding_nose"],

    "severityAssessment": {
