      { "id": "hereditary_hemorrhagic_telangiectasia", "multiplier": 8.0 }
    ],

    "subtypes": [
      {
        "id": "anterior_epistaxis",
        "name": "Anterior Epistaxis",
        "prevalenceModifier": 0.9,
        "keyFeatures": [
          { "feature": "bleeding_from_little_area", "weight": 5 },
          { "feature": "bleeding_out_front", "weight": 4 },
          { "feature": "easy_to_visualize_source", "weight": 4 },
          { "feature": "usually_self_limited", "weight": 3 }
        ],
        "management": "First aid: lean forward, pinch nose for 10-15 min. If continues: topical vasoconstrictor (Oxymetazoline). Cautery (silver nitrate or electrocautery). Absorbable packing (Surgicel, Floseal). Non-absorbable pack if needed."
      },
      {
        "id": "posterior_epistaxis",
        "name": "Posterior Epistaxis",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
          { "feature": "bleeding_down_throat", "weight": 5 },
          { "feature": "no_anterior_source", "weight": 4 },
          { "feature": "hemodynamic_instability", "weight": 4 },
          { "feature": "elderly_hypertensive", "weight": 3 }
        ],
        "management": "Resuscitate. Posterior nasal packing (Foley catheter tamponade, Epistat balloon). Nasal endoscopy to identify source. Sphenopalatine artery ligation or embolization if packing fails. Reverse anticoagulation."
      }
    ],

    "mimics": [
      {
        "diseaseId": "hemoptysis",
        "discriminators": ["coughing_blood", "bronchial_origin", "lung_pathology"]
      },
      {
        "diseaseId": "hematemesis_GI_bleed",
        "discriminators": ["vomiting_blood", "melena", "epigastric_pain", "no_nasal_history"]
      }
    ],

    "investigations": {
