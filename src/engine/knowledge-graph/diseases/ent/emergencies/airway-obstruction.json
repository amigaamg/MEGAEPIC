      { "id": "neck_trauma", "multiplier": 3.0 },
      { "id": "intubation_history", "multiplier": 1.5 },
      { "id": "obesity_osa", "multiplier": 1.5 },
      { "id": "neuromuscular_disorder", "multiplier": 2.0 }
    ],

    "subtypes": [
      {
        "id": "airway_foreign_body",
        "name": "Foreign Body Airway Obstruction",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "sudden_choking", "weight": 5 },
          { "feature": "while_eating_playing", "weight": 4 },
          { "feature": "unilateral_breath_sounds", "weight": 3 }
        ],
        "management": "Heimlich maneuver (conscious >1yr). Back blows + chest thrusts (<1yr). Laryngoscopy and removal with Magill forceps. Bronchoscopy if below cords."
      },
      {
        "id": "acute_epiglottitis",
        "name": "Acute Epiglottitis",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
          { "feature": "rapid_onset_sore_throat", "weight": 4 },
          { "feature": "dysphagia_severe", "weight": 4 },
          { "feature": "drooling", "weight": 4 },
          { "feature": "muffled_voice", "weight": 3 },
          { "feature": "tripod_position", "weight": 4 }
        ],
        "management": "Do NOT examine throat. Keep child calm. Immediate ENT/anes. Inhalation (racemic epinephrine, Heliox). IV antibiotics (Ceftriaxone). Secure airway in OR (awake FOI). Dexamethasone."
      },
      {
        "id": "laryngotracheobronchitis_croup",
        "name": "Croup (Laryngotracheobronchitis)",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
          { "feature": "barking_cough", "weight": 5 },
          { "feature": "hoarse_voice", "weight": 3 },
          { "feature": "inspiratory_stridor", "weight": 4 },
          { "feature": "preceding_URI", "weight": 3 },
          { "feature": "age_6mo_3yr", "weight": 4 }
        ],
        "management": "Mild: single dose Dexamethasone 0.15-0.6 mg/kg PO. Moderate: Dexamethasone + racemic epinephrine neb. Severe/impending: Heliox, CPAP, intubation."
      },
      {
        "id": "angioedema_anaphylaxis",
        "name": "Angioedema / Anaphylaxis",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "lip_tongue_uvula_swelling", "weight": 5 },
          { "feature": "urticaria", "weight": 4 },
          { "feature": "allergen_exposure", "weight": 4 },
          { "feature": "hypotension", "weight": 4 }
        ],
        "management": "IM Epinephrine (1:1000) 0.01 mg/kg (max 0.5 mg). IV fluids. Antihistamines (Diphenhydramine + Ranitidine). Corticosteroids. Secure airway early. ICU."
      },
      {
        "id": "laryngeal_tumor_obstruction",
        "name": "Laryngeal Tumor / Bilateral VC Palsy",
        "prevalenceModifier": 0.05,
        "keyFeatures": [
          { "feature": "progressive_symptoms", "weight": 4 },
          { "feature": "stridor_exertional_initially", "weight": 3 },
          { "feature": "hoarseness_long_standing", "weight": 3 }
        ],
        "management": "Tumor: tracheostomy under local anesthesia + biopsy. VC palsy: Tracheostomy or cordotomy/arytenoidectomy."
      }
    ],

    "mimics": [
      {
        "diseaseId": "lower_airway_obstruction",
