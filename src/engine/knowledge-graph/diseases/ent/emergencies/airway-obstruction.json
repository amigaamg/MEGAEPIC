    "investigations": {
      "bedside": [
        { "name": "Airway Assessment (ABCDE)", "priority": "immediate", "yield": 1.0, "indication": "all patients - first priority" }
      ],
      "laboratory": [],
      "imaging": [
        { "name": "X-ray Neck Lateral", "priority": "high", "yield": 0.6, "indication": "suspected epiglottitis (thumb sign), croup (steeple sign), retropharyngeal abscess" },
        { "name": "CT Neck", "priority": "medium", "yield": 0.7, "indication": "stable patient, suspected tumor/abscess" },
        { "name": "Flexible Nasolaryngoscopy", "priority": "high", "yield": 0.95, "indication": "assess supraglottic/glottic level in stable patient" }
      ]
    },

    "management": {
      "protocolReference": "ASA Difficult Airway Algorithm / PALS Airway Guidelines",
      "pathways": [
        {
          "severity": "mild/moderate",
          "criteria": "stridor only with activity, mild indrawing, saturations normal",
          "treatment": "Keep calm. Position upright. Oxygen. Dexamethasone. Treat underlying cause. Monitor closely."
        },
        {
          "severity": "severe",
          "criteria": "stridor at rest, indrawing, desaturation, drooling, tripod",
          "treatment": "Call anesthesia + ENT immediately. Awake fiberoptic intubation (first choice). Prepare for tracheostomy. Inhalation racemic epinephrine + Heliox. IV access. Dexamethasone."
        },
        {
          "severity": "critical (CICO)",
          "criteria": "cannot intubate, cannot oxygenate",
          "treatment": "Emergency front of neck access (cricothyroidotomy or tracheostomy). Needle cricothyroidotomy in <6yr. Surgical cricothyroidotomy in older children/adults."
        }
      ]
    },

    "pathophysiology": [
      "mechanical_obstruction",
