    "examFeatures": [
      { "signId": "neck_erythema_swelling", "baseWeight": 5 },
      { "signId": "neck_mass_fluctuant", "baseWeight": 4, "doubleWeight": true },
      { "signId": "cervical_tenderness", "baseWeight": 4 },
      { "signId": "trismus", "baseWeight": 4 },
      { "signId": "pharyngeal_bulge", "baseWeight": 4, "note": "Medial bulging of pharyngeal wall in parapharyngeal/retropharyngeal abscess" },
      { "signId": "fever", "baseWeight": 4 },
      { "signId": "torticollis", "baseWeight": 3 },
      { "signId": "submandibular_edema", "baseWeight": 3 },
