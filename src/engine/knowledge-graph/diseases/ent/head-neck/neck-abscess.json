      { "id": "immunosuppression", "multiplier": 3.5 },
      { "id": "poor_dental_hygiene", "multiplier": 2.0 },
      { "id": "iv_drug_use", "multiplier": 3.0 },
      { "id": "young_age_retropharyngeal", "multiplier": 3.0 }
    ],

    "subtypes": [
      {
        "id": "retropharyngeal_abscess",
        "name": "Retropharyngeal Abscess",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
          { "feature": "children_under_5", "weight": 4 },
          { "feature": "neck_extension_torticollis", "weight": 4 },
          { "feature": "stridor", "weight": 3 },
          { "feature": "pharyngeal_bulge_posterior_wall", "weight": 5 }
        ],
        "management": "IV antibiotics (Ceftriaxone + Clindamycin). Surgical drainage via transoral approach. Secure airway (awake FOI if compromised). Culture."
      },
      {
        "id": "parapharyngeal_abscess",
        "name": "Parapharyngeal Abscess",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
          { "feature": "tonsillar_bulge_lateral", "weight": 4 },
          { "feature": "trismus", "weight": 4 },
          { "feature": "neck_swelling_below_angle_mandible", "weight": 4 },
          { "feature": "CN_IX_X_XI_XII_palsies", "weight": 4 }
        ],
        "management": "IV antibiotics. External cervical drainage via transcervical approach. CT-guided drainage if discrete collection. Airway management."
      },
      {
        "id": "submandibular_abscess_ludwig",
        "name": "Ludwig Angina (Submandibular Space)",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
          { "feature": "bilateral_submandibular_swelling", "weight": 5 },
          { "feature": "floor_of_mouth_elevation", "weight": 5 },
          { "feature": "tongue_protrusion", "weight": 4 },
          { "feature": "drooling", "weight": 4 },
          { "feature": "rapid_airway_compromise", "weight": 5 }
        ],
        "management": "Emergency airway (awake FOI or tracheostomy). IV antibiotics (Penicillin + Metronidazole + Gentamicin or Carbapenem). Surgical decompression via transcervical approach. ICU."
      },
      {
        "id": "peritonsillar_abscess",
        "name": "Peritonsillar Abscess (see also separate disease)",
        "prevalenceModifier": 0.35,
        "keyFeatures": [
          { "feature": "unilateral_tonsillar_bulge", "weight": 5 },
          { "feature": "uvula_deviation", "weight": 4 },
          { "feature": "trismus", "weight": 4 },
          { "feature": "muffled_voice", "weight": 3 }
        ],
        "management": "Needle aspiration or I&D intraoral. IV antibiotics. Tonsillectomy if recurrent."
      },
      {
        "id": "necrotizing_fasciitis_neck",
        "name": "Cervical Necrotizing Fasciitis",
        "prevalenceModifier": 0.05,
        "keyFeatures": [
          { "feature": "rapid_progression", "weight": 5 },
          { "feature": "crepitus", "weight": 5 },
          { "feature": "skin_necrosis_bullae", "weight": 5 },
          { "feature": "severe_sepsis", "weight": 5 },
          { "feature": "diabetes", "weight": 4 }
        ],
        "management": "Emergency wide debridement. Broad-spectrum IV antibiotics (Carbapenem + Clindamycin + Vancomycin). ICU. Hyperbaric oxygen. Multiple surgical explorations."
      }
    ],

    "mimics": [
