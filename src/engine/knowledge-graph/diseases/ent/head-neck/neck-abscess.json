        "diseaseId": "carotid_body_tumor",
        "discriminators": ["slow_growth", "pulsatile", "bruit", "no_fever", "transcervical_US"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Flexible Nasolaryngoscopy", "priority": "immediate", "yield": 0.7, "indication": "assess airway patency, pharyngeal bulge" }
      ],
      "laboratory": [
        { "name": "WBC count", "priority": "high", "yield": 0.7, "indication": "leukocytosis" },
        { "name": "CRP", "priority": "high", "yield": 0.8, "indication": "elevated, monitor treatment" },
        { "name": "Blood Culture", "priority": "high", "yield": 0.3, "indication": "sepsis evaluation" },
        { "name": "Lactate", "priority": "high", "yield": 0.5, "indication": "tissue hypoperfusion assessment" }
      ],
      "imaging": [
        { "name": "CT Neck with Contrast", "priority": "immediate", "yield": 0.95, "indication": "gold standard - identify abscess, define extent, airway assessment, mediastinal extension" },
        { "name": "X-ray Neck Lateral", "priority": "medium", "yield": 0.5, "indication": "screen for retropharyngeal widening >7mm at C2" },
        { "name": "MRI Neck", "priority": "low", "yield": 0.9, "indication": "alternative if CT contraindicated, assess soft tissue planes" }
      ]
    },

    "management": {
      "protocolReference": "AAO-HNS Clinical Practice Guideline: Deep Neck Space Infections",
      "pathways": [
        {
          "severity": "non-severe",
          "criteria": "small abscess <2cm, no airway compromise, no systemic sepsis",
          "treatment": "IV antibiotics (Ampicillin-Sulbactam or Clindamycin + Ceftriaxone). CT-guided drainage if accessible. Monitor airway closely."
        },
        {
          "severity": "severe",
          "criteria": "large abscess, airway risk, descending infection, sepsis",
          "treatment": "Secure airway (awake fiberoptic intubation or tracheostomy). Surgical drainage via transcervical approach. IV broad-spectrum antibiotics (Carbapenem or Piperacillin-Tazobactam + Vancomycin). ICU. Culture-directed therapy."
        },
        {
          "severity": "necrotizing fasciitis",
          "criteria": "gas on imaging, rapid progression, septic shock",
          "treatment": "Emergency wide surgical debridement. Repeat explorations Q24-48h. IV broad-spectrum antibiotics. ICU. HVHBOT. Reconstructive surgery after infection control."
        }
      ]
    },

    "pathophysiology": [
      "odontogenic_or_oropharyngeal_infection",
      "spread_along_fascial_planes",
      "lymphatic_extension",
      "purulent_collection",
      "tissue_necrosis_and_edema"
    ],

