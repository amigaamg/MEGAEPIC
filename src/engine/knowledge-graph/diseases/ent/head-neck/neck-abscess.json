        { "sign": "chest_pain_mediastinitis", "weight": 10 }
      ],
      "severeCriteria": {
        "anyDangerSign": true,
        "additionalCriteria": [
          { "sign": "airway_compromise", "weight": 10 },
          { "sign": "descending_infection_below_clavicle", "weight": 9 },
          { "sign": "trismus_severe", "weight": 7 },
          { "sign": "high_fever", "weight": 6 },
          { "sign": "diabetes_immunosuppression", "weight": 5 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
        "noDangerSigns": true
      },
      "severityLabel": "If airway compromise/descending infection/sepsis -> SEVERE; else -> NON-SEVERE"
    },

    "historyFeatures": [
      { "symptomId": "neck_swelling_painful", "weight": 5 },
      { "symptomId": "fever", "weight": 5 },
      { "symptomId": "dysphagia", "weight": 4, "note": "Suggests parapharyngeal or retropharyngeal space involvement" },
      { "symptomId": "dyspnea", "weight": 4 },
      { "symptomId": "trismus", "weight": 3 },
      { "symptomId": "muffled_voice", "weight": 3 },
      { "symptomId": "drooling", "weight": 3 },
      { "symptomId": "neck_stiffness_torticollis", "weight": 3, "note": "Common in retropharyngeal abscess in children" },
      { "symptomId": "recent_pharyngeal_infection", "weight": 3 },
      { "symptomId": "dental_infection_history", "weight": 3, "note": "Dental infections can spread to submandibular space" }
