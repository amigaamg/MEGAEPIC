          { "feature": "bilateral_10_percent", "weight": 3 },
          { "feature": "smoking_strong_association", "weight": 4 },
          { "feature": "male_predominance", "weight": 3 },
          { "feature": "may_be_multifocal", "weight": 3 }
        ],
        "management": "Superficial parotidectomy or enucleation. Observation in elderly. No malignant transformation risk."
      }
    ],

