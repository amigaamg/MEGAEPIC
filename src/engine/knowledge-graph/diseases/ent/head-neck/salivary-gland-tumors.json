    "subtypes": [
      {
        "id": "pleomorphic_adenoma",
        "name": "Pleomorphic Adenoma (Benign Mixed Tumor)",
        "prevalenceModifier": 0.6,
        "keyFeatures": [
          { "feature": "slow_growing_years", "weight": 4 },
          { "feature": "painless", "weight": 4 },
          { "feature": "smooth_lobulated", "weight": 3 },
          { "feature": "mobile_firm", "weight": 3 },
          { "feature": "normal_facial_nerve", "weight": 3 }
        ],
        "management": "Superficial parotidectomy (for parotid) or submandibulectomy for SMG. Extracapsular dissection for select cases. Facial nerve monitoring. Recurrence if incomplete excision."
      },
      {
        "id": "mucoepidermoid_carcinoma",
        "name": "Mucoepidermoid Carcinoma",
        "prevalenceModifier": 0.15,
        "keyFeatures": [
