          { "sign": "facial_nerve_palsy", "weight": 9 },
          { "sign": "fixed_mass", "weight": 7 },
          { "sign": "painful_mass", "weight": 6 },
          { "sign": "rapid_growth", "weight": 6 },
          { "sign": "cervical_lymphadenopathy", "weight": 6 }
        ]
      },
      "nonSevereCriteria": {
        "hasIndrawingOrFastBreathing": false,
