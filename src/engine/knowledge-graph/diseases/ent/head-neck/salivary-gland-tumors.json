          { "feature": "may_be_painful", "weight": 3 },
          { "feature": "facial_nerve_involvement", "weight": 4 },
          { "feature": "lymph_node_metastasis", "weight": 3 }
        ],
        "management": "Total parotidectomy + facial nerve dissection (sacrifice if involved). Neck dissection if nodal disease. Adjuvant radiotherapy if high-grade, positive margins, or nodal disease."
      },
      {
        "id": "adenoid_cystic_carcinoma",
        "name": "Adenoid Cystic Carcinoma",
        "prevalenceModifier": 0.08,
        "keyFeatures": [
