    "management": {
      "protocolReference": "NCCN Guidelines: Salivary Gland Tumors",
      "pathways": [
        {
          "severity": "benign tumor",
          "criteria": "pleomorphic adenoma, Warthin tumor, slow-growing, normal FN, no LN",
          "treatment": "Superficial parotidectomy with facial nerve preservation (parotid). Submandibulectomy for SMG. Extracapsular dissection for select superficial tumors."
        },
        {
          "severity": "low-grade malignant",
          "criteria": "low-grade mucoepidermoid, no FN involvement, no LN",
          "treatment": "Total parotidectomy preserving facial nerve + selective neck dissection (levels I-III). Adjuvant RT if positive margins."
        },
        {
          "severity": "high-grade malignant",
          "criteria": "high-grade histology, FN involvement, LN metastases, perineural spread",
          "treatment": "Total parotidectomy with facial nerve sacrifice and immediate nerve grafting. Comprehensive neck dissection. Adjuvant radiotherapy. Systemic therapy for metastatic disease."
        }
      ]
    },

