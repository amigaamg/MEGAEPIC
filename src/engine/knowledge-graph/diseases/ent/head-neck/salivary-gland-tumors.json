          { "feature": "late_recurrence", "weight": 4 },
          { "feature": "distant_metastasis_lung", "weight": 4 }
        ],
        "management": "Wide local excision with nerve sacrifice if involved. Post-operative radiotherapy. Long-term surveillance for late recurrence and lung metastases."
      },
      {
        "id": "warthin_tumor",
        "name": "Warthin Tumor (Adenolymphoma)",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
