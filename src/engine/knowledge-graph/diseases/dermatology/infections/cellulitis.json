    "management": {
      "protocolReference": "IDSA / NICE Guidelines for Cellulitis and Erysipelas",
      "pathways": [
        {
          "severity": "mild-moderate (outpatient)",
          "criteria": "no systemic signs, small area, no comorbidities",
          "treatment": "Flucloxacillin 500mg PO Q6H x 7-10 days. Cephalexin if penicillin allergic. Elevation. Rest. Mark erythema margin. Review in 48h."
        },
        {
          "severity": "severe (inpatient IV)",
          "criteria": "systemic illness, rapid spread, comorbidities, failed oral",
          "treatment": "IV Flucloxacillin 2g Q6H + Benzylpenicillin 1.2g Q6H. Switch to oral when improving. Total 7-14 days. If MRSA: Vancomycin or Daptomycin. Manage comorbidities (diabetes, edema)."
