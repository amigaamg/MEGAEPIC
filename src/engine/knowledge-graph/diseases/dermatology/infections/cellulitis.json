          { "feature": "no_systemic_toxicity", "weight": 4 },
          { "feature": "no_necrosis_or_bullae", "weight": 4 }
        ],
        "management": "Oral antibiotics: Flucloxacillin 500mg Q6H or Cephalexin 500mg Q6H for 7-10 days. Rest, elevation. Analgesia. Mark erythema border for monitoring."
      },
      {
        "id": "severe_cellulitis",
        "name": "Severe Cellulitis",
        "prevalenceModifier": 0.2,
        "keyFeatures": [
