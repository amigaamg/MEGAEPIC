      { "signId": "full_thickness_skin_loss_stage_3", "baseWeight": 5 },
      { "signId": "full_thickness_tissue_loss_stage_4", "baseWeight": 5 },
      { "signId": "eschar_or_slough_unstageable", "baseWeight": 4 },
      { "signId": "over_sacrum_heels_trochanters", "baseWeight": 4 },
