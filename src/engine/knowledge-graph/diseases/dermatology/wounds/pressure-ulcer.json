    "subtypes": [
      {
        "id": "stage_1_pressure_ulcer",
        "name": "Stage I Pressure Ulcer",
        "prevalenceModifier": 0.25,
        "keyFeatures": [
          { "feature": "non_blanchable_erythema", "weight": 5 },
          { "feature": "intact_skin", "weight": 4 },
          { "feature": "warmth_or_coolness_induration", "weight": 3 }
        ],
        "management": "Pressure relief (reposition q2h). Support surfaces (specialized mattress). Skin care. Moisturizer. Nutritional support. Preventive dressings."
      },
      {
        "id": "stage_3_4_pressure_ulcer",
        "name": "Stage III/IV Pressure Ulcer",
        "prevalenceModifier": 0.4,
        "keyFeatures": [
          { "feature": "full_thickness_skin_loss_stage_3", "weight": 4 },
          { "feature": "muscle_bone_involvement_stage_4", "weight": 5 },
          { "feature": "undermining_tunneling", "weight": 4 }
        ],
        "management": "Debridement (sharp, surgical, enzymatic). Wound care: appropriate dressings (foam, alginate, hydrofiber, NPWT). Infection management (swab, biopsy, antibiotics). Offloading. Nutrition. Surgical closure if needed."
      }
    ],

    "mimics": [
      {
        "diseaseId": "venous_leg_ulcer",
        "discriminators": ["gaiter_area", "varicose_veins", "edema_cvi_signs"]
      },
      {
        "diseaseId": "diabetic_foot_ulcer",
        "discriminators": ["plantar_foot", "neuropathy", "deformity"]
      }
    ],

    "investigations": {
      "bedside": [
        { "name": "Braden Scale risk assessment", "priority": "immediate", "yield": 0.85, "indication": "all at-risk patients" }
      ],
      "laboratory": [
        { "name": "Wound swab culture (superficial, less reliable)", "priority": "medium", "yield": 0.5, "indication": "if signs of infection" },
        { "name": "Deep tissue biopsy for culture (gold standard)", "priority": "high", "yield": 0.8, "indication": "if osteomyelitis or deep infection suspected" },
        { "name": "CRP, ESR, WBC, albumin", "priority": "medium", "yield": 0.5, "indication": "systemic infection, nutrition" }
      ],
      "imaging": [
        { "name": "MRI for suspected osteomyelitis", "priority": "high", "yield": 0.9, "indication": "if bone involved, suspected osteo" },
        { "name": "X-ray to rule out osteomyelitis", "priority": "medium", "yield": 0.5, "indication": "initial bone assessment" }
      ]
    },

    "management": {
      "protocolReference": "NPUAP/EPUAP International Pressure Ulcer Guidelines / NICE",
      "pathways": [
        {
          "severity": "all stages - prevention",
          "criteria": "at-risk or Stage I",
          "treatment": "Risk assessment (Braden). Repositioning q2h. Pressure redistribution surfaces. Skin inspection daily. Moisture management. Nutrition optimization. Preventative dressings."
        },
        {
          "severity": "Stage III-IV / infection",
          "criteria": "full thickness with necrotic tissue or infection",
          "treatment": "Debridement (sharp/surgical). Wound culture. NPWT (negative pressure) for large wounds. Offloading. Antibiotics if cellulitis/osteomyelitis. Surgical closure (flap/graft) if indicated. Nutritional support (protein, vitamins)."
        }
      ]
    },

    "pathophysiology": [
      "prolonged_pressure_exceeding_capillary_filling_pressure",
      "tissue_ischemia",
      "reperfusion_injury",
      "lymphatic_impairment",
      "cell_death_and_necrosis",
      "inflammation_infection",
      "tissue_loss_and_cavity_formation"
