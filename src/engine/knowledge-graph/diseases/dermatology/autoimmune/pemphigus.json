      "pathways": [
        {
          "severity": "mild-moderate",
          "criteria": "limited skin lesions, mild oral involvement",
          "treatment": "Potent topical corticosteroids. High-dose prednisolone 1mg/kg/day. Start steroid-sparing agent: azathioprine 2mg/kg/day or mycophenolate mofetil 2g/day. Calcium and vitamin D supplementation."
