    "management": {
      "protocolReference": "British Association of Dermatologists / Vitiligo Working Group Guidelines",
      "pathways": [
        {
          "severity": "localized (face/neck)",
          "criteria": "limited BSA, good repigmentation potential",
          "treatment": "Topical calcineurin inhibitor (tacrolimus 0.1% BD) or mild corticosteroid. Excimer laser 308nm 2x/week. Cosmetics (camouflage). Sun protection with SPF50."
