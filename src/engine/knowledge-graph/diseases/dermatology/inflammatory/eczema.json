      ]
    },

    "management": {
      "protocolReference": "NICE Guidelines for Atopic Eczema",
      "pathways": [
        {
          "severity": "mild",
          "criteria": "limited areas, mild itch",
          "treatment": "Emollients regularly. Mild topical corticosteroids (hydrocortisone 1%) for flares. Avoid triggers."
        },
        {
          "severity": "moderate",
          "criteria": "more extensive, significant itch",
          "treatment": "Moderate-potency topical corticosteroids. Topical calcineurin inhibitors for sensitive areas. Wet wraps. Treat infection if present."
        },
        {
          "severity": "severe",
          "criteria": "widespread, resistant, significant impact on QoL",
          "treatment": "Specialist referral. Potent topical corticosteroids. Phototherapy. Systemic therapy (cyclosporine, methotrexate, dupilumab)."
        }
      ]
    },

    "pathophysiology": [
      "skin_barrier_dysfunction",
      "immune_dysregulation_th2",
      "filaggrin_deficiency",
      "increased_allergen_penetration",
      "staphylococcal_colonization"
    ],

    "complications": [
