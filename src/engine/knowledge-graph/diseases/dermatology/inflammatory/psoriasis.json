      ],
      "laboratory": [
        { "name": "CRP, ESR", "priority": "medium", "yield": 0.5, "indication": "inflammatory markers if arthritis" }
      ]
    },

    "management": {
      "protocolReference": "NICE Guidelines for Psoriasis",
      "pathways": [
        {
          "severity": "mild",
          "criteria": "BSA <5%, well-controlled with topicals",
          "treatment": "Topical corticosteroids. Vitamin D analogs (calcipotriol). Tar preparations. Emollients."
        },
        {
          "severity": "moderate",
          "criteria": "BSA 5-10%, inadequate response to topicals",
          "treatment": "Phototherapy (UVB, PUVA). Second-line topical therapy. Consider systemic if fails."
        },
        {
          "severity": "severe",
          "criteria": "BSA >10% or significant impact on QoL",
          "treatment": "Systemic therapy (methotrexate, cyclosporine, acitretin). Biologics (TNF-alpha inhibitors, IL-17/IL-23 inhibitors)."
        }
      ]
    },

    "pathophysiology": [
      "keratinocyte_hyperproliferation",
      "t_cell_activation",
      "th1_th17_pathway",
      "inflammatory_cytokines",
      "abnormal_epidermal_differentiation"
