        "diseaseId": "eczema",
        "discriminators": ["flexural", "less_sharp_margins", "more_pruritic", "no_nail_signs"]
      },
      {
        "diseaseId": "seborrheic_dermatitis",
        "discriminators": ["greasy_scale", "central_face", "scalp_only"]
