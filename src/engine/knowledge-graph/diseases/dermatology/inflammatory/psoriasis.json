    "subtypes": [
      {
        "id": "plaque_psoriasis",
        "name": "Plaque Psoriasis",
        "prevalenceModifier": 0.8,
        "keyFeatures": [
          { "feature": "chronic_stable_plaques", "weight": 5 },
          { "feature": "extensor_surfaces", "weight": 4 }
        ],
        "management": "Topical corticosteroids and vitamin D analogs. Phototherapy if widespread. Systemic therapy if severe."
      },
      {
        "id": "guttate_psoriasis",
        "name": "Guttate Psoriasis",
        "prevalenceModifier": 0.1,
        "keyFeatures": [
          { "feature": "sudden_onset_droplet_lesions", "weight": 5 },
          { "feature": "post_strep_infection", "weight": 5 }
        ],
        "management": "Often self-limiting. Topical therapy. Phototherapy if persistent. Treat strep infection."
      }
    ],

    "mimics": [
