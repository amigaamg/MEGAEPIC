      "pathways": [
        {
          "severity": "immediate upon diagnosis",
          "criteria": ">30% detachment, SCORTEN calculated",
          "treatment": "Immediate ICU/burn unit. Withdraw ALL potential culprit drugs. Multidisciplinary: derm, ophtho, respiratory, nutrition. Strict aseptic handling. Warm environment. Central line. Aggressive fluid resuscitation (modified Parkland)."
