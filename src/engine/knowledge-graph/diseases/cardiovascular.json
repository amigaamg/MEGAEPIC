      { "type": "imaging", "name": "Echocardiography", "indication": "definitive — assess function and structure" },
      { "type": "imaging", "name": "Chest X-ray", "indication": "cardiomegaly and pulmonary congestion" },
      { "type": "lab", "name": "BNP/NT-proBNP", "indication": "supportive diagnosis" },
      { "type": "lab", "name": "ECG", "indication": "arrhythmia and chamber enlargement" },
      { "type": "lab", "name": "Serum electrolytes and creatinine", "indication": "baseline before diuretics" },
      { "type": "lab", "name": "Full blood count", "indication": "anaemia as precipitant" }
    ],
    "managementProtocols": [
      {
        "condition": "mild",
        "steps": [
          "Frusemide 1 mg/kg PO BD",
          "Captopril 0.1 mg/kg PO TDS, titrate upward to max 2 mg/kg/day",
          "Spironolactone 1 mg/kg PO BD as adjunct",
          "Salt restriction, daily weight monitoring",
          "Treat underlying cause"
        ]
      },
      {
        "condition": "moderate",
        "steps": [
          "Admit to paediatric ward",
          "Frusemide 1-2 mg/kg IV/IM/PO TDS",
          "Captopril as above, titrate carefully",
          "Spironolactone 1 mg/kg PO BD",
          "Oxygen to maintain SpO2 ≥94%",
          "Monitor daily: weight, urine output, respiratory rate, oxygen requirement",
          "Echocardiography to assess response"
        ]
      },
      {
        "condition": "severe",
        "steps": [
          "Admit to HDU/ICU",
          "Frusemide 2 mg/kg IV, may repeat Q6-8H",
          "Oxygen to maintain SpO2 ≥94%",
          "Inotropic support — Dopamine 5-10 mcg/kg/min IV",
          "Manage pulmonary oedema: elevate head, frusemide, consider CPAP",
          "Correct anaemia if present — packed RBC transfusion",
          "Daily echocardiography monitoring",
          "Consider digoxin 5 mcg/kg PO BD if atrial fibrillation"
        ]
      }
    ]
  },
