    "syndromeTags": ["cardiac_failure", "respiratory_distress"],
    "mustNotMiss": true,
    "diagnosticClues": ["hepatomegaly + tachypnea + feeding difficulty"],
    "exclusionClues": ["clear lungs + no hepatomegaly"],
